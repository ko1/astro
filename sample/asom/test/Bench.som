"Mini benchmark harness — args layout matches SOM-st BenchmarkHarness:
 args[1] = harness class name (Bench), args[2] = bench class, args[3] = iters,
 args[4] = inner. We follow the same protocol so the comparison script can
 invoke asom and CSOM/SOM++/PySOM with the same argv shape modulo the
 CSOM-extra warmup field."

Bench = (
    | name iters innerIters cls |

    run: args = (
        args length >= 2 ifTrue: [ name := args at: 2 ] ifFalse: [ name := 'Sieve' ].
        args length >= 3 ifTrue: [ iters := (args at: 3) asInteger ] ifFalse: [ iters := 10 ].
        args length >= 4
            ifTrue:  [ innerIters := (args at: 4) asInteger ]
            ifFalse: [ innerIters := 0 ].
        cls := system global: name.
        cls isNil ifTrue: [ system print: 'unknown class: '. system println: name. system exit: 1 ].
        ^ self runBench
    )

    runBench = (
        | b total iterStart iterEnd iterTotal |
        "Per-iter print mirrors SOM-st BenchmarkHarness output. Each
         outer iteration prints `iterations=1 runtime: Xus` so the
         comparison harness can parse iter-by-iter and drop warmup."
        b := cls new.
        total := 0.
        iters timesRepeat: [
            iterStart := system ticks.
            innerIters > 0
                ifTrue:  [ b innerBenchmarkLoop: innerIters ]
                ifFalse: [ b verifyResult: b benchmark ].
            iterEnd := system ticks.
            iterTotal := iterEnd - iterStart.
            total := total + iterTotal.
            system print: name. system print: ': iterations=1 runtime: '.
            system print: iterTotal. system println: 'us'.
        ].
        "Summary line in SOM-st format so parse_inner can still pick
         up `total: Yus` for engines that don't emit per-iter."
        system print: name. system print: ': iterations='. system print: iters.
        system print: ' average: '. system print: (total / iters).
        system print: 'us total: '. system print: total. system println: 'us'.
    )

    "Default entry point: Sieve x 10."
    run = (
        name := 'Sieve'. iters := 10. innerIters := 0.
        cls := system global: name.
        ^ self runBench
    )
)
