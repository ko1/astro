// =============================================================================
//  ASTro SOM (asom) — AST node definitions
//
//  Phase 1: a small but realistic node set that covers the SOM grammar.
//  Sends are split by arity (0/1/2/3) so node arity is fixed for ASTroGen.
// =============================================================================

// -----------------------------------------------------------------------------
//  Literals
// -----------------------------------------------------------------------------

NODE_DEF
node_int_lit(CTX * restrict c, NODE * restrict n, int32_t value)
{
    (void)c;
    return ASOM_INT2VAL((intptr_t)value);
}

NODE_DEF
node_string_lit(CTX * restrict c, NODE * restrict n, const char *bytes)
{
    return asom_intern_string(c, bytes);
}

NODE_DEF
node_double_lit(CTX * restrict c, NODE * restrict n, double value)
{
    return asom_double_new(c, value);
}

NODE_DEF
node_symbol_lit(CTX * restrict c, NODE * restrict n, const char *bytes)
{
    return asom_intern_symbol(c, bytes);
}

// -----------------------------------------------------------------------------
//  Self / Nil
// -----------------------------------------------------------------------------

NODE_DEF
node_self(CTX * restrict c, NODE * restrict n)
{
    return c->frame->self;
}

NODE_DEF
node_nil(CTX * restrict c, NODE * restrict n)
{
    return c->val_nil;
}

NODE_DEF
node_true(CTX * restrict c, NODE * restrict n)
{
    return c->val_true;
}

NODE_DEF
node_false(CTX * restrict c, NODE * restrict n)
{
    return c->val_false;
}

// -----------------------------------------------------------------------------
//  Variables.
//   - locals (including method args): scope=0,index = method-local slot
//   - block-captured outer locals: scope>0 walks up `home` chain
//   - instance fields: distinct nodes
// -----------------------------------------------------------------------------

NODE_DEF
node_local_get(CTX * restrict c, NODE * restrict n, uint32_t scope, uint32_t index)
{
    struct asom_frame *f = c->frame;
    for (uint32_t i = 0; i < scope; i++) f = f->lexical_parent;
    return f->locals[index];
}

NODE_DEF
node_local_set(CTX * restrict c, NODE * restrict n, uint32_t scope, uint32_t index, NODE *rhs)
{
    VALUE v = EVAL_ARG(c, rhs);
    struct asom_frame *f = c->frame;
    for (uint32_t i = 0; i < scope; i++) f = f->lexical_parent;
    f->locals[index] = v;
    return v;
}

NODE_DEF
node_field_get(CTX * restrict c, NODE * restrict n, uint32_t index)
{
    struct asom_object *self = ASOM_VAL2OBJ(c->frame->self);
    VALUE *fields = (VALUE *)(self + 1);
    return fields[index];
}

NODE_DEF
node_field_set(CTX * restrict c, NODE * restrict n, uint32_t index, NODE *rhs)
{
    VALUE v = EVAL_ARG(c, rhs);
    struct asom_object *self = ASOM_VAL2OBJ(c->frame->self);
    VALUE *fields = (VALUE *)(self + 1);
    fields[index] = v;
    return v;
}

NODE_DEF
node_class_field_get(CTX * restrict c, NODE * restrict n, uint32_t index)
{
    struct asom_class *cls = (struct asom_class *)ASOM_VAL2OBJ(c->frame->self);
    return cls->class_side_fields[index];
}

NODE_DEF
node_class_field_set(CTX * restrict c, NODE * restrict n, uint32_t index, NODE *rhs)
{
    VALUE v = EVAL_ARG(c, rhs);
    struct asom_class *cls = (struct asom_class *)ASOM_VAL2OBJ(c->frame->self);
    cls->class_side_fields[index] = v;
    return v;
}

NODE_DEF
node_global_get(CTX * restrict c, NODE * restrict n, const char *name)
{
    VALUE v = asom_global_get(c, name);
    if (v != c->val_nil) return v;
    // Smalltalk convention: ask the current receiver to handle the unknown
    // global by name. If `unknownGlobal:` is not defined we keep returning
    // nil so existing programs aren't broken.
    extern struct asom_method *asom_class_lookup(struct asom_class *cls, const char *selector);
    struct asom_class *cls = asom_class_of(c, c->frame->self);
    const char *sel = asom_intern_cstr("unknownGlobal:");
    if (cls && asom_class_lookup(cls, sel)) {
        VALUE args[1] = { asom_intern_symbol(c, name) };
        return asom_send(c, c->frame->self, sel, 1, args, NULL);
    }
    return c->val_nil;
}

// -----------------------------------------------------------------------------
//  Control flow / structure
// -----------------------------------------------------------------------------

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, NODE *head, NODE *tail)
{
    EVAL_ARG(c, head);
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_return_local(CTX * restrict c, NODE * restrict n, NODE *expr)
{
    return EVAL_ARG(c, expr);
}

NODE_DEF
node_return_nlr(CTX * restrict c, NODE * restrict n, NODE *expr)
{
    VALUE v = EVAL_ARG(c, expr);
    asom_nonlocal_return(c, v);
    return v; // unreachable
}

NODE_DEF @noinline
node_method_body(CTX * restrict c, NODE * restrict n, NODE *body)
{
    return EVAL_ARG(c, body);
}

NODE_DEF @noinline
node_block_body(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t num_params, uint32_t num_locals)
{
    return EVAL_ARG(c, body);
}

// Block literal: produce a Block object capturing the current frame.
// `no_nlr` is parse-time analysis: 1 iff the block body has no `^` on any
// path that would execute in this block's frame, so asom_block_invoke can
// skip its escape-catcher setjmp.
NODE_DEF
node_block(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t num_params, uint32_t num_locals, uint32_t no_nlr)
{
    return asom_make_block(c, body, num_params, num_locals, no_nlr);
}

// -----------------------------------------------------------------------------
//  Message sends, by arity. Each carries an inline cache (`cc@ref`) so the
//  cache is mutable side-data not embedded in the node hash.
// -----------------------------------------------------------------------------

NODE_DEF
node_send0(CTX * restrict c, NODE * restrict n, NODE *recv, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    return asom_send(c, r, selector, 0, NULL, cc);
}

// Forward decls for node_send1 (referenced by the specialized variants on
// guard miss) and its type-specialized siblings (referenced by the
// type-feedback hook below).
extern const struct NodeKind kind_node_send1;
extern const struct NodeKind kind_node_send1_intplus;
extern const struct NodeKind kind_node_send1_intminus;
extern const struct NodeKind kind_node_send1_inttimes;
extern const struct NodeKind kind_node_send1_intlt;
extern const struct NodeKind kind_node_send1_intgt;
extern const struct NodeKind kind_node_send1_intle;
extern const struct NodeKind kind_node_send1_intge;
extern const struct NodeKind kind_node_send1_inteq;

// Map a primitive's kind tag to the matching specialized NodeKind.
// Returns NULL when there is no specialization for that primitive.
static inline const struct NodeKind *
asom_send1_specialization(enum asom_prim_kind k)
{
    switch (k) {
        case ASOM_PRIM_INT_PLUS:  return &kind_node_send1_intplus;
        case ASOM_PRIM_INT_MINUS: return &kind_node_send1_intminus;
        case ASOM_PRIM_INT_TIMES: return &kind_node_send1_inttimes;
        case ASOM_PRIM_INT_LT:    return &kind_node_send1_intlt;
        case ASOM_PRIM_INT_GT:    return &kind_node_send1_intgt;
        case ASOM_PRIM_INT_LE:    return &kind_node_send1_intle;
        case ASOM_PRIM_INT_GE:    return &kind_node_send1_intge;
        case ASOM_PRIM_INT_EQ:    return &kind_node_send1_inteq;
        default: return NULL;
    }
}

NODE_DEF
node_send1(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[1];
    args[0] = EVAL_ARG(c, arg0);

    // Inlined IC fast path so the slow branch can run a one-shot
    // type-feedback rewrite without polluting the hot path.
    struct asom_class *cls = asom_class_of(c, r);
    if (__builtin_expect(cc != NULL && cc->serial == c->serial && cc->cached_class == cls, 1)) {
        return asom_invoke_method(c, cc->cached_method, r, args, 1);
    }
    VALUE result = asom_send_slow(c, r, selector, 1, args, cc);
    // After the cache fill: if both args are SmallInteger and the cached
    // method is one of the int_* primitives, rewrite this site to its
    // specialized variant. Hits this path at most a handful of times per
    // call site (re-runs only on serial bumps / class swaps).
    if (cc && cc->cached_method && cc->cached_method->prim_kind != ASOM_PRIM_GENERIC
        && ASOM_IS_INT(r) && ASOM_IS_INT(args[0])) {
        const struct NodeKind *target = asom_send1_specialization(cc->cached_method->prim_kind);
        if (target) swap_dispatcher(n, target);
    }
    return result;
}

NODE_DEF
node_send2(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, NODE *arg1, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[2];
    args[0] = EVAL_ARG(c, arg0);
    args[1] = EVAL_ARG(c, arg1);
    return asom_send(c, r, selector, 2, args, cc);
}

NODE_DEF
node_send3(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, NODE *arg1, NODE *arg2, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[3];
    args[0] = EVAL_ARG(c, arg0);
    args[1] = EVAL_ARG(c, arg1);
    args[2] = EVAL_ARG(c, arg2);
    return asom_send(c, r, selector, 3, args, cc);
}

NODE_DEF
node_send4(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *a0, NODE *a1, NODE *a2, NODE *a3, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[4];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    return asom_send(c, r, selector, 4, args, cc);
}

NODE_DEF
node_send5(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[5];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4);
    return asom_send(c, r, selector, 5, args, cc);
}

NODE_DEF
node_send6(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, NODE *a5, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[6];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4); args[5] = EVAL_ARG(c, a5);
    return asom_send(c, r, selector, 6, args, cc);
}

NODE_DEF
node_send7(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, NODE *a5, NODE *a6, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[7];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4); args[5] = EVAL_ARG(c, a5);
    args[6] = EVAL_ARG(c, a6);
    return asom_send(c, r, selector, 7, args, cc);
}

NODE_DEF
node_send8(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, NODE *a5, NODE *a6, NODE *a7, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE args[8];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4); args[5] = EVAL_ARG(c, a5);
    args[6] = EVAL_ARG(c, a6); args[7] = EVAL_ARG(c, a7);
    return asom_send(c, r, selector, 8, args, cc);
}

// Array / string literal. The runtime VALUE is built once at parse
// time and stored inline via @ref. Hash uses the content surrogate
// (bytes / len) — NOT the VALUE pointer — so the same source produces
// the same hash across processes and the cached SD loads correctly on
// a second run. Without this, every parse builds a fresh asom_string
// with a different heap address; the bake-time hash and the
// load-time hash diverge and cs_load misses for any node that has a
// string/array literal in its subtree.
//
// Limitation: hash_cstr stops at NUL. Embedded-NUL strings would only
// hash their prefix; in practice asom benchmark code never uses those.
NODE_DEF
node_array_lit(CTX * restrict c, NODE * restrict n, uint32_t len, VALUE cached)
{
    (void)c; (void)len;
    return cached;
}

NODE_DEF
node_string_val(CTX * restrict c, NODE * restrict n, const char *bytes, uint32_t len, VALUE cached)
{
    (void)c; (void)bytes; (void)len;
    return cached;
}

// Super send: like node_sendN, but lookup starts in superclass of method holder.
NODE_DEF
node_super_send0(CTX * restrict c, NODE * restrict n, const char *selector, struct asom_callcache *cc)
{
    return asom_super_send(c, c->frame->self, selector, 0, NULL, cc);
}

NODE_DEF
node_super_send1(CTX * restrict c, NODE * restrict n, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE args[1];
    args[0] = EVAL_ARG(c, arg0);
    return asom_super_send(c, c->frame->self, selector, 1, args, cc);
}

NODE_DEF
node_super_send2(CTX * restrict c, NODE * restrict n, NODE *arg0, NODE *arg1, const char *selector, struct asom_callcache *cc)
{
    VALUE args[2];
    args[0] = EVAL_ARG(c, arg0);
    args[1] = EVAL_ARG(c, arg1);
    return asom_super_send(c, c->frame->self, selector, 2, args, cc);
}

NODE_DEF
node_super_send3(CTX * restrict c, NODE * restrict n, NODE *arg0, NODE *arg1, NODE *arg2, const char *selector, struct asom_callcache *cc)
{
    VALUE args[3];
    args[0] = EVAL_ARG(c, arg0);
    args[1] = EVAL_ARG(c, arg1);
    args[2] = EVAL_ARG(c, arg2);
    return asom_super_send(c, c->frame->self, selector, 3, args, cc);
}

NODE_DEF
node_super_send4(CTX * restrict c, NODE * restrict n, NODE *a0, NODE *a1, NODE *a2, NODE *a3, const char *selector, struct asom_callcache *cc)
{
    VALUE args[4];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    return asom_super_send(c, c->frame->self, selector, 4, args, cc);
}

NODE_DEF
node_super_send5(CTX * restrict c, NODE * restrict n, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, const char *selector, struct asom_callcache *cc)
{
    VALUE args[5];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4);
    return asom_super_send(c, c->frame->self, selector, 5, args, cc);
}

NODE_DEF
node_super_send6(CTX * restrict c, NODE * restrict n, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, NODE *a5, const char *selector, struct asom_callcache *cc)
{
    VALUE args[6];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4); args[5] = EVAL_ARG(c, a5);
    return asom_super_send(c, c->frame->self, selector, 6, args, cc);
}

NODE_DEF
node_super_send7(CTX * restrict c, NODE * restrict n, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, NODE *a5, NODE *a6, const char *selector, struct asom_callcache *cc)
{
    VALUE args[7];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4); args[5] = EVAL_ARG(c, a5);
    args[6] = EVAL_ARG(c, a6);
    return asom_super_send(c, c->frame->self, selector, 7, args, cc);
}

NODE_DEF
node_super_send8(CTX * restrict c, NODE * restrict n, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *a4, NODE *a5, NODE *a6, NODE *a7, const char *selector, struct asom_callcache *cc)
{
    VALUE args[8];
    args[0] = EVAL_ARG(c, a0); args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2); args[3] = EVAL_ARG(c, a3);
    args[4] = EVAL_ARG(c, a4); args[5] = EVAL_ARG(c, a5);
    args[6] = EVAL_ARG(c, a6); args[7] = EVAL_ARG(c, a7);
    return asom_super_send(c, c->frame->self, selector, 8, args, cc);
}

// -----------------------------------------------------------------------------
//  Control-flow inlining. The parser emits these in place of `expr ifTrue:
//  [block]`, `[cond] whileTrue: [body]`, etc., when the block argument(s)
//  meet the inline criteria (0 params, 0 locals, no nested block literal —
//  the latter rules out closure escape during the inlined call).
//
//  The body subtree carries scope numbering relative to the original
//  block frame, so we still push a stack-allocated frame whose
//  lexical_parent is the current frame; the body's `lvar_get(scope=N)`
//  refs walk up the same chain as if the block had been heap-allocated,
//  so no AST rewrite is needed. The savings vs the regular send +
//  asom_block_invoke path are: no calloc, no setjmp, and for whileTrue:
//  one fake frame is reused for all iterations.
//
//  ifTrue:/ifFalse:/ifTrue:ifFalse: keep the original node_block AST as
//  a fallback operand so a non-Boolean receiver can still receive the
//  message via asom_send (rare in benchmarks; matches SOM standard).
// -----------------------------------------------------------------------------

// Stack-frame helpers for inlined 0-local control-flow blocks
// (defined in asom_runtime.c). Required: body has no nested block
// creation (escape risk vs the stack-allocated frame).
extern void asom_inline_frame_push(CTX *c, struct asom_frame *frame);
extern void asom_inline_frame_pop(CTX *c, struct asom_frame *frame);

// Pool-allocated inline frame for N-local inlined blocks (e.g. to:do:'s
// 1-param block — locals[0] holds the index). The heap-resident frame
// pins via `captured` if a nested closure escapes, so this version is
// safe regardless of what the body does.
extern struct asom_frame *asom_inline_pool_frame_push(CTX *c, uint32_t num_locals, VALUE **out_locals);
extern void asom_inline_pool_frame_pop(CTX *c, struct asom_frame *frame);

// Each control-flow inline node carries the body subtree as a *direct*
// NODE * operand (`stmts` / `t_stmts` / `f_stmts`) so EVAL_ARG inside
// the fast path uses the SD-passed child dispatcher (constant in the
// SD-baked TU, devirtualizable + inlinable). Without this, EVAL(c,
// stmts) goes through the runtime head.dispatcher pointer of an
// un-swapped descendant and bypasses the SD chain entirely.
//
// `body_block` (or t_block/f_block) is also kept as an operand for the
// non-Boolean-receiver fallback path, where we need a real Block.
NODE_DEF
node_iftrue(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *stmts, NODE *body_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_true)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    if (LIKELY(v == c->val_false)) return c->val_nil;
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, v, asom_intern_cstr("ifTrue:"), 1, &blk, NULL);
}

NODE_DEF
node_iffalse(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *stmts, NODE *body_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_false)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    if (LIKELY(v == c->val_true)) return c->val_nil;
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, v, asom_intern_cstr("ifFalse:"), 1, &blk, NULL);
}

// Boolean>>and: / Boolean>>or: with a block-literal arg. Standard SOM
// definition is `^ self ifTrue: aBlock ifFalse: false` (and `or:` mirrors
// with ifFalse:). Inlining matters most for short-circuit conditions like
// `[notDone and: [z < 50]] whileTrue: [...]` (Mandelbrot inner loop): the
// outer compare otherwise creates a fresh asom_block for `[z < 50]` on
// every iteration, captures the enclosing frame, and leaks it from the
// pool because `frame->captured = true`.
NODE_DEF
node_and(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *stmts, NODE *body_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_true)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    if (LIKELY(v == c->val_false)) return c->val_false;
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, v, asom_intern_cstr("and:"), 1, &blk, NULL);
}

NODE_DEF
node_or(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *stmts, NODE *body_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_false)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    if (LIKELY(v == c->val_true)) return c->val_true;
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, v, asom_intern_cstr("or:"), 1, &blk, NULL);
}

NODE_DEF
node_iftrue_iffalse(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *t_stmts, NODE *f_stmts, NODE *t_block, NODE *f_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_true)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, t_stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    if (LIKELY(v == c->val_false)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, f_stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    VALUE tblk = EVAL_ARG(c, t_block);
    VALUE fblk = EVAL_ARG(c, f_block);
    VALUE args[2] = { tblk, fblk };
    return asom_send(c, v, asom_intern_cstr("ifTrue:ifFalse:"), 2, args, NULL);
}

NODE_DEF
node_iffalse_iftrue(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *f_stmts, NODE *t_stmts, NODE *f_block, NODE *t_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_true)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, t_stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    if (LIKELY(v == c->val_false)) {
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        VALUE result = EVAL_ARG(c, f_stmts);
        asom_inline_frame_pop(c, &frame);
        return result;
    }
    VALUE fblk = EVAL_ARG(c, f_block);
    VALUE tblk = EVAL_ARG(c, t_block);
    VALUE args[2] = { fblk, tblk };
    return asom_send(c, v, asom_intern_cstr("ifFalse:ifTrue:"), 2, args, NULL);
}

// _pool variants: inline ifTrue:/ifFalse: bodies that have N>0 locals
// or nested block creation. Frame is heap-allocated via the per-bucket
// pool (`asom_inline_pool_frame_push`) so escaped closures are safe;
// the `captured` flag pins them out of pool recycling. Same dual-path
// design as node_to_do_pool. The parser picks `_pool` over the
// stack-frame variant when num_locals > 0 or the body has nested
// node_block descendants.
NODE_DEF
node_iftrue_pool(CTX * restrict c, NODE * restrict n, NODE *cond, uint32_t num_locals, NODE *stmts, NODE *body_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_true)) {
        VALUE *unused;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, num_locals, &unused);
        (void)unused;
        VALUE result = EVAL_ARG(c, stmts);
        asom_inline_pool_frame_pop(c, frame);
        return result;
    }
    if (LIKELY(v == c->val_false)) return c->val_nil;
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, v, asom_intern_cstr("ifTrue:"), 1, &blk, NULL);
}

NODE_DEF
node_iffalse_pool(CTX * restrict c, NODE * restrict n, NODE *cond, uint32_t num_locals, NODE *stmts, NODE *body_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_false)) {
        VALUE *unused;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, num_locals, &unused);
        (void)unused;
        VALUE result = EVAL_ARG(c, stmts);
        asom_inline_pool_frame_pop(c, frame);
        return result;
    }
    if (LIKELY(v == c->val_true)) return c->val_nil;
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, v, asom_intern_cstr("ifFalse:"), 1, &blk, NULL);
}

NODE_DEF
node_iftrue_iffalse_pool(CTX * restrict c, NODE * restrict n, NODE *cond, uint32_t t_num_locals, uint32_t f_num_locals, NODE *t_stmts, NODE *f_stmts, NODE *t_block, NODE *f_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_true)) {
        VALUE *unused;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, t_num_locals, &unused);
        (void)unused;
        VALUE result = EVAL_ARG(c, t_stmts);
        asom_inline_pool_frame_pop(c, frame);
        return result;
    }
    if (LIKELY(v == c->val_false)) {
        VALUE *unused;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, f_num_locals, &unused);
        (void)unused;
        VALUE result = EVAL_ARG(c, f_stmts);
        asom_inline_pool_frame_pop(c, frame);
        return result;
    }
    VALUE tblk = EVAL_ARG(c, t_block);
    VALUE fblk = EVAL_ARG(c, f_block);
    VALUE args[2] = { tblk, fblk };
    return asom_send(c, v, asom_intern_cstr("ifTrue:ifFalse:"), 2, args, NULL);
}

NODE_DEF
node_iffalse_iftrue_pool(CTX * restrict c, NODE * restrict n, NODE *cond, uint32_t f_num_locals, uint32_t t_num_locals, NODE *f_stmts, NODE *t_stmts, NODE *f_block, NODE *t_block)
{
    VALUE v = EVAL_ARG(c, cond);
    if (LIKELY(v == c->val_true)) {
        VALUE *unused;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, t_num_locals, &unused);
        (void)unused;
        VALUE result = EVAL_ARG(c, t_stmts);
        asom_inline_pool_frame_pop(c, frame);
        return result;
    }
    if (LIKELY(v == c->val_false)) {
        VALUE *unused;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, f_num_locals, &unused);
        (void)unused;
        VALUE result = EVAL_ARG(c, f_stmts);
        asom_inline_pool_frame_pop(c, frame);
        return result;
    }
    VALUE fblk = EVAL_ARG(c, f_block);
    VALUE tblk = EVAL_ARG(c, t_block);
    VALUE args[2] = { fblk, tblk };
    return asom_send(c, v, asom_intern_cstr("ifFalse:ifTrue:"), 2, args, NULL);
}

// `n timesRepeat: [body]` — inlined when n is SmallInteger and body is
// a 0-param 0-local block. Same stack/pool split as to:do:: stack
// frame is fast but only safe if the body never creates a nested
// closure; pool path is correct in all cases.
NODE_DEF
node_times_repeat(CTX * restrict c, NODE * restrict n, NODE *count, NODE *stmts, NODE *body_block)
{
    VALUE count_v = EVAL_ARG(c, count);
    if (LIKELY(ASOM_IS_INT(count_v))) {
        intptr_t reps = ASOM_VAL2INT(count_v);
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        for (intptr_t i = 0; i < reps; i++) {
            EVAL_ARG(c, stmts);
        }
        asom_inline_frame_pop(c, &frame);
        return count_v;
    }
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, count_v, asom_intern_cstr("timesRepeat:"), 1, &blk, NULL);
}

NODE_DEF
node_times_repeat_pool(CTX * restrict c, NODE * restrict n, NODE *count, NODE *stmts, NODE *body_block)
{
    VALUE count_v = EVAL_ARG(c, count);
    if (LIKELY(ASOM_IS_INT(count_v))) {
        intptr_t reps = ASOM_VAL2INT(count_v);
        VALUE *unused;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, 0, &unused);
        (void)unused;
        for (intptr_t i = 0; i < reps; i++) {
            EVAL_ARG(c, stmts);
        }
        asom_inline_pool_frame_pop(c, frame);
        return count_v;
    }
    VALUE blk = EVAL_ARG(c, body_block);
    return asom_send(c, count_v, asom_intern_cstr("timesRepeat:"), 1, &blk, NULL);
}

// `from to: end by: step do: [ :var | body ]` — 3-arg variant of
// to:do:. Only inlined when from/end/step are all SmallInteger and the
// block has 1 param + 0 locals. Step may be negative for descending
// loops; we handle both with a single guard at the top.
NODE_DEF
node_to_by_do(CTX * restrict c, NODE * restrict n, NODE *from, NODE *end, NODE *step, NODE *stmts, NODE *body_block)
{
    VALUE from_v = EVAL_ARG(c, from);
    VALUE end_v  = EVAL_ARG(c, end);
    VALUE step_v = EVAL_ARG(c, step);
    if (LIKELY(ASOM_IS_INT(from_v) && ASOM_IS_INT(end_v) && ASOM_IS_INT(step_v))) {
        intptr_t lo = ASOM_VAL2INT(from_v);
        intptr_t hi = ASOM_VAL2INT(end_v);
        intptr_t st = ASOM_VAL2INT(step_v);
        VALUE slot = 0;
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        c->frame->locals = &slot;
        if (st > 0) {
            for (intptr_t i = lo; i <= hi; i += st) {
                slot = ASOM_INT2VAL(i);
                EVAL_ARG(c, stmts);
            }
        } else if (st < 0) {
            for (intptr_t i = lo; i >= hi; i += st) {
                slot = ASOM_INT2VAL(i);
                EVAL_ARG(c, stmts);
            }
        }
        asom_inline_frame_pop(c, &frame);
        return from_v;
    }
    VALUE blk = EVAL_ARG(c, body_block);
    VALUE args[3] = { end_v, step_v, blk };
    return asom_send(c, from_v, asom_intern_cstr("to:by:do:"), 3, args, NULL);
}

NODE_DEF
node_to_by_do_pool(CTX * restrict c, NODE * restrict n, NODE *from, NODE *end, NODE *step, NODE *stmts, NODE *body_block)
{
    VALUE from_v = EVAL_ARG(c, from);
    VALUE end_v  = EVAL_ARG(c, end);
    VALUE step_v = EVAL_ARG(c, step);
    if (LIKELY(ASOM_IS_INT(from_v) && ASOM_IS_INT(end_v) && ASOM_IS_INT(step_v))) {
        intptr_t lo = ASOM_VAL2INT(from_v);
        intptr_t hi = ASOM_VAL2INT(end_v);
        intptr_t st = ASOM_VAL2INT(step_v);
        VALUE *locals;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, 1, &locals);
        if (st > 0) {
            for (intptr_t i = lo; i <= hi; i += st) {
                locals[0] = ASOM_INT2VAL(i);
                EVAL_ARG(c, stmts);
            }
        } else if (st < 0) {
            for (intptr_t i = lo; i >= hi; i += st) {
                locals[0] = ASOM_INT2VAL(i);
                EVAL_ARG(c, stmts);
            }
        }
        asom_inline_pool_frame_pop(c, frame);
        return from_v;
    }
    VALUE blk = EVAL_ARG(c, body_block);
    VALUE args[3] = { end_v, step_v, blk };
    return asom_send(c, from_v, asom_intern_cstr("to:by:do:"), 3, args, NULL);
}

// `from to: end do: [ :var | body ]` — inlined when receiver/end are
// SmallInteger and the block has 1 param.
//
// Two flavours, chosen at parse time:
//   - node_to_do  : body has no nested block creation. Frame lives on
//                   the C stack with locals = &slot. Cheapest.
//   - node_to_do_pool: body may create nested closures. Frame is
//                   pool-allocated so escaped closures pin it via
//                   `captured`. Slightly higher per-call overhead,
//                   correctness-equivalent to asom_block_invoke.
NODE_DEF
node_to_do(CTX * restrict c, NODE * restrict n, NODE *from, NODE *end, NODE *stmts, NODE *body_block)
{
    VALUE from_v = EVAL_ARG(c, from);
    VALUE end_v  = EVAL_ARG(c, end);
    if (LIKELY(ASOM_IS_INT(from_v) && ASOM_IS_INT(end_v))) {
        intptr_t lo = ASOM_VAL2INT(from_v);
        intptr_t hi = ASOM_VAL2INT(end_v);
        VALUE slot = 0;
        struct asom_frame frame;
        asom_inline_frame_push(c, &frame);
        c->frame->locals = &slot;
        for (intptr_t i = lo; i <= hi; i++) {
            slot = ASOM_INT2VAL(i);
            EVAL_ARG(c, stmts);
        }
        asom_inline_frame_pop(c, &frame);
        return from_v;
    }
    VALUE blk = EVAL_ARG(c, body_block);
    VALUE args[2] = { end_v, blk };
    return asom_send(c, from_v, asom_intern_cstr("to:do:"), 2, args, NULL);
}

NODE_DEF
node_to_do_pool(CTX * restrict c, NODE * restrict n, NODE *from, NODE *end, NODE *stmts, NODE *body_block)
{
    VALUE from_v = EVAL_ARG(c, from);
    VALUE end_v  = EVAL_ARG(c, end);
    if (LIKELY(ASOM_IS_INT(from_v) && ASOM_IS_INT(end_v))) {
        intptr_t lo = ASOM_VAL2INT(from_v);
        intptr_t hi = ASOM_VAL2INT(end_v);
        VALUE *locals;
        struct asom_frame *frame = asom_inline_pool_frame_push(c, 1, &locals);
        for (intptr_t i = lo; i <= hi; i++) {
            locals[0] = ASOM_INT2VAL(i);
            EVAL_ARG(c, stmts);
        }
        asom_inline_pool_frame_pop(c, frame);
        return from_v;
    }
    VALUE blk = EVAL_ARG(c, body_block);
    VALUE args[2] = { end_v, blk };
    return asom_send(c, from_v, asom_intern_cstr("to:do:"), 2, args, NULL);
}

// whileTrue:/whileFalse: receivers are always block literals at parse
// time so there's no fallback path. Both bodies share one stack frame
// across all iterations — the win scales with the iteration count.
NODE_DEF
node_whiletrue(CTX * restrict c, NODE * restrict n, NODE *cond_stmts, NODE *body_stmts)
{
    struct asom_frame frame;
    asom_inline_frame_push(c, &frame);
    for (;;) {
        VALUE r = EVAL_ARG(c, cond_stmts);
        if (r != c->val_true) break;
        EVAL_ARG(c, body_stmts);
    }
    asom_inline_frame_pop(c, &frame);
    return c->val_nil;
}

NODE_DEF
node_whilefalse(CTX * restrict c, NODE * restrict n, NODE *cond_stmts, NODE *body_stmts)
{
    struct asom_frame frame;
    asom_inline_frame_push(c, &frame);
    for (;;) {
        VALUE r = EVAL_ARG(c, cond_stmts);
        if (r != c->val_false) break;
        EVAL_ARG(c, body_stmts);
    }
    asom_inline_frame_pop(c, &frame);
    return c->val_nil;
}

// _pool variants: cond/body subtrees may contain inlined CF nodes with a
// `body_block` fallback (or other paths that call asom_make_block on the
// rare-recv branch). If we used a stack frame, the closure's
// lexical_parent would dangle when the loop returns. The pool frame is
// heap-resident; `captured` pins it out of pool recycling on closure
// escape. One pool fetch + return per whileTrue: call (vs one pool fetch
// per iteration in the un-inlined `Block>>whileTrue:` path).
NODE_DEF
node_whiletrue_pool(CTX * restrict c, NODE * restrict n, NODE *cond_stmts, NODE *body_stmts)
{
    VALUE *unused;
    struct asom_frame *frame = asom_inline_pool_frame_push(c, 0, &unused);
    (void)unused;
    for (;;) {
        VALUE r = EVAL_ARG(c, cond_stmts);
        if (r != c->val_true) break;
        EVAL_ARG(c, body_stmts);
    }
    asom_inline_pool_frame_pop(c, frame);
    return c->val_nil;
}

NODE_DEF
node_whilefalse_pool(CTX * restrict c, NODE * restrict n, NODE *cond_stmts, NODE *body_stmts)
{
    VALUE *unused;
    struct asom_frame *frame = asom_inline_pool_frame_push(c, 0, &unused);
    (void)unused;
    for (;;) {
        VALUE r = EVAL_ARG(c, cond_stmts);
        if (r != c->val_false) break;
        EVAL_ARG(c, body_stmts);
    }
    asom_inline_pool_frame_pop(c, frame);
    return c->val_nil;
}

// -----------------------------------------------------------------------------
//  Type-specialized send1 variants. These share the canonical Horg with
//  node_send1 (via @canonical=node_send1) so swap_dispatcher rewriting
//  them in place doesn't invalidate the AOT code-store hash. On guard
//  failure they swap back to node_send1 and re-dispatch via asom_send.
// -----------------------------------------------------------------------------

NODE_DEF @canonical=node_send1
node_send1_intplus(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_INT2VAL(ASOM_VAL2INT(r) + ASOM_VAL2INT(a));
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

NODE_DEF @canonical=node_send1
node_send1_intminus(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_INT2VAL(ASOM_VAL2INT(r) - ASOM_VAL2INT(a));
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

NODE_DEF @canonical=node_send1
node_send1_inttimes(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_INT2VAL(ASOM_VAL2INT(r) * ASOM_VAL2INT(a));
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

NODE_DEF @canonical=node_send1
node_send1_intlt(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_VAL2INT(r) < ASOM_VAL2INT(a) ? c->val_true : c->val_false;
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

NODE_DEF @canonical=node_send1
node_send1_intgt(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_VAL2INT(r) > ASOM_VAL2INT(a) ? c->val_true : c->val_false;
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

NODE_DEF @canonical=node_send1
node_send1_intle(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_VAL2INT(r) <= ASOM_VAL2INT(a) ? c->val_true : c->val_false;
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

NODE_DEF @canonical=node_send1
node_send1_intge(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_VAL2INT(r) >= ASOM_VAL2INT(a) ? c->val_true : c->val_false;
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

NODE_DEF @canonical=node_send1
node_send1_inteq(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_INT(r) && ASOM_IS_INT(a), 1)) {
        return ASOM_VAL2INT(r) == ASOM_VAL2INT(a) ? c->val_true : c->val_false;
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

// `array at: i` — Array indexing. Bypasses asom_send + the arr_at_
// primitive on the common case (Array receiver, Integer index, in
// bounds). On any guard miss we revert to node_send1 and re-dispatch.
NODE_DEF @canonical=node_send1
node_send1_arrayat(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE a = EVAL_ARG(c, arg0);
    if (__builtin_expect(ASOM_IS_OBJ(r) && ASOM_IS_INT(a), 1)) {
        struct asom_object *o = ASOM_VAL2OBJ(r);
        if (__builtin_expect(o->klass == c->cls_array, 1)) {
            struct asom_array *arr = (struct asom_array *)o;
            uintptr_t idx = (uintptr_t)(ASOM_VAL2INT(a) - 1);
            if (__builtin_expect(idx < arr->len, 1)) {
                return arr->data[idx];
            }
        }
    }
    swap_dispatcher(n, &kind_node_send1);
    VALUE args[1] = { a };
    return asom_send(c, r, selector, 1, args, cc);
}

// `array at: i put: v` — Array element assignment. Same shape as
// node_send1_arrayat (recv = Array, arg0 = Integer index) but stores
// into arr->data[idx]. Returns the stored value (SOM convention).
extern const struct NodeKind kind_node_send2;
NODE_DEF @canonical=node_send2
node_send2_arrayatput(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *arg0, NODE *arg1, const char *selector, struct asom_callcache *cc)
{
    VALUE r = EVAL_ARG(c, recv);
    VALUE i = EVAL_ARG(c, arg0);
    VALUE v = EVAL_ARG(c, arg1);
    if (__builtin_expect(ASOM_IS_OBJ(r) && ASOM_IS_INT(i), 1)) {
        struct asom_object *o = ASOM_VAL2OBJ(r);
        if (__builtin_expect(o->klass == c->cls_array, 1)) {
            struct asom_array *arr = (struct asom_array *)o;
            uintptr_t idx = (uintptr_t)(ASOM_VAL2INT(i) - 1);
            if (__builtin_expect(idx < arr->len, 1)) {
                arr->data[idx] = v;
                return v;
            }
        }
    }
    swap_dispatcher(n, &kind_node_send2);
    VALUE args[2] = { i, v };
    return asom_send(c, r, selector, 2, args, cc);
}
