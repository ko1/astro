/*
 * astrogre AST nodes.
 *
 * Each match node returns one of three VALUEs (defined as `enum
 * match_result` in context.h):
 *
 *   MR_FAIL     — this branch didn't match here.  Parents undo their own
 *                 state and propagate MR_FAIL up; backtracking is encoded
 *                 in this falsy return without an explicit thread-list.
 *   MR_STOP     — the regex chain reached `node_re_succ`; the scanner
 *                 returns 1 to its caller (search semantics).
 *   MR_CONTINUE — produced only by `node_action_continue` at the tail of
 *                 a `-c` / default-print body chain; tells the scanner
 *                 "match recorded, please resume from c->pos".
 *
 * Regex-chain internals (rep / alt / lit / class / lookaround / capture)
 * only ever see MR_FAIL / MR_STOP, so `if (!r) ...` and `if (r) ...`
 * patterns work as expected.  Only the scanner ↔ body boundary has to
 * distinguish MR_STOP from MR_CONTINUE explicitly.
 *
 * The "next" operand on every match node is the continuation: when this
 * node has consumed its piece, it dispatches `next` to verify the rest
 * of the pattern.  Chains terminate either at `node_re_succ` (search
 * style) or at `node_action_continue` (case-A scan-and-act style).
 *
 * The for-each-start-position search loop is itself a node
 * (node_grep_search), and the per-line scan-and-act loop is a node
 * (node_scan_lit_dual_byte) — the specialiser folds the loop and the
 * inlined body chain into one SD function in both cases.
 */

/* ------------------------------------------------------------------ */
/* Top-level search wrapper                                            */
/* ------------------------------------------------------------------ */

/* node_grep_search wraps the regex AST and *is* the for-each-start-
 * position search loop.  Putting it in node.def means the specializer
 * bakes the loop and the inlined regex chain into one SD function —
 * gcc can then keep `c->str`, `c->str_len`, the start cursor, and the
 * captures all in registers across iterations, and even vectorise
 * pieces of the inner match where applicable.
 *
 * Caller sets c->pos to the desired starting offset (0 for the first
 * search; previous match's end for resume / enumeration).  The loop
 * iterates s from c->pos upwards, writes s into c->pos at each
 * attempt, and returns 1 on the first success.  When body fails it
 * is responsible for undoing its own state (cap_start does this for
 * group 0; inner cap and rep nodes are likewise self-restoring), so
 * the loop just bumps s and tries again.
 *
 * `anchored_bos` is set at parse time when the pattern starts with
 * \A: in that case only `c->pos == 0` is meaningful.  The framework
 * sees the flag in the structural hash so an anchored vs unanchored
 * pattern with the same body get distinct SDs. */
NODE_DEF
node_grep_search(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t anchored_bos)
{
    size_t start = c->pos;
    size_t start_max = anchored_bos ? (start == 0 ? 1 : 0) : c->str_len + 1;
    for (size_t s = start; s < start_max; s++) {
        c->pos = s;
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        if (EVAL_ARG(c, body)) return MR_STOP;
    }
    return MR_FAIL;
}

/* memchr-prefilter variant of node_grep_search.
 *
 * Used when the parser detects that the pattern can only match at
 * positions where the input has a known fixed first byte (e.g.
 * `/static/` always wants 's' at pos).  glibc's memchr is AVX2
 * PCMPEQB-based on x86-64; ~30 GB/s scan throughput is enough to
 * skip whole KB of input in one library call, so the body chain
 * runs only at candidate positions.
 *
 * Constants `first_byte` and `anchored_bos` are baked into the SD
 * by the specialiser; the memchr call survives as a libc PLT call
 * but with the second argument as an immediate. */
NODE_DEF
node_grep_search_memchr(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t first_byte, uint32_t anchored_bos)
{
    if (anchored_bos) {
        if (c->pos != 0) return MR_FAIL;
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        return EVAL_ARG(c, body);
    }
    const uint8_t *p   = c->str + c->pos;
    const uint8_t *end = c->str + c->str_len;
    while (p < end) {
        const uint8_t *q = (const uint8_t *)memchr(p, (int)(unsigned char)first_byte, (size_t)(end - p));
        if (!q) return MR_FAIL;
        c->pos = (size_t)(q - c->str);
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        if (EVAL_ARG(c, body)) return MR_STOP;
        p = q + 1;
    }
    return MR_FAIL;
}

/* SIMD class membership scan via two PSHUFB nibble lookups —
 * "Truffle"-style.  Handles any 256-bit byte set in a single AVX2
 * pass (32 bytes / iter, two PSHUFB + AND).  False positives may
 * occur on bytes whose hi-nibble shares a bit-position with a real
 * member's hi-nibble; those are filtered by the body chain.
 *
 * The nibble tables T_lo[16] and T_hi[16] are built at parse time
 * and passed as four uint64 operands (low + high 8 bytes each); the
 * specialiser bakes them as immediate vectors. */
NODE_DEF
node_grep_search_class_scan(CTX * restrict c, NODE * restrict n, NODE *body, uint64_t t_lo_a, uint64_t t_lo_b, uint64_t t_hi_a, uint64_t t_hi_b, uint32_t anchored_bos)
{
    if (anchored_bos) {
        if (c->pos != 0) return MR_FAIL;
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        return EVAL_ARG(c, body);
    }

    const uint8_t *p   = c->str + c->pos;
    const uint8_t *end = c->str + c->str_len;

#if defined(__AVX2__)
    {
        union { uint64_t u[2]; __m128i v; } t_lo, t_hi;
        t_lo.u[0] = t_lo_a; t_lo.u[1] = t_lo_b;
        t_hi.u[0] = t_hi_a; t_hi.u[1] = t_hi_b;
        __m256i T_lo = _mm256_broadcastsi128_si256(t_lo.v);
        __m256i T_hi = _mm256_broadcastsi128_si256(t_hi.v);
        __m256i nib_mask = _mm256_set1_epi8(0x0F);
        __m256i zero = _mm256_setzero_si256();
        while (p + 32 <= end) {
            __m256i v   = _mm256_loadu_si256((const __m256i *)p);
            __m256i lo  = _mm256_and_si256(v, nib_mask);
            __m256i hi  = _mm256_and_si256(_mm256_srli_epi16(v, 4), nib_mask);
            __m256i ll  = _mm256_shuffle_epi8(T_lo, lo);
            __m256i hl  = _mm256_shuffle_epi8(T_hi, hi);
            __m256i andr = _mm256_and_si256(ll, hl);
            __m256i mask = _mm256_cmpeq_epi8(andr, zero);          /* zero  → not in set */
            uint32_t bits = ~(uint32_t)_mm256_movemask_epi8(mask);  /* invert: 1 = in set */
            while (bits) {
                int idx = __builtin_ctz(bits);
                c->pos = (size_t)((p + idx) - c->str);
                for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
                c->rep_top = NULL;
                if (EVAL_ARG(c, body)) return MR_STOP;
                bits &= bits - 1;
            }
            p += 32;
        }
    }
#endif

    /* Tail: scalar via the same 16x16 nibble table reconstruction. */
    {
        uint8_t T_lo[16], T_hi[16];
        for (int i = 0; i < 8; i++) T_lo[i]     = (uint8_t)((t_lo_a >> (i * 8)) & 0xFF);
        for (int i = 0; i < 8; i++) T_lo[i + 8] = (uint8_t)((t_lo_b >> (i * 8)) & 0xFF);
        for (int i = 0; i < 8; i++) T_hi[i]     = (uint8_t)((t_hi_a >> (i * 8)) & 0xFF);
        for (int i = 0; i < 8; i++) T_hi[i + 8] = (uint8_t)((t_hi_b >> (i * 8)) & 0xFF);
        while (p < end) {
            uint8_t b = *p;
            if (T_lo[b & 0xF] & T_hi[b >> 4]) {
                c->pos = (size_t)(p - c->str);
                for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
                c->rep_top = NULL;
                if (EVAL_ARG(c, body)) return MR_STOP;
            }
            p++;
        }
    }
    return MR_FAIL;
}

/* SIMD multi-byte scan — for patterns where the very first byte of
 * any successful match must come from a small set (≤ 8 distinct
 * bytes).  Covers alt-led patterns like `(if|else|for|while|return)`
 * (first byte ∈ {i, e, f, w, r}) and small character classes.
 *
 * `packed` holds the bytes packed little-endian into a uint64; the
 * baked SD inlines them as 8 set1_epi8 immediates and a fixed-count
 * cmpeq + or chain.  At AOT-cached time a 5-byte set for the
 * keywords above turns into 5 vpcmpeqb + 4 vpor + vpmovmskb +
 * tzcnt — about 10 cycles per 32 bytes, ~10 GB/s. */
NODE_DEF
node_grep_search_byteset(CTX * restrict c, NODE * restrict n, NODE *body, uint64_t packed, uint32_t n_bytes, uint32_t anchored_bos)
{
    if (anchored_bos) {
        if (c->pos != 0) return MR_FAIL;
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        return EVAL_ARG(c, body);
    }
    if (n_bytes == 0 || n_bytes > 8) return MR_FAIL;

    uint8_t bs[8];
    for (int i = 0; i < 8; i++) bs[i] = (uint8_t)((packed >> (i * 8)) & 0xFF);

    const uint8_t *p   = c->str + c->pos;
    const uint8_t *end = c->str + c->str_len;

#if defined(__AVX2__)
    {
        __m256i v_bs[8];
        for (uint32_t i = 0; i < n_bytes; i++)
            v_bs[i] = _mm256_set1_epi8((char)bs[i]);

        while (p + 32 <= end) {
            __m256i v = _mm256_loadu_si256((const __m256i *)p);
            __m256i mask = _mm256_cmpeq_epi8(v, v_bs[0]);
            for (uint32_t i = 1; i < n_bytes; i++) {
                mask = _mm256_or_si256(mask, _mm256_cmpeq_epi8(v, v_bs[i]));
            }
            uint32_t bits = (uint32_t)_mm256_movemask_epi8(mask);
            while (bits) {
                int idx = __builtin_ctz(bits);
                c->pos = (size_t)((p + idx) - c->str);
                for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
                c->rep_top = NULL;
                if (EVAL_ARG(c, body)) return MR_STOP;
                bits &= bits - 1;
            }
            p += 32;
        }
    }
#endif

    /* tail (and the whole input on non-AVX2 hosts) */
    while (p < end) {
        uint8_t b = *p;
        bool match = false;
        for (uint32_t i = 0; i < n_bytes; i++) {
            if (b == bs[i]) { match = true; break; }
        }
        if (match) {
            c->pos = (size_t)(p - c->str);
            for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
            c->rep_top = NULL;
            if (EVAL_ARG(c, body)) return MR_STOP;
        }
        p++;
    }
    return MR_FAIL;
}

/* SIMD class-range prefilter — for patterns starting with a single
 * contiguous byte range like `[a-z]`, `[0-9]`, `\d`.  AVX2 (32 bytes
 * per iteration) saturating-subtract trick:
 *
 *   v_sub  = subs_epu8(v, lo)        ; saturate-to-zero anything below lo
 *   in_set = (min(v_sub, hi-lo) == v_sub)  ; true iff v_sub <= hi-lo
 *
 * One mask per 32 bytes; movemask + ctz to enumerate hits.  This is
 * the same shape ugrep uses for [a-z]-class scans on AVX2 hosts.
 *
 * Constants `lo`, `hi`, `anchored_bos` are baked by the specialiser
 * into the AVX2 set1 immediates, so the inner loop becomes a tight
 * `vmovdqu / vpsubusb / vpminub / vpcmpeqb / vpmovmskb / tzcnt`. */
NODE_DEF
node_grep_search_range(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t lo, uint32_t hi, uint32_t anchored_bos)
{
    if (anchored_bos) {
        if (c->pos != 0) return MR_FAIL;
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        return EVAL_ARG(c, body);
    }

    const uint8_t *p   = c->str + c->pos;
    const uint8_t *end = c->str + c->str_len;

#if defined(__AVX2__)
    {
        __m256i v_lo    = _mm256_set1_epi8((char)(uint8_t)lo);
        __m256i v_width = _mm256_set1_epi8((char)(uint8_t)(hi - lo));
        while (p + 32 <= end) {
            __m256i v       = _mm256_loadu_si256((const __m256i *)p);
            __m256i v_sub   = _mm256_subs_epu8(v, v_lo);
            __m256i clipped = _mm256_min_epu8(v_sub, v_width);
            __m256i mask    = _mm256_cmpeq_epi8(clipped, v_sub);
            uint32_t bits = (uint32_t)_mm256_movemask_epi8(mask);
            while (bits) {
                int idx = __builtin_ctz(bits);
                c->pos = (size_t)((p + idx) - c->str);
                for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
                c->rep_top = NULL;
                if (EVAL_ARG(c, body)) return MR_STOP;
                bits &= bits - 1;
            }
            p += 32;
        }
    }
#endif

    /* tail (and the whole input on non-AVX2 hosts) */
    while (p < end) {
        if ((uint8_t)*p >= (uint8_t)lo && (uint8_t)*p <= (uint8_t)hi) {
            c->pos = (size_t)(p - c->str);
            for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
            c->rep_top = NULL;
            if (EVAL_ARG(c, body)) return MR_STOP;
        }
        p++;
    }
    return MR_FAIL;
}

/* memmem-prefilter variant: same shape as memchr but with a multi-
 * byte needle, used when the pattern starts with a >= 4-byte literal
 * (e.g. `/specialized_dispatcher/`).  glibc's memmem is two-way
 * string match — sublinear average case, much harder to fool than
 * a single-byte memchr scan when the first byte happens to be
 * common.
 *
 * The needle bytes live in `prefix` (a const char * baked into the
 * SD); the body chain re-verifies from c->pos onwards exactly as in
 * the plain search, so a memmem false-positive (the wider regex
 * doesn't match here) just drops back to a normal candidate-position
 * retry. */
NODE_DEF
node_grep_search_memmem(CTX * restrict c, NODE * restrict n, NODE *body, const char *prefix, uint32_t prefix_len, uint32_t anchored_bos)
{
    if (anchored_bos) {
        if (c->pos != 0) return MR_FAIL;
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        return EVAL_ARG(c, body);
    }
    const uint8_t *p   = c->str + c->pos;
    const uint8_t *end = c->str + c->str_len;
    while ((size_t)(end - p) >= (size_t)prefix_len) {
        const uint8_t *q = (const uint8_t *)memmem(p, (size_t)(end - p), prefix, (size_t)prefix_len);
        if (!q) return MR_FAIL;
        c->pos = (size_t)(q - c->str);
        for (int i = 0; i < ASTROGRE_MAX_GROUPS; i++) c->valid[i] = false;
        c->rep_top = NULL;
        if (EVAL_ARG(c, body)) return MR_STOP;
        p = q + 1;
    }
    return MR_FAIL;
}

/* Generic literal-prefilter scanner.  Same dual-byte filter as the
 * old monolithic node_grep_count_lines_lit, but the per-match work
 * is delegated to `body` — a chain that may include action nodes
 * (count / lineskip / emit / etc) and/or the existing regex AST.
 *
 * Return-code protocol (see context.h):
 *   0 = body failed (regex chain didn't match here) → scanner advances
 *       by 1 byte and tries the next position.
 *   1 = body succeeded, search-style stop (re_succ at the tail) →
 *       scanner returns 1 immediately.
 *   2 = body succeeded, action chain completed and may have advanced
 *       c->pos (lineskip / match_end_advance) → scanner reads c->pos
 *       and resumes from there.
 *
 * Hot path (the 99% case where the 64-byte window has no candidate
 * for the dual-byte filter): 8 SIMD ops + vptest + p += 64.  Cold path
 * walks bit-set candidates, verifies the middle bytes, and dispatches
 * body.  Because `needle` is a baked const-string operand and
 * `needle_len` is a baked uint32 immediate, the SD has set1_epi8 of
 * needle[0] / needle[off] folded to constants and the verify memcmp
 * lowered to direct cmpl/cmpb chains. */
NODE_DEF
node_scan_lit_dual_byte(CTX * restrict c, NODE * restrict n, NODE *body, const char *needle, uint32_t needle_len)
{
    const uint8_t *p   = c->str + c->pos;
    const uint8_t *end = c->str + c->str_len;

    if (needle_len == 0) return MR_FAIL;

    if (needle_len == 1) {
        const int target = (int)(uint8_t)needle[0];
        while (p < end) {
            const uint8_t *q = (const uint8_t *)memchr(p, target, (size_t)(end - p));
            if (!q) break;
            c->pos = (size_t)(q - c->str);
            VALUE r = EVAL_ARG(c, body);
            if (r == MR_STOP) return MR_STOP;
            if (r == MR_CONTINUE) p = c->str + c->pos;
            else        p = q + 1;
        }
        return MR_FAIL;
    }

#if defined(__AVX2__)
    {
        const uint32_t off = needle_len - 1;
        __m256i v_first = _mm256_set1_epi8((char)(uint8_t)needle[0]);
        __m256i v_last  = _mm256_set1_epi8((char)(uint8_t)needle[off]);
        while (p + 64 + needle_len <= end) {
            __m256i a0 = _mm256_loadu_si256((const __m256i *)p);
            __m256i a1 = _mm256_loadu_si256((const __m256i *)(p + 32));
            __m256i b0 = _mm256_loadu_si256((const __m256i *)(p + off));
            __m256i b1 = _mm256_loadu_si256((const __m256i *)(p + 32 + off));
            __m256i ma0 = _mm256_cmpeq_epi8(a0, v_first);
            __m256i ma1 = _mm256_cmpeq_epi8(a1, v_first);
            __m256i mb0 = _mm256_cmpeq_epi8(b0, v_last);
            __m256i mb1 = _mm256_cmpeq_epi8(b1, v_last);
            __m256i mask0 = _mm256_and_si256(ma0, mb0);
            __m256i mask1 = _mm256_and_si256(ma1, mb1);
            __m256i any = _mm256_or_si256(mask0, mask1);
            if (__builtin_expect(_mm256_testz_si256(any, any), 1)) {
                p += 64;
                continue;
            }
            /* Cold: walk candidate bits, verify, dispatch body. */
            uint64_t bits = (uint64_t)(uint32_t)_mm256_movemask_epi8(mask0)
                          | ((uint64_t)(uint32_t)_mm256_movemask_epi8(mask1) << 32);
            const uint8_t *new_p = NULL;
            while (bits) {
                int idx = __builtin_ctzll(bits);
                const uint8_t *q = p + idx;
                bits &= bits - 1;
                if (new_p && q < new_p) continue;          /* a previous match advanced past q */
                bool ok = true;
                if (needle_len > 2) {
                    ok = (memcmp(q + 1, needle + 1, (size_t)(needle_len - 2)) == 0);
                }
                if (ok) {
                    c->pos = (size_t)(q - c->str);
                    VALUE r = EVAL_ARG(c, body);
                    if (r == MR_STOP) return MR_STOP;
                    if (r == MR_CONTINUE) {
                        new_p = c->str + c->pos;
                        if (new_p >= p + 64) goto chunk_done;
                    }
                    /* r == MR_FAIL (regex chain failed at q): keep walking bits. */
                }
            }
            p = (new_p && new_p > p + 64) ? new_p : p + 64;
        chunk_done:
            if (new_p) p = new_p;
        }
    }
#endif

    /* Tail (and the whole input on non-AVX2 hosts). */
    while (p + needle_len <= end) {
        if ((uint8_t)*p == (uint8_t)needle[0]
            && (needle_len == 1 || memcmp(p + 1, needle + 1, (size_t)(needle_len - 1)) == 0)) {
            c->pos = (size_t)(p - c->str);
            VALUE r = EVAL_ARG(c, body);
            if (r == MR_STOP) return MR_STOP;
            if (r == MR_CONTINUE) p = c->str + c->pos;
            else        p++;
        } else {
            p++;
        }
    }
    return MR_FAIL;
}

/* ------------------------------------------------------------------ */
/* Per-match action nodes (case-A factorization)                       */
/* ------------------------------------------------------------------ */

/* `c->count_result++`, dispatch next.  Used in the body chain for `-c`
 * mode: scanner finds match, count action increments, lineskip advances
 * past the line, continue terminator returns 2 to scanner. */
NODE_DEF
node_action_count(CTX * restrict c, NODE * restrict n, NODE *next)
{
    c->count_result++;
    return EVAL_ARG(c, next);
}

/* Advance `c->pos` to the byte after the next '\n' (or to str_len + 1
 * when no more newlines).  Used after count / emit so the scanner
 * resumes from the next line. */
NODE_DEF
node_action_lineskip(CTX * restrict c, NODE * restrict n, NODE *next)
{
    const uint8_t *p   = c->str + c->pos;
    const uint8_t *end = c->str + c->str_len;
    const uint8_t *nl  = (const uint8_t *)memchr(p, '\n', (size_t)(end - p));
    c->pos = nl ? (size_t)(nl - c->str) + 1 : c->str_len + 1;
    return EVAL_ARG(c, next);
}

/* Action-chain terminator: signals "match recorded, please continue
 * scanning from c->pos" (= return code 2).  Contrast with re_succ
 * which returns 1 (= "stop, search succeeded"). */
NODE_DEF
node_action_continue(CTX * restrict c, NODE * restrict n)
{
    return MR_CONTINUE;
}

/* Emit the line containing the current match for grep-style printing.
 *
 * Inputs:
 *   c->pos     — match start (set by scanner)
 *   match_len  — match length in bytes (baked immediate)
 *   opts       — bit field, baked immediate; the framework's structural
 *                hash treats this as part of the operand list so each
 *                option combo produces its own SD:
 *                  bit 0: emit `<fname>:` prefix
 *                  bit 1: emit `<lineno>:` prefix (uses c->lineno)
 *                  bit 2: --color: surround the match span with ANSI
 *                         red and reset
 *
 * Side-effect on c->pos: none.  Lineskip happens in a separate
 * `node_action_lineskip` downstream; emitting and advancing are kept
 * orthogonal so a future `-o` (only-matching) variant can reuse this
 * shape with a different advance strategy.
 *
 * lineno tracking: when bit 1 is set, advance c->lineno by counting
 * '\n' bytes between c->lineno_pos and the matched line's start.  The
 * caller initialises lineno=0, lineno_pos=0 per file; this action keeps
 * them in sync incrementally so per-file work is O(file_size) total
 * regardless of how many matches there are. */
/* ASTROGRE_EMIT_FNAME / _LINENO / _COLOR are in context.h so the CLI
 * driver can build the opts bitfield before constructing the AST. */
NODE_DEF
node_action_emit_match_line(CTX * restrict c, NODE * restrict n, NODE *next, uint32_t match_len, uint32_t opts)
{
    const uint8_t *str = c->str;
    const size_t str_len = c->str_len;
    const size_t match_start = c->pos;
    const size_t match_end   = match_start + match_len;

    /* Line bounds. */
    size_t line_start = 0;
    if (match_start > 0) {
        const uint8_t *p = (const uint8_t *)memrchr(str, '\n', match_start);
        if (p) line_start = (size_t)(p - str) + 1;
    }
    size_t line_end = str_len;
    if (match_end < str_len) {
        const uint8_t *p = (const uint8_t *)memchr(str + match_end, '\n',
                                                     str_len - match_end);
        if (p) line_end = (size_t)(p - str);
    }

    /* Lazy lineno: advance from previous lineno_pos to this line's start. */
    if (opts & ASTROGRE_EMIT_LINENO) {
        const uint8_t *lp = str + c->lineno_pos;
        const uint8_t *te = str + line_start;
        while (lp < te) {
            const uint8_t *nl = (const uint8_t *)memchr(lp, '\n', (size_t)(te - lp));
            if (!nl) break;
            c->lineno++;
            lp = nl + 1;
        }
        c->lineno_pos = line_start;
        c->lineno++;       /* the matching line itself */
    }

    FILE *out = c->out ? c->out : stdout;
    if (opts & ASTROGRE_EMIT_FNAME) {
        fputs(c->fname ? c->fname : "", out);
        fputc(':', out);
    }
    if (opts & ASTROGRE_EMIT_LINENO) {
        fprintf(out, "%ld:", c->lineno);
    }

    if (opts & ASTROGRE_EMIT_COLOR) {
        /* before-match | RED match RESET | after-match | NL */
        fwrite(str + line_start, 1, match_start - line_start, out);
        fputs("\x1b[01;31m\x1b[K", out);
        fwrite(str + match_start, 1, match_end - match_start, out);
        fputs("\x1b[m\x1b[K", out);
        fwrite(str + match_end, 1, line_end - match_end, out);
    } else {
        fwrite(str + line_start, 1, line_end - line_start, out);
    }
    fputc('\n', out);

    /* Bump lineno_pos past the just-emitted line so subsequent matches
     * on later lines don't re-count the newlines we already crossed. */
    if (opts & ASTROGRE_EMIT_LINENO) {
        c->lineno_pos = (line_end < str_len) ? line_end + 1 : str_len;
    }

    return EVAL_ARG(c, next);
}

/* ------------------------------------------------------------------ */
/* Terminator                                                          */
/* ------------------------------------------------------------------ */

NODE_DEF
node_re_succ(CTX * restrict c, NODE * restrict n)
{
    /* Reached end of pattern: record end of whole match and signal success. */
    c->ends[0]  = c->pos;
    c->valid[0] = true;
    return MR_STOP;
}

/* ------------------------------------------------------------------ */
/* Literal byte sequence                                               */
/* ------------------------------------------------------------------ */

NODE_DEF
node_re_lit(CTX * restrict c, NODE * restrict n, const char *bytes, uint32_t len, NODE *next)
{
    if (c->pos + (size_t)len > c->str_len) return MR_FAIL;
    if (memcmp(c->str + c->pos, bytes, len) != 0) return MR_FAIL;
    c->pos += len;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos -= len;
    return r;
}

/* Case-insensitive literal (ASCII fold).  `bytes` is already lowercased
 * at parse time; we lowercase the input on the fly. */
NODE_DEF
node_re_lit_ci(CTX * restrict c, NODE * restrict n, const char *bytes, uint32_t len, NODE *next)
{
    if (c->pos + (size_t)len > c->str_len) return MR_FAIL;
    const uint8_t *s = c->str + c->pos;
    for (uint32_t i = 0; i < len; i++) {
        uint8_t b = s[i];
        if (b >= 'A' && b <= 'Z') b += 32;
        if (b != (uint8_t)bytes[i]) return MR_FAIL;
    }
    c->pos += len;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos -= len;
    return r;
}

/* ------------------------------------------------------------------ */
/* "."                                                                 */
/* ------------------------------------------------------------------ */

/* ASCII dot: any single byte except '\n' */
NODE_DEF
node_re_dot(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos >= c->str_len) return MR_FAIL;
    if (c->str[c->pos] == '\n') return MR_FAIL;
    c->pos++;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos--;
    return r;
}

/* ASCII dot with /m flag: any single byte */
NODE_DEF
node_re_dot_m(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos >= c->str_len) return MR_FAIL;
    c->pos++;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos--;
    return r;
}

/* UTF-8 dot: one full codepoint, except '\n' */
NODE_DEF
node_re_dot_utf8(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos >= c->str_len) return MR_FAIL;
    uint8_t b = c->str[c->pos];
    if (b == '\n') return MR_FAIL;
    int adv;
    if      (b < 0x80)         adv = 1;
    else if ((b & 0xE0)==0xC0) adv = 2;
    else if ((b & 0xF0)==0xE0) adv = 3;
    else if ((b & 0xF8)==0xF0) adv = 4;
    else                       return MR_FAIL;
    if (c->pos + (size_t)adv > c->str_len) return MR_FAIL;
    c->pos += adv;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos -= adv;
    return r;
}

/* UTF-8 dot, /m flag */
NODE_DEF
node_re_dot_utf8_m(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos >= c->str_len) return MR_FAIL;
    uint8_t b = c->str[c->pos];
    int adv;
    if      (b < 0x80)         adv = 1;
    else if ((b & 0xE0)==0xC0) adv = 2;
    else if ((b & 0xF0)==0xE0) adv = 3;
    else if ((b & 0xF8)==0xF0) adv = 4;
    else                       return MR_FAIL;
    if (c->pos + (size_t)adv > c->str_len) return MR_FAIL;
    c->pos += adv;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos -= adv;
    return r;
}

/* ------------------------------------------------------------------ */
/* Character class (256-bit ASCII bitmap)                              */
/* ------------------------------------------------------------------ */

/* For UTF-8 input with non-ASCII bytes (>= 0x80), matching is byte-wise
 * on the leading byte.  Patterns intended to match arbitrary UTF-8
 * codepoints inside a class fall back to a two-stage check the parser
 * builds (alternation of literals).  For ASCII-only classes this is the
 * fast path. */
NODE_DEF
node_re_class(CTX * restrict c, NODE * restrict n, uint64_t bm0, uint64_t bm1, uint64_t bm2, uint64_t bm3, NODE *next)
{
    if (c->pos >= c->str_len) return MR_FAIL;
    uint8_t b = c->str[c->pos];
    uint64_t bm[4] = { bm0, bm1, bm2, bm3 };
    if (!((bm[b >> 6] >> (b & 63)) & 1ULL)) return MR_FAIL;
    c->pos++;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos--;
    return r;
}

/* ------------------------------------------------------------------ */
/* Alternation                                                         */
/* ------------------------------------------------------------------ */

/* Branches each carry their own continuation (the parser threads the
 * outer next into both left and right), so alt only needs to try left,
 * and on failure restore pos and try right. */
NODE_DEF
node_re_alt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    size_t saved = c->pos;
    if (EVAL_ARG(c, left)) return MR_STOP;
    c->pos = saved;
    return EVAL_ARG(c, right);
}

/* ------------------------------------------------------------------ */
/* Repetition (*, +, ?, {n,m})                                         */
/* ------------------------------------------------------------------ */

/* Push a frame and dispatch the rep_cont sentinel to drive iteration.
 * The body of the rep has its tail wired to the rep_cont sentinel, so
 * each successful body run lands back in rep_cont — which decides to
 * iterate again or to proceed to outer_next. */
NODE_DEF
node_re_rep(CTX * restrict c, NODE * restrict n, NODE *body, NODE *outer_next, int32_t min, int32_t max, uint32_t greedy)
{
    struct rep_frame f;
    f.body = body;
    f.outer_next = outer_next;
    f.min = min;
    f.max = max;
    f.greedy = greedy;
    f.prev = c->rep_top;
    c->rep_top = &f;

    NODE *cont = c->rep_cont_sentinel;
    VALUE r = (*cont->head.dispatcher)(c, cont);

    c->rep_top = f.prev;
    return r;
}

/* Singleton continuation node attached as the `next` of every rep body.
 * Reads top of c->rep_top to know which rep frame is active. */
NODE_DEF
node_re_rep_cont(CTX * restrict c, NODE * restrict n)
{
    struct rep_frame *f = c->rep_top;

    if (f->greedy) {
        /* Greedy: try to take one more iteration first. */
        if (f->max != 0) {
            int32_t saved_min = f->min;
            int32_t saved_max = f->max;
            size_t  saved_pos = c->pos;
            f->min = (f->min > 0) ? f->min - 1 : 0;
            f->max = (f->max == -1) ? -1 : f->max - 1;
            VALUE r = (*f->body->head.dispatcher)(c, f->body);
            if (r) return MR_STOP;
            c->pos = saved_pos;
            f->min = saved_min;
            f->max = saved_max;
        }
        /* Otherwise, if min satisfied, fall through to outer_next. */
        if (f->min == 0) {
            struct rep_frame *prev = f->prev;
            c->rep_top = prev;
            VALUE r = (*f->outer_next->head.dispatcher)(c, f->outer_next);
            c->rep_top = f;
            return r;
        }
        return MR_FAIL;
    }
    else {
        /* Lazy: try outer_next first, only iterate if it fails. */
        if (f->min == 0) {
            struct rep_frame *prev = f->prev;
            c->rep_top = prev;
            VALUE r = (*f->outer_next->head.dispatcher)(c, f->outer_next);
            if (r) return MR_STOP;
            c->rep_top = f;
        }
        if (f->max != 0) {
            int32_t saved_min = f->min;
            int32_t saved_max = f->max;
            size_t  saved_pos = c->pos;
            f->min = (f->min > 0) ? f->min - 1 : 0;
            f->max = (f->max == -1) ? -1 : f->max - 1;
            VALUE r = (*f->body->head.dispatcher)(c, f->body);
            if (r) return MR_STOP;
            c->pos = saved_pos;
            f->min = saved_min;
            f->max = saved_max;
        }
        return MR_FAIL;
    }
}

/* ------------------------------------------------------------------ */
/* Captures                                                            */
/* ------------------------------------------------------------------ */

NODE_DEF
node_re_cap_start(CTX * restrict c, NODE * restrict n, uint32_t idx, NODE *next)
{
    size_t saved_start = c->starts[idx];
    bool   saved_valid = c->valid[idx];
    c->starts[idx] = c->pos;
    VALUE r = EVAL_ARG(c, next);
    if (!r) {
        c->starts[idx] = saved_start;
        c->valid[idx]  = saved_valid;
    }
    return r;
}

NODE_DEF
node_re_cap_end(CTX * restrict c, NODE * restrict n, uint32_t idx, NODE *next)
{
    size_t saved_end   = c->ends[idx];
    bool   saved_valid = c->valid[idx];
    c->ends[idx]  = c->pos;
    c->valid[idx] = true;
    VALUE r = EVAL_ARG(c, next);
    if (!r) {
        c->ends[idx]  = saved_end;
        c->valid[idx] = saved_valid;
    }
    return r;
}

/* ------------------------------------------------------------------ */
/* Anchors                                                             */
/* ------------------------------------------------------------------ */

NODE_DEF
node_re_bos(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos != 0) return MR_FAIL;
    return EVAL_ARG(c, next);
}

NODE_DEF
node_re_eos(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos != c->str_len) return MR_FAIL;
    return EVAL_ARG(c, next);
}

/* \Z — end of string, or just before a final \n */
NODE_DEF
node_re_eos_nl(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos == c->str_len) return EVAL_ARG(c, next);
    if (c->pos == c->str_len - 1 && c->str[c->pos] == '\n') return EVAL_ARG(c, next);
    return MR_FAIL;
}

NODE_DEF
node_re_bol(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos == 0) return EVAL_ARG(c, next);
    if (c->str[c->pos - 1] == '\n') return EVAL_ARG(c, next);
    return MR_FAIL;
}

NODE_DEF
node_re_eol(CTX * restrict c, NODE * restrict n, NODE *next)
{
    if (c->pos == c->str_len) return EVAL_ARG(c, next);
    if (c->str[c->pos] == '\n') return EVAL_ARG(c, next);
    return MR_FAIL;
}

static inline int agre_is_word_char(uint8_t b)
{
    return (b >= 'A' && b <= 'Z')
        || (b >= 'a' && b <= 'z')
        || (b >= '0' && b <= '9')
        || (b == '_');
}

NODE_DEF
node_re_word_boundary(CTX * restrict c, NODE * restrict n, NODE *next)
{
    int prev_w = (c->pos > 0)            ? agre_is_word_char(c->str[c->pos - 1]) : 0;
    int next_w = (c->pos < c->str_len)   ? agre_is_word_char(c->str[c->pos])     : 0;
    if (prev_w == next_w) return MR_FAIL;
    return EVAL_ARG(c, next);
}

NODE_DEF
node_re_non_word_boundary(CTX * restrict c, NODE * restrict n, NODE *next)
{
    int prev_w = (c->pos > 0)            ? agre_is_word_char(c->str[c->pos - 1]) : 0;
    int next_w = (c->pos < c->str_len)   ? agre_is_word_char(c->str[c->pos])     : 0;
    if (prev_w != next_w) return MR_FAIL;
    return EVAL_ARG(c, next);
}

/* ------------------------------------------------------------------ */
/* Backreference                                                       */
/* ------------------------------------------------------------------ */

NODE_DEF
node_re_backref(CTX * restrict c, NODE * restrict n, uint32_t idx, NODE *next)
{
    if (!c->valid[idx]) return MR_FAIL;
    size_t s = c->starts[idx];
    size_t e = c->ends[idx];
    size_t cap_len = e - s;
    if (c->pos + cap_len > c->str_len) return MR_FAIL;
    if (c->case_insensitive) {
        for (size_t i = 0; i < cap_len; i++) {
            uint8_t a = c->str[s + i], b = c->str[c->pos + i];
            if (a >= 'A' && a <= 'Z') a += 32;
            if (b >= 'A' && b <= 'Z') b += 32;
            if (a != b) return MR_FAIL;
        }
    } else {
        if (memcmp(c->str + s, c->str + c->pos, cap_len) != 0) return MR_FAIL;
    }
    c->pos += cap_len;
    VALUE r = EVAL_ARG(c, next);
    if (!r) c->pos -= cap_len;
    return r;
}

/* ------------------------------------------------------------------ */
/* Lookaround (zero-width)                                             */
/* ------------------------------------------------------------------ */

/* (?=body) — body matches but consumes nothing. */
NODE_DEF
node_re_lookahead(CTX * restrict c, NODE * restrict n, NODE *body, NODE *next)
{
    size_t saved_pos = c->pos;
    /* Save and restore captures: lookahead's body may run cap_start/end,
     * but the conventional Ruby semantics keeps captures opened inside
     * lookahead live if they succeed. We honour that: don't restore caps
     * on success, only on failure. */
    if (!(*body->head.dispatcher)(c, body)) {
        c->pos = saved_pos;
        return MR_FAIL;
    }
    c->pos = saved_pos;
    return EVAL_ARG(c, next);
}

NODE_DEF
node_re_neg_lookahead(CTX * restrict c, NODE * restrict n, NODE *body, NODE *next)
{
    size_t saved_pos = c->pos;
    /* Snapshot caps so the inner body can't leak captures on success
     * (which we treat as failure here). */
    size_t st[ASTROGRE_MAX_GROUPS], en[ASTROGRE_MAX_GROUPS];
    bool   vd[ASTROGRE_MAX_GROUPS];
    memcpy(st, c->starts, sizeof(st));
    memcpy(en, c->ends,   sizeof(en));
    memcpy(vd, c->valid,  sizeof(vd));

    VALUE r = (*body->head.dispatcher)(c, body);
    c->pos = saved_pos;
    memcpy(c->starts, st, sizeof(st));
    memcpy(c->ends,   en, sizeof(en));
    memcpy(c->valid,  vd, sizeof(vd));
    if (r) return MR_FAIL;
    return EVAL_ARG(c, next);
}
