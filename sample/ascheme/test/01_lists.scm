;; list operations
(display (cons 1 2)) (newline)
(display (cons 1 (cons 2 (cons 3 '())))) (newline)
(display (list 1 2 3 4)) (newline)
(display (car '(a b c))) (newline)
(display (cdr '(a b c))) (newline)
(display (length '(1 2 3 4 5))) (newline)
(display (reverse '(1 2 3 4 5))) (newline)
(display (append '(1 2) '(3 4) '(5 6))) (newline)
(display (list-ref '(a b c d) 2)) (newline)
(display (list-tail '(1 2 3 4) 2)) (newline)
(display (null? '())) (newline)
(display (null? '(1))) (newline)
(display (pair? '(1 2))) (newline)
(display (pair? '())) (newline)
(display (list? '(1 2 3))) (newline)
(display (list? '(1 . 2))) (newline)
(display (memv 3 '(1 2 3 4 5))) (newline)
(display (assq 'b '((a 1) (b 2) (c 3)))) (newline)
(display (cadr '(1 2 3))) (newline)
(display (caddr '(1 2 3 4))) (newline)
(let ((p (cons 1 2)))
  (set-car! p 10)
  (set-cdr! p 20)
  (display p) (newline))
