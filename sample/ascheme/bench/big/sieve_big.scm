;; Sieve of Eratosthenes up to 10,000,000 — large vector + nested
;; integer loops.
(define (sieve n)
  (let ((v (make-vector (+ n 1) #t)))
    (vector-set! v 0 #f)
    (vector-set! v 1 #f)
    (let outer ((i 2))
      (cond ((> i n) #t)
            ((vector-ref v i)
             (let inner ((j (* i i)))
               (cond ((> j n) (outer (+ i 1)))
                     (else (vector-set! v j #f) (inner (+ j i))))))
            (else (outer (+ i 1)))))
    (let count ((i 0) (acc 0))
      (cond ((> i n) acc)
            ((vector-ref v i) (count (+ i 1) (+ acc 1)))
            (else (count (+ i 1) acc))))))
(display (sieve 10000000))
(newline)
