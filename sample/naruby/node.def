
// literal

NODE_DEF
node_num(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, int32_t num)
{
    return RESULT_OK(num);
}

// local variables — fp[index] reads/writes the current frame slot
// directly, so the SD chain never has to round-trip through `c->fp`.

NODE_DEF
node_lget(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t index)
{
    return RESULT_OK(fp[index]);
}

NODE_DEF
node_lset(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t index, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    fp[index] = v;
    return RESULT_OK(v);
}

// syntax

NODE_DEF
node_scope(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t envsize, NODE *body)
{
    return EVAL(c, body, fp + envsize);
}

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *head, NODE *tail)
{
    // Discard head's value but propagate non-NORMAL state (e.g. RETURN
    // inside an `if` whose branch is `head`).  UNWRAP returns from the
    // current function on non-NORMAL.
    (void)UNWRAP(EVAL_ARG(c, head));
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *then_node, NODE *else_node)
{
    if (UNWRAP(EVAL_ARG(c, cond))) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *body)
{
    while (UNWRAP(EVAL_ARG(c, cond))) {
        RESULT r = EVAL_ARG(c, body);
        // RETURN propagates up; the body's value is discarded.
        if (UNLIKELY(r.state != RESULT_NORMAL)) return r;
    }
    return RESULT_OK(0);
}

// `return expr` — emit RESULT_RETURN.  The enclosing function-call site
// (call_body / node_call2's fast path) catches it and converts back to
// RESULT_NORMAL so the caller sees a normal return value.

NODE_DEF
node_return(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return RESULT_RETURN_(v);
}

// functions

static struct function_entry *
get_func_entry(CTX * restrict c, const char *name)
{
    for (int i=0; i<c->func_set_cnt; i++) {
        // override
        if (strcmp(c->func_set[i].name, name) == 0) {
            return &c->func_set[i];
        }
    }
    return &c->func_set[c->func_set_cnt++];
}

NODE_DEF @noinline
node_def(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, NODE *body, uint32_t params_cnt, uint32_t locals_cnt)
{
    struct function_entry *fe = get_func_entry(c, name);
    fe->name = name;
    fe->body = OPTIMIZE(body);
    // Override OPTIMIZE's AOT-only cs_load with a PGC-aware load: pass
    // `name` as `file` so cs_load consults the hopt_index for a
    // profile-baked PGSD_<HOPT>, falling back to SD_<HORG>.
    (void)astro_cs_load(fe->body, name);
    fe->params_cnt = params_cnt;
    fe->locals_cnt = locals_cnt;
    c->serial++;

    return RESULT_OK(0);
}

static struct function_entry *
find_func_entry(CTX * restrict c, const char *name)
{
    for (int i=0; i < c->func_set_cnt; i++) {
        struct function_entry *fe = &c->func_set[i];
        if (strcmp(name, fe->name) == 0) {
            return fe;
        }
    }

    return NULL;
}

static void
call_check(struct function_entry *fe, const char *name, uint32_t params_cnt)
{
    if (UNLIKELY(fe == NULL)) {
        fprintf(stderr, "unknown function: %s\n", name);
        exit(1);
    }
    else if (UNLIKELY(fe->params_cnt != params_cnt)) {
        fprintf(stderr, "wrong parameter count for %s (%u for %u)\n", name, params_cnt, fe->params_cnt);
    }
}

#define CALL_DEBUG 0

// Catch RESULT_RETURN at the function boundary.  A `return expr` inside
// `body` propagates up via RESULT.state until it hits this catch — at
// which point it converts to RESULT_NORMAL so the caller sees the value
// as the call's return.  Other states (none yet for naruby) would pass
// through unchanged.
//
// `fp` is the caller's frame; the callee's frame is `fp + arg_index`
// (args were already laid down by the caller's `lset` chain).
static RESULT
call_body(CTX * restrict c, VALUE * restrict fp, uint32_t arg_index, NODE *body)
{
#ifndef ASTRO_SPECIALIZED
    // profile
    if (OPTION.jit &&
        (body->head.jit_status != JIT_STATUS_Compiled ||
         body->head.jit_status != JIT_STATUS_Compiling)) {

        body->head.dispatch_cnt++;
        if (body->head.dispatch_cnt == 100) {
            fprintf(stderr, "cnt:%d\n", body->head.dispatch_cnt);
            void astro_jit_submit_compile(NODE *);
            astro_jit_submit_compile(body);
        }
    }
#endif

    RESULT r = EVAL(c, body, fp + arg_index);

    // Unconditional state-clear (≡ `RESULT_OK(r.value)`): naruby's only
    // non-NORMAL state is RESULT_RETURN, which we want to catch at the
    // function boundary anyway.  vs the conditional form
    // `if (state == RETURN) state = NORMAL`, this lets gcc see state
    // is provably 0 after the call — caller's UNWRAP DCEs to a no-op
    // and the SD chain inlines deeper.
    return RESULT_OK(r.value);
}

NODE_DEF
node_call(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t params_cnt, uint32_t arg_index, struct callcache *cc@ref)
{
    if (LIKELY(c->serial == cc->serial)) {
        return call_body(c, fp, arg_index, cc->body);
    }
    else {
        struct function_entry *fe = find_func_entry(c, name);
        call_check(fe, name, params_cnt);

        cc->serial = c->serial;
        cc->body = fe->body;

        return call_body(c, fp, arg_index, fe->body);
    }
}

// Arity-specialized AOT/interp call sites.  Mirror `node_pg_call_<N>`
// but **without** `sp_body` — the body is resolved through `cc` on
// every call (just like `node_call`).
//
// Why these exist:
//   PG mode's `node_pg_call_<N>` combines two effects — (a) baked
//   direct call to `SD_<HASH(sp_body)>` (= the inlining win), and
//   (b) arity-N specialization (explicit arg operands + fresh callee
//   frame `F[locals_cnt]`, no node_lset chain).  To isolate (a) in
//   the AOT-vs-PG comparison, the AOT/interp path also needs (b).
//   These nodes provide it: same arg-eval / fresh-frame shape as
//   `node_pg_call_<N>`, but dispatch goes through the dynamic
//   `cc->body` (= the AOT convention).
//
// Like `node_pg_call_<N>`, `arg_index` is unused at runtime (we use
// the fresh frame F, not caller_fp + arg_index) but kept as an
// operand for parser/locals_cnt patching consistency.

NODE_DEF
node_call_0(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref)
{
    (void)arg_index;
    NODE *body;
    if (LIKELY(c->serial == cc->serial)) {
        body = cc->body;
    }
    else {
        return node_call_n_slowpath(c, n, NULL, 0, name, cc);
    }
    VALUE F[locals_cnt > 0 ? locals_cnt : 1];
    return RESULT_OK(EVAL(c, body, F).value);
}

NODE_DEF
node_call_1(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref, NODE *a0)
{
    (void)arg_index;
    VALUE v0 = UNWRAP(EVAL_ARG(c, a0));
    NODE *body;
    if (LIKELY(c->serial == cc->serial)) {
        body = cc->body;
    }
    else {
        VALUE args[1] = { v0 };
        return node_call_n_slowpath(c, n, args, 1, name, cc);
    }
    VALUE F[locals_cnt];
    F[0] = v0;
    return RESULT_OK(EVAL(c, body, F).value);
}

NODE_DEF
node_call_2(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref, NODE *a0, NODE *a1)
{
    (void)arg_index;
    VALUE v0 = UNWRAP(EVAL_ARG(c, a0));
    VALUE v1 = UNWRAP(EVAL_ARG(c, a1));
    NODE *body;
    if (LIKELY(c->serial == cc->serial)) {
        body = cc->body;
    }
    else {
        VALUE args[2] = { v0, v1 };
        return node_call_n_slowpath(c, n, args, 2, name, cc);
    }
    VALUE F[locals_cnt];
    F[0] = v0;
    F[1] = v1;
    return RESULT_OK(EVAL(c, body, F).value);
}

NODE_DEF
node_call_3(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref, NODE *a0, NODE *a1, NODE *a2)
{
    (void)arg_index;
    VALUE v0 = UNWRAP(EVAL_ARG(c, a0));
    VALUE v1 = UNWRAP(EVAL_ARG(c, a1));
    VALUE v2 = UNWRAP(EVAL_ARG(c, a2));
    NODE *body;
    if (LIKELY(c->serial == cc->serial)) {
        body = cc->body;
    }
    else {
        VALUE args[3] = { v0, v1, v2 };
        return node_call_n_slowpath(c, n, args, 3, name, cc);
    }
    VALUE F[locals_cnt];
    F[0] = v0;
    F[1] = v1;
    F[2] = v2;
    return RESULT_OK(EVAL(c, body, F).value);
}

// Slowpath bodies for `node_call2` / `node_pg_call_<N>` are defined
// in node_slowpath.c and declared extern in node.h.  Splitting them
// out of node_eval.c (which is `#include`d by every AOT/PG
// code_store/*.c) keeps each generated .so small: the slowpath lives
// only in the main binary, and dlopen + -rdynamic resolves the
// extern reference at load time.


NODE_DEF
node_call2(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t params_cnt, uint32_t arg_index, struct callcache *cc@ref, NODE *sp_body)
{
    // Two-step guard.  (1) cc fresh — name → body resolution still valid.
    // (2) cc->body == sp_body — current body matches the parse-time
    // speculation that the SD's baked direct call assumes.  Both must
    // hold to take the fast path; otherwise fall to slowpath, which
    // dispatches via cc->body (= the current body) and leaves sp_body
    // alone (it's a parse-time constant tied to the baked SD).
    if (LIKELY(c->serial == cc->serial && cc->body == sp_body)) {
        if (CALL_DEBUG) fprintf(stderr, "name:%s hit!\n", name);
        // Use sp_body_dispatcher (= the framework-supplied
        // node_dispatcher_func_t parameter for `sp_body`) so the SD
        // calls the dispatcher that was baked at SPECIALIZE time as a
        // constant — i.e. SD_<HASH(sp_body)> for the AOT path.  EVAL()
        // would re-load `sp_body->head.dispatcher` at runtime and lose
        // the direct call.
        RESULT r = (*sp_body_dispatcher)(c, sp_body, fp + arg_index);
        return RESULT_OK(r.value);   // unconditional state-clear: see call_body
    }
    else {
        return node_pg_call_slowpath(c, n, fp, name, params_cnt, arg_index, cc);
    }
}

// Arity-specialized PG call sites.  Each `node_pg_call_<N>` evaluates
// its `N` argument operands inline (instead of going through separate
// `node_lset` writes the parser would otherwise emit), then dispatches
// to the linked body.
//
// Why specialize on arity:
//
//   - Args are explicit `NODE *` operands of the call node, so the SD's
//     specializer recurses into them, enabling cross-arg fusion (each
//     arg evaluation, the `fp[arg_index+i] = ...` store, and the body
//     dispatch all live in one EVAL_ function body).
//   - The parser no longer wraps argument evaluation in a node_lset +
//     node_seq chain — fewer NODE allocations, fewer dispatch hops in
//     plain mode, smaller AST hash chain in PG mode.
//
// Slowpath is shared with `node_call2_slowpath` since the recovery
// (look up `name` in func_set, refill `cc`, demote dispatcher on
// redef) is identical.

// In each pg_call_<N>, fast path allocates the callee's frame as a
// fresh VLA `VALUE F[locals_cnt]` so it doesn't alias with the
// caller's `fp` slots (jstro's pattern).  With `restrict fp` on the
// dispatcher param and the alloca-style fresh allocation, gcc can
// keep the caller's `fp[0]` (= the caller's parameter, e.g. `n` in
// fib) in a register across the recursive call instead of reloading
// it after each recursion.
//
// `locals_cnt` is patched at parse time (callsite_resolve) — it's the
// callee's full frame size including param slots and any temporaries
// the body uses.  Stored separately from sp_body in the node operand
// list so SPECIALIZE can bake both as constants.
//
// Slowpath path uses caller's `fp[arg_index..]` (unchanged convention)
// — only fired on cc miss.

// pg_call_<N>: each call site allocates a fresh `VALUE F[locals_cnt]`
// (callee's frame) and dispatches the body with F as its `fp`.  F is
// disjoint from the caller's fp slots — `restrict` lets gcc keep the
// caller's locals in registers across the recursive call.
//
// `locals_cnt` is an operand (patched at parse-time / callsite_resolve)
// so the framework's generic SPECIALIZE machinery bakes it as a literal
// constant.  EVAL_<name> is `static inline always_inline`, so gcc
// constant-propagates the literal into the inlined body — the VLA
// `VALUE F[locals_cnt]` becomes a fixed-size array `VALUE F[<n>]` in
// the optimized SD, no runtime VLA cost.
//
// `arg_index` is unused at runtime here (the callee frame is F, not
// caller_fp + arg_index).  Kept as an operand only for the legacy
// `node_pg_call_slowpath` fallback in interpreter mode (arity > 3).

// Two-step guard for `node_pg_call_<N>`:
//   (1) `c->serial == cc->serial` — cc is fresh (no def has bumped
//       serial since cc was last filled).
//   (2) `cc->body == sp_body` — the current body equals the
//       speculatively-linked body baked into this call site at parse
//       time.  Required because the SD's baked direct call uses
//       `SD_<HASH(parse_time_sp_body)>` as a *compile-time constant*
//       — if the actual body has changed (e.g. interleaved def/call)
//       the baked SD would be invoked with mismatched NODE structure.
//
// Both must hold to take the fast (baked-direct) path.  If either
// fails, fall to slowpath, which dispatches via the resolved body
// (= cc->body after refresh).  The slowpath does **not** write back
// `sp_body` — sp_body remains a parse-time invariant so the SD's
// baked dispatcher constant is always valid for the matched case.

NODE_DEF
node_pg_call0(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref, NODE *sp_body)
{
    (void)arg_index;
    if (LIKELY(c->serial == cc->serial && cc->body == sp_body)) {
        VALUE F[locals_cnt > 0 ? locals_cnt : 1];
        // Reassign fp = F so EVAL_ARG below dispatches sp_body with F
        // (the fresh callee frame).  EVAL_ARG uses the baked
        // sp_body_dispatcher (= constant SD pointer in specialized SD).
        fp = F;
        return RESULT_OK(EVAL_ARG(c, sp_body).value);
    }
    return node_pg_call_n_slowpath(c, n, NULL, 0, name, cc);
}

NODE_DEF
node_pg_call1(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref, NODE *sp_body, NODE *a0)
{
    (void)arg_index;
    VALUE v0 = UNWRAP(EVAL_ARG(c, a0));
    if (LIKELY(c->serial == cc->serial && cc->body == sp_body)) {
        VALUE F[locals_cnt];
        F[0] = v0;
        fp = F;
        return RESULT_OK(EVAL_ARG(c, sp_body).value);
    }
    VALUE args[1] = { v0 };
    return node_pg_call_n_slowpath(c, n, args, 1, name, cc);
}

NODE_DEF
node_pg_call2(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref, NODE *sp_body, NODE *a0, NODE *a1)
{
    (void)arg_index;
    VALUE v0 = UNWRAP(EVAL_ARG(c, a0));
    VALUE v1 = UNWRAP(EVAL_ARG(c, a1));
    if (LIKELY(c->serial == cc->serial && cc->body == sp_body)) {
        VALUE F[locals_cnt];
        F[0] = v0;
        F[1] = v1;
        fp = F;
        return RESULT_OK(EVAL_ARG(c, sp_body).value);
    }
    VALUE args[2] = { v0, v1 };
    return node_pg_call_n_slowpath(c, n, args, 2, name, cc);
}

NODE_DEF
node_pg_call3(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *name, uint32_t arg_index, uint32_t locals_cnt, struct callcache *cc@ref, NODE *sp_body, NODE *a0, NODE *a1, NODE *a2)
{
    (void)arg_index;
    VALUE v0 = UNWRAP(EVAL_ARG(c, a0));
    VALUE v1 = UNWRAP(EVAL_ARG(c, a1));
    VALUE v2 = UNWRAP(EVAL_ARG(c, a2));
    if (LIKELY(c->serial == cc->serial && cc->body == sp_body)) {
        VALUE F[locals_cnt];
        F[0] = v0;
        F[1] = v1;
        F[2] = v2;
        fp = F;
        return RESULT_OK(EVAL_ARG(c, sp_body).value);
    }
    VALUE args[3] = { v0, v1, v2 };
    return node_pg_call_n_slowpath(c, n, args, 3, name, cc);
}

NODE_DEF
node_call_static(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *body, uint32_t arg_index)
{
    RESULT r = (*body_dispatcher)(c, body, fp + arg_index);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_builtin(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, struct builtin_func *bf, builtin_func_ptr func_ptr, uint32_t params_cnt)
{
    VALUE v;
    switch (params_cnt) {
      case 0:
        v = (*func_ptr)();
        break;
      case 1:
        v = (*(builtin_func1_ptr)func_ptr)(fp[0]);
        break;
      case 2:
        v = (*(builtin_func2_ptr)func_ptr)(fp[0], fp[1]);
        break;
      case 3:
        v = (*(builtin_func3_ptr)func_ptr)(fp[0], fp[1], fp[2]);
        break;
      case 4:
        v = (*(builtin_func4_ptr)func_ptr)(fp[0], fp[1], fp[2], fp[3]);
        break;
      default:
        fprintf(stderr, "too much params:%u\n", params_cnt);
        v = 0;
    }
    return RESULT_OK(v);
}

// binary operators

NODE_DEF
node_add(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l + r);
}

NODE_DEF
node_sub(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l - r);
}

NODE_DEF
node_mul(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l * r);
}

NODE_DEF
node_div(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l / r);
}

NODE_DEF
node_mod(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l % r);
}

NODE_DEF
node_lt(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l < r);
}

NODE_DEF
node_le(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l <= r);
}

NODE_DEF
node_gt(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l > r);
}

NODE_DEF
node_ge(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l >= r);
}

NODE_DEF
node_eq(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l == r);
}

NODE_DEF
node_neq(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *lhs, NODE *rhs)
{
    VALUE l = UNWRAP(EVAL_ARG(c, lhs));
    VALUE r = UNWRAP(EVAL_ARG(c, rhs));

    return RESULT_OK(l != r);
}
