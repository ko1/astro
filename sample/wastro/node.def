// wastro v0.5 — WebAssembly subset on ASTro.
//
// Numeric scope:
//   * Types: i32, i64, f32, f64.  All carried in `VALUE` (== uint64_t)
//     using AS_*/FROM_* reinterpret helpers from context.h.
//   * Literals: i32.const, i64.const, f32.const, f64.const.
//   * Arithmetic: add, sub, mul (per type).
//   * Comparison: eq, lt_s/lt (per type).  Result is i32 (0 or 1).
//
// Generic / type-erased:
//   * local.get, local.set — VALUE is uint64_t for any type, the
//     parser ensures the operator at the use site reinterprets correctly.
//   * if/else, seq, call_N — pass values through without inspecting
//     their wasm type (statically validated by the parser).
//
// Notes:
//   * ASTroGen accepts int32_t, uint32_t, uint64_t, double, const char *
//     and NODE *.  For i64/f32 we route through uint64_t (i64 raw) and
//     uint32_t (f32 bit pattern).
//   * Per-call arguments are declared as NODE * children so the
//     specializer inlines them via EVAL_ARG.

// =====================================================================
// Locals — `union wastro_slot frame[local_cnt]` allocated by caller's
// node_call_N (or by wastro_invoke at the module entry).  Each slot is
// 8 bytes; the wasm-static type chooses which union member is read or
// written — that gives gcc per-slot type info so SROA can promote each
// slot to a register at its real C type (int32_t / int64_t / float /
// double) when the SD chain inlines.
//
// One get/set/tee variant per wasm value type.  The parser picks the
// right node kind per local based on the function's signature +
// (local) declarations.
// =====================================================================

NODE_DEF
node_local_get_i32(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index)
{
    return RESULT_OK(FROM_I32(frame[index].i32));
}

NODE_DEF
node_local_get_i64(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index)
{
    return RESULT_OK(FROM_I64(frame[index].i64));
}

NODE_DEF
node_local_get_f32(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index)
{
    return RESULT_OK(FROM_F32(frame[index].f32));
}

NODE_DEF
node_local_get_f64(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index)
{
    return RESULT_OK(FROM_F64(frame[index].f64));
}

NODE_DEF
node_local_set_i32(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    frame[index].i32 = AS_I32(UNWRAP(EVAL_ARG(c, expr)));
    return RESULT_OK(0);
}

NODE_DEF
node_local_set_i64(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    frame[index].i64 = AS_I64(UNWRAP(EVAL_ARG(c, expr)));
    return RESULT_OK(0);
}

NODE_DEF
node_local_set_f32(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    frame[index].f32 = AS_F32(UNWRAP(EVAL_ARG(c, expr)));
    return RESULT_OK(0);
}

NODE_DEF
node_local_set_f64(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    frame[index].f64 = AS_F64(UNWRAP(EVAL_ARG(c, expr)));
    return RESULT_OK(0);
}

// local.tee — like local.set but ALSO leaves the value on the stack.
NODE_DEF
node_local_tee_i32(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    int32_t v = AS_I32(UNWRAP(EVAL_ARG(c, expr)));
    frame[index].i32 = v;
    return RESULT_OK(FROM_I32(v));
}

NODE_DEF
node_local_tee_i64(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    int64_t v = AS_I64(UNWRAP(EVAL_ARG(c, expr)));
    frame[index].i64 = v;
    return RESULT_OK(FROM_I64(v));
}

NODE_DEF
node_local_tee_f32(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, expr)));
    frame[index].f32 = v;
    return RESULT_OK(FROM_F32(v));
}

NODE_DEF
node_local_tee_f64(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *expr)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, expr)));
    frame[index].f64 = v;
    return RESULT_OK(FROM_F64(v));
}

// =====================================================================
// i32 — signed 32-bit integer
// =====================================================================

NODE_DEF
node_i32_const(CTX *c, NODE *n, union wastro_slot *frame, int32_t value)
{
    return RESULT_OK(FROM_I32(value));
}

NODE_DEF
node_i32_add(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    int32_t rv = AS_I32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_I32(lv + rv));
}

NODE_DEF
node_i32_sub(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    int32_t rv = AS_I32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_I32(lv - rv));
}

NODE_DEF
node_i32_mul(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    int32_t rv = AS_I32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_I32(lv * rv));
}

NODE_DEF
node_i32_eq(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    int32_t rv = AS_I32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_BOOL(lv == rv));
}

NODE_DEF
node_i32_lt_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    int32_t rv = AS_I32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_BOOL(lv < rv));
}

// --- i32 division / remainder (trap on divide by zero or i32_min/-1 for div_s) ---

NODE_DEF
node_i32_div_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    int32_t rv = AS_I32(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT32_MIN && rv == -1) wastro_trap("integer overflow");
    return RESULT_OK(FROM_I32(lv / rv));
}

NODE_DEF
node_i32_div_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(UNWRAP(EVAL_ARG(c, l)));
    uint32_t rv = AS_U32(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    return RESULT_OK(FROM_U32(lv / rv));
}

NODE_DEF
node_i32_rem_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    int32_t rv = AS_I32(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT32_MIN && rv == -1) return RESULT_OK(FROM_I32(0));  // wasm spec: returns 0
    return RESULT_OK(FROM_I32(lv % rv));
}

NODE_DEF
node_i32_rem_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(UNWRAP(EVAL_ARG(c, l)));
    uint32_t rv = AS_U32(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    return RESULT_OK(FROM_U32(lv % rv));
}

// --- i32 bitwise ---

NODE_DEF
node_i32_and(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_U32(AS_U32(UNWRAP(EVAL_ARG(c, l))) & AS_U32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_or(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_U32(AS_U32(UNWRAP(EVAL_ARG(c, l))) | AS_U32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_xor(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_U32(AS_U32(UNWRAP(EVAL_ARG(c, l))) ^ AS_U32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_shl(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(UNWRAP(EVAL_ARG(c, l)));
    uint32_t rv = AS_U32(UNWRAP(EVAL_ARG(c, r))) & 31;  // wasm spec: shift amount mod 32
    return RESULT_OK(FROM_U32(lv << rv));
}

NODE_DEF
node_i32_shr_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(UNWRAP(EVAL_ARG(c, l)));
    uint32_t rv = AS_U32(UNWRAP(EVAL_ARG(c, r))) & 31;
    return RESULT_OK(FROM_I32(lv >> rv));
}

NODE_DEF
node_i32_shr_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(UNWRAP(EVAL_ARG(c, l)));
    uint32_t rv = AS_U32(UNWRAP(EVAL_ARG(c, r))) & 31;
    return RESULT_OK(FROM_U32(lv >> rv));
}

NODE_DEF
node_i32_rotl(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(UNWRAP(EVAL_ARG(c, l)));
    uint32_t rv = AS_U32(UNWRAP(EVAL_ARG(c, r))) & 31;
    return RESULT_OK(FROM_U32((lv << rv) | (lv >> ((32 - rv) & 31))));
}

NODE_DEF
node_i32_rotr(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(UNWRAP(EVAL_ARG(c, l)));
    uint32_t rv = AS_U32(UNWRAP(EVAL_ARG(c, r))) & 31;
    return RESULT_OK(FROM_U32((lv >> rv) | (lv << ((32 - rv) & 31))));
}

// --- i32 remaining comparisons ---

NODE_DEF
node_i32_ne(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I32(UNWRAP(EVAL_ARG(c, l))) != AS_I32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_lt_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U32(UNWRAP(EVAL_ARG(c, l))) < AS_U32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_le_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I32(UNWRAP(EVAL_ARG(c, l))) <= AS_I32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_le_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U32(UNWRAP(EVAL_ARG(c, l))) <= AS_U32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_gt_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I32(UNWRAP(EVAL_ARG(c, l))) > AS_I32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_gt_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U32(UNWRAP(EVAL_ARG(c, l))) > AS_U32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_ge_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I32(UNWRAP(EVAL_ARG(c, l))) >= AS_I32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i32_ge_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U32(UNWRAP(EVAL_ARG(c, l))) >= AS_U32(UNWRAP(EVAL_ARG(c, r)))));
}

// --- i32 unary ---

NODE_DEF
node_i32_eqz(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_BOOL(AS_I32(UNWRAP(EVAL_ARG(c, e))) == 0));
}

NODE_DEF
node_i32_clz(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    uint32_t v = AS_U32(UNWRAP(EVAL_ARG(c, e)));
    return RESULT_OK(FROM_I32(v ? __builtin_clz(v) : 32));
}

NODE_DEF
node_i32_ctz(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    uint32_t v = AS_U32(UNWRAP(EVAL_ARG(c, e)));
    return RESULT_OK(FROM_I32(v ? __builtin_ctz(v) : 32));
}

NODE_DEF
node_i32_popcnt(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_I32(__builtin_popcount(AS_U32(UNWRAP(EVAL_ARG(c, e))))));
}

// =====================================================================
// i64 — signed 64-bit integer (operand `value` carries the raw bits)
// =====================================================================

NODE_DEF
node_i64_const(CTX *c, NODE *n, union wastro_slot *frame, uint64_t value)
{
    return RESULT_OK(value);
}

NODE_DEF
node_i64_add(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    int64_t rv = AS_I64(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_I64(lv + rv));
}

NODE_DEF
node_i64_sub(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    int64_t rv = AS_I64(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_I64(lv - rv));
}

NODE_DEF
node_i64_mul(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    int64_t rv = AS_I64(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_I64(lv * rv));
}

NODE_DEF
node_i64_eq(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    int64_t rv = AS_I64(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_BOOL(lv == rv));
}

NODE_DEF
node_i64_lt_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    int64_t rv = AS_I64(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_BOOL(lv < rv));
}

// --- i64 division / remainder ---

NODE_DEF
node_i64_div_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    int64_t rv = AS_I64(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT64_MIN && rv == -1) wastro_trap("integer overflow");
    return RESULT_OK(FROM_I64(lv / rv));
}

NODE_DEF
node_i64_div_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(UNWRAP(EVAL_ARG(c, l)));
    uint64_t rv = AS_U64(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    return RESULT_OK(FROM_U64(lv / rv));
}

NODE_DEF
node_i64_rem_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    int64_t rv = AS_I64(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT64_MIN && rv == -1) return RESULT_OK(FROM_I64(0));
    return RESULT_OK(FROM_I64(lv % rv));
}

NODE_DEF
node_i64_rem_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(UNWRAP(EVAL_ARG(c, l)));
    uint64_t rv = AS_U64(UNWRAP(EVAL_ARG(c, r)));
    if (rv == 0) wastro_trap("integer divide by zero");
    return RESULT_OK(FROM_U64(lv % rv));
}

// --- i64 bitwise ---

NODE_DEF
node_i64_and(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_U64(AS_U64(UNWRAP(EVAL_ARG(c, l))) & AS_U64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_or(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_U64(AS_U64(UNWRAP(EVAL_ARG(c, l))) | AS_U64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_xor(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_U64(AS_U64(UNWRAP(EVAL_ARG(c, l))) ^ AS_U64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_shl(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(UNWRAP(EVAL_ARG(c, l)));
    uint64_t rv = AS_U64(UNWRAP(EVAL_ARG(c, r))) & 63;
    return RESULT_OK(FROM_U64(lv << rv));
}

NODE_DEF
node_i64_shr_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(UNWRAP(EVAL_ARG(c, l)));
    uint64_t rv = AS_U64(UNWRAP(EVAL_ARG(c, r))) & 63;
    return RESULT_OK(FROM_I64(lv >> rv));
}

NODE_DEF
node_i64_shr_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(UNWRAP(EVAL_ARG(c, l)));
    uint64_t rv = AS_U64(UNWRAP(EVAL_ARG(c, r))) & 63;
    return RESULT_OK(FROM_U64(lv >> rv));
}

NODE_DEF
node_i64_rotl(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(UNWRAP(EVAL_ARG(c, l)));
    uint64_t rv = AS_U64(UNWRAP(EVAL_ARG(c, r))) & 63;
    return RESULT_OK(FROM_U64((lv << rv) | (lv >> ((64 - rv) & 63))));
}

NODE_DEF
node_i64_rotr(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(UNWRAP(EVAL_ARG(c, l)));
    uint64_t rv = AS_U64(UNWRAP(EVAL_ARG(c, r))) & 63;
    return RESULT_OK(FROM_U64((lv >> rv) | (lv << ((64 - rv) & 63))));
}

// --- i64 remaining comparisons (result is i32) ---

NODE_DEF
node_i64_ne(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I64(UNWRAP(EVAL_ARG(c, l))) != AS_I64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_lt_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U64(UNWRAP(EVAL_ARG(c, l))) < AS_U64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_le_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I64(UNWRAP(EVAL_ARG(c, l))) <= AS_I64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_le_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U64(UNWRAP(EVAL_ARG(c, l))) <= AS_U64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_gt_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I64(UNWRAP(EVAL_ARG(c, l))) > AS_I64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_gt_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U64(UNWRAP(EVAL_ARG(c, l))) > AS_U64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_ge_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_I64(UNWRAP(EVAL_ARG(c, l))) >= AS_I64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_i64_ge_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_U64(UNWRAP(EVAL_ARG(c, l))) >= AS_U64(UNWRAP(EVAL_ARG(c, r)))));
}

// --- i64 unary ---

NODE_DEF
node_i64_eqz(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
