}

// =====================================================================
// f32 — IEEE 754 single (operand `bits` carries the raw bit pattern,
// since ASTroGen does not natively accept `float`)
// =====================================================================

NODE_DEF
node_f32_const(CTX *c, NODE *n, union wastro_slot *frame, uint32_t bits)
{
    return RESULT_OK(FROM_U32(bits));
}

NODE_DEF
node_f32_add(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    float lv = AS_F32(UNWRAP(EVAL_ARG(c, l)));
    float rv = AS_F32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_F32(lv + rv));
}

NODE_DEF
node_f32_sub(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    float lv = AS_F32(UNWRAP(EVAL_ARG(c, l)));
    float rv = AS_F32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_F32(lv - rv));
}

NODE_DEF
node_f32_mul(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    float lv = AS_F32(UNWRAP(EVAL_ARG(c, l)));
    float rv = AS_F32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_F32(lv * rv));
}

NODE_DEF
node_f32_eq(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    float lv = AS_F32(UNWRAP(EVAL_ARG(c, l)));
    float rv = AS_F32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_BOOL(lv == rv));
}

NODE_DEF
node_f32_lt(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    float lv = AS_F32(UNWRAP(EVAL_ARG(c, l)));
    float rv = AS_F32(UNWRAP(EVAL_ARG(c, r)));
    return RESULT_OK(FROM_BOOL(lv < rv));
}

// --- f32 division / min / max / copysign ---

NODE_DEF
node_f32_div(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_F32(AS_F32(UNWRAP(EVAL_ARG(c, l))) / AS_F32(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_f32_min(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    float lv = AS_F32(UNWRAP(EVAL_ARG(c, l)));
    float rv = AS_F32(UNWRAP(EVAL_ARG(c, r)));
    if (lv != lv || rv != rv) return RESULT_OK(FROM_F32(lv != lv ? lv : rv));  // NaN propagation
    // ±0 disambiguation: spec returns -0 if either operand is -0.
    if (lv == 0.0f && rv == 0.0f) return RESULT_OK(FROM_F32(signbit(lv) ? lv : rv));
    return RESULT_OK(FROM_F32(lv < rv ? lv : rv));
}

NODE_DEF
node_f32_max(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    float lv = AS_F32(UNWRAP(EVAL_ARG(c, l)));
    float rv = AS_F32(UNWRAP(EVAL_ARG(c, r)));
    if (lv != lv || rv != rv) return RESULT_OK(FROM_F32(lv != lv ? lv : rv));
    // ±0 disambiguation: spec returns +0 if either operand is +0.
    if (lv == 0.0f && rv == 0.0f) return RESULT_OK(FROM_F32(signbit(lv) ? rv : lv));
    return RESULT_OK(FROM_F32(lv > rv ? lv : rv));
}

NODE_DEF
node_f32_copysign(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_F32(copysignf(AS_F32(UNWRAP(EVAL_ARG(c, l))), AS_F32(UNWRAP(EVAL_ARG(c, r))))));
}

// --- f32 remaining comparisons (result is i32) ---

