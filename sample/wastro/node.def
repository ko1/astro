node_i32_extend8_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_I32((int32_t)(int8_t)AS_I32(UNWRAP(EVAL_ARG(c, e)))));
}

