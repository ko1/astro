node_i64_extend32_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_I64((int64_t)(int32_t)AS_I64(UNWRAP(EVAL_ARG(c, e)))));
}

// Float → integer truncation (trapping variant).  trunc_sat_* (saturating)
// is wasm 2.0; we currently provide only the trapping form per wasm 1.0.

NODE_DEF
node_i32_trunc_f32_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    double t = (double)v;
    if (t > 2147483647.0 || t < -2147483648.0) wastro_trap("integer overflow");
    return RESULT_OK(FROM_I32((int32_t)t));
}

NODE_DEF
node_i32_trunc_f32_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    double t = (double)v;
    if (t >= 4294967296.0 || t <= -1.0) wastro_trap("integer overflow");
    return RESULT_OK(FROM_U32((uint32_t)t));
}

NODE_DEF
node_i32_trunc_f64_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v >= 2147483648.0 || v <= -2147483649.0) wastro_trap("integer overflow");
    return RESULT_OK(FROM_I32((int32_t)v));
}

NODE_DEF
node_i32_trunc_f64_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v >= 4294967296.0 || v <= -1.0) wastro_trap("integer overflow");
    return RESULT_OK(FROM_U32((uint32_t)v));
}

NODE_DEF
node_i64_trunc_f32_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    // i64 range: [-2^63, 2^63-1].  Boundaries in f32: -9223372036854775808.0f
    // is exactly representable; +2^63 is the trap point.
    if (v >= 9223372036854775808.0f || v < -9223372036854775808.0f) wastro_trap("integer overflow");
    return RESULT_OK(FROM_I64((int64_t)v));
}

NODE_DEF
node_i64_trunc_f32_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v >= 18446744073709551616.0f || v <= -1.0f) wastro_trap("integer overflow");
    return RESULT_OK(FROM_U64((uint64_t)v));
}

NODE_DEF
node_i64_trunc_f64_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    // -9223372036854775808.0 is exact in f64 (it equals INT64_MIN).
    if (v >= 9223372036854775808.0 || v < -9223372036854775808.0) wastro_trap("integer overflow");
    return RESULT_OK(FROM_I64((int64_t)v));
}

NODE_DEF
node_i64_trunc_f64_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v <= -1.0 || v >= 18446744073709551616.0) wastro_trap("integer overflow");
    return RESULT_OK(FROM_U64((uint64_t)v));
}

// Saturating truncation (wasm 2.0): NaN → 0, < min → min, > max → max,
// otherwise truncated.  Used by LLVM-emitted wasm by default.

NODE_DEF
node_i32_trunc_sat_f32_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_I32(0));
    if (v < (float)INT32_MIN) return RESULT_OK(FROM_I32(INT32_MIN));
    if (v >= 2147483648.0f) return RESULT_OK(FROM_I32(INT32_MAX));
    return RESULT_OK(FROM_I32((int32_t)v));
}

NODE_DEF
node_i32_trunc_sat_f32_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_U32(0));
    if (v <= 0.0f) return RESULT_OK(FROM_U32(0));
    if (v >= 4294967296.0f) return RESULT_OK(FROM_U32(UINT32_MAX));
    return RESULT_OK(FROM_U32((uint32_t)v));
}

NODE_DEF
node_i32_trunc_sat_f64_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_I32(0));
    if (v < (double)INT32_MIN) return RESULT_OK(FROM_I32(INT32_MIN));
    if (v >= 2147483648.0) return RESULT_OK(FROM_I32(INT32_MAX));
    return RESULT_OK(FROM_I32((int32_t)v));
}

NODE_DEF
node_i32_trunc_sat_f64_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_U32(0));
    if (v <= 0.0) return RESULT_OK(FROM_U32(0));
    if (v >= 4294967296.0) return RESULT_OK(FROM_U32(UINT32_MAX));
    return RESULT_OK(FROM_U32((uint32_t)v));
}

NODE_DEF
node_i64_trunc_sat_f32_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_I64(0));
    if (v < (float)INT64_MIN) return RESULT_OK(FROM_I64(INT64_MIN));
    if (v >= 9223372036854775808.0f) return RESULT_OK(FROM_I64(INT64_MAX));
    return RESULT_OK(FROM_I64((int64_t)v));
}

NODE_DEF
node_i64_trunc_sat_f32_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    float v = AS_F32(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_U64(0));
    if (v <= 0.0f) return RESULT_OK(FROM_U64(0));
    if (v >= 18446744073709551616.0f) return RESULT_OK(FROM_U64(UINT64_MAX));
    return RESULT_OK(FROM_U64((uint64_t)v));
}

NODE_DEF
node_i64_trunc_sat_f64_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_I64(0));
    if (v < (double)INT64_MIN) return RESULT_OK(FROM_I64(INT64_MIN));
    if (v >= 9223372036854775808.0) return RESULT_OK(FROM_I64(INT64_MAX));
    return RESULT_OK(FROM_I64((int64_t)v));
}

NODE_DEF
node_i64_trunc_sat_f64_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    double v = AS_F64(UNWRAP(EVAL_ARG(c, e)));
    if (v != v) return RESULT_OK(FROM_U64(0));
    if (v <= 0.0) return RESULT_OK(FROM_U64(0));
    if (v >= 18446744073709551616.0) return RESULT_OK(FROM_U64(UINT64_MAX));
    return RESULT_OK(FROM_U64((uint64_t)v));
}

