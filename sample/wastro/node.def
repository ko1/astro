}

// memory.size — current pages (i32)
NODE_DEF
node_memory_size(CTX *c, NODE *n, union wastro_slot *frame)
{
    return RESULT_OK(FROM_I32((int32_t)c->memory_pages));
}

// memory.grow — grow by `delta` pages, return previous page count, or -1 on failure.
NODE_DEF
node_memory_grow(CTX *c, NODE *n, union wastro_slot *frame, NODE *delta)
{
    uint32_t d = AS_U32(UNWRAP(EVAL_ARG(c, delta)));
    uint64_t new_pages = (uint64_t)c->memory_pages + d;
    if (new_pages > c->memory_max_pages) return RESULT_OK(FROM_I32(-1));
    if (new_pages > 65536) return RESULT_OK(FROM_I32(-1));  // wasm 32-bit limit
    uint8_t *new_mem = realloc(c->memory, (size_t)(new_pages * WASTRO_PAGE_SIZE));
    if (!new_mem) return RESULT_OK(FROM_I32(-1));
    memset(new_mem + c->memory_pages * WASTRO_PAGE_SIZE, 0, d * WASTRO_PAGE_SIZE);
    c->memory = new_mem;
    uint32_t prev = c->memory_pages;
    c->memory_pages = (uint32_t)new_pages;
    c->memory_size_bytes = (uint64_t)new_pages * WASTRO_PAGE_SIZE;
    return RESULT_OK(FROM_I32((int32_t)prev));
}

// =====================================================================
// Globals — global.get / global.set
// =====================================================================
//
// Globals live in a flat parser-managed array `WASTRO_GLOBALS[]` (raw
// VALUE bits, like locals).  Per-global type and mutability are
// validated at parse time, not at run time.

NODE_DEF
node_global_get(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index)
{
    extern VALUE *WASTRO_GLOBALS;
    return RESULT_OK(WASTRO_GLOBALS[index]);
}

NODE_DEF
node_global_set(CTX *c, NODE *n, union wastro_slot *frame, uint32_t index, NODE *value)
{
    extern VALUE *WASTRO_GLOBALS;
    WASTRO_GLOBALS[index] = UNWRAP(EVAL_ARG(c, value));
    return RESULT_OK(0);
}

// =====================================================================
// Direct function call — fixed-arity variants (Phase 1)
// =====================================================================

// Direct call: evaluate args into the caller's stack-top region,
// switch fp/sp, EVAL the callee's body, then restore.
//
// `body` is the callee's body NODE — declared as a child slot so that
// the framework specializer recurses into it when generating SD_ for
// the call site, naturally inlining small leaf callees (rotr, idx, ...)
// into their parents.  Cycles (self / mutual recursion) are broken by
// the framework's `is_specializing` flag in astro_code_store.c —
// recursive specialization stops at the cycle, leaving the closing
// edge as a direct call to the already-emitted SD_<body_hash>.
// node_call_N: caller-allocates the callee's frame on the C stack and
// passes its address as the new `frame` to the body's dispatcher.
// Locals (params + zero-initialized declared locals) live in the
// stack-allocated F[]; the callee's lifted local ops dereference it via
// the frame parameter.  When the call chain is fully `static inline`
// (typical for AOT chains), &F doesn't escape and gcc SROA's its slots
// into registers — the structural reason mandelbrot's inner loop now
// keeps zx/zy/zx2/zy2/iter in xmm/gpr instead of paying memory traffic.
//
// VLA size is bounded by `local_cnt` from the parser; gcc treats it as
// a normal stack frame.  The `body_dispatcher` parameter is the static
// dispatcher pointer materialized by ASTroGen for the `body` child slot
// — calling it directly (instead of going through `body->head.dispatcher`)
// is what lets gcc inline transitively.
NODE_DEF
node_call_0(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, uint32_t local_cnt, NODE *body)
{
    union wastro_slot F[local_cnt];
    for (uint32_t i = 0; i < local_cnt; i++) F[i].raw = 0;
    RESULT r = body_dispatcher(c, body, F);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_1(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, uint32_t local_cnt, NODE *a0, NODE *body)
{
    union wastro_slot F[local_cnt];
    F[0].raw = UNWRAP(EVAL_ARG(c, a0));
    for (uint32_t i = 1; i < local_cnt; i++) F[i].raw = 0;
    RESULT r = body_dispatcher(c, body, F);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_2(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, uint32_t local_cnt, NODE *a0, NODE *a1, NODE *body)
{
    union wastro_slot F[local_cnt];
    F[0].raw = UNWRAP(EVAL_ARG(c, a0));
    F[1].raw = UNWRAP(EVAL_ARG(c, a1));
    for (uint32_t i = 2; i < local_cnt; i++) F[i].raw = 0;
    RESULT r = body_dispatcher(c, body, F);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_3(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, uint32_t local_cnt, NODE *a0, NODE *a1, NODE *a2, NODE *body)
{
    union wastro_slot F[local_cnt];
    F[0].raw = UNWRAP(EVAL_ARG(c, a0));
    F[1].raw = UNWRAP(EVAL_ARG(c, a1));
    F[2].raw = UNWRAP(EVAL_ARG(c, a2));
    for (uint32_t i = 3; i < local_cnt; i++) F[i].raw = 0;
    RESULT r = body_dispatcher(c, body, F);
    return RESULT_OK(r.value);
}

// Host call (imported function): host_fn returns a plain VALUE which
// we wrap in RESULT_OK.  Host functions can't issue wasm branches.

NODE_DEF
node_host_call_0(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index)
{
    extern struct wastro_function WASTRO_FUNCS[];
    return RESULT_OK(WASTRO_FUNCS[func_index].host_fn(c, NULL, 0));
}

NODE_DEF
node_host_call_1(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, NODE *a0)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE args[1];
    args[0] = UNWRAP(EVAL_ARG(c, a0));
    return RESULT_OK(WASTRO_FUNCS[func_index].host_fn(c, args, 1));
}

NODE_DEF
node_host_call_2(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, NODE *a0, NODE *a1)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE args[2];
    args[0] = UNWRAP(EVAL_ARG(c, a0));
    args[1] = UNWRAP(EVAL_ARG(c, a1));
    return RESULT_OK(WASTRO_FUNCS[func_index].host_fn(c, args, 2));
}

NODE_DEF
node_host_call_3(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, NODE *a0, NODE *a1, NODE *a2)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE args[3];
    args[0] = UNWRAP(EVAL_ARG(c, a0));
    args[1] = UNWRAP(EVAL_ARG(c, a1));
    args[2] = UNWRAP(EVAL_ARG(c, a2));
    return RESULT_OK(WASTRO_FUNCS[func_index].host_fn(c, args, 3));
}

NODE_DEF
node_call_4(CTX *c, NODE *n, union wastro_slot *frame, uint32_t func_index, uint32_t local_cnt, NODE *a0, NODE *a1, NODE *a2, NODE *a3, NODE *body)
{
    union wastro_slot F[local_cnt];
    F[0].raw = UNWRAP(EVAL_ARG(c, a0));
    F[1].raw = UNWRAP(EVAL_ARG(c, a1));
    F[2].raw = UNWRAP(EVAL_ARG(c, a2));
    F[3].raw = UNWRAP(EVAL_ARG(c, a3));
    for (uint32_t i = 4; i < local_cnt; i++) F[i].raw = 0;
    RESULT r = body_dispatcher(c, body, F);
    return RESULT_OK(r.value);
}

// =====================================================================
// Indirect function call (call_indirect via single funcref table)
// =====================================================================
//
// `call_indirect (type $sig) <args>... <idx>` looks up
// WASTRO_TABLE[idx], structurally checks the resolved function's
// signature against WASTRO_TYPES[type_index], then dispatches.
// Mirrors node_call_N but the callee is determined at runtime.
//
// Wasm spec evaluation order: args first, idx last (idx is on top of
// the stack at the trap point).  Indirect calls can target either
// defined funcs (frame setup + EVAL body) or imported funcs (no frame,
// direct host_fn call), distinguished by `fn->is_import`.

NODE_DEF
node_call_indirect_0(CTX *c, NODE *n, union wastro_slot *frame, uint32_t type_index, NODE *idx)
{
    extern struct wastro_function WASTRO_FUNCS[];
    extern int32_t *WASTRO_TABLE;
    extern uint32_t WASTRO_TABLE_SIZE;
    extern struct wastro_type_sig WASTRO_TYPES[];

    uint32_t i = AS_U32(UNWRAP(EVAL_ARG(c, idx)));
    if (i >= WASTRO_TABLE_SIZE) wastro_trap("undefined element");
    int32_t func_idx = WASTRO_TABLE[i];
    if (func_idx < 0) wastro_trap("uninitialized element");

    struct wastro_function *fn = &WASTRO_FUNCS[func_idx];
    struct wastro_type_sig *sig = &WASTRO_TYPES[type_index];
    if (fn->param_cnt != sig->param_cnt || fn->result_type != sig->result_type)
        wastro_trap("indirect call type mismatch");

    if (fn->is_import) return RESULT_OK(fn->host_fn(c, NULL, 0));

    uint32_t local_cnt = fn->local_cnt;
    union wastro_slot F[local_cnt];
    for (uint32_t k = 0; k < local_cnt; k++) F[k].raw = 0;
    RESULT r = EVAL(c, fn->body, F);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_indirect_1(CTX *c, NODE *n, union wastro_slot *frame, uint32_t type_index, NODE *idx, NODE *a0)
{
    extern struct wastro_function WASTRO_FUNCS[];
    extern int32_t *WASTRO_TABLE;
    extern uint32_t WASTRO_TABLE_SIZE;
    extern struct wastro_type_sig WASTRO_TYPES[];

    VALUE arg0 = UNWRAP(EVAL_ARG(c, a0));
    uint32_t i = AS_U32(UNWRAP(EVAL_ARG(c, idx)));
    if (i >= WASTRO_TABLE_SIZE) wastro_trap("undefined element");
    int32_t func_idx = WASTRO_TABLE[i];
    if (func_idx < 0) wastro_trap("uninitialized element");

    struct wastro_function *fn = &WASTRO_FUNCS[func_idx];
    struct wastro_type_sig *sig = &WASTRO_TYPES[type_index];
    if (fn->param_cnt != sig->param_cnt || fn->result_type != sig->result_type)
        wastro_trap("indirect call type mismatch");
    if (fn->param_types[0] != sig->param_types[0])
        wastro_trap("indirect call type mismatch");

    if (fn->is_import) {
        VALUE host_args[1] = { arg0 };
        return RESULT_OK(fn->host_fn(c, host_args, 1));
    }

    uint32_t local_cnt = fn->local_cnt;
    union wastro_slot F[local_cnt];
    F[0].raw = arg0;
    for (uint32_t k = 1; k < local_cnt; k++) F[k].raw = 0;
    RESULT r = EVAL(c, fn->body, F);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_indirect_2(CTX *c, NODE *n, union wastro_slot *frame, uint32_t type_index, NODE *idx, NODE *a0, NODE *a1)
{
    extern struct wastro_function WASTRO_FUNCS[];
    extern int32_t *WASTRO_TABLE;
    extern uint32_t WASTRO_TABLE_SIZE;
    extern struct wastro_type_sig WASTRO_TYPES[];

    VALUE arg0 = UNWRAP(EVAL_ARG(c, a0));
    VALUE arg1 = UNWRAP(EVAL_ARG(c, a1));
    uint32_t i = AS_U32(UNWRAP(EVAL_ARG(c, idx)));
    if (i >= WASTRO_TABLE_SIZE) wastro_trap("undefined element");
    int32_t func_idx = WASTRO_TABLE[i];
    if (func_idx < 0) wastro_trap("uninitialized element");

    struct wastro_function *fn = &WASTRO_FUNCS[func_idx];
    struct wastro_type_sig *sig = &WASTRO_TYPES[type_index];
    if (fn->param_cnt != sig->param_cnt || fn->result_type != sig->result_type)
        wastro_trap("indirect call type mismatch");
    if (fn->param_types[0] != sig->param_types[0] ||
        fn->param_types[1] != sig->param_types[1])
        wastro_trap("indirect call type mismatch");

    if (fn->is_import) {
        VALUE host_args[2] = { arg0, arg1 };
        return RESULT_OK(fn->host_fn(c, host_args, 2));
    }

    uint32_t local_cnt = fn->local_cnt;
    union wastro_slot F[local_cnt];
    F[0].raw = arg0; F[1].raw = arg1;
    for (uint32_t k = 2; k < local_cnt; k++) F[k].raw = 0;
    RESULT r = EVAL(c, fn->body, F);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_indirect_3(CTX *c, NODE *n, union wastro_slot *frame, uint32_t type_index, NODE *idx, NODE *a0, NODE *a1, NODE *a2)
{
    extern struct wastro_function WASTRO_FUNCS[];
    extern int32_t *WASTRO_TABLE;
    extern uint32_t WASTRO_TABLE_SIZE;
    extern struct wastro_type_sig WASTRO_TYPES[];

    VALUE arg0 = UNWRAP(EVAL_ARG(c, a0));
    VALUE arg1 = UNWRAP(EVAL_ARG(c, a1));
    VALUE arg2 = UNWRAP(EVAL_ARG(c, a2));
    uint32_t i = AS_U32(UNWRAP(EVAL_ARG(c, idx)));
    if (i >= WASTRO_TABLE_SIZE) wastro_trap("undefined element");
    int32_t func_idx = WASTRO_TABLE[i];
    if (func_idx < 0) wastro_trap("uninitialized element");

    struct wastro_function *fn = &WASTRO_FUNCS[func_idx];
    struct wastro_type_sig *sig = &WASTRO_TYPES[type_index];
    if (fn->param_cnt != sig->param_cnt || fn->result_type != sig->result_type)
        wastro_trap("indirect call type mismatch");
    for (uint32_t k = 0; k < 3; k++)
        if (fn->param_types[k] != sig->param_types[k])
            wastro_trap("indirect call type mismatch");

    if (fn->is_import) {
        VALUE host_args[3] = { arg0, arg1, arg2 };
        return RESULT_OK(fn->host_fn(c, host_args, 3));
    }

    uint32_t local_cnt = fn->local_cnt;
    union wastro_slot F[local_cnt];
    F[0].raw = arg0; F[1].raw = arg1; F[2].raw = arg2;
    for (uint32_t k = 3; k < local_cnt; k++) F[k].raw = 0;
    RESULT r = EVAL(c, fn->body, F);
    return RESULT_OK(r.value);
}

NODE_DEF
node_call_indirect_4(CTX *c, NODE *n, union wastro_slot *frame, uint32_t type_index, NODE *idx, NODE *a0, NODE *a1, NODE *a2, NODE *a3)
{
    extern struct wastro_function WASTRO_FUNCS[];
    extern int32_t *WASTRO_TABLE;
    extern uint32_t WASTRO_TABLE_SIZE;
    extern struct wastro_type_sig WASTRO_TYPES[];

    VALUE arg0 = UNWRAP(EVAL_ARG(c, a0));
    VALUE arg1 = UNWRAP(EVAL_ARG(c, a1));
    VALUE arg2 = UNWRAP(EVAL_ARG(c, a2));
    VALUE arg3 = UNWRAP(EVAL_ARG(c, a3));
    uint32_t i = AS_U32(UNWRAP(EVAL_ARG(c, idx)));
    if (i >= WASTRO_TABLE_SIZE) wastro_trap("undefined element");
    int32_t func_idx = WASTRO_TABLE[i];
    if (func_idx < 0) wastro_trap("uninitialized element");

    struct wastro_function *fn = &WASTRO_FUNCS[func_idx];
    struct wastro_type_sig *sig = &WASTRO_TYPES[type_index];
    if (fn->param_cnt != sig->param_cnt || fn->result_type != sig->result_type)
        wastro_trap("indirect call type mismatch");
    for (uint32_t k = 0; k < 4; k++)
        if (fn->param_types[k] != sig->param_types[k])
            wastro_trap("indirect call type mismatch");

    if (fn->is_import) {
        VALUE host_args[4] = { arg0, arg1, arg2, arg3 };
        return RESULT_OK(fn->host_fn(c, host_args, 4));
    }

    uint32_t local_cnt = fn->local_cnt;
    union wastro_slot F[local_cnt];
    F[0].raw = arg0; F[1].raw = arg1; F[2].raw = arg2; F[3].raw = arg3;
    for (uint32_t k = 4; k < local_cnt; k++) F[k].raw = 0;
    RESULT r = EVAL(c, fn->body, F);
    return RESULT_OK(r.value);
}
