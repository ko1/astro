node_f32_ne(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_BOOL(AS_F32(UNWRAP(EVAL_ARG(c, l))) != AS_F32(UNWRAP(EVAL_ARG(c, r)))));
}

