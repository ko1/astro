// Host call (imported function) — fixed-arity variants.  The host
// function pointer is fetched from WASTRO_FUNCS[func_index].host_fn
// and invoked directly with the evaluated args; no frame is set up
// since host functions don't see CTX->fp.

NODE_DEF
node_host_call_0(CTX *c, NODE *n, uint32_t func_index)
{
    extern struct wastro_function WASTRO_FUNCS[];
    return WASTRO_FUNCS[func_index].host_fn(c, NULL, 0);
}

NODE_DEF
node_host_call_1(CTX *c, NODE *n, uint32_t func_index, NODE *a0)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE args[1];
    args[0] = EVAL_ARG(c, a0);
    return WASTRO_FUNCS[func_index].host_fn(c, args, 1);
}

NODE_DEF
node_host_call_2(CTX *c, NODE *n, uint32_t func_index, NODE *a0, NODE *a1)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE args[2];
    args[0] = EVAL_ARG(c, a0);
    args[1] = EVAL_ARG(c, a1);
    return WASTRO_FUNCS[func_index].host_fn(c, args, 2);
}

NODE_DEF
node_host_call_3(CTX *c, NODE *n, uint32_t func_index, NODE *a0, NODE *a1, NODE *a2)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE args[3];
    args[0] = EVAL_ARG(c, a0);
    args[1] = EVAL_ARG(c, a1);
    args[2] = EVAL_ARG(c, a2);
    return WASTRO_FUNCS[func_index].host_fn(c, args, 3);
}

NODE_DEF
node_call_4(CTX *c, NODE *n, uint32_t func_index, uint32_t local_cnt, NODE *a0, NODE *a1, NODE *a2, NODE *a3)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE *new_fp = c->sp;
    new_fp[0] = EVAL_ARG(c, a0);
    new_fp[1] = EVAL_ARG(c, a1);
    new_fp[2] = EVAL_ARG(c, a2);
    new_fp[3] = EVAL_ARG(c, a3);
    for (uint32_t i = 4; i < local_cnt; i++) new_fp[i] = 0;
    VALUE *save_fp = c->fp; VALUE *save_sp = c->sp;
    c->fp = new_fp; c->sp = new_fp + local_cnt;
    // Wasm validation guarantees br_depth == 0 at a call site, so we
    // don't need to save it.  Body may set WASTRO_BR_RETURN; consume
    // it here and zero out before returning.
    VALUE result = EVAL(c, WASTRO_FUNCS[func_index].body);
    if (c->br_depth) {
        result = c->br_value;     // WASTRO_BR_RETURN landed here
        c->br_depth = 0;
    }
    c->fp = save_fp; c->sp = save_sp;
    return result;
}
