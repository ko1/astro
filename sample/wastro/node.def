node_i32_extend16_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_I32((int32_t)(int16_t)AS_I32(UNWRAP(EVAL_ARG(c, e)))));
}

