// =====================================================================
// Conversions (wrap / extend / trunc / convert / demote / promote / reinterpret)
// =====================================================================
// Reinterprets are bit-pattern moves only; they're free at runtime
// after gcc -O2 because VALUE is already uint64_t.

NODE_DEF
node_i32_wrap_i64(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_I32((int32_t)AS_I64(UNWRAP(EVAL_ARG(c, e)))));
}

NODE_DEF
node_i64_extend_i32_s(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_I64((int64_t)AS_I32(UNWRAP(EVAL_ARG(c, e)))));
}

NODE_DEF
node_i64_extend_i32_u(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    return RESULT_OK(FROM_U64((uint64_t)AS_U32(UNWRAP(EVAL_ARG(c, e)))));
}

