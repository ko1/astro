}

NODE_DEF
node_i32_extend8_s(CTX *c, NODE *n, NODE *e)
{
    return FROM_I32((int32_t)(int8_t)AS_I32(EVAL_ARG(c, e)));
}

NODE_DEF
node_i32_extend16_s(CTX *c, NODE *n, NODE *e)
{
    return FROM_I32((int32_t)(int16_t)AS_I32(EVAL_ARG(c, e)));
