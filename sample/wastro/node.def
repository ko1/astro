// --- f64 division / min / max / copysign ---

NODE_DEF
node_f64_div(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_F64(AS_F64(UNWRAP(EVAL_ARG(c, l))) / AS_F64(UNWRAP(EVAL_ARG(c, r)))));
}

NODE_DEF
node_f64_min(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    double lv = AS_F64(UNWRAP(EVAL_ARG(c, l)));
    double rv = AS_F64(UNWRAP(EVAL_ARG(c, r)));
    if (lv != lv || rv != rv) return RESULT_OK(FROM_F64(lv != lv ? lv : rv));
    if (lv == 0.0 && rv == 0.0) return RESULT_OK(FROM_F64(signbit(lv) ? lv : rv));
    return RESULT_OK(FROM_F64(lv < rv ? lv : rv));
}

NODE_DEF
node_f64_max(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    double lv = AS_F64(UNWRAP(EVAL_ARG(c, l)));
    double rv = AS_F64(UNWRAP(EVAL_ARG(c, r)));
    if (lv != lv || rv != rv) return RESULT_OK(FROM_F64(lv != lv ? lv : rv));
    if (lv == 0.0 && rv == 0.0) return RESULT_OK(FROM_F64(signbit(lv) ? rv : lv));
    return RESULT_OK(FROM_F64(lv > rv ? lv : rv));
}

NODE_DEF
node_f64_copysign(CTX *c, NODE *n, union wastro_slot *frame, NODE *l, NODE *r)
{
    return RESULT_OK(FROM_F64(copysign(AS_F64(UNWRAP(EVAL_ARG(c, l))), AS_F64(UNWRAP(EVAL_ARG(c, r))))));
}

