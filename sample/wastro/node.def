// memory.size — current pages (i32)
NODE_DEF
node_memory_size(CTX *c, NODE *n)
{
    return FROM_I32((int32_t)c->memory_pages);
}

// memory.grow — grow by `delta` pages, return previous page count, or -1 on failure.
NODE_DEF
node_memory_grow(CTX *c, NODE *n, NODE *delta)
{
    uint32_t d = AS_U32(EVAL_ARG(c, delta));
    uint64_t new_pages = (uint64_t)c->memory_pages + d;
    if (new_pages > c->memory_max_pages) return FROM_I32(-1);
    if (new_pages > 65536) return FROM_I32(-1);  // wasm 32-bit limit
    uint8_t *new_mem = realloc(c->memory, (size_t)(new_pages * WASTRO_PAGE_SIZE));
    if (!new_mem) return FROM_I32(-1);
    memset(new_mem + c->memory_pages * WASTRO_PAGE_SIZE, 0, d * WASTRO_PAGE_SIZE);
    c->memory = new_mem;
    uint32_t prev = c->memory_pages;
    c->memory_pages = (uint32_t)new_pages;
    return FROM_I32((int32_t)prev);
}

// =====================================================================
// Globals — global.get / global.set
// =====================================================================
//
// Globals live in a flat parser-managed array `WASTRO_GLOBALS[]` (raw
// VALUE bits, like locals).  Per-global type and mutability are
// validated at parse time, not at run time.

NODE_DEF
node_global_get(CTX *c, NODE *n, uint32_t index)
{
    extern VALUE *WASTRO_GLOBALS;
    return WASTRO_GLOBALS[index];
}

NODE_DEF
node_global_set(CTX *c, NODE *n, uint32_t index, NODE *value)
{
    extern VALUE *WASTRO_GLOBALS;
    WASTRO_GLOBALS[index] = EVAL_ARG(c, value);
    return 0;
}

// =====================================================================
// Direct function call — fixed-arity variants (Phase 1)
// =====================================================================

NODE_DEF
node_call_0(CTX *c, NODE *n, uint32_t func_index, uint32_t local_cnt)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE *new_fp = c->sp;
    for (uint32_t i = 0; i < local_cnt; i++) new_fp[i] = 0;
    VALUE *save_fp = c->fp; VALUE *save_sp = c->sp;
    c->fp = new_fp; c->sp = new_fp + local_cnt;
    // Wasm validation guarantees br_depth == 0 at a call site, so we
    // don't need to save it.  Body may set WASTRO_BR_RETURN; consume
    // it here and zero out before returning.
    VALUE result = EVAL(c, WASTRO_FUNCS[func_index].body);
    if (c->br_depth) {
        result = c->br_value;     // WASTRO_BR_RETURN landed here
        c->br_depth = 0;
    }
    c->fp = save_fp; c->sp = save_sp;
    return result;
}

NODE_DEF
node_call_1(CTX *c, NODE *n, uint32_t func_index, uint32_t local_cnt, NODE *a0)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE *new_fp = c->sp;
    new_fp[0] = EVAL_ARG(c, a0);
    for (uint32_t i = 1; i < local_cnt; i++) new_fp[i] = 0;
    VALUE *save_fp = c->fp; VALUE *save_sp = c->sp;
    c->fp = new_fp; c->sp = new_fp + local_cnt;
    // Wasm validation guarantees br_depth == 0 at a call site, so we
    // don't need to save it.  Body may set WASTRO_BR_RETURN; consume
    // it here and zero out before returning.
    VALUE result = EVAL(c, WASTRO_FUNCS[func_index].body);
    if (c->br_depth) {
        result = c->br_value;     // WASTRO_BR_RETURN landed here
        c->br_depth = 0;
    }
    c->fp = save_fp; c->sp = save_sp;
    return result;
}

NODE_DEF
node_call_2(CTX *c, NODE *n, uint32_t func_index, uint32_t local_cnt, NODE *a0, NODE *a1)
{
    extern struct wastro_function WASTRO_FUNCS[];
    VALUE *new_fp = c->sp;
    new_fp[0] = EVAL_ARG(c, a0);
    new_fp[1] = EVAL_ARG(c, a1);
    for (uint32_t i = 2; i < local_cnt; i++) new_fp[i] = 0;
    VALUE *save_fp = c->fp; VALUE *save_sp = c->sp;
    c->fp = new_fp; c->sp = new_fp + local_cnt;
    // Wasm validation guarantees br_depth == 0 at a call site, so we
    // don't need to save it.  Body may set WASTRO_BR_RETURN; consume
    // it here and zero out before returning.
    VALUE result = EVAL(c, WASTRO_FUNCS[func_index].body);
    if (c->br_depth) {
        result = c->br_value;     // WASTRO_BR_RETURN landed here
        c->br_depth = 0;
