// wastro v0.5 — WebAssembly subset on ASTro.
//
// Numeric scope:
//   * Types: i32, i64, f32, f64.  All carried in `VALUE` (== uint64_t)
//     using AS_*/FROM_* reinterpret helpers from context.h.
//   * Literals: i32.const, i64.const, f32.const, f64.const.
//   * Arithmetic: add, sub, mul (per type).
//   * Comparison: eq, lt_s/lt (per type).  Result is i32 (0 or 1).
//
// Generic / type-erased:
//   * local.get, local.set — VALUE is uint64_t for any type, the
//     parser ensures the operator at the use site reinterprets correctly.
//   * if/else, seq, call_N — pass values through without inspecting
//     their wasm type (statically validated by the parser).
//
// Notes:
//   * ASTroGen accepts int32_t, uint32_t, uint64_t, double, const char *
//     and NODE *.  For i64/f32 we route through uint64_t (i64 raw) and
//     uint32_t (f32 bit pattern).
//   * Per-call arguments are declared as NODE * children so the
//     specializer inlines them via EVAL_ARG.

// =====================================================================
// Locals (type-erased — VALUE carries any wasm numeric type)
// =====================================================================

NODE_DEF
node_local_get(CTX *c, NODE *n, uint32_t index)
{
    return c->fp[index];
}

NODE_DEF
node_local_set(CTX *c, NODE *n, uint32_t index, NODE *expr)
{
    c->fp[index] = EVAL_ARG(c, expr);
    return 0;
}

// =====================================================================
// i32 — signed 32-bit integer
// =====================================================================

NODE_DEF
node_i32_const(CTX *c, NODE *n, int32_t value)
{
    return FROM_I32(value);
}

NODE_DEF
node_i32_add(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    int32_t rv = AS_I32(EVAL_ARG(c, r));
    return FROM_I32(lv + rv);
}

NODE_DEF
node_i32_sub(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    int32_t rv = AS_I32(EVAL_ARG(c, r));
    return FROM_I32(lv - rv);
}

NODE_DEF
node_i32_mul(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    int32_t rv = AS_I32(EVAL_ARG(c, r));
    return FROM_I32(lv * rv);
}

NODE_DEF
node_i32_eq(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    int32_t rv = AS_I32(EVAL_ARG(c, r));
    return FROM_BOOL(lv == rv);
}

NODE_DEF
node_i32_lt_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    int32_t rv = AS_I32(EVAL_ARG(c, r));
    return FROM_BOOL(lv < rv);
}

// --- i32 division / remainder (trap on divide by zero or i32_min/-1 for div_s) ---

NODE_DEF
node_i32_div_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    int32_t rv = AS_I32(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT32_MIN && rv == -1) wastro_trap("integer overflow");
    return FROM_I32(lv / rv);
}

NODE_DEF
node_i32_div_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(EVAL_ARG(c, l));
    uint32_t rv = AS_U32(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    return FROM_U32(lv / rv);
}

NODE_DEF
node_i32_rem_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    int32_t rv = AS_I32(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT32_MIN && rv == -1) return FROM_I32(0);  // wasm spec: returns 0
    return FROM_I32(lv % rv);
}

NODE_DEF
node_i32_rem_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(EVAL_ARG(c, l));
    uint32_t rv = AS_U32(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    return FROM_U32(lv % rv);
}

// --- i32 bitwise ---

NODE_DEF
node_i32_and(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_U32(AS_U32(EVAL_ARG(c, l)) & AS_U32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_or(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_U32(AS_U32(EVAL_ARG(c, l)) | AS_U32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_xor(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_U32(AS_U32(EVAL_ARG(c, l)) ^ AS_U32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_shl(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(EVAL_ARG(c, l));
    uint32_t rv = AS_U32(EVAL_ARG(c, r)) & 31;  // wasm spec: shift amount mod 32
    return FROM_U32(lv << rv);
}

NODE_DEF
node_i32_shr_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int32_t lv = AS_I32(EVAL_ARG(c, l));
    uint32_t rv = AS_U32(EVAL_ARG(c, r)) & 31;
    return FROM_I32(lv >> rv);
}

NODE_DEF
node_i32_shr_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(EVAL_ARG(c, l));
    uint32_t rv = AS_U32(EVAL_ARG(c, r)) & 31;
    return FROM_U32(lv >> rv);
}

NODE_DEF
node_i32_rotl(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(EVAL_ARG(c, l));
    uint32_t rv = AS_U32(EVAL_ARG(c, r)) & 31;
    return FROM_U32((lv << rv) | (lv >> ((32 - rv) & 31)));
}

NODE_DEF
node_i32_rotr(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint32_t lv = AS_U32(EVAL_ARG(c, l));
    uint32_t rv = AS_U32(EVAL_ARG(c, r)) & 31;
    return FROM_U32((lv >> rv) | (lv << ((32 - rv) & 31)));
}

// --- i32 remaining comparisons ---

NODE_DEF
node_i32_ne(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I32(EVAL_ARG(c, l)) != AS_I32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_lt_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U32(EVAL_ARG(c, l)) < AS_U32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_le_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I32(EVAL_ARG(c, l)) <= AS_I32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_le_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U32(EVAL_ARG(c, l)) <= AS_U32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_gt_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I32(EVAL_ARG(c, l)) > AS_I32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_gt_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U32(EVAL_ARG(c, l)) > AS_U32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_ge_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I32(EVAL_ARG(c, l)) >= AS_I32(EVAL_ARG(c, r)));
}

NODE_DEF
node_i32_ge_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U32(EVAL_ARG(c, l)) >= AS_U32(EVAL_ARG(c, r)));
}

// --- i32 unary ---

NODE_DEF
node_i32_eqz(CTX *c, NODE *n, NODE *e)
{
    return FROM_BOOL(AS_I32(EVAL_ARG(c, e)) == 0);
}

NODE_DEF
node_i32_clz(CTX *c, NODE *n, NODE *e)
{
    uint32_t v = AS_U32(EVAL_ARG(c, e));
    return FROM_I32(v ? __builtin_clz(v) : 32);
}

NODE_DEF
node_i32_ctz(CTX *c, NODE *n, NODE *e)
{
    uint32_t v = AS_U32(EVAL_ARG(c, e));
    return FROM_I32(v ? __builtin_ctz(v) : 32);
}

NODE_DEF
node_i32_popcnt(CTX *c, NODE *n, NODE *e)
{
    return FROM_I32(__builtin_popcount(AS_U32(EVAL_ARG(c, e))));
}

// =====================================================================
// i64 — signed 64-bit integer (operand `value` carries the raw bits)
// =====================================================================

NODE_DEF
node_i64_const(CTX *c, NODE *n, uint64_t value)
{
    return value;
}

NODE_DEF
node_i64_add(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    int64_t rv = AS_I64(EVAL_ARG(c, r));
    return FROM_I64(lv + rv);
}

NODE_DEF
node_i64_sub(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    int64_t rv = AS_I64(EVAL_ARG(c, r));
    return FROM_I64(lv - rv);
}

NODE_DEF
node_i64_mul(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    int64_t rv = AS_I64(EVAL_ARG(c, r));
    return FROM_I64(lv * rv);
}

NODE_DEF
node_i64_eq(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    int64_t rv = AS_I64(EVAL_ARG(c, r));
    return FROM_BOOL(lv == rv);
}

NODE_DEF
node_i64_lt_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    int64_t rv = AS_I64(EVAL_ARG(c, r));
    return FROM_BOOL(lv < rv);
}

// --- i64 division / remainder ---

NODE_DEF
node_i64_div_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    int64_t rv = AS_I64(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT64_MIN && rv == -1) wastro_trap("integer overflow");
    return FROM_I64(lv / rv);
}

NODE_DEF
node_i64_div_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(EVAL_ARG(c, l));
    uint64_t rv = AS_U64(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    return FROM_U64(lv / rv);
}

NODE_DEF
node_i64_rem_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    int64_t rv = AS_I64(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    if (lv == INT64_MIN && rv == -1) return FROM_I64(0);
    return FROM_I64(lv % rv);
}

NODE_DEF
node_i64_rem_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(EVAL_ARG(c, l));
    uint64_t rv = AS_U64(EVAL_ARG(c, r));
    if (rv == 0) wastro_trap("integer divide by zero");
    return FROM_U64(lv % rv);
}

// --- i64 bitwise ---

NODE_DEF
node_i64_and(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_U64(AS_U64(EVAL_ARG(c, l)) & AS_U64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_or(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_U64(AS_U64(EVAL_ARG(c, l)) | AS_U64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_xor(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_U64(AS_U64(EVAL_ARG(c, l)) ^ AS_U64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_shl(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(EVAL_ARG(c, l));
    uint64_t rv = AS_U64(EVAL_ARG(c, r)) & 63;
    return FROM_U64(lv << rv);
}

NODE_DEF
node_i64_shr_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    int64_t lv = AS_I64(EVAL_ARG(c, l));
    uint64_t rv = AS_U64(EVAL_ARG(c, r)) & 63;
    return FROM_I64(lv >> rv);
}

NODE_DEF
node_i64_shr_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(EVAL_ARG(c, l));
    uint64_t rv = AS_U64(EVAL_ARG(c, r)) & 63;
    return FROM_U64(lv >> rv);
}

NODE_DEF
node_i64_rotl(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(EVAL_ARG(c, l));
    uint64_t rv = AS_U64(EVAL_ARG(c, r)) & 63;
    return FROM_U64((lv << rv) | (lv >> ((64 - rv) & 63)));
}

NODE_DEF
node_i64_rotr(CTX *c, NODE *n, NODE *l, NODE *r)
{
    uint64_t lv = AS_U64(EVAL_ARG(c, l));
    uint64_t rv = AS_U64(EVAL_ARG(c, r)) & 63;
    return FROM_U64((lv >> rv) | (lv << ((64 - rv) & 63)));
}

// --- i64 remaining comparisons (result is i32) ---

NODE_DEF
node_i64_ne(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I64(EVAL_ARG(c, l)) != AS_I64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_lt_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U64(EVAL_ARG(c, l)) < AS_U64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_le_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I64(EVAL_ARG(c, l)) <= AS_I64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_le_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U64(EVAL_ARG(c, l)) <= AS_U64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_gt_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I64(EVAL_ARG(c, l)) > AS_I64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_gt_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U64(EVAL_ARG(c, l)) > AS_U64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_ge_s(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_I64(EVAL_ARG(c, l)) >= AS_I64(EVAL_ARG(c, r)));
}

NODE_DEF
node_i64_ge_u(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_U64(EVAL_ARG(c, l)) >= AS_U64(EVAL_ARG(c, r)));
}

// --- i64 unary ---

NODE_DEF
node_i64_eqz(CTX *c, NODE *n, NODE *e)
{
    return FROM_BOOL(AS_I64(EVAL_ARG(c, e)) == 0);
}

NODE_DEF
node_i64_clz(CTX *c, NODE *n, NODE *e)
{
    uint64_t v = AS_U64(EVAL_ARG(c, e));
    return FROM_I64(v ? __builtin_clzll(v) : 64);
}

NODE_DEF
node_i64_ctz(CTX *c, NODE *n, NODE *e)
{
    uint64_t v = AS_U64(EVAL_ARG(c, e));
    return FROM_I64(v ? __builtin_ctzll(v) : 64);
}

NODE_DEF
node_i64_popcnt(CTX *c, NODE *n, NODE *e)
{
    return FROM_I64(__builtin_popcountll(AS_U64(EVAL_ARG(c, e))));
}

// =====================================================================
// f32 — IEEE 754 single (operand `bits` carries the raw bit pattern,
// since ASTroGen does not natively accept `float`)
// =====================================================================

NODE_DEF
node_f32_const(CTX *c, NODE *n, uint32_t bits)
{
    return FROM_U32(bits);
}

NODE_DEF
node_f32_add(CTX *c, NODE *n, NODE *l, NODE *r)
{
    float lv = AS_F32(EVAL_ARG(c, l));
    float rv = AS_F32(EVAL_ARG(c, r));
    return FROM_F32(lv + rv);
}

NODE_DEF
node_f32_sub(CTX *c, NODE *n, NODE *l, NODE *r)
{
    float lv = AS_F32(EVAL_ARG(c, l));
    float rv = AS_F32(EVAL_ARG(c, r));
    return FROM_F32(lv - rv);
}

NODE_DEF
node_f32_mul(CTX *c, NODE *n, NODE *l, NODE *r)
{
    float lv = AS_F32(EVAL_ARG(c, l));
    float rv = AS_F32(EVAL_ARG(c, r));
    return FROM_F32(lv * rv);
}

NODE_DEF
node_f32_eq(CTX *c, NODE *n, NODE *l, NODE *r)
{
    float lv = AS_F32(EVAL_ARG(c, l));
    float rv = AS_F32(EVAL_ARG(c, r));
    return FROM_BOOL(lv == rv);
}

NODE_DEF
node_f32_lt(CTX *c, NODE *n, NODE *l, NODE *r)
{
    float lv = AS_F32(EVAL_ARG(c, l));
    float rv = AS_F32(EVAL_ARG(c, r));
    return FROM_BOOL(lv < rv);
}

// --- f32 division / min / max / copysign ---

NODE_DEF
node_f32_div(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_F32(AS_F32(EVAL_ARG(c, l)) / AS_F32(EVAL_ARG(c, r)));
}

NODE_DEF
node_f32_min(CTX *c, NODE *n, NODE *l, NODE *r)
{
    float lv = AS_F32(EVAL_ARG(c, l));
    float rv = AS_F32(EVAL_ARG(c, r));
    if (lv != lv || rv != rv) return FROM_F32(lv != lv ? lv : rv);  // NaN propagation
    return FROM_F32(lv < rv ? lv : rv);
}

NODE_DEF
node_f32_max(CTX *c, NODE *n, NODE *l, NODE *r)
{
    float lv = AS_F32(EVAL_ARG(c, l));
    float rv = AS_F32(EVAL_ARG(c, r));
    if (lv != lv || rv != rv) return FROM_F32(lv != lv ? lv : rv);
    return FROM_F32(lv > rv ? lv : rv);
}

NODE_DEF
node_f32_copysign(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_F32(copysignf(AS_F32(EVAL_ARG(c, l)), AS_F32(EVAL_ARG(c, r))));
}

// --- f32 remaining comparisons (result is i32) ---

NODE_DEF
node_f32_ne(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F32(EVAL_ARG(c, l)) != AS_F32(EVAL_ARG(c, r)));
}

NODE_DEF
node_f32_le(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F32(EVAL_ARG(c, l)) <= AS_F32(EVAL_ARG(c, r)));
}

NODE_DEF
node_f32_gt(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F32(EVAL_ARG(c, l)) > AS_F32(EVAL_ARG(c, r)));
}

NODE_DEF
node_f32_ge(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F32(EVAL_ARG(c, l)) >= AS_F32(EVAL_ARG(c, r)));
}

// --- f32 unary ---

NODE_DEF
node_f32_abs(CTX *c, NODE *n, NODE *e)
{
    return FROM_F32(fabsf(AS_F32(EVAL_ARG(c, e))));
}

NODE_DEF
node_f32_neg(CTX *c, NODE *n, NODE *e)
{
    return FROM_F32(-AS_F32(EVAL_ARG(c, e)));
}

NODE_DEF
node_f32_sqrt(CTX *c, NODE *n, NODE *e)
{
    return FROM_F32(sqrtf(AS_F32(EVAL_ARG(c, e))));
}

NODE_DEF
node_f32_ceil(CTX *c, NODE *n, NODE *e)
{
    return FROM_F32(ceilf(AS_F32(EVAL_ARG(c, e))));
}

NODE_DEF
node_f32_floor(CTX *c, NODE *n, NODE *e)
{
    return FROM_F32(floorf(AS_F32(EVAL_ARG(c, e))));
}

NODE_DEF
node_f32_trunc(CTX *c, NODE *n, NODE *e)
{
    return FROM_F32(truncf(AS_F32(EVAL_ARG(c, e))));
}

// nearest = round-to-even (wasm spec).  C's `nearbyintf` uses current
// rounding mode (default round-to-even) — matches.
NODE_DEF
node_f32_nearest(CTX *c, NODE *n, NODE *e)
{
    return FROM_F32(nearbyintf(AS_F32(EVAL_ARG(c, e))));
}

// =====================================================================
// f64 — IEEE 754 double
// =====================================================================

NODE_DEF
node_f64_const(CTX *c, NODE *n, double value)
{
    return FROM_F64(value);
}

NODE_DEF
node_f64_add(CTX *c, NODE *n, NODE *l, NODE *r)
{
    double lv = AS_F64(EVAL_ARG(c, l));
    double rv = AS_F64(EVAL_ARG(c, r));
    return FROM_F64(lv + rv);
}

NODE_DEF
node_f64_sub(CTX *c, NODE *n, NODE *l, NODE *r)
{
    double lv = AS_F64(EVAL_ARG(c, l));
    double rv = AS_F64(EVAL_ARG(c, r));
    return FROM_F64(lv - rv);
}

NODE_DEF
node_f64_mul(CTX *c, NODE *n, NODE *l, NODE *r)
{
    double lv = AS_F64(EVAL_ARG(c, l));
    double rv = AS_F64(EVAL_ARG(c, r));
    return FROM_F64(lv * rv);
}

NODE_DEF
node_f64_eq(CTX *c, NODE *n, NODE *l, NODE *r)
{
    double lv = AS_F64(EVAL_ARG(c, l));
    double rv = AS_F64(EVAL_ARG(c, r));
    return FROM_BOOL(lv == rv);
}

NODE_DEF
node_f64_lt(CTX *c, NODE *n, NODE *l, NODE *r)
{
    double lv = AS_F64(EVAL_ARG(c, l));
    double rv = AS_F64(EVAL_ARG(c, r));
    return FROM_BOOL(lv < rv);
}

// --- f64 division / min / max / copysign ---

NODE_DEF
node_f64_div(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_F64(AS_F64(EVAL_ARG(c, l)) / AS_F64(EVAL_ARG(c, r)));
}

NODE_DEF
node_f64_min(CTX *c, NODE *n, NODE *l, NODE *r)
{
    double lv = AS_F64(EVAL_ARG(c, l));
    double rv = AS_F64(EVAL_ARG(c, r));
    if (lv != lv || rv != rv) return FROM_F64(lv != lv ? lv : rv);
    return FROM_F64(lv < rv ? lv : rv);
}

NODE_DEF
node_f64_max(CTX *c, NODE *n, NODE *l, NODE *r)
{
    double lv = AS_F64(EVAL_ARG(c, l));
    double rv = AS_F64(EVAL_ARG(c, r));
    if (lv != lv || rv != rv) return FROM_F64(lv != lv ? lv : rv);
    return FROM_F64(lv > rv ? lv : rv);
}

NODE_DEF
node_f64_copysign(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_F64(copysign(AS_F64(EVAL_ARG(c, l)), AS_F64(EVAL_ARG(c, r))));
}

// --- f64 remaining comparisons ---

NODE_DEF
node_f64_ne(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F64(EVAL_ARG(c, l)) != AS_F64(EVAL_ARG(c, r)));
}

NODE_DEF
node_f64_le(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F64(EVAL_ARG(c, l)) <= AS_F64(EVAL_ARG(c, r)));
}

NODE_DEF
node_f64_gt(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F64(EVAL_ARG(c, l)) > AS_F64(EVAL_ARG(c, r)));
}

NODE_DEF
node_f64_ge(CTX *c, NODE *n, NODE *l, NODE *r)
{
    return FROM_BOOL(AS_F64(EVAL_ARG(c, l)) >= AS_F64(EVAL_ARG(c, r)));
}

// --- f64 unary ---

NODE_DEF
node_f64_abs(CTX *c, NODE *n, NODE *e)
{
    return FROM_F64(fabs(AS_F64(EVAL_ARG(c, e))));
}

NODE_DEF
node_f64_neg(CTX *c, NODE *n, NODE *e)
