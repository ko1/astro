// =====================================================================
// Control flow & sequencing
// =====================================================================
//
// Branch state lives in the RESULT struct returned by every dispatcher:
//
//   * `br N` returns RESULT { value=0,        br_depth = N+1 }
//   * `br N v` returns       { value=v,        br_depth = N+1 }
//   * `return` returns       { value=0,        br_depth = WASTRO_BR_RETURN }
//   * `return v` returns     { value=v,        br_depth = WASTRO_BR_RETURN }
//   * `block` decrements the body's br_depth on exit; consumes (resets
//     to 0) when it reaches 0, returning RESULT.value as its own value.
//   * `loop` decrements similarly and re-enters on consumption.
//   * `if` introduces a label too (decrement on exit), per wasm spec.
//   * `node_call_N` consumes WASTRO_BR_RETURN at the function boundary.
//
// UNWRAP propagates non-normal RESULT immediately, so multi-operand
// nodes don't need explicit short-circuit checks — the macro returns
// from the enclosing function the moment a branch is in flight.

NODE_DEF
node_nop(CTX *c, NODE *n, union wastro_slot *frame)
{
    return RESULT_OK(0);
}

// drop — evaluate the operand for its side effects, discard the value.
NODE_DEF
node_drop(CTX *c, NODE *n, union wastro_slot *frame, NODE *e)
{
    UNWRAP(EVAL_ARG(c, e));
    return RESULT_OK(0);
}

// select — pops cond, v2, v1; pushes (cond ? v1 : v2).  Both v1 and
// v2 are evaluated unconditionally per wasm spec (they're already on
// the stack when select runs).
NODE_DEF
node_select(CTX *c, NODE *n, union wastro_slot *frame, NODE *v1, NODE *v2, NODE *cond)
{
    VALUE a = UNWRAP(EVAL_ARG(c, v1));
    VALUE b = UNWRAP(EVAL_ARG(c, v2));
    int32_t k = AS_I32(UNWRAP(EVAL_ARG(c, cond)));
    return RESULT_OK(k ? a : b);
}

// Control-flow nodes (if / seq / block / loop / br / br_if) get
// `@always_inline` so the loop body, branches, and sequencing collapse
// into the enclosing function's SD — that's what lets gcc see the full
// frame's live range and SROA each `union wastro_slot` slot at its real
// type.  Without this, gcc's heuristic gives up around node_loop and
// emits an `EVAL_node_loop.isra.0` out-of-line copy, breaking SROA at
// the loop boundary (see mandelbrot's nested-loop perf gap).
NODE_DEF @always_inline
node_if(CTX *c, NODE *n, union wastro_slot *frame, NODE *cond, NODE *then_branch, NODE *else_branch)
{
    int32_t cv = AS_I32(UNWRAP(EVAL_ARG(c, cond)));
    RESULT r = cv ? EVAL_ARG(c, then_branch) : EVAL_ARG(c, else_branch);
    // `if` introduces a label that `br N` from inside the body can
    // target.  Decrement br_depth on exit just like block/loop.
    if (r.br_depth == 0) return r;
    if (r.br_depth == WASTRO_BR_RETURN) return r;
    if (--r.br_depth == 0) return RESULT_OK(r.value);
    return r;
}

NODE_DEF
node_seq(CTX *c, NODE *n, union wastro_slot *frame, NODE *head, NODE *tail)
{
    UNWRAP(EVAL_ARG(c, head));
    return EVAL_ARG(c, tail);
}

// Labelled scope.  Body's value is the block's result if it falls
// through normally, otherwise the carried RESULT.value when a `br`
// targets us.
NODE_DEF @always_inline
node_block(CTX *c, NODE *n, union wastro_slot *frame, NODE *body)
{
    RESULT r = EVAL_ARG(c, body);
    if (r.br_depth == 0) return r;
    if (r.br_depth == WASTRO_BR_RETURN) return r;   // function-level return: propagate
    if (--r.br_depth == 0) return RESULT_OK(r.value);  // we are the target
    return r;                                        // deeper br: propagate
}

// Like block, but a br targeting it loops back to the start.
NODE_DEF @always_inline
node_loop(CTX *c, NODE *n, union wastro_slot *frame, NODE *body)
{
    for (;;) {
        RESULT r = EVAL_ARG(c, body);
        if (r.br_depth == 0) return r;
        if (r.br_depth == WASTRO_BR_RETURN) return r;
        if (--r.br_depth == 0) {
            // br to the loop's own label re-enters the loop.
            continue;
        }
        return r;                                   // deeper br: propagate
    }
}

// Unconditional branch with no value.
NODE_DEF @always_inline
node_br(CTX *c, NODE *n, union wastro_slot *frame, uint32_t depth)
{
    return (RESULT){0, depth + 1};
}

// Unconditional branch carrying a value (typed block / loop result).
NODE_DEF @always_inline
node_br_v(CTX *c, NODE *n, union wastro_slot *frame, uint32_t depth, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, depth + 1};
}

// Conditional branch: takes if cond is non-zero (i32 truthy).
NODE_DEF @always_inline
node_br_if(CTX *c, NODE *n, union wastro_slot *frame, uint32_t depth, NODE *cond)
{
    int32_t cv = AS_I32(UNWRAP(EVAL_ARG(c, cond)));
    if (cv) return (RESULT){0, depth + 1};
    return RESULT_OK(0);
}

NODE_DEF @always_inline
node_br_if_v(CTX *c, NODE *n, union wastro_slot *frame, uint32_t depth, NODE *cond, NODE *value)
{
    // Wasm stack order is value-then-cond — evaluate value first.
    // UNWRAP propagates a branch from either operand.
    VALUE val = UNWRAP(EVAL_ARG(c, value));
    int32_t cv = AS_I32(UNWRAP(EVAL_ARG(c, cond)));
    if (cv) return (RESULT){val, depth + 1};
    return RESULT_OK(0);
}

NODE_DEF
node_return(CTX *c, NODE *n, union wastro_slot *frame)
{
    return (RESULT){0, WASTRO_BR_RETURN};
}

NODE_DEF
node_return_v(CTX *c, NODE *n, union wastro_slot *frame, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, WASTRO_BR_RETURN};
}

// Trap: prints "unreachable" and exits.  Models wasm's `unreachable`.
NODE_DEF
node_unreachable(CTX *c, NODE *n, union wastro_slot *frame)
{
    wastro_trap("unreachable");
    __builtin_unreachable();
}

// br_table — computed branch into a table of targets.
//
// Targets (uint32_t depths) are stored in an external parser-managed
// array `WASTRO_BR_TABLE[]`; the node carries the offset, count, and
// default depth.  Spec semantics: `br_table L0 ... LN_default <idx>`
// branches to `L[idx]` if `idx < N`, otherwise to `L_default`.
NODE_DEF
node_br_table(CTX *c, NODE *n, union wastro_slot *frame, uint32_t target_index, uint32_t target_cnt, uint32_t default_depth, NODE *idx)
{
    extern uint32_t *WASTRO_BR_TABLE;
    uint32_t i = AS_U32(UNWRAP(EVAL_ARG(c, idx)));
    uint32_t depth = (i < target_cnt) ? WASTRO_BR_TABLE[target_index + i] : default_depth;
    return (RESULT){0, depth + 1};
}

// br_table with carried value — same as br_table but value is forwarded.
NODE_DEF
node_br_table_v(CTX *c, NODE *n, union wastro_slot *frame, uint32_t target_index, uint32_t target_cnt, uint32_t default_depth, NODE *idx, NODE *value)
{
    extern uint32_t *WASTRO_BR_TABLE;
    // Stack order: value first, then idx on top.
    VALUE val = UNWRAP(EVAL_ARG(c, value));
    uint32_t i = AS_U32(UNWRAP(EVAL_ARG(c, idx)));
    uint32_t depth = (i < target_cnt) ? WASTRO_BR_TABLE[target_index + i] : default_depth;
    return (RESULT){val, depth + 1};
}

// =====================================================================
// Linear memory — load / store / size / grow
// =====================================================================
//
// Wasm load/store carry an immediate `offset` and `align` hint; we
// store only `offset` (alignment is informational).  Effective address
// = addr + offset.  Bounds check trap on OOB.
//
// Load width / sign:
//   *.load     — full type width
//   *.load8_s/u, *.load16_s/u, *.load32_s/u  — narrow load + sign / zero
//   extension to the result type's width.
// Stores write the low N bits of the source value.

NODE_DEF
node_i32_load(CTX *c, NODE *n, union wastro_slot *frame, uint32_t offset, NODE *addr)
{
    uint64_t a = (uint64_t)AS_U32(UNWRAP(EVAL_ARG(c, addr))) + (uint64_t)offset;
    if ((uint64_t)a + 4 > c->memory_size_bytes) wastro_trap("out of bounds memory access");
    uint32_t v; memcpy(&v, c->memory + a, 4);
    return RESULT_OK(FROM_U32(v));
}

NODE_DEF
node_i32_load8_s(CTX *c, NODE *n, union wastro_slot *frame, uint32_t offset, NODE *addr)
{
    uint64_t a = (uint64_t)AS_U32(UNWRAP(EVAL_ARG(c, addr))) + (uint64_t)offset;
    if ((uint64_t)a + 1 > c->memory_size_bytes) wastro_trap("out of bounds memory access");
    return RESULT_OK(FROM_I32((int32_t)(int8_t)c->memory[a]));
}

NODE_DEF
node_i32_load8_u(CTX *c, NODE *n, union wastro_slot *frame, uint32_t offset, NODE *addr)
{
    uint64_t a = (uint64_t)AS_U32(UNWRAP(EVAL_ARG(c, addr))) + (uint64_t)offset;
    if ((uint64_t)a + 1 > c->memory_size_bytes) wastro_trap("out of bounds memory access");
    return RESULT_OK(FROM_U32((uint32_t)c->memory[a]));
}

NODE_DEF
node_i32_load16_s(CTX *c, NODE *n, union wastro_slot *frame, uint32_t offset, NODE *addr)
{
    uint64_t a = (uint64_t)AS_U32(UNWRAP(EVAL_ARG(c, addr))) + (uint64_t)offset;
    if ((uint64_t)a + 2 > c->memory_size_bytes) wastro_trap("out of bounds memory access");
    int16_t v; memcpy(&v, c->memory + a, 2);
    return RESULT_OK(FROM_I32((int32_t)v));
}

