// Float → integer truncation (trapping variant).  trunc_sat_* (saturating)
// is wasm 2.0; we currently provide only the trapping form per wasm 1.0.

NODE_DEF
node_i32_trunc_f32_s(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v < (float)INT32_MIN || v >= 2147483648.0f) wastro_trap("integer overflow");
    return FROM_I32((int32_t)v);
}

NODE_DEF
node_i32_trunc_f32_u(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v <= -1.0f || v >= 4294967296.0f) wastro_trap("integer overflow");
    return FROM_U32((uint32_t)v);
}

NODE_DEF
node_i32_trunc_f64_s(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v < (double)INT32_MIN || v >= 2147483648.0) wastro_trap("integer overflow");
    return FROM_I32((int32_t)v);
}

NODE_DEF
node_i32_trunc_f64_u(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v <= -1.0 || v >= 4294967296.0) wastro_trap("integer overflow");
    return FROM_U32((uint32_t)v);
}

NODE_DEF
node_i64_trunc_f32_s(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v < (float)INT64_MIN || v >= 9223372036854775808.0f) wastro_trap("integer overflow");
    return FROM_I64((int64_t)v);
}

NODE_DEF
node_i64_trunc_f32_u(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v <= -1.0f || v >= 18446744073709551616.0f) wastro_trap("integer overflow");
    return FROM_U64((uint64_t)v);
}

NODE_DEF
node_i64_trunc_f64_s(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v < (double)INT64_MIN || v >= 9223372036854775808.0) wastro_trap("integer overflow");
    return FROM_I64((int64_t)v);
}

NODE_DEF
node_i64_trunc_f64_u(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) wastro_trap("invalid conversion to integer");
    if (v <= -1.0 || v >= 18446744073709551616.0) wastro_trap("integer overflow");
    return FROM_U64((uint64_t)v);
}

// Saturating truncation (wasm 2.0): NaN → 0, < min → min, > max → max,
// otherwise truncated.  Used by LLVM-emitted wasm by default.

NODE_DEF
node_i32_trunc_sat_f32_s(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) return FROM_I32(0);
    if (v < (float)INT32_MIN) return FROM_I32(INT32_MIN);
    if (v >= 2147483648.0f) return FROM_I32(INT32_MAX);
    return FROM_I32((int32_t)v);
}

NODE_DEF
node_i32_trunc_sat_f32_u(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) return FROM_U32(0);
    if (v <= 0.0f) return FROM_U32(0);
    if (v >= 4294967296.0f) return FROM_U32(UINT32_MAX);
    return FROM_U32((uint32_t)v);
}

NODE_DEF
node_i32_trunc_sat_f64_s(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) return FROM_I32(0);
    if (v < (double)INT32_MIN) return FROM_I32(INT32_MIN);
    if (v >= 2147483648.0) return FROM_I32(INT32_MAX);
    return FROM_I32((int32_t)v);
}

NODE_DEF
node_i32_trunc_sat_f64_u(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) return FROM_U32(0);
    if (v <= 0.0) return FROM_U32(0);
    if (v >= 4294967296.0) return FROM_U32(UINT32_MAX);
    return FROM_U32((uint32_t)v);
}

NODE_DEF
node_i64_trunc_sat_f32_s(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) return FROM_I64(0);
    if (v < (float)INT64_MIN) return FROM_I64(INT64_MIN);
    if (v >= 9223372036854775808.0f) return FROM_I64(INT64_MAX);
    return FROM_I64((int64_t)v);
}

NODE_DEF
node_i64_trunc_sat_f32_u(CTX *c, NODE *n, NODE *e)
{
    float v = AS_F32(EVAL_ARG(c, e));
    if (v != v) return FROM_U64(0);
    if (v <= 0.0f) return FROM_U64(0);
    if (v >= 18446744073709551616.0f) return FROM_U64(UINT64_MAX);
    return FROM_U64((uint64_t)v);
}

NODE_DEF
node_i64_trunc_sat_f64_s(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) return FROM_I64(0);
    if (v < (double)INT64_MIN) return FROM_I64(INT64_MIN);
    if (v >= 9223372036854775808.0) return FROM_I64(INT64_MAX);
    return FROM_I64((int64_t)v);
}

NODE_DEF
node_i64_trunc_sat_f64_u(CTX *c, NODE *n, NODE *e)
{
    double v = AS_F64(EVAL_ARG(c, e));
    if (v != v) return FROM_U64(0);
    if (v <= 0.0) return FROM_U64(0);
    if (v >= 18446744073709551616.0) return FROM_U64(UINT64_MAX);
