// Reinterpret (bitcast, no value change).

NODE_DEF
node_i32_reinterpret_f32(CTX *c, NODE *n, NODE *e)
{
    return FROM_U32(AS_U32(EVAL_ARG(c, e)));
}

NODE_DEF
node_i64_reinterpret_f64(CTX *c, NODE *n, NODE *e)
{
    return EVAL_ARG(c, e);
}

NODE_DEF
node_f32_reinterpret_i32(CTX *c, NODE *n, NODE *e)
{
    return FROM_U32(AS_U32(EVAL_ARG(c, e)));
}

NODE_DEF
node_f64_reinterpret_i64(CTX *c, NODE *n, NODE *e)
{
    return EVAL_ARG(c, e);
}

// =====================================================================
// Control flow & sequencing
// =====================================================================
//
// Structured control flow uses CTX-side branch state (c->br_depth /
// c->br_value) instead of setjmp.  Semantics:
//
//   * `br N` sets br_depth = N + 1 and stashes the carried value
//     (if any) in br_value.  The return value of the br node itself
//     is irrelevant — every parent that runs after a branch checks
//     br_depth and either consumes (block / loop / call boundary)
//     or propagates (seq / if / arithmetic, by short-circuiting).
//   * `block` decrements br_depth on the way out and consumes when
//     the count reaches 0.  Its result is the carried value.
//   * `loop` decrements similarly but loops back when consumed.
//   * `return` uses the special sentinel WASTRO_BR_RETURN so that
//     enclosing blocks/loops always propagate, and only the function
//     boundary (node_call_N) consumes it.

NODE_DEF
node_nop(CTX *c, NODE *n)
{
    return 0;
}

NODE_DEF
node_if(CTX *c, NODE *n, NODE *cond, NODE *then_branch, NODE *else_branch)
{
    if (AS_I32(EVAL_ARG(c, cond))) {
        return EVAL_ARG(c, then_branch);
    }
    else {
        return EVAL_ARG(c, else_branch);
    }
}

NODE_DEF
node_seq(CTX *c, NODE *n, NODE *head, NODE *tail)
{
    EVAL_ARG(c, head);
    if (c->br_depth) return 0;   // mid-sequence branch, skip tail
    return EVAL_ARG(c, tail);
}

// Labelled scope.  Body's value is the block's result if it falls
// through normally, otherwise br_value when a `br` targets us.
NODE_DEF
node_block(CTX *c, NODE *n, NODE *body)
{
    VALUE v = EVAL_ARG(c, body);
    if (c->br_depth == 0) return v;
    if (c->br_depth == WASTRO_BR_RETURN) return v;  // function-level return: propagate
    if (--c->br_depth == 0) return c->br_value;     // we are the target
    return v;                                        // deeper br: propagate
}

// Like block, but a br targeting it loops back to the start.
NODE_DEF
node_loop(CTX *c, NODE *n, NODE *body)
{
    for (;;) {
        VALUE v = EVAL_ARG(c, body);
        if (c->br_depth == 0) return v;
        if (c->br_depth == WASTRO_BR_RETURN) return v;
        if (--c->br_depth == 0) {
            // br to the loop's own label re-enters the loop.
            continue;
        }
        return v;                                    // deeper br: propagate
    }
}

// Unconditional branch with no value.
NODE_DEF
node_br(CTX *c, NODE *n, uint32_t depth)
{
    c->br_depth = depth + 1;
    return 0;
}

// Unconditional branch carrying a value (typed block / loop result).
NODE_DEF
node_br_v(CTX *c, NODE *n, uint32_t depth, NODE *value)
{
    c->br_value = EVAL_ARG(c, value);
    c->br_depth = depth + 1;
    return c->br_value;
}

// Conditional branch: takes if cond is non-zero (i32 truthy).
NODE_DEF
node_br_if(CTX *c, NODE *n, uint32_t depth, NODE *cond)
{
    if (AS_I32(EVAL_ARG(c, cond))) {
        c->br_depth = depth + 1;
    }
    return 0;
}

NODE_DEF
node_br_if_v(CTX *c, NODE *n, uint32_t depth, NODE *cond, NODE *value)
{
    if (AS_I32(EVAL_ARG(c, cond))) {
        // Spec: value is consumed regardless, but only forwarded on taken
        // branch.  v0.6 evaluates only on the taken branch — fine for
        // value-pure expressions.  Side-effecting carry values would need
        // unconditional eval; revisit when we have side-effecting ops.
        c->br_value = EVAL_ARG(c, value);
        c->br_depth = depth + 1;
    }
    return 0;
}

NODE_DEF
node_return(CTX *c, NODE *n)
{
    c->br_depth = WASTRO_BR_RETURN;
    return 0;
}

NODE_DEF
node_return_v(CTX *c, NODE *n, NODE *value)
{
    c->br_value = EVAL_ARG(c, value);
    c->br_depth = WASTRO_BR_RETURN;
    return c->br_value;
}

// Trap: prints "unreachable" and exits.  Models wasm's `unreachable`.
NODE_DEF
node_unreachable(CTX *c, NODE *n)
{
    wastro_trap("unreachable");
    return 0;  // unreachable
}

// br_table — computed branch into a table of targets.
//
// Targets (uint32_t depths) are stored in an external parser-managed
// array `WASTRO_BR_TABLE[]`; the node carries the offset, count, and
// default depth.  Spec semantics: `br_table L0 ... LN_default <idx>`
// branches to `L[idx]` if `idx < N`, otherwise to `L_default`.
NODE_DEF
node_br_table(CTX *c, NODE *n, uint32_t target_index, uint32_t target_cnt, uint32_t default_depth, NODE *idx)
{
    extern uint32_t *WASTRO_BR_TABLE;
    uint32_t i = AS_U32(EVAL_ARG(c, idx));
    uint32_t depth = (i < target_cnt) ? WASTRO_BR_TABLE[target_index + i] : default_depth;
    c->br_depth = depth + 1;
    return 0;
}

// br_table with carried value — same as br_table but value is forwarded.
NODE_DEF
node_br_table_v(CTX *c, NODE *n, uint32_t target_index, uint32_t target_cnt, uint32_t default_depth, NODE *idx, NODE *value)
{
    extern uint32_t *WASTRO_BR_TABLE;
    c->br_value = EVAL_ARG(c, value);
    uint32_t i = AS_U32(EVAL_ARG(c, idx));
    uint32_t depth = (i < target_cnt) ? WASTRO_BR_TABLE[target_index + i] : default_depth;
    c->br_depth = depth + 1;
    return c->br_value;
}

// =====================================================================
// Linear memory — load / store / size / grow
// =====================================================================
//
// Wasm load/store carry an immediate `offset` and `align` hint; we
// store only `offset` (alignment is informational).  Effective address
// = addr + offset.  Bounds check trap on OOB.
//
// Load width / sign:
//   *.load     — full type width
//   *.load8_s/u, *.load16_s/u, *.load32_s/u  — narrow load + sign / zero
//   extension to the result type's width.
// Stores write the low N bits of the source value.

NODE_DEF
node_i32_load(CTX *c, NODE *n, uint32_t offset, NODE *addr)
{
    uint32_t a = AS_U32(EVAL_ARG(c, addr)) + offset;
    if ((uint64_t)a + 4 > (uint64_t)c->memory_pages * WASTRO_PAGE_SIZE) wastro_trap("out of bounds memory access");
    uint32_t v; memcpy(&v, c->memory + a, 4);
    return FROM_U32(v);
}

NODE_DEF
node_i32_load8_s(CTX *c, NODE *n, uint32_t offset, NODE *addr)
{
    uint32_t a = AS_U32(EVAL_ARG(c, addr)) + offset;
    if ((uint64_t)a + 1 > (uint64_t)c->memory_pages * WASTRO_PAGE_SIZE) wastro_trap("out of bounds memory access");
    return FROM_I32((int32_t)(int8_t)c->memory[a]);
}

NODE_DEF
node_i32_load8_u(CTX *c, NODE *n, uint32_t offset, NODE *addr)
{
    uint32_t a = AS_U32(EVAL_ARG(c, addr)) + offset;
    if ((uint64_t)a + 1 > (uint64_t)c->memory_pages * WASTRO_PAGE_SIZE) wastro_trap("out of bounds memory access");
    return FROM_U32((uint32_t)c->memory[a]);
}

NODE_DEF
node_i32_load16_s(CTX *c, NODE *n, uint32_t offset, NODE *addr)
{
    uint32_t a = AS_U32(EVAL_ARG(c, addr)) + offset;
    if ((uint64_t)a + 2 > (uint64_t)c->memory_pages * WASTRO_PAGE_SIZE) wastro_trap("out of bounds memory access");
    int16_t v; memcpy(&v, c->memory + a, 2);
    return FROM_I32((int32_t)v);
}

NODE_DEF
node_i32_load16_u(CTX *c, NODE *n, uint32_t offset, NODE *addr)
{
    uint32_t a = AS_U32(EVAL_ARG(c, addr)) + offset;
    if ((uint64_t)a + 2 > (uint64_t)c->memory_pages * WASTRO_PAGE_SIZE) wastro_trap("out of bounds memory access");
    uint16_t v; memcpy(&v, c->memory + a, 2);
    return FROM_U32((uint32_t)v);
}

NODE_DEF
node_i64_load(CTX *c, NODE *n, uint32_t offset, NODE *addr)
{
    uint32_t a = AS_U32(EVAL_ARG(c, addr)) + offset;
    if ((uint64_t)a + 8 > (uint64_t)c->memory_pages * WASTRO_PAGE_SIZE) wastro_trap("out of bounds memory access");
    uint64_t v; memcpy(&v, c->memory + a, 8);
    return FROM_U64(v);
}

