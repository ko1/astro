// Stores

NODE_DEF
node_i32_store(CTX *c, NODE *n, union wastro_slot *frame, uint32_t offset, NODE *addr, NODE *value)
{
    uint64_t a = (uint64_t)AS_U32(UNWRAP(EVAL_ARG(c, addr))) + (uint64_t)offset;
    uint32_t v = AS_U32(UNWRAP(EVAL_ARG(c, value)));
    if ((uint64_t)a + 4 > c->memory_size_bytes) wastro_trap("out of bounds memory access");
    memcpy(c->memory + a, &v, 4);
    return RESULT_OK(0);
}

