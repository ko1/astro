#!/usr/bin/env ruby

require 'optparse'
require 'rbconfig'
require_relative '../lib/abruby'
require_relative '../lib/abruby/version'

# CFLAGS needed to compile specialized code (needs ruby.h)
RUBY_CFLAGS = "-I#{RbConfig::CONFIG['rubyhdrdir']} -I#{RbConfig::CONFIG['rubyarchhdrdir']}"

code = nil
mode = :run          # :run, :plain, :compile, :compile_first, :pg
compile_files = nil  # files to compile (--compile)
run_file = nil       # file to run after --compile (--run)
run_args = []        # args for --run
dump_mode = nil      # nil, :ast, :disasm
verbose = false
compiled_only = false

opt = OptionParser.new
opt.banner = "Usage: abruby [options] [file] [args...]"

opt.on('-e CODE', 'evaluate CODE') { |v| code = v }
opt.on('-d', 'dump disasm (shorthand for --dump=disasm)') { dump_mode = :disasm }
opt.on('--dump[=MODE]', 'dump AST (default) or disasm') do |v|
  dump_mode = case v
  when nil, 'ast' then :ast
  when 'disasm'   then :disasm
  else
    $stderr.puts "unknown dump mode: #{v} (use ast or disasm)"
    exit 1
  end
end
opt.on('--plain', 'run without code store') { mode = :plain }
opt.on('--compile', 'compile files (AOT)') { mode = :compile }
opt.on('-c', '--compile-first', 'compile then run') { mode = :compile_first }
opt.on('--pg', 'run then compile (profile-guided)') { mode = :pg }
opt.on('--verbose', 'show code store operations') { verbose = true }
opt.on('--compiled-only', 'abort if default dispatcher is used') { compiled_only = true }
opt.on('-v', '--version', 'show version') do
  puts "abruby #{AbRuby::VERSION}"
  exit
end

# Handle --run (appears after --compile file list)
argv = ARGV.dup
run_idx = argv.index('--run')
if run_idx
  compile_argv = argv[0...run_idx]
  run_argv = argv[(run_idx + 1)..]
  opt.parse!(compile_argv)
  compile_files = compile_argv
  run_file = run_argv.shift
  run_args = run_argv
  mode = :compile unless mode == :pg
else
  opt.parse!(ARGV)
end

# Read source file
read_file = ->(path) {
  unless File.exist?(path)
    $stderr.puts "abruby: cannot load such file -- #{path}"
    exit 1
  end
  File.read(path)
}

# Initialize code store (shared by all modes except --plain)
ABRUBY_DIR = File.expand_path('..', __dir__)
AbRuby.verbose = verbose

ABRUBY_SO_MTIME = File.mtime(File.join(ABRUBY_DIR, 'abruby.so')).to_i rescue 0

cs_init = ->() {
  store_dir = File.join(ABRUBY_DIR, 'code_store')
  $stderr.puts "cs_init: #{store_dir} (src: #{ABRUBY_DIR}, ver: #{ABRUBY_SO_MTIME})" if verbose
  AbRuby.cs_init(store_dir, ABRUBY_DIR, ABRUBY_SO_MTIME)
}

# Compile an AST entry node
cs_compile = ->(ast, label = nil) {
  $stderr.puts "cs_compile: #{label}" if verbose
  AbRuby.cs_compile(ast)
}

case mode
when :plain
  script_file = code ? nil : ARGV.shift
  src = code || (script_file && read_file.(script_file))
  unless src
    opt.parse!(['--help'])
    exit
  end
  vm = AbRuby.new
  if dump_mode == :ast
    puts vm.dump(src)
  else
    vm.current_file = script_file if script_file
    vm.eval(src)
  end

when :compile
  files = compile_files || ARGV.dup
  if files.empty?
    $stderr.puts "abruby: --compile requires at least one file"
    exit 1
  end

  cs_init.()

  vm = AbRuby.new
  all_entries = []
  files.each do |f|
    src = read_file.(f)
    $stderr.puts "compile: #{f}" if verbose
    ast = vm.parse(src, f)
    cs_compile.(ast, f)
    all_entries << [f, ast]
    vm.last_entries.each do |name, body|
      cs_compile.(body, "#{f}:#{name}")
      all_entries << ["#{f}:#{name}", body]
    end
  end

  $stderr.puts "cs_build" if verbose
  AbRuby.cs_build(RUBY_CFLAGS)
  AbRuby.cs_reload

  if dump_mode == :disasm
    all_entries.each do |label, node|
      $stdout.flush
      puts "--- #{label} ---"
      $stdout.flush
      puts vm.dump_ast(node)
      $stdout.flush
      AbRuby.cs_disasm(node)
    end
  end

  if run_file
    src = read_file.(run_file)
    $stderr.puts "run: #{run_file}" if verbose
    vm.current_file = run_file
    vm.eval(src)
  end

when :pg
  src = code || (ARGV[0] && read_file.(ARGV[0]))
  unless src
    opt.parse!(['--help'])
    exit
  end

  cs_init.()


  vm = AbRuby.new
  vm.current_file = ARGV[0] if ARGV[0]
  $stderr.puts "pg: running #{ARGV[0] || '-e'}" if verbose
  ast = vm.parse(src)
  vm.eval_ast(ast)

  $stderr.puts "pg: compiling" if verbose
  cs_compile.(ast, ARGV[0] || '-e')
  vm.last_entries.each do |name, body|
    cs_compile.(body, name)
  end
  AbRuby.cs_build(RUBY_CFLAGS)
  $stderr.puts "pg: done" if verbose

when :compile_first
  src = code || (ARGV[0] && read_file.(ARGV[0]))
  unless src
    opt.parse!(['--help'])
    exit
  end

  cs_init.()
  AbRuby.compiled_only = true if compiled_only

  vm = AbRuby.new
  vm.current_file = ARGV[0] if ARGV[0]

  # Compile
  ast = vm.parse(src)
  entries = [[ARGV[0] || '-e', ast]]
  vm.last_entries.each { |name, body| entries << [name, body] }
  entries.each { |label, node| cs_compile.(node, label) }

  $stderr.puts "cs_build" if verbose
  AbRuby.cs_build(RUBY_CFLAGS)
  AbRuby.cs_reload
  entries.each { |_, node| AbRuby.cs_load(node) }

  if dump_mode == :disasm
    entries.each do |label, node|
      $stdout.flush
      puts "--- #{label} ---"
      $stdout.flush
      puts vm.dump_ast(node)
      $stdout.flush
      AbRuby.cs_disasm(node)
    end
  end

  # Run
  $stderr.puts "run: #{ARGV[0] || '-e'}" if verbose
  vm.eval_ast(ast)

when :run
  run_script = code ? nil : ARGV.shift
  src = code || (run_script && read_file.(run_script))
  unless src
    opt.parse!(['--help'])
    exit
  end

  if dump_mode == :ast
    vm = AbRuby.new
    puts vm.dump(src)
  else
    cs_init.()
    AbRuby.compiled_only = true if compiled_only

    vm = AbRuby.new
    vm.current_file = run_script if run_script
    $stderr.puts "run: #{ARGV[0] || '-e'}" if verbose
    vm.eval(src)

    if dump_mode == :disasm
      # TODO: iterate specialized nodes and show disasm
    end
  end
end
