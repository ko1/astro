#!/usr/bin/env ruby

require 'optparse'
require 'rbconfig'
require_relative '../lib/abruby'
require_relative '../lib/abruby/version'

# CFLAGS needed to compile specialized code (needs ruby.h).  Propagate
# ABRUBY_DEBUG so the SD_*.c files see the same NodeHead layout as abruby.so
# — the debug build adds head.parent and mismatched offsets between the two
# images produce SEGVs that are extremely painful to trace.
abruby_debug_flag = (AbRuby::DEBUG rescue false) ? 1 : 0
RUBY_CFLAGS = "-I#{RbConfig::CONFIG['rubyhdrdir']} -I#{RbConfig::CONFIG['rubyarchhdrdir']} -DABRUBY_DEBUG=#{abruby_debug_flag}"

code = nil
mode = :run          # :run, :plain, :compile, :compile_first, :pg
compile_files = nil  # files to compile (--compile)
run_file = nil       # file to run after --compile (--run)
run_args = []        # args for --run
dump_mode = nil      # nil, :ast, :disasm
verbose = false
compiled_only = false

opt = OptionParser.new
opt.banner = "Usage: abruby [options] [file] [args...]"

opt.on('-e CODE', 'evaluate CODE') { |v| code = v }
opt.on('-d', 'dump disasm (shorthand for --dump=disasm)') { dump_mode = :disasm }
opt.on('--dump[=MODE]', 'dump AST (default) or disasm') do |v|
  dump_mode = case v
  when nil, 'ast' then :ast
  when 'disasm'   then :disasm
  else
    $stderr.puts "unknown dump mode: #{v} (use ast or disasm)"
    exit 1
  end
end
opt.on('--plain', 'run without code store') { mode = :plain }
opt.on('--compile', 'compile files (AOT)') { mode = :compile }
opt.on('-c', '--compile-first', 'compile then run') { mode = :compile_first }
opt.on('--pgc', 'profile-guided compilation: run, then recompile with profile data') { mode = :pgc }
opt.on('--verbose', 'show code store operations') { verbose = true }
opt.on('--compiled-only', 'abort if default dispatcher is used') { compiled_only = true }
opt.on('-v', '--version', 'show version') do
  puts "abruby #{AbRuby::VERSION}"
  exit
end

# Handle --run (appears after --compile file list)
argv = ARGV.dup
run_idx = argv.index('--run')
if run_idx
  compile_argv = argv[0...run_idx]
  run_argv = argv[(run_idx + 1)..]
  opt.parse!(compile_argv)
  compile_files = compile_argv
  run_file = run_argv.shift
  run_args = run_argv
  mode = :compile unless mode == :pg
else
  # Use order! so that options after the script path are forwarded to the
  # script via ARGV (mirroring `ruby script.rb -b ...` behaviour).
  opt.order!(ARGV)
end

# Read source file
read_file = ->(path) {
  unless File.exist?(path)
    $stderr.puts "abruby: cannot load such file -- #{path}"
    exit 1
  end
  File.read(path)
}

# Initialize code store (shared by all modes except --plain)
ABRUBY_DIR = File.expand_path('..', __dir__)
AbRuby.verbose = verbose

ABRUBY_SO_MTIME = File.mtime(File.join(ABRUBY_DIR, 'abruby.so')).to_i rescue 0

cs_init = ->() {
  store_dir = File.join(ABRUBY_DIR, 'code_store')
  $stderr.puts "cs_init: #{store_dir} (src: #{ABRUBY_DIR}, ver: #{ABRUBY_SO_MTIME})" if verbose
  AbRuby.cs_init(store_dir, ABRUBY_DIR, ABRUBY_SO_MTIME)
}

# Compile an AST entry node
cs_compile = ->(ast, label = nil) {
  $stderr.puts "cs_compile: #{label}" if verbose
  AbRuby.cs_compile(ast)
}

case mode
when :plain
  script_file = code ? nil : ARGV.shift
  src = code || (script_file && read_file.(script_file))
  unless src
    opt.parse!(['--help'])
    exit
  end
  abm = AbRuby.new
  if dump_mode == :ast
    puts abm.dump(src)
  else
    abm.current_file = script_file if script_file
    abm.eval(src)
  end

when :compile
  files = compile_files || ARGV.dup
  if files.empty?
    $stderr.puts "abruby: --compile requires at least one file"
    exit 1
  end

  cs_init.()

  abm = AbRuby.new
  all_entries = []
  files.each do |f|
    src = read_file.(f)
    $stderr.puts "compile: #{f}" if verbose
    ast = abm.parse(src, f)
    cs_compile.(ast, f)
    all_entries << [f, ast]
    abm.last_entries.each do |name, body|
      cs_compile.(body, "#{f}:#{name}")
      all_entries << ["#{f}:#{name}", body]
    end
  end

  $stderr.puts "cs_build" if verbose
  AbRuby.cs_build(RUBY_CFLAGS)
  AbRuby.cs_reload

  if dump_mode == :disasm
    all_entries.each do |label, node|
      $stdout.flush
      puts "--- #{label} ---"
      $stdout.flush
      puts abm.dump_ast(node)
      $stdout.flush
      AbRuby.cs_disasm(node)
    end
  end

  if run_file
    src = read_file.(run_file)
    $stderr.puts "run: #{run_file}" if verbose
    abm.current_file = run_file
    abm.eval(src)
  end

when :pgc
  # Profile-guided compilation (run-once then leave baked code store for next run):
  #   pass 1: compile stubs, cs_build, cs_reload, cs_load all entries.
  #     Caches each node's HASH based on its parse-time kind (important:
  #     later cs_compile calls return the cached hash even after swap).
  #   run: exercise the program.  swap_dispatcher updates inner node kinds
  #     (e.g. node_call1 → node_call1_ast) and method_cache_fill populates
  #     mc->prologue / mc->prologue_kind.  These become the profile.
  #   pass 2: recompile entries.  SPECIALIZE sees post-swap kinds and
  #     emits EVAL_<specialized>(...) calls; storageless PGO operands
  #     (method_prologue_t baked_prologue) get filled from mc.  Same
  #     SD_ filename (cached hash) — content is overwritten with the baked
  #     version.  Exit — next process picks up the baked code store.
  run_script = code ? nil : ARGV.shift
  src = code || (run_script && read_file.(run_script))
  unless src
    opt.parse!(['--help'])
    exit
  end

  cs_init.()
  AbRuby.compiled_only = true if compiled_only

  # Collect every AST entry the parser produces so we can re-compile them
  # after profiling.
  compiled_entries = []
  AbRuby::Parser.on_parse = ->(parsed_ast, entries, src_file) {
    label = src_file || '-e'
    cs_compile.(parsed_ast, label)
    compiled_entries << [label, parsed_ast]
    entries.each do |name, body|
      cs_compile.(body, "#{label}:#{name}")
      compiled_entries << ["#{label}:#{name}", body]
    end
    $stderr.puts "pgc pass1: cs_build" if verbose
    AbRuby.cs_build(RUBY_CFLAGS)
    AbRuby.cs_reload
    compiled_entries.each { |_, node| AbRuby.cs_load(node) }
  }

  abm = AbRuby.new
  abm.current_file = run_script if run_script
  $stderr.puts "pgc: parsing + compile stubs" if verbose
  ast = abm.parse(src)

  # Profiling run: populate mc->prologue, let inner nodes swap.  swap_dispatcher
  # updates inner (non-entry) nodes because only entries are is_specialized.
  $stderr.puts "pgc: profiling run" if verbose
  abm.eval_ast(ast)

  # Recompile entries with profile data baked in, rebuild.  The next
  # process invocation (e.g. abruby file.rb) loads the baked SD_s via
  # cs_init and benefits from the PGO.
  $stderr.puts "pgc pass2: recompile with profile data" if verbose
  compiled_entries.each { |label, node| cs_compile.(node, label) }
  AbRuby.cs_build(RUBY_CFLAGS)
  $stderr.puts "pgc: done" if verbose

when :compile_first
  # Consume the script path so the remaining ARGV is forwarded to the
  # script (matches :run / ruby invocation semantics).
  run_script = code ? nil : ARGV.shift
  src = code || (run_script && read_file.(run_script))
  unless src
    opt.parse!(['--help'])
    exit
  end

  cs_init.()
  AbRuby.compiled_only = true if compiled_only

  # Install a parse hook that compiles and loads every file the script
  # pulls in at runtime (require / require_relative / eval).  Without
  # this, only the top-level script is in the code store and
  # --compiled-only crashes on any node from a required file.
  #
  # cs_reload replaces the loaded .so, invalidating dispatcher pointers
  # installed on previously-compiled nodes by earlier cs_load calls.
  # Re-cs_load every accumulated AST after each reload so their
  # dispatchers point at symbols in the new .so.
  compiled_entries = []  # [(label, node)], kept across reloads
  # Is this node already specialized (cs_load succeeded during ALLOC from an
  # earlier run's store)?  If so, we skip cs_compile — its SD_*.c already
  # sits in code_store/c/ and rebuilding would just touch mtimes and force
  # make to relink for nothing.
  already_compiled = ->(node) { AbRuby.verify_compiled(node).nil? }

  AbRuby::Parser.on_parse = ->(parsed_ast, entries, src_file) {
    label = src_file || '-e'
    new_nodes = []
    unless already_compiled.(parsed_ast)
      cs_compile.(parsed_ast, label)
      new_nodes << [label, parsed_ast]
    end
    entries.each do |name, body|
      next if already_compiled.(body)
      cs_compile.(body, "#{label}:#{name}")
      new_nodes << ["#{label}:#{name}", body]
    end

    if new_nodes.empty?
      compiled_entries.concat(new_nodes)  # empty, no-op
      next
    end
    compiled_entries.concat(new_nodes)

    $stderr.puts "cs_build" if verbose
    AbRuby.cs_build(RUBY_CFLAGS)
    AbRuby.cs_reload
    # cs_reload replaces all.so with a freshly-built image.  Dispatcher
    # pointers from the earlier image still work (we keep old mappings),
    # but nodes whose dlsym lookup missed on that older (smaller) image
    # need to be rebound now that their SD_ symbol exists.
    compiled_entries.each { |_, node| AbRuby.cs_load(node) }
  }

  abm = AbRuby.new
  abm.current_file = run_script if run_script

  # Parse the top-level script.  The on_parse hook above takes care of
  # cs_compile / cs_build / cs_reload / cs_load for it and every file
  # subsequently loaded via require_relative etc.
  $stderr.puts "run: #{run_script || '-e'}" if verbose
  ast = abm.parse(src)

  if dump_mode == :disasm
    compiled_entries.each do |label, node|
      $stdout.flush
      puts "--- #{label} ---"
      $stdout.flush
      puts abm.dump_ast(node)
      $stdout.flush
      AbRuby.cs_disasm(node)
    end
  end

  abm.eval_ast(ast)

when :run
  run_script = code ? nil : ARGV.shift
  src = code || (run_script && read_file.(run_script))
  unless src
    opt.parse!(['--help'])
    exit
  end

  if dump_mode == :ast
    abm = AbRuby.new
    puts abm.dump(src)
  else
    cs_init.()
    AbRuby.compiled_only = true if compiled_only

    abm = AbRuby.new
    abm.current_file = run_script if run_script
    $stderr.puts "run: #{ARGV[0] || '-e'}" if verbose
    abm.eval(src)

    if dump_mode == :disasm
      # TODO: iterate specialized nodes and show disasm
    end
  end
end
