#!/usr/bin/env ruby

require 'optparse'
require 'rbconfig'
require_relative '../lib/abruby'
require_relative '../lib/abruby/version'

# CFLAGS needed to compile specialized code (needs ruby.h).  Propagate
# ABRUBY_DEBUG so the SD_*.c files see the same NodeHead layout as abruby.so
# — the debug build adds head.parent and mismatched offsets between the two
# images produce SEGVs that are extremely painful to trace.
abruby_debug_flag = (AbRuby::DEBUG rescue false) ? 1 : 0
RUBY_CFLAGS = "-I#{RbConfig::CONFIG['rubyhdrdir']} -I#{RbConfig::CONFIG['rubyarchhdrdir']} -DABRUBY_DEBUG=#{abruby_debug_flag}"

code = nil
# Mode — one of the top-level execution flows:
#   :run     — execute the script (default).  Optionally augmented with
#              `compile_first` (pre-run AOT bake) and/or `pgc_at_exit`
#              (post-run PGC bake), which are orthogonal flags below.
#   :plain   — execute without the code store at all (interpreter only).
#   :compile — compile files, don't run (used with --compile [files] --run).
mode = :run
compile_first  = false  # -c: ensure AOT bake before entering eval
pgc_at_exit    = false  # --pgc: bake PGC after eval returns
compile_files = nil  # files to compile (--compile)
run_file = nil       # file to run after --compile (--run)
run_args = []        # args for --run
dump_mode = nil      # nil, :ast, :disasm
verbose = false
compiled_only = false
aot_only = false

opt = OptionParser.new
opt.banner = "Usage: abruby [options] [file] [args...]"

opt.on('-e CODE', 'evaluate CODE') { |v| code = v }
opt.on('-d', 'dump disasm (shorthand for --dump=disasm)') { dump_mode = :disasm }
opt.on('--dump[=MODE]', 'dump AST (default) or disasm') do |v|
  dump_mode = case v
  when nil, 'ast' then :ast
  when 'disasm'   then :disasm
  else
    $stderr.puts "unknown dump mode: #{v} (use ast or disasm)"
    exit 1
  end
end
set_mode = ->(m) {
  if mode != :run && mode != m
    $stderr.puts "warning: mode #{mode.inspect} overridden by #{m.inspect} (can't combine mode flags)"
  end
  mode = m
}
opt.on('--plain',               'run without code store') { set_mode.(:plain) }
opt.on('--compile',             'compile files (AOT only, no run)') { set_mode.(:compile) }
opt.on('-c', '--compile-first', 'bake AOT before run (composes with --pgc)') { compile_first = true }
opt.on('--pgc',                 'bake PGC after run (composes with -c)') { pgc_at_exit = true }
opt.on('--verbose',       'show code store operations') { verbose = true }
opt.on('--compiled-only', 'abort if default dispatcher is used') { compiled_only = true }
opt.on('--aot-only',      'load only AOT (SD_<Horg>); skip PGC index lookup — for benchmarking') { aot_only = true }
opt.on('-v', '--version', 'show version') do
  puts "abruby #{AbRuby::VERSION}"
  exit
end

# Handle --run (appears after --compile file list)
argv = ARGV.dup
run_idx = argv.index('--run')
if run_idx
  compile_argv = argv[0...run_idx]
  run_argv = argv[(run_idx + 1)..]
  opt.parse!(compile_argv)
  compile_files = compile_argv
  run_file = run_argv.shift
  run_args = run_argv
  set_mode.(:compile)
else
  # Use order! so that options after the script path are forwarded to the
  # script via ARGV (mirroring `ruby script.rb -b ...` behaviour).
  opt.order!(ARGV)
end

# Read source file
read_file = ->(path) {
  unless File.exist?(path)
    $stderr.puts "abruby: cannot load such file -- #{path}"
    exit 1
  end
  File.read(path)
}

# Initialize code store (shared by all modes except --plain)
ABRUBY_DIR = File.expand_path('..', __dir__)
AbRuby.verbose = verbose

ABRUBY_SO_MTIME = File.mtime(File.join(ABRUBY_DIR, 'abruby.so')).to_i rescue 0

cs_init = ->() {
  store_dir = File.join(ABRUBY_DIR, 'code_store')
  $stderr.puts "cs_init: #{store_dir} (src: #{ABRUBY_DIR}, ver: #{ABRUBY_SO_MTIME})" if verbose
  AbRuby.cs_init(store_dir, ABRUBY_DIR, ABRUBY_SO_MTIME)
}

# Compile an AST entry node.  `file` toggles AOT vs PGC:
#   nil — AOT: emits SD_<Horg>.c, no profile info
#   str — PGC: emits SD_<Hopt>.c, records (Horg, file, line) → Hopt in index
cs_compile = ->(ast, label: nil, file: nil) {
  $stderr.puts "cs_compile: #{label}#{' [pgc]' if file}" if verbose
  AbRuby.cs_compile(ast, file)
}

case mode
when :plain
  script_file = code ? nil : ARGV.shift
  src = code || (script_file && read_file.(script_file))
  unless src
    opt.parse!(['--help'])
    exit
  end
  abm = AbRuby.new
  if dump_mode == :ast
    puts abm.dump(src)
  else
    abm.current_file = script_file if script_file
    abm.eval(src)
  end

when :compile
  files = compile_files || ARGV.dup
  if files.empty?
    $stderr.puts "abruby: --compile requires at least one file"
    exit 1
  end

  cs_init.()

  abm = AbRuby.new
  all_entries = []
  files.each do |f|
    src = read_file.(f)
    $stderr.puts "compile: #{f}" if verbose
    ast = abm.parse(src, f)
    cs_compile.(ast, label: f)  # AOT
    all_entries << [f, ast]
    abm.last_entries.each do |name, body|
      cs_compile.(body, label: "#{f}:#{name}")  # AOT
      all_entries << ["#{f}:#{name}", body]
    end
  end

  $stderr.puts "cs_build" if verbose
  AbRuby.cs_build(RUBY_CFLAGS)
  AbRuby.cs_reload

  if dump_mode == :disasm
    all_entries.each do |label, node|
      $stdout.flush
      puts "--- #{label} ---"
      $stdout.flush
      puts abm.dump_ast(node)
      $stdout.flush
      AbRuby.cs_disasm(node)
    end
  end

  if run_file
    src = read_file.(run_file)
    $stderr.puts "run: #{run_file}" if verbose
    abm.current_file = run_file
    abm.eval(src)
  end

when :run
  # Unified execution branch.  `compile_first` and `pgc_at_exit` are
  # orthogonal flags that layer onto the base "parse + run" flow:
  #
  #   compile_first (-c):
  #     on each parse, AOT-compile any entry not already baked in the
  #     store (via verify_compiled), cs_build, cs_reload, and cs_load
  #     every accumulated entry so freshly-built SD_<Horg> take effect.
  #     Guarantees every entry has a compiled dispatcher before
  #     eval_ast runs — required for --compiled-only on multi-file
  #     programs (required files parsed on the fly).
  #
  #   pgc_at_exit (--pgc):
  #     after eval_ast returns cleanly, walk every parsed entry and
  #     bake:  Hopt != Horg → PGSD_<Hopt>.c + hopt_index.txt,  Hopt ==
  #     Horg → SD_<Horg>.c (AOT fallback so the next --compiled-only
  #     run covers entries profile didn't touch).
  run_script = code ? nil : ARGV.shift
  src = code || (run_script && read_file.(run_script))
  unless src
    opt.parse!(['--help'])
    exit
  end

  if dump_mode == :ast
    abm = AbRuby.new
    puts abm.dump(src)
    exit
  end

  cs_init.()
  AbRuby.compiled_only = true if compiled_only

  # Cumulative tracker of every entry parsed this process — drives
  # --dump=disasm and PGC bake.  (label, node, src_file) triples.
  parsed_entries = []
  already_compiled = ->(node) { AbRuby.verify_compiled(node).nil? }

  AbRuby::Parser.on_parse = ->(parsed_ast, entries, src_file) {
    label = src_file || '-e'
    # pgc_file: stable index key for inline runs so repeated invocations
    # reuse keys.  --aot-only forces nil to bypass the PGC lookup.
    pgc_file = aot_only ? nil : (src_file || '-e')

    this_parse = [[label, parsed_ast, src_file]]
    entries.each { |name, body| this_parse << ["#{label}:#{name}", body, src_file] }
    parsed_entries.concat(this_parse)

    new_compiles = []
    if compile_first
      this_parse.each do |l, node, _|
        next if already_compiled.(node)
        cs_compile.(node, label: l)  # AOT (SD_<Horg>)
        new_compiles << [l, node]
      end
    end

    if !new_compiles.empty?
      $stderr.puts "cs_build" if verbose
      AbRuby.cs_build(RUBY_CFLAGS)
      AbRuby.cs_reload
      # cs_reload replaces all.so; rebind every accumulated entry so
      # their dispatchers point at the new image's SD_ / PGSD_.
      parsed_entries.each do |_, node, file|
        pf = aot_only ? nil : (file || '-e')
        AbRuby.cs_load(node, pf)
      end
    else
      # Even without a rebuild this round, this_parse entries may have
      # cached dispatchers available from an earlier invocation — try
      # cs_load now so the evaluator runs with them.
      this_parse.each { |_, node, _| AbRuby.cs_load(node, pgc_file) }
    end
  }

  abm = AbRuby.new
  abm.current_file = run_script if run_script
  $stderr.puts "run: #{run_script || '-e'}" if verbose
  ast = abm.parse(src)

  # --dump=disasm: show the dispatcher each entry is about to execute
  # with.  For --pgc that's the pre-profile state (pre-baked PGSD_ from
  # an earlier --pgc if any; otherwise the SD_<Horg> from -c, or the
  # default dispatcher if nothing is compiled for this entry).
  if dump_mode == :disasm
    parsed_entries.each do |label, node, _file|
      $stdout.flush
      puts "--- #{label} ---"
      $stdout.flush
      puts abm.dump_ast(node)
      $stdout.flush
      AbRuby.cs_disasm(node)
    end
  end

  abm.eval_ast(ast)

  # --pgc: bake after a clean run.  Skipped if eval_ast raised (we
  # don't want to persist profile from a crashed run).
  if pgc_at_exit
    pgc_ents, aot_ents = parsed_entries.partition { |_, node, _|
      AbRuby.horg(node) != AbRuby.hopt(node)
    }
    if verbose
      $stderr.puts "pgc bake: pgc=#{pgc_ents.size} aot=#{aot_ents.size} of #{parsed_entries.size}"
    end
    pgc_ents.each { |label, node, file| cs_compile.(node, label: label, file: file || '-e') }
    aot_ents.each { |label, node, _file| cs_compile.(node, label: label) }
    AbRuby.cs_build(RUBY_CFLAGS) if parsed_entries.any?
    $stderr.puts "pgc: done" if verbose
  end
end
