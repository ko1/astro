#!/usr/bin/env ruby
# iabrb: interactive abruby REPL with code store compilation and disasm

require 'optparse'
require 'rbconfig'

begin
  require 'readline'
  HAS_READLINE = true
rescue LoadError
  HAS_READLINE = false
end

require_relative '../lib/abruby'
require_relative '../lib/abruby/version'

compile = false
pgc      = false
disasm   = false
clear_store = false
initial_exprs = []

opt = OptionParser.new
opt.banner = "Usage: iabrb [options]"
opt.on('-e CODE', 'evaluate CODE before entering REPL') { |v| initial_exprs << v }
opt.on('-c', '--compile-first', 'AOT-compile each input before execution') { compile = true }
opt.on('--pgc', 'after execution, PGC-compile based on the profile collected') { pgc = true }
opt.on('-d', '--disasm', 'show disassembly after compile (implies --compile-first unless --pgc)') { disasm = true }
opt.on('--clear-code-store', 'wipe code_store/ before starting (force fresh compiles, pick up new CC/CFLAGS)') { clear_store = true }
opt.on('-v', '--version', 'show version') { puts "iabrb #{AbRuby::VERSION}"; exit }
opt.parse!(ARGV)

# -c and --pgc don't compose cleanly: AOT pre-bake makes the baked body
# is_specialized=true, which short-circuits swap_dispatcher — the very
# mechanism PGC relies on to notice new type observations.  Pick one.
if compile && pgc
  $stderr.puts "iabrb: --compile-first and --pgc are mutually exclusive (pick one)"
  exit 1
end

# -d alone keeps the historical "compile then disasm" behaviour (AOT); pair
# it with --pgc to disasm the post-profile bake instead.
compile = true if disasm && !pgc

any_cs = compile || pgc || disasm
if any_cs
  abruby_dir = File.expand_path('..', __dir__)
  cflags = "-I#{RbConfig::CONFIG['rubyhdrdir']} -I#{RbConfig::CONFIG['rubyarchhdrdir']}"
  code_store = File.join(abruby_dir, 'code_store')
  # --clear-code-store: wipe any pre-existing baked code before cs_init so
  # the new run picks up whatever CC / CFLAGS the environment now sets
  # (otherwise cached SD_*.o compiled by a previous CC would be reused).
  require 'fileutils'
  FileUtils.rm_rf(code_store) if clear_store
  so_mtime = File.mtime(File.join(abruby_dir, 'abruby.so')).to_i rescue 0
  AbRuby.cs_init(code_store, abruby_dir, so_mtime)
end

abm = AbRuby.new

# Entries seen across the whole REPL session — each line's top-level AST +
# any def bodies it introduced.  Accumulating lets --pgc re-bake previously
# defined methods after their body is exercised by the current line (so
# `f 0.5` re-PGCs `f` with the just-observed profile).
# Each entry is [line_no, name, node] so headers can distinguish multiple
# <toplevel> entries defined on different REPL lines.
session_entries = []
line_no = 0
# Hopt hashes already baked / shown this session — skip re-compile + re-
# disasm of entries whose profile didn't actually change this round (e.g.
# the same bare `f` typed three times in a row).
hopt_shown = {}

dump_and_disasm = ->(entries) {
  entries.each do |ln, name, node|
    if entries.size > 1
      $stdout.flush
      label = name || '<toplevel>'
      label = "#{label} (line #{ln})" if ln
      puts "--- #{label} ---"
      $stdout.flush
    end
    puts abm.dump_ast(node)
    $stdout.flush
    AbRuby.cs_disasm(node)
  end
}

eval_line = ->(line) {
  ast = abm.parse(line)
  line_no += 1
  new_entries = [[line_no, nil, ast]] + abm.last_entries.map { |n, node| [line_no, n, node] }
  session_entries.concat(new_entries)

  # Each phase that compiles also disasms its own output (when -d is on),
  # so the transcript reads in time order:
  #    -cd           : AOT → disasm → eval → result
  #    --pgc -d      :                eval → result → PGC → disasm
  #    -cd --pgc -d  : AOT → disasm → eval → result → PGC → disasm
  # The PGC disasm shows only the entries actually re-baked (those with
  # real profile), so it adds new info rather than repeating AOT output.

  # ---------- Pre-eval: AOT bake ----------------------------------------
  if compile
    new_entries.each { |_, _, node| AbRuby.cs_compile(node) }
    AbRuby.cs_build(cflags)
    AbRuby.cs_reload
    new_entries.each { |_, _, node| AbRuby.cs_load(node) }
    dump_and_disasm.(new_entries) if disasm
  end

  # ---------- Eval ------------------------------------------------------
  result = abm.eval_ast(ast)
  puts "=> #{result.inspect}"

  # ---------- Post-eval: PGC bake ---------------------------------------
  # Only bake entries with real runtime profile AND whose Hopt hash moved
  # this round — repeated invocations with the same types produce the same
  # Hopt, so nothing new to compile or disasm.  hopt_shown dedupes.
  # Leaving no-profile entries as interpreter lets swap_dispatcher continue
  # to retune their kind on next exec (a method defined now may transition
  # to node_flonum_* next line before bake).
  if pgc
    pgc_ents = session_entries.select { |_, _, node| AbRuby.has_profile?(node) }
    pgc_file = '-e'
    newly_baked = pgc_ents.select do |_, _, node|
      hopt = AbRuby.hopt(node)
      next false if hopt_shown[hopt]
      hopt_shown[hopt] = true
      true
    end
    newly_baked.each { |_, _, node| AbRuby.cs_compile(node, pgc_file) }
    if newly_baked.any?
      AbRuby.cs_build(cflags)
      AbRuby.cs_reload
      # Re-load ALL pgc_ents — cs_reload swaps the .so and invalidates
      # every dispatcher, including unchanged entries baked earlier.
      pgc_ents.each { |_, _, node| AbRuby.cs_load(node, pgc_file) }
    end
    dump_and_disasm.(newly_baked) if disasm && newly_baked.any?
  end
}

# Execute initial expressions
initial_exprs.each { |expr| eval_line.(expr) }

mode_tag = []
mode_tag << 'compile' if compile
mode_tag << 'pgc' if pgc
mode_tag << 'disasm' if disasm
puts "iabrb #{AbRuby::VERSION}#{mode_tag.empty? ? '' : ' (' + mode_tag.join('+') + ')'}"

loop do
  begin
    line = if HAS_READLINE
      Readline.readline("iabrb> ", true)
    else
      print "iabrb> "
      $stdout.flush
      $stdin.gets&.chomp
    end
  rescue Interrupt
    puts
    next
  end

  break unless line
  next if line.strip.empty?

  begin
    eval_line.(line)
  rescue SyntaxError => e
    puts "SyntaxError: #{e.message}"
  rescue => e
    puts "#{e.class}: #{e.message}"
  end
end

puts
