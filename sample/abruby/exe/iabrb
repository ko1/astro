#!/usr/bin/env ruby
# iabrb: interactive abruby REPL with code store compilation and disasm

require 'optparse'
require 'rbconfig'

begin
  require 'readline'
  HAS_READLINE = true
rescue LoadError
  HAS_READLINE = false
end

require_relative '../lib/abruby'
require_relative '../lib/abruby/version'

compile = false
pgc      = false
disasm   = false
initial_exprs = []

opt = OptionParser.new
opt.banner = "Usage: iabrb [options]"
opt.on('-e CODE', 'evaluate CODE before entering REPL') { |v| initial_exprs << v }
opt.on('-c', '--compile-first', 'AOT-compile each input before execution') { compile = true }
opt.on('--pgc', 'after execution, PGC-compile based on the profile collected') { pgc = true }
opt.on('-d', '--disasm', 'show disassembly after compile (implies --compile-first unless --pgc)') { disasm = true }
opt.on('-v', '--version', 'show version') { puts "iabrb #{AbRuby::VERSION}"; exit }
opt.parse!(ARGV)

# -d alone keeps the historical "compile then disasm" behaviour (AOT); pair
# it with --pgc to disasm the post-profile bake instead.
compile = true if disasm && !pgc

any_cs = compile || pgc || disasm
if any_cs
  abruby_dir = File.expand_path('..', __dir__)
  cflags = "-I#{RbConfig::CONFIG['rubyhdrdir']} -I#{RbConfig::CONFIG['rubyarchhdrdir']}"
  so_mtime = File.mtime(File.join(abruby_dir, 'abruby.so')).to_i rescue 0
  AbRuby.cs_init(File.join(abruby_dir, 'code_store'), abruby_dir, so_mtime)
end

abm = AbRuby.new

# Entries seen across the whole REPL session — each line's top-level AST +
# any def bodies it introduced.  Accumulating lets --pgc re-bake previously
# defined methods after their body is exercised by the current line (so
# `f 0.5` re-PGCs `f` with the just-observed profile).
session_entries = []

dump_and_disasm = ->(entries) {
  entries.each do |name, node|
    if entries.size > 1
      $stdout.flush
      puts "--- #{name || '<toplevel>'} ---"
      $stdout.flush
    end
    puts abm.dump_ast(node)
    $stdout.flush
    AbRuby.cs_disasm(node)
  end
}

eval_line = ->(line) {
  ast = abm.parse(line)
  new_entries = [[nil, ast]] + abm.last_entries
  session_entries.concat(new_entries)

  # Pre-run AOT compile (-c / -d without --pgc): bake before first execution.
  if compile
    new_entries.each { |_, node| AbRuby.cs_compile(node) }
    AbRuby.cs_build(cflags)
    AbRuby.cs_reload
    new_entries.each { |_, node| AbRuby.cs_load(node) }
  end

  result = abm.eval_ast(ast)

  # Post-run PGC: only bake entries with real runtime profile.  Leaving the
  # no-profile ones as interpreter lets swap_dispatcher continue to retune
  # their kind on next exec — e.g. a method body defined this line may be
  # exercised with Float args next line and transition to node_flonum_*
  # before we bake it here.  Already-compiled entries whose hash didn't
  # change are skipped by astro_cs_compile (existing file check).
  if pgc
    pgc_ents = session_entries.select { |_, node| AbRuby.has_profile?(node) }
    pgc_file = '-e'  # stable index key for inline REPL input
    pgc_ents.each { |_, node| AbRuby.cs_compile(node, pgc_file) }
    if pgc_ents.any?
      AbRuby.cs_build(cflags)
      AbRuby.cs_reload
      pgc_ents.each { |_, node| AbRuby.cs_load(node, pgc_file) }
    end
  end

  # Print the eval result first, then the disasm.  With --pgc the disasm
  # reflects the post-eval profile — seeing `=> 1.5` then scrolling through
  # the PGC-baked code reads in the order things happened.
  puts "=> #{result.inspect}"

  # -d alone disasms the AOT bake done before eval.
  # -d with --pgc disasms the PGC bake done after eval — and we show the
  # whole session view so methods defined earlier are visible with their
  # updated post-profile code.
  if disasm
    dump_and_disasm.(pgc ? session_entries : new_entries)
  end
}

# Execute initial expressions
initial_exprs.each { |expr| eval_line.(expr) }

mode_tag = []
mode_tag << 'compile' if compile
mode_tag << 'pgc' if pgc
mode_tag << 'disasm' if disasm
puts "iabrb #{AbRuby::VERSION}#{mode_tag.empty? ? '' : ' (' + mode_tag.join('+') + ')'}"

loop do
  begin
    line = if HAS_READLINE
      Readline.readline("iabrb> ", true)
    else
      print "iabrb> "
      $stdout.flush
      $stdin.gets&.chomp
    end
  rescue Interrupt
    puts
    next
  end

  break unless line
  next if line.strip.empty?

  begin
    eval_line.(line)
  rescue SyntaxError => e
    puts "SyntaxError: #{e.message}"
  rescue => e
    puts "#{e.class}: #{e.message}"
  end
end

puts
