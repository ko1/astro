# ASTroGen rules
ASTROGEN = ruby -I ../../lib -r ./abruby_gen -e 'ASTroGen.start([], node_def_class: AbRubyNodeDef)'
GENERATED = node_eval.c node_dispatch.c node_hash.c node_dump.c node_alloc.c node_specialize.c node_head.h

$(GENERATED): node.def ../../lib/astrogen.rb abruby_gen.rb
	$(ASTROGEN)

node.o: $(GENERATED) context.h node.h
abruby.o: node_head.h context.h node.h

BUILTIN_OBJS = array.o class.o complex.o exception.o false.o float.o hash.o integer.o \
               kernel.o nil.o object.o range.o rational.o regexp.o string.o \
               symbol.o true.o
$(BUILTIN_OBJS): builtin/builtin.h context.h node.h

run: all
	ruby exe/abruby test.ab.rb

test: test-interp test-compiled

test-interp: all
	@echo "=== test-interp (--plain) ==="
	ABRUBY_MODE=plain ruby test/run_all.rb

test-compiled: all
	@echo "=== test-compiled (compile + run) ==="
	$(Q)$(RM) -rf code_store
	ruby test/compile_all.rb
	ABRUBY_MODE=compiled ruby test/run_all.rb

bench: all
	ruby benchmark/run.rb

bench-optcarrot: all
	exe/abruby benchmark/optcarrot/bin/optcarrot-bench

debug-test:
	$(MAKE) clean
	$(MAKE) cflags="$(cflags) -DABRUBY_DEBUG=1"
	ruby test/run_all.rb
	$(MAKE) clean
	$(MAKE)

clean: clean-generated

clean-generated:
	$(Q)$(RM) $(GENERATED)

