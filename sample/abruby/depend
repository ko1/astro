# ASTroGen rules
ASTROGEN = ruby -I ../../lib -r ./abruby_gen -e 'ASTroGen.start([], node_def_class: AbRubyNodeDef)'
GENERATED = node_eval.c node_dispatch.c node_hash.c node_dump.c node_alloc.c node_specialize.c node_head.h

$(GENERATED): node.def ../../lib/astrogen.rb abruby_gen.rb
	$(ASTROGEN)

node.o: $(GENERATED)
abruby.o: node_head.h

run: all
	ruby exe/abruby test.ab.rb

test: all
	ruby test/run_all.rb

bench: all
	ruby benchmark/run.rb

debug-test:
	$(MAKE) clean
	$(MAKE) cflags="$(cflags) -DABRUBY_DEBUG=1"
	ruby test/run_all.rb
	$(MAKE) clean
	$(MAKE)

clean: clean-generated

clean-generated:
	$(Q)$(RM) $(GENERATED)
