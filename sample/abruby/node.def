NODE_DEF @canonical=node_div
node_flonum_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(ab_is_float(lv) && ab_is_float(rv) && !c->abm->basic_op_redefined)) {
        return flonum_div_calc(c, lv, rv);
    }
    return node_flonum_div_slow(c, n, lv, rv, arg_index);
}

NODE_DEF @canonical=node_div
node_fixnum_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr(c,"divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    return node_fixnum_div_slow(c, n, lv, rv, arg_index);
}

NODE_DEF @canonical=node_div
node_integer_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr(c,"divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_div_calc(c, lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
}

