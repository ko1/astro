// === Equality / Modulo ===

static RESULT DISPATCH_node_eq(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_eq(CTX *c, NODE *n);
static RESULT DISPATCH_node_neq(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_neq(CTX *c, NODE *n);
static RESULT DISPATCH_node_mod(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_mod(CTX *c, NODE *n);

extern const struct NodeKind kind_node_eq;
extern const struct NodeKind kind_node_fixnum_eq;
extern const struct NodeKind kind_node_neq;
extern const struct NodeKind kind_node_fixnum_neq;
extern const struct NodeKind kind_node_mod;
extern const struct NodeKind kind_node_fixnum_mod;

NODE_DEF
node_eq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    // Object identity fast path: if lv and rv are the same VALUE, == always
    // returns true regardless of the == method override. Skips method dispatch
    // for common patterns like `@left == nil`, symbol equality, etc.
    if (lv == rv) return RESULT_OK(Qtrue);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_eq_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_eq);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
}
#endif

NODE_DEF @canonical=node_eq
node_fixnum_eq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        return RESULT_OK(lv == rv ? Qtrue : Qfalse);
    }
    return node_fixnum_eq_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_neq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    // Identity fast path for the converse of == above.
    if (lv == rv) return RESULT_OK(Qfalse);
    // != is defined as !(==), fallback through ==
    RESULT eq = node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
    if (eq.state != RESULT_NORMAL) return eq;
    return RESULT_OK(RTEST(eq.value) ? Qfalse : Qtrue);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_neq_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_neq);
    // != is defined as !(==), fallback through ==
    RESULT eq = node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
    if (eq.state != RESULT_NORMAL) return eq;
    return RESULT_OK(RTEST(eq.value) ? Qfalse : Qtrue);
}
#endif

NODE_DEF @canonical=node_neq
node_fixnum_neq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        return RESULT_OK(lv != rv ? Qtrue : Qfalse);
    }
    return node_fixnum_neq_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_mod(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mod, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_mod_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_mod);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mod, arg_index);
}
#endif

NODE_DEF @canonical=node_mod
node_fixnum_mod(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr(c,"divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long r = a % b;
        if (r && (a ^ b) < 0) r += b;
        return RESULT_OK(LONG2FIX(r));
    }
    return node_fixnum_mod_slow(c, n, lv, rv, arg_index);
}

// ===================================================================
// Bitwise operators (&, |, ^, >>): Fixnum fast path + method fallback.
// Same structure as node_plus / node_fixnum_plus.  optcarrot's CPU/PPU
// emulation runs these at > 600 calls per parsed file; the Fixnum case
// is a single machine instruction but previously went all the way
// through node_call1 → prologue_cfunc → ab_integer_band → rb_funcall.
// ===================================================================

static RESULT DISPATCH_node_and(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_and(CTX *c, NODE *n);
static RESULT DISPATCH_node_or(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_or(CTX *c, NODE *n);
static RESULT DISPATCH_node_xor(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_xor(CTX *c, NODE *n);
static RESULT DISPATCH_node_gtgt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_gtgt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_ltlt(CTX *c, NODE *n);

extern const struct NodeKind kind_node_and;
extern const struct NodeKind kind_node_fixnum_and;
extern const struct NodeKind kind_node_or;
extern const struct NodeKind kind_node_fixnum_or;
extern const struct NodeKind kind_node_xor;
extern const struct NodeKind kind_node_fixnum_xor;
extern const struct NodeKind kind_node_gtgt;
extern const struct NodeKind kind_node_fixnum_gtgt;
extern const struct NodeKind kind_node_fixnum_ltlt;

// --- node_and / node_fixnum_and ---
NODE_DEF
node_and(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_and, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_and_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_and);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_and, arg_index);
}
#endif

NODE_DEF @canonical=node_and
node_fixnum_and(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        // Both Fixnum VALUEs carry the low tag bit (= 1); ANDing them
        // preserves the tag, so the result is a valid Fixnum VALUE.
        return RESULT_OK(lv & rv);
    }
    return node_fixnum_and_slow(c, n, lv, rv, arg_index);
}

// --- node_or / node_fixnum_or ---
NODE_DEF
node_or(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_or, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_or_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_or);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_or, arg_index);
}
#endif

NODE_DEF @canonical=node_or
node_fixnum_or(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        // OR of two tagged Fixnum values preserves the tag.
        return RESULT_OK(lv | rv);
    }
    return node_fixnum_or_slow(c, n, lv, rv, arg_index);
}

// --- node_xor / node_fixnum_xor ---
NODE_DEF
node_xor(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_xor, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_xor_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_xor);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_xor, arg_index);
}
#endif

NODE_DEF @canonical=node_xor
node_fixnum_xor(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        // XOR of two tagged Fixnums clears the tag; re-set it.
        return RESULT_OK((lv ^ rv) | (VALUE)RUBY_FIXNUM_FLAG);
    }
    return node_fixnum_xor_slow(c, n, lv, rv, arg_index);
}

// --- node_gtgt / node_fixnum_gtgt ---
NODE_DEF
node_gtgt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_gtgt, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_gtgt_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_gtgt);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_gtgt, arg_index);
}
#endif

NODE_DEF @canonical=node_gtgt
node_fixnum_gtgt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long a = FIX2LONG(lv);
        long sh = FIX2LONG(rv);
        if (LIKELY(sh >= 0)) {
            // Shift >= 63 collapses to 0 (or -1 for negatives) per Ruby.
            if (UNLIKELY(sh >= (long)(sizeof(long) * 8 - 1))) {
                return RESULT_OK(LONG2FIX(a < 0 ? -1 : 0));
            }
            return RESULT_OK(LONG2FIX(a >> sh));
        }
        // Negative rhs → method dispatch fallback (becomes a left shift,
        // potentially Bignum).
    }
    return node_fixnum_gtgt_slow(c, n, lv, rv, arg_index);
}

// ===================================================================
// Indexing operators (a[b], a[b] = c, a << b)
//
// Parser emits the speculative Array kind (node_array_aref /
// node_array_aset / node_array_ltlt) for every `[]` / `[]=` / `<<`
// call site — Array is the dominant receiver, and committing at parse
// time keeps the SD hot body compact.
//
// Fast path (inlined into the SD): Array receiver (+ Fixnum index for
// aref/aset).  Out-of-line fallback: classifies the receiver; on Hash
// / Fixnum it swap_dispatcher()s the node to the matching monomorphic
// kind (node_hash_aref / node_fixnum_aref / node_hash_aset /
// node_fixnum_ltlt) so later calls skip the classification.  Receivers
// outside the catalogue fall through to method dispatch.
// ===================================================================

static RESULT DISPATCH_node_array_aref(CTX *c, NODE *n);
static RESULT DISPATCH_node_hash_aref(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_aref(CTX *c, NODE *n);
static RESULT DISPATCH_node_array_aset(CTX *c, NODE *n);
static RESULT DISPATCH_node_hash_aset(CTX *c, NODE *n);
static RESULT DISPATCH_node_array_ltlt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_ltlt(CTX *c, NODE *n);

extern const struct NodeKind kind_node_array_aref;
extern const struct NodeKind kind_node_hash_aref;
extern const struct NodeKind kind_node_fixnum_aref;
extern const struct NodeKind kind_node_array_aset;
extern const struct NodeKind kind_node_hash_aset;
extern const struct NodeKind kind_node_array_ltlt;
extern const struct NodeKind kind_node_fixnum_ltlt;

// 2-arg method dispatch fallback (recv.op(idx, val)) — used by the
// aset fallbacks for the []= method.  Parallels node_arith_fallback
// but with two call-args.
#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_indexset_fallback(CTX * restrict c, NODE * restrict n, VALUE recv, VALUE idx, VALUE val, ID op, uint32_t arg_index)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, recv);
    const struct abruby_method *method = abruby_class_find_method(klass, op);
    if (!method) {
        method = abruby_class_find_method(klass, c->ids->method_missing);
        if (!method) {
            VALUE exc;
            PUSH_FRAME(n);
            VALUE m = rb_str_new_cstr("undefined method `");
            rb_str_cat_cstr(m, rb_id2name(op));
            rb_str_cat_cstr(m, "'");
            exc = abruby_exception_new(c, c->current_frame, m);
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        c->current_frame->fp[arg_index]     = abruby_str_new_cstr(c, rb_id2name(op));
        c->current_frame->fp[arg_index + 1] = idx;
        c->current_frame->fp[arg_index + 2] = val;
        return dispatch_method_with_klass(c, n, recv, klass, method, 3, arg_index);
    }
    c->current_frame->fp[arg_index]     = idx;
    c->current_frame->fp[arg_index + 1] = val;
    return dispatch_method_with_klass(c, n, recv, klass, method, 2, arg_index);
}
#endif

// --- Inline helpers shared by the monomorphic kinds and the fallbacks ---

static inline RESULT
do_hash_aref(VALUE rv, VALUE iv)
{
    return RESULT_OK(rb_hash_aref(RHSH(rv), ab_hash_key(iv)));
}

static inline RESULT
do_fixnum_aref(VALUE rv, VALUE iv)
{
    // Caller has already checked FIXNUM_P(rv) && FIXNUM_P(iv).
    long val = FIX2LONG(rv);
    long i = FIX2LONG(iv);
    if (i < 0) return RESULT_OK(INT2FIX(0));
    if (i >= (long)(sizeof(long) * 8)) return RESULT_OK(INT2FIX(val < 0 ? 1 : 0));
    return RESULT_OK(INT2FIX((val >> i) & 1));
}

static inline RESULT
do_hash_aset(VALUE rv, VALUE iv, VALUE vv)
{
    rb_hash_aset(RHSH(rv), ab_hash_key(iv), vv);
    return RESULT_OK(vv);
}

// do_fixnum_ltlt returns (Qundef, NORMAL) to signal overflow / non-Fixnum
// rhs; callers then fall through to method dispatch.
static inline RESULT
do_fixnum_ltlt(VALUE lv, VALUE rv)
{
    if (LIKELY(FIXNUM_P(rv))) {
        long a = FIX2LONG(lv);
        long sh = FIX2LONG(rv);
        if (LIKELY(sh >= 0 && sh < (long)(sizeof(long) * 8 - 1))) {
            long result = a << sh;
            if (LIKELY((result >> sh) == a && FIXABLE(result))) {
                return RESULT_OK(LONG2FIX(result));
            }
        }
    }
    return RESULT_OK(Qundef);
}

// === Shared aref fallback ===
//
// Called from every aref kind (array_aref, hash_aref, fixnum_aref)
// when their specific fast path misses.  Classifies the receiver,
// swap_dispatcher()s to the matching monomorphic kind, and runs the
// operation.  Unknown receiver → method dispatch.
#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
node_aref_fallback(CTX * restrict c, NODE * restrict n, VALUE rv, VALUE iv, uint32_t arg_index)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, rv);
    if (klass == c->abm->array_class) {
        if (LIKELY(FIXNUM_P(iv))) {
            swap_dispatcher(n, &kind_node_array_aref);
            return RESULT_OK(ab_ary_entry(RARY(rv), FIX2LONG(iv)));
        }
    }
    else if (klass == c->abm->hash_class) {
        swap_dispatcher(n, &kind_node_hash_aref);
        return do_hash_aref(rv, iv);
    }
    else if (FIXNUM_P(rv) && FIXNUM_P(iv)) {
        swap_dispatcher(n, &kind_node_fixnum_aref);
        return do_fixnum_aref(rv, iv);
    }

    return node_arith_fallback(c, n, rv, iv, c->ids->op_aref, arg_index);
}
#endif

NODE_DEF @canonical=node_aref
node_array_aref(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *idx, uint32_t arg_index)
{
    VALUE rv = UNWRAP(EVAL_ARG(c, recv));
    VALUE iv = UNWRAP(EVAL_ARG(c, idx));
    if (LIKELY(AB_CLASS_OF(c, rv) == c->abm->array_class && FIXNUM_P(iv) && !c->abm->basic_op_redefined)) {
        return RESULT_OK(ab_ary_entry(RARY(rv), FIX2LONG(iv)));
    }
    return node_aref_fallback(c, n, rv, iv, arg_index);
}

NODE_DEF @canonical=node_aref
node_hash_aref(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *idx, uint32_t arg_index)
{
    VALUE rv = UNWRAP(EVAL_ARG(c, recv));
    VALUE iv = UNWRAP(EVAL_ARG(c, idx));
    if (LIKELY(AB_CLASS_OF(c, rv) == c->abm->hash_class && !c->abm->basic_op_redefined)) {
        return do_hash_aref(rv, iv);
    }
    return node_aref_fallback(c, n, rv, iv, arg_index);
}

NODE_DEF @canonical=node_aref
node_fixnum_aref(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *idx, uint32_t arg_index)
{
    VALUE rv = UNWRAP(EVAL_ARG(c, recv));
    VALUE iv = UNWRAP(EVAL_ARG(c, idx));
    if (LIKELY(FIXNUM_P(rv) && FIXNUM_P(iv))) {
        return do_fixnum_aref(rv, iv);
    }
    return node_aref_fallback(c, n, rv, iv, arg_index);
}

// === Shared ltlt fallback ===
//
// Called from node_array_ltlt and node_fixnum_ltlt on a type miss.
// Only swaps when the target kind's fast path will actually apply.
#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
node_ltlt_fallback(CTX * restrict c, NODE * restrict n, VALUE rv, VALUE xv, uint32_t arg_index)
{
    if (AB_CLASS_OF(c, rv) == c->abm->array_class) {
        swap_dispatcher(n, &kind_node_array_ltlt);
        rb_ary_push(RARY(rv), xv);
        return RESULT_OK(rv);
    }
    else if (FIXNUM_P(rv)) {
        RESULT r = do_fixnum_ltlt(rv, xv);
        if (r.value != Qundef) {
            swap_dispatcher(n, &kind_node_fixnum_ltlt);
            return r;
        }
        // overflow — fall through to method dispatch without swapping
    }

    return node_arith_fallback(c, n, rv, xv, c->ids->op_ltlt, arg_index);
}
#endif

NODE_DEF @canonical=node_ltlt
node_array_ltlt(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *right, uint32_t arg_index)
{
    VALUE rv = UNWRAP(EVAL_ARG(c, recv));
    VALUE xv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(AB_CLASS_OF(c, rv) == c->abm->array_class && !c->abm->basic_op_redefined)) {
        rb_ary_push(RARY(rv), xv);
        return RESULT_OK(rv);
    }
    return node_ltlt_fallback(c, n, rv, xv, arg_index);
}

NODE_DEF @canonical=node_ltlt
node_fixnum_ltlt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && !c->abm->basic_op_redefined)) {
        RESULT r = do_fixnum_ltlt(lv, rv);
        if (LIKELY(r.value != Qundef)) return r;
    }
    return node_ltlt_fallback(c, n, lv, rv, arg_index);
}

// === Shared aset fallback ===
// Only swaps when the target kind's fast path will actually apply.
#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
node_aset_fallback(CTX * restrict c, NODE * restrict n, VALUE rv, VALUE iv, VALUE vv, uint32_t arg_index)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, rv);
    if (klass == c->abm->array_class) {
        if (LIKELY(FIXNUM_P(iv))) {
            swap_dispatcher(n, &kind_node_array_aset);
            rb_ary_store(RARY(rv), FIX2LONG(iv), vv);
            return RESULT_OK(vv);
        }
    }
    else if (klass == c->abm->hash_class) {
        swap_dispatcher(n, &kind_node_hash_aset);
        return do_hash_aset(rv, iv, vv);
    }

    return node_indexset_fallback(c, n, rv, iv, vv, c->ids->op_aset, arg_index);
}
#endif

NODE_DEF @canonical=node_aset
node_array_aset(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *idx, NODE *value, uint32_t arg_index)
{
    VALUE rv = UNWRAP(EVAL_ARG(c, recv));
    VALUE iv = UNWRAP(EVAL_ARG(c, idx));
    VALUE vv = UNWRAP(EVAL_ARG(c, value));
    if (LIKELY(AB_CLASS_OF(c, rv) == c->abm->array_class && FIXNUM_P(iv) && !c->abm->basic_op_redefined)) {
        rb_ary_store(RARY(rv), FIX2LONG(iv), vv);
        return RESULT_OK(vv);
    }
    return node_aset_fallback(c, n, rv, iv, vv, arg_index);
}

NODE_DEF @canonical=node_aset
node_hash_aset(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *idx, NODE *value, uint32_t arg_index)
{
    VALUE rv = UNWRAP(EVAL_ARG(c, recv));
    VALUE iv = UNWRAP(EVAL_ARG(c, idx));
    VALUE vv = UNWRAP(EVAL_ARG(c, value));
    if (LIKELY(AB_CLASS_OF(c, rv) == c->abm->hash_class && !c->abm->basic_op_redefined)) {
        return do_hash_aset(rv, iv, vv);
    }
    return node_aset_fallback(c, n, rv, iv, vv, arg_index);
}

// ---------------------------------------------------------------------------
// PGO resolver: map a call-site NODE to the C identifier of its baked
// prologue ("prologue_ast_simple_1" etc.), or "none" if we shouldn't bake
// here.  Called from the generated HASH_* and SPECIALIZE_* functions (which
// live in node_hash.c / node_specialize.c, included after node_eval.c in
// node.c — so they see this symbol).
//
// "Shouldn't bake" covers: unknown node kind, mc never filled, POLY bit set,
// prologue pointer is one we don't have a stable name for.
// ---------------------------------------------------------------------------

extern const struct NodeKind kind_node_call;
extern const struct NodeKind kind_node_apply_call;
extern const struct NodeKind kind_node_super;

static inline const struct method_cache *
abruby_pgo_mc_for(const NODE *n)
{
    const struct NodeKind *k = n->head.kind;
    if (k == &kind_node_call0)           return &n->u.node_call0.mc;
    if (k == &kind_node_call1)           return &n->u.node_call1.mc;
    if (k == &kind_node_call2)           return &n->u.node_call2.mc;
    if (k == &kind_node_call0_ast)       return &n->u.node_call0_ast.mc;
    if (k == &kind_node_call0_cfunc)     return &n->u.node_call0_cfunc.mc;
    if (k == &kind_node_call0_ivar_get)  return &n->u.node_call0_ivar_get.mc;
    if (k == &kind_node_call1_ast)       return &n->u.node_call1_ast.mc;
    if (k == &kind_node_call1_cfunc)     return &n->u.node_call1_cfunc.mc;
    if (k == &kind_node_call1_ivar_set)  return &n->u.node_call1_ivar_set.mc;
    if (k == &kind_node_call2_ast)       return &n->u.node_call2_ast.mc;
    if (k == &kind_node_call2_cfunc)     return &n->u.node_call2_cfunc.mc;
    if (k == &kind_node_call)            return &n->u.node_call.mc;
    if (k == &kind_node_apply_call)      return &n->u.node_apply_call.mc;
    if (k == &kind_node_super)           return &n->u.node_super.mc;
    return NULL;
}

static const char *
abruby_pgo_prologue_name_for(const NODE *n)
{
    const struct method_cache *mc = abruby_pgo_mc_for(n);
    if (!mc) return "none";
    if (mc->flags & MC_PROLOGUE_POLY) return "none";

    switch (mc->prologue_kind) {
      case PROLOGUE_KIND_AST_SIMPLE_0: return "prologue_ast_simple_0";
      case PROLOGUE_KIND_AST_SIMPLE_1: return "prologue_ast_simple_1";
      case PROLOGUE_KIND_AST_SIMPLE_2: return "prologue_ast_simple_2";
      case PROLOGUE_KIND_AST_SIMPLE_N: return "prologue_ast_simple_n";
      case PROLOGUE_KIND_CFUNC:        return "prologue_cfunc";
      case PROLOGUE_KIND_IVAR_GETTER:  return "prologue_ivar_getter";
      case PROLOGUE_KIND_IVAR_SETTER:  return "prologue_ivar_setter";
      default:                         return "none";  // NONE or AST_COMPLEX — don't bake
    }
}
