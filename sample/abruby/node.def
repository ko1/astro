// === Equality / Modulo ===

static RESULT DISPATCH_node_eq(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_eq(CTX *c, NODE *n);
static RESULT DISPATCH_node_neq(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_neq(CTX *c, NODE *n);
static RESULT DISPATCH_node_mod(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_mod(CTX *c, NODE *n);

extern const struct NodeKind kind_node_eq;
extern const struct NodeKind kind_node_fixnum_eq;
extern const struct NodeKind kind_node_neq;
extern const struct NodeKind kind_node_fixnum_neq;
extern const struct NodeKind kind_node_mod;
extern const struct NodeKind kind_node_fixnum_mod;

NODE_DEF
node_eq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    // Object identity fast path: if lv and rv are the same VALUE, == always
    // returns true regardless of the == method override. Skips method dispatch
    // for common patterns like `@left == nil`, symbol equality, etc.
    if (lv == rv) return RESULT_OK(Qtrue);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_eq_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_eq);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
}

NODE_DEF
node_fixnum_eq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK(lv == rv ? Qtrue : Qfalse);
    }
    return node_fixnum_eq_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_neq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    // Identity fast path for the converse of == above.
    if (lv == rv) return RESULT_OK(Qfalse);
    // != is defined as !(==), fallback through ==
    RESULT eq = node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
    if (eq.state != RESULT_NORMAL) return eq;
    return RESULT_OK(RTEST(eq.value) ? Qfalse : Qtrue);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_neq_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_neq);
    // != is defined as !(==), fallback through ==
    RESULT eq = node_arith_fallback(c, n, lv, rv, c->ids->op_eq, arg_index);
    if (eq.state != RESULT_NORMAL) return eq;
    return RESULT_OK(RTEST(eq.value) ? Qfalse : Qtrue);
}

NODE_DEF
node_fixnum_neq(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK(lv != rv ? Qtrue : Qfalse);
    }
    return node_fixnum_neq_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_mod(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mod, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_mod_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_mod);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mod, arg_index);
}

NODE_DEF
node_fixnum_mod(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr(c,"divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long r = a % b;
        if (r && (a ^ b) < 0) r += b;
        return RESULT_OK(LONG2FIX(r));
    }
    return node_fixnum_mod_slow(c, n, lv, rv, arg_index);
}

