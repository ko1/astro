// abruby node definitions
// RESULT is the return type for all node evaluators.
// UNWRAP extracts VALUE from RESULT, propagating non-normal state.

#define UNWRAP(r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL)) return _r; \
    _r.value; \
})

// UNWRAP_ALSO: like UNWRAP but does not propagate the specified state.
// Used in dispatch_method_frame to catch RESULT_RETURN while propagating others.
#define UNWRAP_ALSO(except_state, r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL && _r.state != (except_state))) return _r; \
    _r.value; \
})

// Push/pop a lightweight frame to record the current execution point.
// Used before creating inline exceptions (e.g., division by zero) so that
// the backtrace includes the correct source location.
// PUSH_FRAME opens a do { block; POP_FRAME closes it with } while (0).
// This scoping prevents accidental nesting of _push_frame variable names.
// Variables needed after POP_FRAME must be declared BEFORE PUSH_FRAME.
// PUSH_FRAME / POP_FRAME moved to node.h (needed by node_helper.c too).

// helper functions (included before generated eval code)

// VM accessor helpers
#define CTX_MAIN_CLASS(c) (&(c)->abm->main_class_body)
#define CTX_GVARS(c)      (&(c)->abm->gvars)

// class system helpers

// Forward declarations so abruby_class_add_method can recognize attr_reader /
// attr_writer style bodies and mark the method as an IVAR accessor.
extern const struct NodeKind kind_node_ivar_get;
extern const struct NodeKind kind_node_ivar_set;
extern const struct NodeKind kind_node_lvar_get;

// Detect the AST shapes the parser emits for attr_reader / attr_writer:
//   def x;       @x;                     end  -> node_ivar_get
//   def x=(v);   @x = v;                 end  -> node_ivar_set(name, node_lvar_get(0))
// If matched, mark the method so the dispatch hot path skips the frame setup.
static inline bool
abruby_method_try_set_ivar_accessor(struct abruby_method *m, struct Node *body,
                                    unsigned int params_cnt)
{
    if (body == NULL) return false;
    if (params_cnt == 0 && body->head.kind == &kind_node_ivar_get) {
        m->type = ABRUBY_METHOD_IVAR_GETTER;
        m->u.ivar_accessor.ivar_name = body->u.node_ivar_get.name;
        return true;
    }
    if (params_cnt == 1 && body->head.kind == &kind_node_ivar_set) {
        const NODE *rhs = body->u.node_ivar_set.value;
        if (rhs && rhs->head.kind == &kind_node_lvar_get &&
            rhs->u.node_lvar_get.index == 0) {
            m->type = ABRUBY_METHOD_IVAR_SETTER;
            m->u.ivar_accessor.ivar_name = body->u.node_ivar_set.name;
            return true;
        }
    }
    return false;
}

// Check if a method definition on `klass` with `name` shadows a built-in
// operator that has a type-specialized node (fixnum_plus, array_aref, etc.).
// If so, set basic_op_redefined to disable all specializations.
static void
abruby_check_basic_op_redefined(struct abruby_machine *abm,
                                const struct abruby_class *klass, ID name)
{
    if (abm->basic_op_redefined) return;  // already set
    const struct abruby_id_cache *ids = &abm->id_cache;
    // Integer operators
    if (klass == abm->integer_class) {
        if (name == ids->op_plus || name == ids->op_minus ||
            name == ids->op_mul  || name == ids->op_div   ||
            name == ids->op_mod  || name == ids->op_lt    ||
            name == ids->op_le   || name == ids->op_gt    ||
            name == ids->op_ge   || name == ids->op_eq    ||
            name == ids->op_and  || name == ids->op_or    ||
            name == ids->op_xor  || name == ids->op_gtgt  ||
            name == ids->op_aref || name == ids->op_ltlt) {
            abm->basic_op_redefined = 1;
            return;
        }
    }
    // Float operators
    if (klass == abm->float_class) {
        if (name == ids->op_plus || name == ids->op_minus ||
            name == ids->op_mul  || name == ids->op_div) {
            abm->basic_op_redefined = 1;
            return;
        }
    }
    // Array operators
    if (klass == abm->array_class) {
        if (name == ids->op_aref || name == ids->op_aset || name == ids->op_ltlt) {
            abm->basic_op_redefined = 1;
            return;
        }
    }
    // Hash operators
    if (klass == abm->hash_class) {
        if (name == ids->op_aref || name == ids->op_aset) {
            abm->basic_op_redefined = 1;
            return;
        }
    }
}

static void
abruby_class_add_method(CTX *c, struct abruby_class *klass, ID name,
                        struct Node *body, unsigned int required_params_cnt,
                        unsigned int params_cnt, unsigned int post_params_cnt,
                        int rest_index, struct Node **opt_pc,
                        unsigned int locals_cnt, const char *source_file)
{
    const struct abruby_cref *def_cref = ctx_cref(c);
    VALUE existing;
    // (debug removed)
    if (ab_id_table_lookup(&klass->methods, name, &existing)) {
        struct abruby_method *m = (struct abruby_method *)existing;
        if (!abruby_method_try_set_ivar_accessor(m, body, params_cnt)) {
            m->type = ABRUBY_METHOD_AST;
            m->u.ast.body = body;
            m->u.ast.required_params_cnt = required_params_cnt;
            m->u.ast.params_cnt = params_cnt;
            m->u.ast.post_params_cnt = post_params_cnt;
            m->u.ast.rest_index = rest_index;
            m->u.ast.opt_pc = opt_pc;
            m->u.ast.locals_cnt = locals_cnt;
            m->entry.source_file = source_file;
            m->entry.cref = def_cref;
            m->entry.method = m;
            m->entry.stack_limit = locals_cnt;
        }
        abruby_check_basic_op_redefined(c->abm, klass, name);
        c->abm->method_serial++;
        return;
    }
    struct abruby_method *m = ruby_xcalloc(1, sizeof(struct abruby_method));
    m->name = name;
    m->defining_class = klass;
    m->entry.method = m;  // self-reference (frame->entry->method → this method)
    m->entry.stack_limit = locals_cnt;
    if (!abruby_method_try_set_ivar_accessor(m, body, params_cnt)) {
        m->type = ABRUBY_METHOD_AST;
        m->u.ast.body = body;
        m->u.ast.required_params_cnt = required_params_cnt;
        m->u.ast.params_cnt = params_cnt;
        m->u.ast.post_params_cnt = post_params_cnt;
        m->u.ast.rest_index = rest_index;
        m->u.ast.opt_pc = opt_pc;
        m->u.ast.locals_cnt = locals_cnt;
        m->entry.source_file = source_file;
        m->entry.cref = def_cref;
    }
    ab_id_table_insert(&klass->methods, name, (VALUE)m);
    abruby_check_basic_op_redefined(c->abm, klass, name);
    c->abm->method_serial++;
}

static struct abruby_method *
abruby_class_find_method(const struct abruby_class *klass, ID name)
{
    while (klass) {
        VALUE v;
        if (ab_id_table_lookup(&klass->methods, name, &v))
            return (struct abruby_method *)v;
        klass = klass->super;
    }
    return NULL;
}

extern VALUE abruby_new_object(CTX *c, struct abruby_class *klass);
extern void abruby_object_grow_ivars(struct abruby_object *obj, unsigned int new_cnt);

// === Literals ===

NODE_DEF
node_num(CTX * restrict c, NODE * restrict n, int32_t num)
{
    return RESULT_OK(INT2FIX(num));
}

extern VALUE abruby_float_new_wrap(CTX *c, VALUE rb_float);
extern VALUE abruby_bignum_new(CTX *c, VALUE rb_bignum);

NODE_DEF
node_float_new(CTX * restrict c, NODE * restrict n, double val)
{
    // Non-flonum fallback only. Flonum-representable literals are
    // pre-encoded at parse time by rb_alloc_node_float_new and routed
    // to node_literal instead.
    return RESULT_OK(abruby_float_new_wrap(c, rb_float_new(val)));
}

// Immediate-valued literal.  The uint64_t operand is any Ruby VALUE
// whose bit pattern is stable across processes — today only the CRuby
// flonum encoding (a pure function of the source double, computed once
// by rb_alloc_node_float_new via ab_flonum_encode); in the future,
// node_num/node_sym/node_true/node_false/node_nil could collapse into
// this node for uniform handling.  EVAL just returns the stored VALUE.
// The code store serializes the operand as a C integer literal.
NODE_DEF
node_literal(CTX * restrict c, NODE * restrict n, uint64_t val)
{
    (void)c; (void)n;
    return RESULT_OK((VALUE)val);
}

NODE_DEF
node_bignum_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_bignum_new(c, rb_cstr_to_inum(str, 10, 1)));
}

NODE_DEF
node_true(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qtrue);
}

NODE_DEF
node_false(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qfalse);
}

NODE_DEF
node_nil(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qnil);
}

NODE_DEF
node_str_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_str_new_cstr(c, str));
}

NODE_DEF
node_str_concat(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE result = rb_str_new(NULL, 0);
    for (uint32_t i = 0; i < argc; i++) {
        VALUE part = c->current_frame->fp[arg_index + i];
        VALUE rs;
        if (ab_obj_type_p(part, ABRUBY_OBJ_STRING)) {
            rs = abruby_str_rstr(part);
        } else if (RB_TYPE_P(part, T_STRING)) {
            // Tolerate raw CRuby strings landing here from cfuncs that
            // forgot to wrap their return value.  Treat as the string.
            rs = part;
        } else {
            // Fall back to dispatching to_s on the part.
            const struct abruby_method *to_s_m =
                abruby_find_method(AB_CLASS_OF(c, part), rb_intern("to_s"));
            if (to_s_m) {
                RESULT r = abruby_call_method(c, part, to_s_m, 0, NULL);
                if (UNLIKELY(r.state != RESULT_NORMAL)) return r;
                if (ab_obj_type_p(r.value, ABRUBY_OBJ_STRING)) {
                    rs = abruby_str_rstr(r.value);
                } else if (RB_TYPE_P(r.value, T_STRING)) {
                    rs = r.value;
                } else {
                    rs = rb_str_new_cstr("");
                }
            } else {
                rs = rb_str_new_cstr("");
            }
        }
        rb_str_cat(result, RSTRING_PTR(rs), RSTRING_LEN(rs));
    }
    return RESULT_OK(abruby_str_new(c, result));
}

NODE_DEF
node_sym(CTX * restrict c, NODE * restrict n, const char *str)
{
    extern VALUE abruby_sym_new(CTX *c, VALUE rb_sym);
    return RESULT_OK(abruby_sym_new(c, ID2SYM(rb_intern(str))));
}

extern VALUE abruby_range_new(CTX *c, VALUE begin, VALUE end, bool exclude_end);

NODE_DEF
node_range_new(CTX * restrict c, NODE * restrict n, NODE *begin_node, NODE *end_node, uint32_t exclude_end)
{
    VALUE b = UNWRAP(EVAL_ARG(c, begin_node));
    VALUE e = UNWRAP(EVAL_ARG(c, end_node));
    return RESULT_OK(abruby_range_new(c, b, e, exclude_end != 0));
}

extern VALUE abruby_regexp_new(CTX *c, VALUE rb_regexp);

NODE_DEF
node_regexp_new(CTX * restrict c, NODE * restrict n, const char *source, const char *flags)
{
    int options = 0;
    for (const char *p = flags; *p; p++) {
        if (*p == 'i') options |= 1;  // ONIG_OPTION_IGNORECASE
        if (*p == 'x') options |= 2;  // ONIG_OPTION_EXTEND
        if (*p == 'm') options |= 4;  // ONIG_OPTION_MULTILINE
    }
    VALUE src = rb_str_new_cstr(source);
    VALUE re = rb_reg_new(RSTRING_PTR(src), RSTRING_LEN(src), options);
    return RESULT_OK(abruby_regexp_new(c, re));
}

NODE_DEF
node_self(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(c->current_frame->self);
}

static RESULT
abruby_const_get(CTX *c, NODE *n, const struct abruby_class *klass, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(&klass->constants, name, &v))
        return RESULT_OK(v);
    VALUE exc;
    PUSH_FRAME(n);
    {
        VALUE m = rb_str_new_cstr("uninitialized constant ");
        rb_str_cat_cstr(m, rb_id2name(name));
        exc = abruby_exception_new(c, c->current_frame, m);
    }
    POP_FRAME();
    return (RESULT){exc, RESULT_RAISE};
}

NODE_DEF
node_const_path_get(CTX * restrict c, NODE * restrict n, ID parent_name, ID name)
{
    // Resolve `parent_name` via the same lexical/super chain we use for
    // bare constants — this is needed for `Outer::Inner` references where
    // `Outer` is a constant defined in an enclosing module.
    VALUE parent_v = Qundef;
    for (const struct abruby_cref *cr = ctx_cref(c); cr; cr = cr->outer) {
        for (const struct abruby_class *k = cr->klass; k; k = k->super) {
            if (ab_id_table_lookup(&k->constants, parent_name, &parent_v)) goto found;
        }
    }
    for (const struct abruby_class *k = c->current_class; k; k = k->super) {
        if (ab_id_table_lookup(&k->constants, parent_name, &parent_v)) goto found;
    }
    if (ab_id_table_lookup(&CTX_MAIN_CLASS(c)->constants, parent_name, &parent_v)) goto found;
    if (CTX_MAIN_CLASS(c) != c->abm->object_class &&
        ab_id_table_lookup(&c->abm->object_class->constants, parent_name, &parent_v)) goto found;
found:
    if (parent_v == Qundef || !RB_TYPE_P(parent_v, T_DATA)) {
        VALUE exc;
        PUSH_FRAME(n);
        VALUE m = rb_str_new_cstr("uninitialized constant ");
        rb_str_cat_cstr(m, rb_id2name(parent_name));
        exc = abruby_exception_new(c, c->current_frame, m);
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    struct abruby_header *h = (struct abruby_header *)ABRUBY_DATA_PTR(parent_v);
    // Accept anything that's a class/module value: per-instance
    // metaclasses (h->klass == class_class/module_class) AND the
    // self-referential singleton classes we use for File / Struct /
    // Process / Proc / Fiber / Method.
    bool is_class_value =
        h->klass == c->abm->class_class ||
        h->klass == c->abm->module_class ||
        h->klass == (struct abruby_class *)h;  // self-referential
    if (!is_class_value) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c, "constant path parent is not a class or module"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    return abruby_const_get(c, n, (struct abruby_class *)h, name);
}

NODE_DEF
node_const_set(CTX * restrict c, NODE * restrict n, ID name, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    struct abruby_class *scope = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    abruby_class_set_const(scope, name, v);
    return RESULT_OK(v);
}

NODE_DEF
node_const_get(CTX * restrict c, NODE * restrict n, ID name)
{
    VALUE v;
    // 1) Walk the lexical cref chain: for each enclosing class/module,
    //    check its own constants *and* its super chain.  This matches
    //    Ruby's bare-constant lookup semantics (lexical first, then
    //    inheritance).
    for (const struct abruby_cref *cr = ctx_cref(c); cr; cr = cr->outer) {
        for (const struct abruby_class *k = cr->klass; k; k = k->super) {
            if (ab_id_table_lookup(&k->constants, name, &v))
                return RESULT_OK(v);
        }
    }
    // 2) When no cref is active (top-level code, cfuncs), fall back to
    //    the current class's super chain so inherited class-body reads
    //    still work (e.g., `class B < A; MAPPER = A::MAPPER; end`).
    for (const struct abruby_class *k = c->current_class; k; k = k->super) {
        if (ab_id_table_lookup(&k->constants, name, &v))
            return RESULT_OK(v);
    }
    // 3) Top-level / main class constants.
    if (ab_id_table_lookup(&CTX_MAIN_CLASS(c)->constants, name, &v))
        return RESULT_OK(v);
    // 4) Object class constants (built-ins like Float::INFINITY source).
    if (CTX_MAIN_CLASS(c) != c->abm->object_class) {
        return abruby_const_get(c, n, c->abm->object_class, name);
    }
    VALUE exc;
    PUSH_FRAME(n);
    exc = abruby_exception_new(c, c->current_frame,
        abruby_str_new_cstr(c,"uninitialized constant"));
    POP_FRAME();
    return (RESULT){exc, RESULT_RAISE};
}

// === Array / Hash literals ===

NODE_DEF
node_ary_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE ary = rb_ary_new_from_values(argc, &c->current_frame->fp[arg_index]);
    return RESULT_OK(abruby_ary_new(c, ary));
}

// Convert abruby value to CRuby value for use as Hash key
static VALUE
ab_to_hash_key(VALUE v)
{
    if (RB_SPECIAL_CONST_P(v)) return v;
    const struct abruby_header *h = (const struct abruby_header *)ABRUBY_DATA_PTR(v);
    if (h->obj_type == ABRUBY_OBJ_STRING) return ((const struct abruby_string *)h)->rb_str;
    if (h->obj_type == ABRUBY_OBJ_ARRAY)  return ((const struct abruby_array *)h)->rb_ary;
    if (h->obj_type == ABRUBY_OBJ_SYMBOL) return ((const struct abruby_symbol *)h)->rb_sym;
    return v;
}

NODE_DEF
node_hash_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE hash = rb_hash_new();
    for (uint32_t i = 0; i < argc; i += 2) {
        rb_hash_aset(hash, ab_to_hash_key(c->current_frame->fp[arg_index + i]), c->current_frame->fp[arg_index + i + 1]);
    }
    return RESULT_OK(abruby_hash_new_wrap(c, hash));
}

// === Instance Variables ===

// node_ivar_get_slow moved to node_helper.c.

NODE_DEF
node_ivar_get(CTX * restrict c, NODE * restrict n, ID name, struct ivar_cache *ic@ref)
{
    ab_verify(c->current_frame->self);
    VALUE self = c->current_frame->self;
    // shape_id 0 is reserved for "unassigned": every abruby heap object
    // is stamped with shape_id >= 1 at allocation (abruby_heap_init_shape),
    // so a cold ic (shape_id == 0) automatically mismatches any real self
    // without an explicit != 0 test.
    if (LIKELY(ic->shape_id == abruby_shape_id_read(self))) {
        // shape match ⇒ slot is valid (ivar_cnt ≥ slot+1 by construction).
        const struct abruby_object *obj =
            (const struct abruby_object *)ABRUBY_DATA_PTR(self);
        if (LIKELY(ic->slot < ABRUBY_OBJECT_INLINE_IVARS)) {
            return RESULT_OK(obj->ivars[ic->slot]);
        }
        return RESULT_OK(obj->extra_ivars[ic->slot - ABRUBY_OBJECT_INLINE_IVARS]);
    }
    return RESULT_OK(node_ivar_get_slow(self, name, ic));
}

// node_ivar_set_slow moved to node_helper.c.

NODE_DEF
node_ivar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *value, struct ivar_cache *ic@ref)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    ab_verify(c->current_frame->self);
    VALUE self = c->current_frame->self;
    if (UNLIKELY(!RB_TYPE_P(self, T_DATA))) {
        rb_raise(rb_eRuntimeError, "can't set instance variable on non-object");
    }
    // Guard extra-strict against shape_id == 0: a cold cache (ic cleared
    // by alloc) matches self's 0 shape_id on non-abruby_object receivers,
    // misreading obj->ivars at arbitrary flag-bit positions.
    // Fast path covers two cases:
    //   (a) overwrite of an existing slot — pre_shape == post_shape, no
    //       transition; slot is already within obj->ivar_cnt so both the
    //       inline and overflow store positions are valid.
    //   (b) inline grow — pre != post, but slot < INLINE_IVARS, so the
    //       inline `ivars` array was already there; just update ivar_cnt
    //       and the shape_id.
    // An overflow grow (pre != post, slot >= INLINE) must go through the
    // slow path because extra_ivars may need to be allocated.
    if (LIKELY(ic->shape_id == abruby_shape_id_read(self))) {
        bool transition = (ic->shape_id != ic->post_shape_id);
        if (LIKELY(!(transition && ic->slot >= ABRUBY_OBJECT_INLINE_IVARS))) {
            struct abruby_object *obj =
                (struct abruby_object *)ABRUBY_DATA_PTR(self);
            if (LIKELY(ic->slot < ABRUBY_OBJECT_INLINE_IVARS)) {
                obj->ivars[ic->slot] = v;
            } else {
                obj->extra_ivars[ic->slot - ABRUBY_OBJECT_INLINE_IVARS] = v;
            }
            if (UNLIKELY(transition)) {
                if (obj->ivar_cnt < ic->slot + 1) obj->ivar_cnt = ic->slot + 1;
                abruby_shape_id_write(self, ic->post_shape_id);
            }
            return RESULT_OK(v);
        }
    }
    node_ivar_set_slow(c, self, name, v, ic);
    return RESULT_OK(v);
}

// === Global Variables ===

static VALUE
abruby_gvar_get(CTX *c, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(CTX_GVARS(c), name, &v)) return v;
    return Qnil;
}

static void
abruby_gvar_set(CTX *c, ID name, VALUE val)
{
    ab_id_table_insert(CTX_GVARS(c), name, val);
}

NODE_DEF
node_gvar_get(CTX * restrict c, NODE * restrict n, ID name)
{
    return RESULT_OK(abruby_gvar_get(c, name));
}

NODE_DEF
node_gvar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    abruby_gvar_set(c, name, v);
    return RESULT_OK(v);
}

// === Local Variables ===

NODE_DEF
node_lvar_get(CTX * restrict c, NODE * restrict n, uint32_t index)
{
    return RESULT_OK(c->current_frame->fp[index]);
}

NODE_DEF
node_lvar_set(CTX * restrict c, NODE * restrict n, uint32_t index, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    c->current_frame->fp[index] = v;
    return RESULT_OK(v);
}

// === Control Flow ===

NODE_DEF
node_scope(CTX * restrict c, NODE * restrict n, uint32_t envsize, NODE *body)
{
    c->current_frame->fp += envsize;
    ABRUBY_ASSERT(c->current_frame->fp + envsize <= c->stack + ABRUBY_STACK_SIZE);
    // Zero-fill all slots so GC sees valid VALUEs within stack_limit.
    for (uint32_t i = 0; i < envsize; i++) c->current_frame->fp[i] = Qnil;
    // Set stack_limit on the entry for GC frame-walk.
    ((struct abruby_entry *)c->current_frame->entry)->stack_limit = envsize;
    RESULT r = EVAL_ARG(c, body);
    c->current_frame->fp -= envsize;
    return r;
}

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, NODE *head, NODE *tail)
{
    UNWRAP(EVAL_ARG(c, head));
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_not(CTX * restrict c, NODE * restrict n, NODE *expr)
{
    return RESULT_OK(RTEST(UNWRAP(EVAL_ARG(c, expr))) ? Qfalse : Qtrue);
}

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *then_node, NODE *else_node)
{
    if (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    while (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        RESULT r = EVAL_ARG(c, body);
        if (UNLIKELY(r.state != RESULT_NORMAL)) {
            if (r.state == RESULT_BREAK) return RESULT_OK(r.value);
            return r;
        }
    }
    return RESULT_OK(Qnil);
}

NODE_DEF
node_break(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_BREAK};
}

// === Non-local exit ===

NODE_DEF
node_return(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    // Non-local return encoding:
    //   - Plain `return` from a method body (not in a block): skip count = 0
    //     → caught at the nearest method boundary.  Zero-cost for the
    //     common case: no CTX writes, no frame walks.
    //   - `return` inside a block body: walk from c->current_frame up to
    //     c->current_block->defining_frame and count the intervening method
    //     frames.  That count is the skip count — each method boundary on
    //     the way up decrements it, and only the frame with skip == 0
    //     catches.  The walk is O(nesting depth) and happens only on this
    //     rare exceptional path, not on every frame push.
    unsigned int state = RESULT_RETURN;
    if (UNLIKELY(abruby_in_block(c))) {
        const struct abruby_frame *target = c->current_block->defining_frame;
        unsigned int skip = 0;
        for (const struct abruby_frame *f = c->current_frame;
             f != target; f = f->prev) {
            skip++;
        }
        state |= (skip << RESULT_SKIP_SHIFT);
    }
    return (RESULT){v, state};
}

// `next` inside a block returns (value) to the yielding call site, which
// demotes NEXT back to NORMAL with that value.  Outside a block this still
// propagates RESULT_NEXT; there is no enclosing catcher, so a LocalJumpError
// is the intended Ruby behavior.  In MVP we leave that to fall out naturally.
NODE_DEF
node_next(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_NEXT};
}

// Materialise the implicit block of the current method as a Proc and
// store it in the named local slot.  Emitted by the parser at the
// start of methods that have a `&blk` parameter.  When no block was
// passed, the slot gets nil.  See builtin/proc.c::abruby_block_to_proc
// for the actual heap conversion.
extern VALUE abruby_block_to_proc(CTX *c, const struct abruby_block *blk, bool is_lambda);

NODE_DEF
node_block_param(CTX * restrict c, NODE * restrict n, uint32_t lvar_index)
{
    (void)n;
    const struct abruby_block *blk = c->current_frame ? c->current_frame->block : NULL;
    if (blk == NULL) {
        c->current_frame->fp[lvar_index] = Qnil;
    } else {
        c->current_frame->fp[lvar_index] = abruby_block_to_proc(c, blk, /*is_lambda=*/false);
    }
    return RESULT_OK(c->current_frame->fp[lvar_index]);
}

// Data-only node carrying a block literal attached to a call site.  Parser
// emits it as the `block_literal` operand of a node_*_call_with_block; the
// call node unpacks `body`, `params_cnt`, `param_base` directly from the
// NODE union at dispatch time.  It should never be dispatched on its own;
// the @noinline annotation keeps it out of specialization, and the body is
// a safety net that returns nil (asserting in debug builds).
NODE_DEF @noinline
node_block_literal(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t params_cnt, uint32_t param_base, uint32_t env_size)
{
    (void)c; (void)body; (void)params_cnt; (void)param_base; (void)env_size;
    ABRUBY_ASSERT(!"node_block_literal must not be EVAL'd directly");
    (void)n;
    return RESULT_OK(Qnil);
}

// Block argument data node: wraps the `&expr` form. The call dispatch reads
// `expr` and evaluates it to a Proc, then converts via build_block_from_proc_value.
// Like node_block_literal, this is a data node — never EVAL'd directly.
NODE_DEF @noinline
node_block_arg(CTX * restrict c, NODE * restrict n, NODE *expr)
{
    (void)c; (void)expr;
    ABRUBY_ASSERT(!"node_block_arg must not be EVAL'd directly");
    (void)n;
    return RESULT_OK(Qnil);
}

// `yield args` from within an AST method body.
// Looks up the block attached to the current frame, transfers argc values
// into the block's captured frame at param_base, swaps the execution context
// into the block (fp/self/current_block/current_block_frame), evaluates the block body,
// then restores the swapped state.  NEXT is demoted to NORMAL here so `next`
// returns from the block cleanly; BREAK / RAISE / RETURN keep propagating.
NODE_DEF
node_yield(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    // The block to yield to is the one attached to the lexically enclosing
    // method frame.  When executing inside a block body a nested `yield` must
    // reach the *outer* block — i.e. the block received by the defining
    // method of the currently-executing block, not the block received by the
    // physical yielding method.  abruby_context_frame() returns that lexical
    // enclosing frame (physical current_frame outside blocks, defining_frame
    // of the current block inside blocks).
    const struct abruby_block *blk = abruby_context_frame(c)->block;
    if (UNLIKELY(blk == NULL)) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c, "no block given (yield)"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }

    // Transfer args into the block's captured fp at param_base.
    // Ruby proc-style semantics (yield / proc, NOT lambda):
    //   - Missing args default to nil.
    //   - Extra args are dropped.
    //   - **Implicit array destructuring**: if the block declares 2+
    //     required params and exactly one argument is yielded, and that
    //     argument is an Array, splat it.  So
    //       def f; yield [1, 2]; end
    //       f { |a, b| ... }
    //     binds a=1, b=2 (not a=[1,2], b=nil).  Single-param blocks and
    //     multi-arg yields skip this path.
    uint32_t n_params = blk->params_cnt;
    VALUE * restrict dst = blk->captured_fp + blk->param_base;
    const VALUE *src = c->current_frame->fp + arg_index;
    if (n_params >= 2 && argc == 1 &&
            AB_CLASS_OF(c, src[0]) == c->abm->array_class) {
        VALUE rb_ary = RARY(src[0]);
        long len = RARRAY_LEN(rb_ary);
        uint32_t n_copy = ((unsigned long)len < n_params) ? (uint32_t)len : n_params;
        for (uint32_t i = 0; i < n_copy; i++) {
            dst[i] = RARRAY_AREF(rb_ary, i);
        }
        for (uint32_t i = n_copy; i < n_params; i++) {
            dst[i] = Qnil;
        }
    }
    else {
        uint32_t n_copy = argc < n_params ? argc : n_params;
        for (uint32_t i = 0; i < n_copy; i++) {
            dst[i] = src[i];
        }
        for (uint32_t i = n_copy; i < n_params; i++) {
            dst[i] = Qnil;
        }
    }

    // Swap closure environment (fp / self) and block-execution markers.
    // current_frame is NOT swapped — it stays pointing at the physical
    // yielding method's frame so the call stack chain linked through
    // frame->prev remains the real chain.  This is load-bearing for
    // non-local return skip counting: node_return walks current_frame up
    // to current_block->defining_frame and expects the walk length to
    // equal the number of method boundaries the RETURN has to cross.
    //
    // current_block_frame is set to c->current_frame so that
    // abruby_in_block(c) returns true while we're evaluating the block
    // body but flips to false the moment a callee method pushes a new
    // physical frame — giving that callee its own non-block context.
    VALUE *save_fp = c->current_frame->fp;
    VALUE save_self = c->current_frame->self;
    const struct abruby_entry *save_entry = c->current_frame->entry;
    const struct abruby_block *save_current_block = c->current_block;
    const struct abruby_frame *save_current_block_frame = c->current_block_frame;

    // Install a synthetic entry carrying the block's captured cref so
    // constant lookups inside the block body walk the lexical scope chain
    // active at block-literal creation, not the yielding method's chain.
    struct abruby_entry blk_entry = {blk->cref, NULL, NULL, blk->env_size};
    c->current_frame->fp = blk->captured_fp;
    c->current_frame->self = blk->captured_self;
    c->current_frame->entry = &blk_entry;
    c->current_block = blk;
    c->current_block_frame = c->current_frame;


    RESULT r = EVAL(c, blk->body);

    c->current_frame->fp = save_fp;
    c->current_frame->self = save_self;
    c->current_frame->entry = save_entry;
    c->current_block = save_current_block;
    c->current_block_frame = save_current_block_frame;

    // Demote NEXT → NORMAL (value retained).  BREAK / RAISE / RETURN
    // pass through for upper-layer catches.
    r.state &= ~(unsigned)RESULT_NEXT;
    return r;
}

NODE_DEF
node_rescue(CTX * restrict c, NODE * restrict n, NODE *body, NODE *rescue_body, NODE *ensure_body, uint32_t exception_lvar_index)
{
    RESULT r = EVAL_ARG(c, body);

    if (r.state == RESULT_RAISE && exception_lvar_index != 0xFFFFFFFEu) {
        if (exception_lvar_index != UINT32_MAX) {
            c->current_frame->fp[exception_lvar_index] = r.value;
        }
        r = EVAL_ARG(c, rescue_body);
    }

    // ensure: always run; raise/return in ensure overrides original
    RESULT er = EVAL_ARG(c, ensure_body);
    if (er.state != RESULT_NORMAL) return er;

    return r;
}

// === Method definition & call ===

NODE_DEF @noinline
node_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body, uint32_t required_params_cnt, uint32_t params_cnt, uint32_t post_params_cnt, int32_t rest_index, uint32_t locals_cnt)
{
    struct abruby_class *klass = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    const char *file = NULL;
    if (c->current_frame) {
        if (c->current_frame->entry)
            file = c->current_frame->entry->source_file;
    }
    // Build opt_pc table by walking the default-assignment seq chain.
    unsigned int n_opt = params_cnt - required_params_cnt;
    struct Node **opt_pc = NULL;
    if (n_opt > 0) {
        opt_pc = ruby_xmalloc(sizeof(struct Node *) * (n_opt + 1));
        struct Node *cur = body;
        for (unsigned int i = 0; i < n_opt; i++) {
            opt_pc[i] = cur;
            cur = cur->u.node_seq.tail;
        }
        opt_pc[n_opt] = cur;
        body = cur;
    }
    abruby_class_add_method(c, klass, name, body, required_params_cnt, params_cnt,
                            post_params_cnt, (int)rest_index, opt_pc, locals_cnt, file);
    return RESULT_OK(Qnil);
}

// === OOP: class, method call with receiver, new ===

NODE_DEF @noinline
node_module_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body)
{
    // Look for an existing module with this name.  Same scope walk as node_class_def.
    struct abruby_class *outer = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    VALUE existing_v;
    struct abruby_class *mod = NULL;
    for (const struct abruby_class *scope = outer; scope; scope = scope->super) {
        if (ab_id_table_lookup(&scope->constants, name, &existing_v) && RB_TYPE_P(existing_v, T_DATA)) {
            struct abruby_header *h = (struct abruby_header *)ABRUBY_DATA_PTR(existing_v);
            if (h->klass == c->abm->module_class || h->klass == c->abm->class_class) {
                mod = (struct abruby_class *)h;
                break;
            }
        }
    }
    if (!mod && ab_id_table_lookup(&c->abm->object_class->constants, name, &existing_v) && RB_TYPE_P(existing_v, T_DATA)) {
        struct abruby_header *h = (struct abruby_header *)ABRUBY_DATA_PTR(existing_v);
        if (h->klass == c->abm->module_class || h->klass == c->abm->class_class) {
            mod = (struct abruby_class *)h;
        }
    }
    if (!mod) {
        mod = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        mod->klass = c->abm->module_class;
        mod->obj_type = ABRUBY_OBJ_MODULE;
        mod->instance_obj_type = ABRUBY_OBJ_GENERIC; // modules have no direct instances
        mod->name = name;
        mod->super = NULL;
        // Register on the enclosing class/module so `Outer::Inner` resolves.
        abruby_class_set_const(outer, name, abruby_wrap_class(mod));
        // Also expose at the top level when at file scope so `Inner` works
        // bare from main code paths that don't carry a cref.
        if (outer == CTX_MAIN_CLASS(c)) {
            // already on main; no-op
        }
    }

    // Heap-allocated cref — AST method bodies defined inside this module
    // capture it (via abruby_class_add_method) and reuse it at invocation.
    struct abruby_cref *mod_cref = (struct abruby_cref *)ruby_xcalloc(1, sizeof(struct abruby_cref));
    *(struct abruby_class **)&mod_cref->klass = mod;
    *(const struct abruby_cref **)&mod_cref->outer = ctx_cref(c);

    struct abruby_entry mod_entry = {mod_cref, NULL, NULL, 0};
    struct abruby_class *save_class = c->current_class;
    struct abruby_frame mod_frame;
    mod_frame.prev = c->current_frame;
    mod_frame.caller_node = n;
    mod_frame.block = NULL;
    mod_frame.self = abruby_wrap_class(mod);
    mod_frame.fp = c->current_frame->fp;
    mod_frame.entry = &mod_entry;
    c->current_frame = &mod_frame;
    c->current_class = mod;

    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->current_frame = mod_frame.prev;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(mod));
}

NODE_DEF @noinline
node_class_def(CTX * restrict c, NODE * restrict n, ID name, NODE *super_expr, NODE *body)
{
    // Look for an existing class with this name in the enclosing scope.
    // Walk from `outer` up through the super chain and fall back to
    // object_class, so that built-in classes registered on object_class
    // (Integer, String, etc.) are found when reopened at top level.
    struct abruby_class *outer = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    VALUE existing_v;
    struct abruby_class *klass = NULL;
    for (const struct abruby_class *scope = outer; scope; scope = scope->super) {
        if (ab_id_table_lookup(&scope->constants, name, &existing_v) && RB_TYPE_P(existing_v, T_DATA)) {
            struct abruby_header *h = (struct abruby_header *)ABRUBY_DATA_PTR(existing_v);
            if (h->klass == c->abm->class_class || h->klass == c->abm->module_class) {
                klass = (struct abruby_class *)h;
                break;
            }
        }
    }
    // Also check object_class directly (built-in classes are registered there).
    if (!klass && ab_id_table_lookup(&c->abm->object_class->constants, name, &existing_v) && RB_TYPE_P(existing_v, T_DATA)) {
        struct abruby_header *h = (struct abruby_header *)ABRUBY_DATA_PTR(existing_v);
        if (h->klass == c->abm->class_class || h->klass == c->abm->module_class) {
            klass = (struct abruby_class *)h;
        }
    }
    if (!klass) {
        struct abruby_class *super = c->abm->object_class;
        VALUE sv = UNWRAP(EVAL_ARG(c, super_expr));
        if (sv != Qnil) {
            if (AB_CLASS_OF(c, sv) != c->abm->class_class) {
                VALUE exc;
                PUSH_FRAME(n);
                exc = abruby_exception_new(c, c->current_frame,
                    abruby_str_new_cstr(c,"superclass must be a Class"));
                POP_FRAME();
                return (RESULT){exc, RESULT_RAISE};
            }
            super = abruby_unwrap_class(sv);
        }
        klass = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        klass->klass = c->abm->class_class;
        klass->obj_type = ABRUBY_OBJ_CLASS;              // this is a class struct
        klass->instance_obj_type = ABRUBY_OBJ_GENERIC;  // instances are user objects
        klass->name = name;
        klass->super = super;
        // Register on the enclosing scope (current_class or main).  When
        // nested in a module/class, the constant lives there and is
        // reached via `Outer::Name` or via cref-based lookup from inside
        // the enclosing body.
        abruby_class_set_const(outer, name, abruby_wrap_class(klass));
    }

    struct abruby_cref *cls_cref = (struct abruby_cref *)ruby_xcalloc(1, sizeof(struct abruby_cref));
    *(struct abruby_class **)&cls_cref->klass = klass;
    *(const struct abruby_cref **)&cls_cref->outer = ctx_cref(c);

    struct abruby_entry cls_entry = {cls_cref, NULL, NULL, 0};
    struct abruby_class *save_class = c->current_class;
    struct abruby_frame cls_frame;
    cls_frame.prev = c->current_frame;
    cls_frame.caller_node = n;
    cls_frame.block = NULL;
    cls_frame.self = abruby_wrap_class(klass);
    cls_frame.fp = c->current_frame->fp;
    cls_frame.entry = &cls_entry;
    c->current_frame = &cls_frame;
    c->current_class = klass;

    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->current_frame = cls_frame.prev;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(klass));
}


// Forward declarations of prologue functions (defined below).
// Most prologues are `inline __attribute__((always_inline))` so that
// specialized call dispatchers (node_call1_ast, etc., added later in this
// file) can directly call them and get them fully inlined at the call site.
// ast_complex is the one exception — kept out-of-line because its body is
// large (dispatch_setup_args + opt_pc entry selection) and would bloat code
// if inlined at every complex call site.
#define DECL_PROLOGUE_INLINE(name) \
    static inline __attribute__((always_inline, no_stack_protector)) RESULT \
    name(CTX *c, NODE *call_site, \
        const struct method_cache *mc, VALUE recv_self, \
        unsigned int argc, uint32_t arg_index)

DECL_PROLOGUE_INLINE(prologue_ast_simple_0);
DECL_PROLOGUE_INLINE(prologue_ast_simple_1);
DECL_PROLOGUE_INLINE(prologue_ast_simple_2);
DECL_PROLOGUE_INLINE(prologue_ast_simple_n);
DECL_PROLOGUE_INLINE(prologue_cfunc);
DECL_PROLOGUE_INLINE(prologue_ivar_getter);
DECL_PROLOGUE_INLINE(prologue_ivar_setter);
#undef DECL_PROLOGUE_INLINE

static __attribute__((no_stack_protector)) RESULT prologue_ast_complex(CTX *c, NODE *call_site,
    const struct method_cache *mc, VALUE recv_self,
    unsigned int argc, uint32_t arg_index);

// Populate cached fields in method_cache.
//
// argc: the caller's argument count at the point of cache fill.  Used to
//       pick between the "simple" (no-check) prologue and the "complex"
//       (checks via dispatch_setup_args) prologue for AST methods.
// static_argc: true when the caller's argc is statically determined by the
//       call-site's node kind (node_call0/1/2, node_call with fixed argc).
//       For splat-based sites (node_apply_call) argc varies across calls
//       with the same cache, so we can't rely on the one-shot fill-time
//       check — always install the checking prologue (complex path).
static inline void
method_cache_fill(CTX *c, struct method_cache *mc, const struct abruby_class *klass,
                  const struct abruby_method *method,
                  unsigned int argc, bool static_argc)
{
    // Remember previous prologue kind so we can detect POLY (prologue
    // transition) after writing the new one.  PROLOGUE_KIND_NONE (zero,
    // from xcalloc or memset) means "never filled" — not a POLY transition.
    uint8_t prev_kind = mc->prologue_kind;
    uint8_t new_kind;

    mc->klass = klass;
    mc->method = method;
    mc->serial = c->abm->method_serial;
    mc->ivar_slot = 0;
    if (method->type == ABRUBY_METHOD_AST) {
        mc->body = method->u.ast.body;
        mc->dispatcher = method->u.ast.body->head.dispatcher;
        unsigned int req = method->u.ast.required_params_cnt;
        bool is_simple_shape =
            (method->u.ast.params_cnt == req &&
             method->u.ast.rest_index < 0 &&
             method->u.ast.post_params_cnt == 0);
        if (is_simple_shape && static_argc && argc == req) {
            // Simple shape: argc-specialized variants for req=0/1/2, generic for >=3.
            // The check moved to cache fill time — prologues skip it.
            switch (req) {
              case 0:  mc->prologue = prologue_ast_simple_0; new_kind = PROLOGUE_KIND_AST_SIMPLE_0; break;
              case 1:  mc->prologue = prologue_ast_simple_1; new_kind = PROLOGUE_KIND_AST_SIMPLE_1; break;
              case 2:  mc->prologue = prologue_ast_simple_2; new_kind = PROLOGUE_KIND_AST_SIMPLE_2; break;
              default: mc->prologue = prologue_ast_simple_n; new_kind = PROLOGUE_KIND_AST_SIMPLE_N; break;
            }
        } else {
            // opt/rest/post or dynamic argc (splat) — full validation path.
            mc->prologue = prologue_ast_complex;
            new_kind = PROLOGUE_KIND_AST_COMPLEX;
        }
    } else if (method->type == ABRUBY_METHOD_IVAR_GETTER) {
        mc->body = NULL;
        mc->dispatcher = NULL;
        mc->prologue = prologue_ivar_getter;
        new_kind = PROLOGUE_KIND_IVAR_GETTER;
        // Resolve (or register) the ivar's slot in the receiver's class shape.
        struct abruby_class *klass_mut = (struct abruby_class *)klass;
        ID ivar_name = method->u.ivar_accessor.ivar_name;
        VALUE slot_fix;
        if (ab_id_table_lookup(&klass_mut->ivar_shape, ivar_name, &slot_fix)) {
            mc->ivar_slot = (uint32_t)FIX2ULONG(slot_fix);
        } else {
            uint32_t new_slot = klass_mut->ivar_shape.cnt;
            ab_id_table_insert(&klass_mut->ivar_shape, ivar_name, LONG2FIX((long)new_slot));
            mc->ivar_slot = new_slot;
        }
    } else if (method->type == ABRUBY_METHOD_IVAR_SETTER) {
        mc->body = NULL;
        mc->dispatcher = NULL;
        mc->prologue = prologue_ivar_setter;
        new_kind = PROLOGUE_KIND_IVAR_SETTER;
        // Resolve (or register) the ivar's slot in the receiver's class shape.
        struct abruby_class *klass_mut = (struct abruby_class *)klass;
        ID ivar_name = method->u.ivar_accessor.ivar_name;
        VALUE slot_fix;
        if (ab_id_table_lookup(&klass_mut->ivar_shape, ivar_name, &slot_fix)) {
            mc->ivar_slot = (uint32_t)FIX2ULONG(slot_fix);
        } else {
            uint32_t new_slot = klass_mut->ivar_shape.cnt;
            ab_id_table_insert(&klass_mut->ivar_shape, ivar_name, LONG2FIX((long)new_slot));
            mc->ivar_slot = new_slot;
        }
    } else {
        // CFUNC
        mc->body = NULL;
        mc->dispatcher = NULL;
        mc->prologue = prologue_cfunc;
        new_kind = PROLOGUE_KIND_CFUNC;
    }
    mc->prologue_kind = new_kind;

    // Track prologue POLY: if we just overwrote a previously-set kind with
    // a different one, this site is polymorphic-in-prologue and the PGO
    // specializer must not bake the prologue here.  Sticky bit.
    if (prev_kind != PROLOGUE_KIND_NONE && prev_kind != new_kind) {
        mc->flags |= MC_PROLOGUE_POLY;
    }
}

// raise_argc_error moved to node_helper.c (see node.h prototype).

// Max post params supported (for stack-allocated save buffer).
// Real Ruby code rarely exceeds 2-3 post params; 16 is a safe upper bound.
#define ABRUBY_MAX_POST_PARAMS 16

// Set up fp for AST method invocation: handle rest array building and
// post parameter placement.  Returns 0 on success, or stores exception
// in *err_r and returns -1 on argc error.
//
// Layout after setup:
//   fp[0..pre_num-1]            : pre required params (caller-placed)
//   fp[pre_num..pre_num+opt_num-1] : optional slots (some from caller, rest from opt_pc)
//   fp[rest_index]              : rest array (if has_rest)
//   fp[post_start..]            : post required params (relocated from end of argv)
//
// Returns the opt_idx (how many optionals were filled from argv).
static inline int
dispatch_setup_args(CTX * restrict c, NODE * restrict call_site,
                    const struct method_cache *mc,
                    unsigned int argc, uint32_t arg_index,
                    RESULT *err_r)
{
    unsigned int pre_num = mc->method->u.ast.required_params_cnt;
    unsigned int max_opt = mc->method->u.ast.params_cnt;  // pre + opt
    unsigned int opt_num = max_opt - pre_num;
    unsigned int post_num = mc->method->u.ast.post_params_cnt;
    int rest_idx = mc->method->u.ast.rest_index;
    bool has_rest = (rest_idx >= 0);

    unsigned int min_args = pre_num + post_num;
    unsigned int max_args = pre_num + opt_num + post_num;

    if (UNLIKELY(argc < min_args || (!has_rest && argc > max_args))) {
        *err_r = raise_argc_error(c, call_site, argc, min_args, max_args, has_rest);
        return -1;
    }

    c->current_frame->fp = c->current_frame->prev->fp + arg_index;

    // Save post params from the end of argv (before we overwrite them).
    VALUE post_vals[ABRUBY_MAX_POST_PARAMS];
    if (UNLIKELY(post_num > ABRUBY_MAX_POST_PARAMS)) {
        // Extremely unlikely; fail safely.
        *err_r = raise_argc_error(c, call_site, argc, min_args, max_args, has_rest);
        return -1;
    }
    for (unsigned int i = 0; i < post_num; i++)
        post_vals[i] = c->current_frame->fp[argc - post_num + i];

    // How many optionals are filled from argv.
    unsigned int non_post_argc = argc - post_num;
    unsigned int opt_filled = (non_post_argc > pre_num) ? (non_post_argc - pre_num) : 0;
    if (opt_filled > opt_num) opt_filled = opt_num;

    // Build rest array if has_rest.
    unsigned int rest_count = non_post_argc - pre_num - opt_filled;
    if (has_rest) {
        VALUE rb_rest = rb_ary_new_capa((long)rest_count);
        for (unsigned int i = 0; i < rest_count; i++)
            rb_ary_push(rb_rest, c->current_frame->fp[pre_num + opt_filled + i]);
        c->current_frame->fp[rest_idx] = abruby_ary_new(c, rb_rest);
    }

    // Write post params to their slots.
    unsigned int post_start = has_rest ? (unsigned int)(rest_idx + 1)
                                       : pre_num + opt_num;
    for (unsigned int i = 0; i < post_num; i++)
        c->current_frame->fp[post_start + i] = post_vals[i];

    // Update sp to cover all written slots.
    unsigned int frame_top = post_start + post_num;
    if (max_opt > frame_top) frame_top = max_opt;  // opt slots may exceed post

    return (int)opt_filled;
}

// Inner dispatch using cached method_cache.
// Does NOT save/restore c->current_frame->self — caller is responsible.
// Cache hit paths call this directly; non-cache paths go through dispatch_method_with_klass.
//
// NOTE: mc->prologue / mc->prologue_blk are populated by method_cache_fill
// and ready for direct use, but this function keeps the inline mtype switch
// for interpreter performance.  The indirect call through mc->prologue would
// defeat gcc's inlining of the method-type-specific code at each call site.
// When PG specialize makes the prologue pointer a compile-time constant,
// call sites can switch to mc->prologue(c, n, mc, argc, arg_index) directly.
// ===================================================================
// Method-type-specialized prologue functions.
// method_cache_fill selects one and stores in mc->prologue.
// dispatch_method_frame just calls mc->prologue — no runtime type checks.
// ===================================================================

// --- Return-value demotion at method boundary ---
// Method boundary absorbs RESULT_RETURN at skip=0; decrements otherwise.
static inline void
demote_return_at_method_boundary(RESULT *r)
{
    if (LIKELY(r->state == 0)) return;
    if (r->state & RESULT_RETURN) {
        if ((r->state & RESULT_SKIP_MASK) == 0) {
            r->state &= ~(unsigned)RESULT_RETURN_CATCH_MASK;
        } else {
            r->state -= RESULT_SKIP_UNIT;
        }
    }
}

// --- AST simple prologues (argc precondition: argc == REQ) ---
// Hot path: most user-defined methods fall here.  PRECONDITION: argc has
// already been validated at method_cache_fill time — prologues are installed
// only when argc == required_params_cnt, so no runtime argc check.
//
// REQ is a compile-time constant for _0/_1/_2 (0, 1, 2) enabling the
// compiler to fold (fp + REQ) and remove the req load from mc->method.
// _n handles req >= 3 by reading mc->method.

#define DEFINE_AST_SIMPLE_PROLOGUE(name, req_expr) \
static inline __attribute__((always_inline)) RESULT \
name(CTX * restrict c, NODE * restrict call_site, \
     const struct method_cache *mc, VALUE recv_self, \
     unsigned int argc, uint32_t arg_index) \
{ \
    (void)argc;  /* argc precondition enforced at cache fill */ \
    (void)(req_expr); \
    struct abruby_frame frame; \
    frame.prev = c->current_frame; \
    frame.caller_node = call_site; \
    frame.block = NULL; \
    frame.self = recv_self; \
    frame.fp = c->current_frame->fp + arg_index; \
    frame.entry = &mc->method->entry; \
    c->current_frame = &frame; \
    /* Zero-fill locals+temps beyond params so GC sees valid VALUEs. */ \
    RESULT r = mc->dispatcher(c, mc->body); \
    demote_return_at_method_boundary(&r); \
    c->current_frame = frame.prev; \
    return r; \
}

DEFINE_AST_SIMPLE_PROLOGUE(prologue_ast_simple_0, 0)
DEFINE_AST_SIMPLE_PROLOGUE(prologue_ast_simple_1, 1)
DEFINE_AST_SIMPLE_PROLOGUE(prologue_ast_simple_2, 2)
DEFINE_AST_SIMPLE_PROLOGUE(prologue_ast_simple_n,
    mc->method->u.ast.required_params_cnt)

// --- AST complex prologue (opt/rest/post or dynamic argc) ---
// argc validation is handled by dispatch_setup_args.
static RESULT
prologue_ast_complex(CTX * restrict c, NODE * restrict call_site,
                     const struct method_cache *mc, VALUE recv_self,
                     unsigned int argc, uint32_t arg_index)
{
    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.caller_node = call_site;
    frame.block = NULL;
    frame.self = recv_self;
    frame.fp = c->current_frame->fp;
    frame.entry = &mc->method->entry;
    c->current_frame = &frame;

    RESULT err_r;
    int opt_idx = dispatch_setup_args(c, call_site, mc, argc, arg_index, &err_r);
    if (UNLIKELY(opt_idx < 0)) {
        c->current_frame = frame.prev;
        return err_r;
    }
    unsigned int req = mc->method->u.ast.required_params_cnt;
    unsigned int opt_num = mc->method->u.ast.params_cnt - req;
    RESULT r;
    if (LIKELY((unsigned int)opt_idx >= opt_num || !mc->method->u.ast.opt_pc)) {
        r = mc->dispatcher(c, mc->body);
    } else {
        NODE *entry = mc->method->u.ast.opt_pc[opt_idx];
        r = EVAL(c, entry);
    }
    demote_return_at_method_boundary(&r);
    c->current_frame = frame.prev;
    return r;
}

// --- CFUNC prologue ---
static inline __attribute__((always_inline)) RESULT
prologue_cfunc(CTX * restrict c, NODE * restrict call_site,
               const struct method_cache *mc, VALUE recv_self,
               unsigned int argc, uint32_t arg_index)
{
    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.caller_node = call_site;
    frame.block = NULL;
    frame.self = recv_self;
    frame.fp = c->current_frame->fp;
    // cfunc method's entry carries the method pointer for backtrace.
    // stack_limit = 0 (set by xcalloc) so GC marks nothing for this frame.
    frame.entry = &mc->method->entry;
    c->current_frame = &frame;

    RESULT r = mc->method->u.cfunc.func(c, recv_self, argc, frame.fp + arg_index);
    demote_return_at_method_boundary(&r);
    c->current_frame = frame.prev;
    return r;
}

// --- prologue_ivar_getter / prologue_ivar_setter: attr_reader/writer ---
// No frame push — ivar access is a pure load/store with the caller's frame.
static inline __attribute__((always_inline)) RESULT
prologue_ivar_getter(CTX * restrict c, NODE * restrict call_site,
                     const struct method_cache *mc, VALUE recv_self,
                     unsigned int argc, uint32_t arg_index)
{
    (void)arg_index;
    if (UNLIKELY(argc != 0))
        return raise_argc_error(c, call_site, argc, 0, 0, false);
    const struct abruby_object *obj =
        (const struct abruby_object *)ABRUBY_DATA_PTR(recv_self);
    unsigned int slot;
    if (LIKELY(mc->klass == obj->klass)) {
        slot = mc->ivar_slot;
    } else {
        VALUE slot_fix;
        if (!ab_id_table_lookup(&obj->klass->ivar_shape,
                                mc->method->u.ivar_accessor.ivar_name, &slot_fix)) {
            return RESULT_OK(Qnil);
        }
        slot = (unsigned int)FIX2ULONG(slot_fix);
    }
    if (LIKELY(slot < obj->ivar_cnt)) {
        return RESULT_OK(abruby_object_ivar_read(obj, slot));
    }
    return RESULT_OK(Qnil);
}

static inline __attribute__((always_inline)) RESULT
prologue_ivar_setter(CTX * restrict c, NODE * restrict call_site,
                     const struct method_cache *mc, VALUE recv_self,
                     unsigned int argc, uint32_t arg_index)
{
    if (UNLIKELY(argc != 1))
        return raise_argc_error(c, call_site, argc, 1, 1, false);
    struct abruby_object *obj =
        (struct abruby_object *)ABRUBY_DATA_PTR(recv_self);
    VALUE v = c->current_frame->fp[arg_index];
    unsigned int slot;
    if (LIKELY(mc->klass == obj->klass)) {
        slot = mc->ivar_slot;
    } else {
        struct abruby_class *obj_klass = obj->klass;
        ID ivar_name = mc->method->u.ivar_accessor.ivar_name;
        VALUE slot_fix;
        if (ab_id_table_lookup(&obj_klass->ivar_shape, ivar_name, &slot_fix)) {
            slot = (unsigned int)FIX2ULONG(slot_fix);
        } else {
            slot = obj_klass->ivar_shape.cnt;
            ab_id_table_insert(&obj_klass->ivar_shape, ivar_name, LONG2FIX((long)slot));
        }
    }
    if (slot >= obj->ivar_cnt) {
        abruby_object_grow_ivars(obj, slot + 1);
        // shape transitions on ivar_cnt growth.
        abruby_shape_id_write(recv_self,
            abruby_shape_for(c->abm, obj->klass, obj->ivar_cnt));
    }
    if (LIKELY(slot < ABRUBY_OBJECT_INLINE_IVARS)) {
        obj->ivars[slot] = v;
    } else {
        obj->extra_ivars[slot - ABRUBY_OBJECT_INLINE_IVARS] = v;
    }
    return RESULT_OK(v);
}

// dispatch_method_frame: single indirect call to the pre-selected prologue.
// No runtime method-type branching — all decided at method_cache_fill time.
static inline RESULT
dispatch_method_frame(CTX * restrict c, NODE * restrict call_site,
                      const struct method_cache *mc, VALUE recv_self,
                      unsigned int argc, uint32_t arg_index)
{
    return mc->prologue(c, call_site, mc, recv_self, argc, arg_index);
}

// ---------------------------------------------------------------------------
// PGO prologue baking (forward decls; definitions at end of file after all
// call-node kinds and prologue functions are declared)
// ---------------------------------------------------------------------------
//
// Dispatch sites with a `method_prologue_t baked_prologue` storageless
// operand use this helper on the hot path.  If `baked` is non-NULL it is a
// literal function pointer that was frozen at SPECIALIZE time from the
// observed mc->prologue value — call it directly (always_inline).  If `baked`
// is NULL, interpreter mode: forward through mc->prologue as usual.
//
// Helper inlined from node.def: map a function pointer to its stable kind
// tag at compile time.  Used to express T3 guards without relying on
// cross-SO function-pointer equality (each SD_.so has its own static inline
// prologue copies with distinct addresses).
#define PROLOGUE_KIND_OF(fn) \
    ((fn) == prologue_ast_simple_0 ? PROLOGUE_KIND_AST_SIMPLE_0 : \
     (fn) == prologue_ast_simple_1 ? PROLOGUE_KIND_AST_SIMPLE_1 : \
     (fn) == prologue_ast_simple_2 ? PROLOGUE_KIND_AST_SIMPLE_2 : \
     (fn) == prologue_ast_simple_n ? PROLOGUE_KIND_AST_SIMPLE_N : \
     (fn) == prologue_cfunc        ? PROLOGUE_KIND_CFUNC        : \
     (fn) == prologue_ivar_getter  ? PROLOGUE_KIND_IVAR_GETTER  : \
     (fn) == prologue_ivar_setter  ? PROLOGUE_KIND_IVAR_SETTER  : \
     PROLOGUE_KIND_NONE)

// T3 guard: compare by stable tag instead of function-pointer identity so
// the baked path stays selected even when baked's address differs from
// mc->prologue's address (cross-image call; they point to the same kind
// but different static inline copies).
static inline __attribute__((always_inline)) RESULT
dispatch_method_frame_pgo(CTX * restrict c, NODE * restrict call_site,
                          const struct method_cache *mc, VALUE recv_self,
                          unsigned int argc, uint32_t arg_index,
                          method_prologue_t baked)
{
    if (baked) {
        /* baked is a compile-time literal in the PGO path → gcc constant-
           folds the comparison into a simple cmp against an immediate */
        if (LIKELY(mc->prologue_kind == PROLOGUE_KIND_OF(baked))) {
            return baked(c, call_site, mc, recv_self, argc, arg_index);
        }
    }
    return mc->prologue(c, call_site, mc, recv_self, argc, arg_index);
}

static const char *abruby_pgo_prologue_name_for(const NODE *n);

// Outer dispatch for non-cache paths: build temp mc, save/restore self.
// Used by method_missing_dispatch, node_super, node_arith_fallback.
static inline RESULT
dispatch_method_with_klass(CTX * restrict c, NODE * restrict call_site,
                           VALUE recv, const struct abruby_class *klass,
                           const struct abruby_method *method,
                           unsigned int argc, uint32_t arg_index)
{
    struct method_cache mc = {0};
    // Temporary mc used exactly once for this dispatch — current argc is
    // authoritative, so static_argc=true yields the correct prologue choice.
    method_cache_fill(c, &mc, klass, method, argc, true);
    return dispatch_method_frame(c, call_site, &mc, recv, argc, arg_index);
}

// Block-carrying variant of dispatch_method_frame.
// Inline mtype switch (AST vs CFUNC) — cheaper than an indirect call
// because block-carrying sites are monomorphic in practice and the body
// branch is perfectly predicted.  IVAR getter/setter block calls fall
// through to the AST path (body == NULL → cfunc branch) but since ivar
// accessors don't have mc->body or mc->method->u.cfunc.func, we route
// them to prologue directly for safety.
static inline RESULT
dispatch_method_frame_with_block(CTX * restrict c, NODE * restrict call_site,
                                 const struct method_cache *mc, VALUE recv_self,
                                 unsigned int argc, uint32_t arg_index,
                                 const struct abruby_block *blk)
{
    // IVAR accessors — block is silently dropped (attr_reader/writer
    // rarely take a block; matches historical behavior).
    if (UNLIKELY(mc->method->type == ABRUBY_METHOD_IVAR_GETTER ||
                 mc->method->type == ABRUBY_METHOD_IVAR_SETTER)) {
        return mc->prologue(c, call_site, mc, recv_self, argc, arg_index);
    }

    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.caller_node = call_site;
    frame.block = blk;
    frame.self = recv_self;
    frame.fp = c->current_frame->fp;
    // entry carries the method pointer for backtrace / super walk; cref is
    // meaningful only for AST methods (cfunc has NULL cref).
    frame.entry = &mc->method->entry;
    c->current_frame = &frame;

    RESULT r;
    if (LIKELY(mc->body != NULL)) {
        RESULT err_r;
        int opt_idx = dispatch_setup_args(c, call_site, mc, argc, arg_index, &err_r);
        if (UNLIKELY(opt_idx < 0)) {
            c->current_frame = frame.prev;
            return err_r;
        }
        unsigned int opt_num = mc->method->u.ast.params_cnt - mc->method->u.ast.required_params_cnt;
        if (LIKELY((unsigned int)opt_idx >= opt_num || !mc->method->u.ast.opt_pc)) {
            r = mc->dispatcher(c, mc->body);
        } else {
            NODE *entry = mc->method->u.ast.opt_pc[opt_idx];
            r = EVAL(c, entry);
        }
    } else {
        // CFUNC
        r = mc->method->u.cfunc.func(c, recv_self, argc, c->current_frame->fp + arg_index);
    }

    if (UNLIKELY(r.state)) {
        r.state &= ~(unsigned)RESULT_BREAK;
        if (r.state & RESULT_RETURN) {
            if ((r.state & RESULT_SKIP_MASK) == 0) {
                r.state &= ~(unsigned)RESULT_RETURN_CATCH_MASK;
            } else {
                r.state -= RESULT_SKIP_UNIT;
            }
        }
    }

    c->current_frame = frame.prev;
    return r;
}

// Slow-path wrapper that fills a method_cache and delegates to the
// block-carrying dispatcher.
static inline RESULT
dispatch_method_with_klass_with_block(CTX * restrict c, NODE * restrict call_site,
                                      VALUE recv, const struct abruby_class *klass,
                                      const struct abruby_method *method,
                                      unsigned int argc, uint32_t arg_index,
                                      const struct abruby_block *blk)
{
    struct method_cache mc = {0};
    // Temp mc: current argc is authoritative (one-shot).
    method_cache_fill(c, &mc, klass, method, argc, true);
    return dispatch_method_frame_with_block(c, call_site, &mc, recv, argc, arg_index, blk);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
method_missing_dispatch(CTX * restrict c, NODE * restrict n, const struct abruby_class *klass,
                        ID name, VALUE recv_val,
                        uint32_t params_cnt, uint32_t arg_index)
{
    const struct abruby_method *mm = abruby_class_find_method(klass, c->ids->method_missing);
    if (!mm) {
        VALUE exc;
        PUSH_FRAME(n);
        VALUE mstr = rb_str_new_cstr("undefined method `");
        rb_str_cat_cstr(mstr, rb_id2name(name));
        rb_str_cat_cstr(mstr, "'");
        exc = abruby_exception_new(c, c->current_frame, mstr);
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    // shift args by 1, insert method name as first arg
    for (int i = (int)params_cnt - 1; i >= 0; i--) {
        c->current_frame->fp[arg_index + i + 1] = c->current_frame->fp[arg_index + i];
    }
    c->current_frame->fp[arg_index] = abruby_str_new_cstr(c,rb_id2name(name));
    return dispatch_method_with_klass(c, n, recv_val, klass, mm, params_cnt + 1, arg_index);
}
#endif

// If recv_val is itself a class/module object, return its own methods
// table for "singleton" lookup; otherwise return NULL.  This is the
// minimal hack we use to make `def self.foo` (stored on the class's
// own methods table by node_def) callable as `ClassName.foo` and from
// inside the class body itself, without implementing real metaclasses.
//
// We detect "recv is a class/module value" by checking whether its
// metaclass (the `klass` field at offset 0 of the data) is the
// per-instance class_class or module_class — that's how class/module
// values are tagged in abruby.
static inline struct abruby_class *
abruby_singleton_table_class(CTX *c, VALUE recv_val)
{
    if (RB_SPECIAL_CONST_P(recv_val)) return NULL;
    struct abruby_header *h = (struct abruby_header *)ABRUBY_DATA_PTR(recv_val);
    if (h->klass != c->abm->class_class && h->klass != c->abm->module_class) {
        return NULL;
    }
    return (struct abruby_class *)h;
}

// Forward decls (defined after specialized call kinds).
static inline void maybe_specialize_call_kind(NODE *n, const struct method_cache *mc);
// swap_dispatcher forward decl provided via node.h (non-static, in node_helper.c).

// Not marked `cold`: polymorphic dispatch sites (e.g. bm_dispatch) hit this
// path every other iteration, and sending it to the cold section wrecks icache.
#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
node_method_call_slow(CTX * restrict c, NODE * restrict n,
                      VALUE recv_val, const struct abruby_class *klass, ID name,
                      uint32_t params_cnt, uint32_t arg_index,
                      struct method_cache *mc, bool static_argc)
{
    const struct abruby_method *method = abruby_class_find_method(klass, name);
    if (UNLIKELY(method == NULL)) {
        // Class/module objects: also check their own method table for
        // "class methods" defined via `def self.foo`.  Cached only weakly
        // (no IC) — class-method dispatch is rare on the hot path.
        struct abruby_class *singleton = abruby_singleton_table_class(c, recv_val);
        if (singleton) {
            method = abruby_class_find_method(singleton, name);
            if (method) {
                return dispatch_method_with_klass(c, n, recv_val, klass, method, params_cnt, arg_index);
            }
        }
        return method_missing_dispatch(c, n, klass, name, recv_val, params_cnt, arg_index);
    }
    method_cache_fill(c, mc, klass, method, params_cnt, static_argc);
    maybe_specialize_call_kind(n, mc);
    return dispatch_method_with_klass(c, n, recv_val, klass, method, params_cnt, arg_index);
}
#endif

// === Apply (splat) call nodes ===
//
// Used when a call has a splat argument (`foo(a, *b, c)`).  The parser
// lowers the full argument list to a single Array-valued expression and
// passes it here via the `args` operand.
//
// Runtime contract:
//   - Evaluate `args` to an abruby Array (parser guarantees this).
//   - Store the array VALUE at c->current_frame->fp[arg_index] to keep it GC-pinned for
//     the duration of the dispatched call.
//   - Copy its elements into c->current_frame->fp[arg_index+1 .. arg_index+1+argc].
//   - Dispatch with (argc, arg_index+1).
//
// The parser reserves ABRUBY_APPLY_MAX_ARGS + 1 slots at arg_index so the
// runtime copy cannot overflow the caller's frame.  If argc exceeds the
// reservation, we raise a RuntimeError.

#define ABRUBY_APPLY_MAX_ARGS 32

static inline RESULT
apply_unpack(CTX * restrict c, NODE * restrict n,
             VALUE args_val, uint32_t arg_index, uint32_t *out_argc)
{
    // args_val must be an abruby Array.
    if (!ab_obj_type_p(args_val, ABRUBY_OBJ_ARRAY)) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c, "splat argument must be an Array"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    VALUE rb_ary = RARY(args_val);
    long n_args = RARRAY_LEN(rb_ary);
    if (n_args > ABRUBY_APPLY_MAX_ARGS) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c, "too many arguments in splat call"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    // Keep the array pinned at fp[arg_index] so GC during dispatch sees it.
    c->current_frame->fp[arg_index] = args_val;
    for (long i = 0; i < n_args; i++) {
        c->current_frame->fp[arg_index + 1 + i] = RARRAY_AREF(rb_ary, i);
    }
    *out_argc = (uint32_t)n_args;
    return RESULT_OK(Qnil);
}

// Forward declarations (defined later, after block-carrying call nodes).
__attribute__((noinline)) RESULT
node_method_call_with_block_slow(CTX *c, NODE *n,
                                 VALUE recv_val, const struct abruby_class *klass, ID name,
                                 uint32_t params_cnt, uint32_t arg_index,
                                 struct method_cache *mc,
                                 const struct abruby_block *blk, bool static_argc);

static inline RESULT
build_block_from_proc_value(CTX *c, NODE *call_site, VALUE proc_val, struct abruby_block *out_blk);

// =================================================================
// === New consolidated call nodes (replacing the 12 old variants) ==
// =================================================================
//
// Design:
//   - recv unified as a NODE* operand (implicit self uses node_self)
//   - blk unified as a NODE* operand (no block uses node_nil)
//     blk kind dispatched at runtime: nil / block_literal / block_arg
//   - simple variants (call0/1/2): args evaluated inline as NODE operands
//   - call (general): static argc, args pre-placed in fp by caller seq
//   - apply_call: splat call, runtime argc via args_node Array

extern const struct NodeKind kind_node_nil;
extern const struct NodeKind kind_node_block_literal;
extern const struct NodeKind kind_node_block_arg;

// Materialize abruby_block from a blk operand.
// Returns: 0 = no block, 1 = block ready in *out_blk, -1 = error in *err
static inline int
materialize_block(CTX *c, NODE *call_site, NODE *blk_node,
                  struct abruby_block *out_blk, RESULT *err)
{
    if (blk_node == NULL || blk_node->head.kind == &kind_node_nil) {
        return 0;
    }
    if (blk_node->head.kind == &kind_node_block_literal) {
        out_blk->body          = blk_node->u.node_block_literal.body;
        out_blk->captured_fp   = c->current_frame->fp;
        out_blk->captured_self = c->current_frame->self;
        out_blk->defining_frame = (struct abruby_frame *)abruby_context_frame(c);
        out_blk->cref          = ctx_cref(c);
        out_blk->params_cnt    = blk_node->u.node_block_literal.params_cnt;
        out_blk->param_base    = blk_node->u.node_block_literal.param_base;
        out_blk->env_size      = blk_node->u.node_block_literal.env_size;
        return 1;
    }
    // node_block_arg: evaluate the &expr to a Proc
    NODE *expr = blk_node->u.node_block_arg.expr;
    RESULT r = (*expr->head.dispatcher)(c, expr);
    if (UNLIKELY(r.state != RESULT_NORMAL)) {
        *err = r;
        return -1;
    }
    if (r.value == Qnil) return 0;  // &nil → no block
    RESULT br = build_block_from_proc_value(c, call_site, r.value, out_blk);
    if (UNLIKELY(br.state != RESULT_NORMAL)) {
        *err = br;
        return -1;
    }
    return (br.value == Qnil) ? 0 : 1;
}

// Slow path for dispatch_call: block present or cache miss. Out-of-line.
#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
dispatch_call_slow(CTX * restrict c, NODE * restrict call_site, VALUE recv_val,
                   ID name, unsigned int argc, uint32_t arg_index,
                   NODE *blk_node, const struct abruby_class *klass,
                   struct method_cache *mc, bool cache_hit, bool static_argc)
{
    struct abruby_block blk_storage;
    RESULT blk_err;
    int blk_kind = materialize_block(c, call_site, blk_node, &blk_storage, &blk_err);
    if (UNLIKELY(blk_kind < 0)) return blk_err;
    const struct abruby_block *blk_ptr = (blk_kind > 0) ? &blk_storage : NULL;

    if (cache_hit) {
        return blk_ptr ? dispatch_method_frame_with_block(c, call_site, mc, recv_val, argc, arg_index, blk_ptr)
                       : dispatch_method_frame(c, call_site, mc, recv_val, argc, arg_index);
    }
    return blk_ptr ? node_method_call_with_block_slow(c, call_site, recv_val, klass, name,
                                                      argc, arg_index, mc, blk_ptr, static_argc)
                   : node_method_call_slow(c, call_site, recv_val, klass, name,
                                           argc, arg_index, mc, static_argc);
}
#endif

// Common dispatch path for all 5 new call nodes.
// Caller has already evaluated recv (recv_val) and placed args in fp.
// Fast path (no block, cache hit) is inlined; everything else goes out-of-line.
// No self save/restore needed — dispatch_method_frame sets new frame's self
// to recv_val directly, and frame pop (c->current_frame = frame.prev) restores
// the caller's frame (whose self was never modified).
static inline RESULT
dispatch_call(CTX * restrict c, NODE * restrict call_site, VALUE recv_val,
              ID name, unsigned int argc, uint32_t arg_index,
              NODE *blk_node, struct method_cache *mc, bool static_argc)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    bool cache_hit = (mc->klass == klass && mc->serial == c->abm->method_serial);

    // Fast path: no block + cache hit → inline dispatch_method_frame directly.
    if (LIKELY(blk_node->head.kind == &kind_node_nil && cache_hit)) {
        return dispatch_method_frame(c, call_site, mc, recv_val, argc, arg_index);
    }
    // Slow path: block materialization or cache miss.
    return dispatch_call_slow(c, call_site, recv_val, name, argc, arg_index,
                              blk_node, klass, mc, cache_hit, static_argc);
}

// PGO-aware variant of dispatch_call for the cache-hit no-block fast path.
// Routes through dispatch_method_frame_pgo so a PGO-baked prologue can be
// called directly (devirtualizing mc->prologue).
static inline __attribute__((always_inline)) RESULT
dispatch_call_pgo(CTX * restrict c, NODE * restrict call_site, VALUE recv_val,
                  ID name, unsigned int argc, uint32_t arg_index,
                  NODE *blk_node, struct method_cache *mc, bool static_argc,
                  method_prologue_t baked)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    bool cache_hit = (mc->klass == klass && mc->serial == c->abm->method_serial);

    if (LIKELY(blk_node->head.kind == &kind_node_nil && cache_hit)) {
        return dispatch_method_frame_pgo(c, call_site, mc, recv_val, argc, arg_index, baked);
    }
    return dispatch_call_slow(c, call_site, recv_val, name, argc, arg_index,
                              blk_node, klass, mc, cache_hit, static_argc);
}

// --- Simple no-block variants: 0/1/2 args, args evaluated inline ---
// Hot path: no block operand at all (block-less calls dominate in Ruby code).

// Baked-prologue variant of the hot path: used by node_call0/1/2 when the
// SPECIALIZE step supplied a literal prologue (PGO).  Interpreter passes
// NULL and we fall through to the normal indirect call.
static inline __attribute__((always_inline)) RESULT
dispatch_simple_noblock_pgo(CTX * restrict c, NODE * restrict call_site, VALUE recv_val,
                            ID name, unsigned int argc, uint32_t arg_index,
                            struct method_cache *mc,
                            method_prologue_t baked)
{
#if ABRUBY_PROFILE
    { extern void abruby_dispatch_count_inc(ID); abruby_dispatch_count_inc(name); }
#endif
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return dispatch_method_frame_pgo(c, call_site, mc, recv_val, argc, arg_index, baked);
    }
    return node_method_call_slow(c, call_site, recv_val, klass, name, argc, arg_index, mc, true);
}

static inline RESULT
dispatch_simple_noblock(CTX * restrict c, NODE * restrict call_site, VALUE recv_val,
                        ID name, unsigned int argc, uint32_t arg_index,
                        struct method_cache *mc)
{
#if ABRUBY_PROFILE
    { extern void abruby_dispatch_count_inc(ID); abruby_dispatch_count_inc(name); }
#endif
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return dispatch_method_frame(c, call_site, mc, recv_val, argc, arg_index);
    }
    if (ABRUBY_PROFILE && mc->serial == c->abm->method_serial) {
        fprintf(stderr, "slow path (klass miss) name:%s klass:%s cached:%s\n",
                rb_id2name(name),
                klass->name ? rb_id2name(klass->name) : "(nil)",
                mc->klass && mc->klass->name ? rb_id2name(mc->klass->name) : "(empty)");
    }
    return node_method_call_slow(c, call_site, recv_val, klass, name, argc, arg_index, mc, true);
}

NODE_DEF
node_call0(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t arg_index, struct method_cache *mc@ref, method_prologue_t baked_prologue)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    return dispatch_simple_noblock_pgo(c, n, recv_val, name, 0, arg_index, mc, baked_prologue);
}

NODE_DEF
node_call1(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, uint32_t arg_index, struct method_cache *mc@ref, method_prologue_t baked_prologue)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index] = UNWRAP(EVAL_ARG(c, arg0));
    return dispatch_simple_noblock_pgo(c, n, recv_val, name, 1, arg_index, mc, baked_prologue);
}

NODE_DEF
node_call2(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, NODE *arg1, uint32_t arg_index, struct method_cache *mc@ref, method_prologue_t baked_prologue)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index]     = UNWRAP(EVAL_ARG(c, arg0));
    c->current_frame->fp[arg_index + 1] = UNWRAP(EVAL_ARG(c, arg1));
    return dispatch_simple_noblock_pgo(c, n, recv_val, name, 2, arg_index, mc, baked_prologue);
}

// ===================================================================
// Specialized simple-call variants (mtype-specialized via swap_dispatcher).
//
// After method_cache_fill determines the callee's mtype, the generic
// node_call0/1/2 is rewritten to a matching _ast / _cfunc / _ivar_* kind.
// The specialized dispatcher calls the prologue function DIRECTLY (no
// `mc->prologue` indirection) and — since prologues are now always_inline
// — the compiler can fold the prologue body into the call site.
//
// Cache miss inside a specialized kind is handled carefully:
//
//  1. recv and args have already been EVAL'd (and written to fp) by the
//     time we detect the miss — we CANNOT re-enter the generic
//     dispatcher because that would re-evaluate them (double side
//     effects + wasted work).  Instead we demote the kind and call
//     node_method_call_slow directly with the already-computed values.
//
//  2. Polymorphic call sites (same node, receiver class cycles through
//     several) would otherwise thrash by re-specializing on each miss.
//     We count misses in mc->demote_cnt and, once the threshold is
//     exceeded, leave the node demoted permanently — maybe_specialize
//     honors this flag and skips re-specialization.
// ===================================================================

extern const struct NodeKind kind_node_call0;
extern const struct NodeKind kind_node_call1;
extern const struct NodeKind kind_node_call2;

// Threshold: at most this many demotes before the site is considered
// polymorphic.  Higher = more swap overhead; lower = faster give-up.
#define ABRUBY_CALL_POLY_THRESHOLD 2

// Common miss handler for specialized call0/1/2 variants.  Assumes recv
// and all args are already evaluated (recv_val passed, args already in
// fp).  Bumps demote_cnt, demotes the kind to generic, and fills the
// cache via the slow path without re-evaluating anything.
static inline RESULT
specialized_call_miss(CTX * restrict c, NODE * restrict n,
                      VALUE recv_val, const struct abruby_class *klass,
                      ID name, unsigned int argc, uint32_t arg_index,
                      struct method_cache *mc,
                      const struct NodeKind *generic_kind)
{
    if (mc->demote_cnt < 0xff) mc->demote_cnt++;
    swap_dispatcher(n, generic_kind);
    return node_method_call_slow(c, n, recv_val, klass, name, argc, arg_index, mc, true);
}

NODE_DEF @canonical=node_call0
node_call0_ast(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_ast_simple_0(c, n, mc, recv_val, 0, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 0, arg_index, mc, &kind_node_call0);
}

NODE_DEF @canonical=node_call0
node_call0_cfunc(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_cfunc(c, n, mc, recv_val, 0, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 0, arg_index, mc, &kind_node_call0);
}

NODE_DEF @canonical=node_call0
node_call0_ivar_get(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_ivar_getter(c, n, mc, recv_val, 0, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 0, arg_index, mc, &kind_node_call0);
}

NODE_DEF @canonical=node_call1
node_call1_ast(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index] = UNWRAP(EVAL_ARG(c, arg0));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_ast_simple_1(c, n, mc, recv_val, 1, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 1, arg_index, mc, &kind_node_call1);
}

NODE_DEF @canonical=node_call1
node_call1_cfunc(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index] = UNWRAP(EVAL_ARG(c, arg0));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_cfunc(c, n, mc, recv_val, 1, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 1, arg_index, mc, &kind_node_call1);
}

NODE_DEF @canonical=node_call1
node_call1_ivar_set(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index] = UNWRAP(EVAL_ARG(c, arg0));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_ivar_setter(c, n, mc, recv_val, 1, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 1, arg_index, mc, &kind_node_call1);
}

NODE_DEF @canonical=node_call2
node_call2_ast(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, NODE *arg1, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index]     = UNWRAP(EVAL_ARG(c, arg0));
    c->current_frame->fp[arg_index + 1] = UNWRAP(EVAL_ARG(c, arg1));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_ast_simple_2(c, n, mc, recv_val, 2, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 2, arg_index, mc, &kind_node_call2);
}

NODE_DEF @canonical=node_call2
node_call2_cfunc(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, NODE *arg1, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index]     = UNWRAP(EVAL_ARG(c, arg0));
    c->current_frame->fp[arg_index + 1] = UNWRAP(EVAL_ARG(c, arg1));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return prologue_cfunc(c, n, mc, recv_val, 2, arg_index);
    }
    return specialized_call_miss(c, n, recv_val, klass, name, 2, arg_index, mc, &kind_node_call2);
}

// After method_cache_fill, rewrite the call node to a specialized kind
// matching the selected prologue.  Called from node_method_call_slow.
// Only handles node_call0/1/2 (the generic simple-noblock variants);
// block-carrying variants (call*_b) and general node_call are left as-is
// for Phase 1.
extern const struct NodeKind kind_node_call0_ast;
extern const struct NodeKind kind_node_call0_cfunc;
extern const struct NodeKind kind_node_call0_ivar_get;
extern const struct NodeKind kind_node_call1_ast;
extern const struct NodeKind kind_node_call1_cfunc;
extern const struct NodeKind kind_node_call1_ivar_set;
extern const struct NodeKind kind_node_call2_ast;
extern const struct NodeKind kind_node_call2_cfunc;

static inline void
maybe_specialize_call_kind(NODE *n, const struct method_cache *mc)
{
    // Polymorphic site: too many demotes — leave as generic permanently.
    if (mc->demote_cnt >= ABRUBY_CALL_POLY_THRESHOLD) return;
    const struct NodeKind *k = n->head.kind;
    if (k == &kind_node_call0) {
        if      (mc->prologue == prologue_ast_simple_0) swap_dispatcher(n, &kind_node_call0_ast);
        else if (mc->prologue == prologue_cfunc)        swap_dispatcher(n, &kind_node_call0_cfunc);
        else if (mc->prologue == prologue_ivar_getter)  swap_dispatcher(n, &kind_node_call0_ivar_get);
    } else if (k == &kind_node_call1) {
        if      (mc->prologue == prologue_ast_simple_1) swap_dispatcher(n, &kind_node_call1_ast);
        else if (mc->prologue == prologue_cfunc)        swap_dispatcher(n, &kind_node_call1_cfunc);
        else if (mc->prologue == prologue_ivar_setter)  swap_dispatcher(n, &kind_node_call1_ivar_set);
    } else if (k == &kind_node_call2) {
        if      (mc->prologue == prologue_ast_simple_2) swap_dispatcher(n, &kind_node_call2_ast);
        else if (mc->prologue == prologue_cfunc)        swap_dispatcher(n, &kind_node_call2_cfunc);
    }
}

// --- Simple with-block variants: 0/1/2 args + literal block ---
// blk is ALWAYS a node_block_literal (parser guarantee). No kind check.

static inline RESULT
dispatch_simple_block(CTX * restrict c, NODE * restrict call_site, VALUE recv_val,
                      ID name, unsigned int argc, uint32_t arg_index,
                      NODE *blk_literal, struct method_cache *mc)
{
    // Inline-materialize block from the literal (no kind dispatch).
    struct abruby_block blk;
    blk.body          = blk_literal->u.node_block_literal.body;
    blk.captured_fp   = c->current_frame->fp;
    blk.captured_self = c->current_frame->self;
    blk.defining_frame = (struct abruby_frame *)abruby_context_frame(c);
    blk.cref          = ctx_cref(c);
    blk.params_cnt    = blk_literal->u.node_block_literal.params_cnt;
    blk.param_base    = blk_literal->u.node_block_literal.param_base;
    blk.env_size      = blk_literal->u.node_block_literal.env_size;

    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);
    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return dispatch_method_frame_with_block(c, call_site, mc, recv_val, argc, arg_index, &blk);
    }
    return node_method_call_with_block_slow(c, call_site, recv_val, klass, name, argc, arg_index, mc, &blk, true);
}

NODE_DEF
node_call0_b(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t arg_index, NODE *blk, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    return dispatch_simple_block(c, n, recv_val, name, 0, arg_index, blk, mc);
}

NODE_DEF
node_call1_b(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, uint32_t arg_index, NODE *blk, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index] = UNWRAP(EVAL_ARG(c, arg0));
    return dispatch_simple_block(c, n, recv_val, name, 1, arg_index, blk, mc);
}

NODE_DEF
node_call2_b(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *arg0, NODE *arg1, uint32_t arg_index, NODE *blk, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    c->current_frame->fp[arg_index]     = UNWRAP(EVAL_ARG(c, arg0));
    c->current_frame->fp[arg_index + 1] = UNWRAP(EVAL_ARG(c, arg1));
    return dispatch_simple_block(c, n, recv_val, name, 2, arg_index, blk, mc);
}

// --- General: 3+ static args, pre-placed in fp by caller seq ---

NODE_DEF
node_call(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t argc, uint32_t arg_index, NODE *blk, struct method_cache *mc@ref, method_prologue_t baked_prologue)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    return dispatch_call_pgo(c, n, recv_val, name, argc, arg_index, blk, mc, true, baked_prologue);
}

// --- Apply (splat) call: runtime argc via args_node Array ---

NODE_DEF
node_apply_call(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *args_node, uint32_t arg_index, NODE *blk, struct method_cache *mc@ref, method_prologue_t baked_prologue)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    // Pin recv to keep alive across args evaluation (apply_unpack overwrites the slot).
    c->current_frame->fp[arg_index] = recv_val;
    VALUE args_val = UNWRAP(EVAL_ARG(c, args_node));
    recv_val = c->current_frame->fp[arg_index];
    uint32_t argc;
    RESULT rr = apply_unpack(c, n, args_val, arg_index, &argc);
    if (UNLIKELY(rr.state != RESULT_NORMAL)) return rr;
    // static_argc=false: argc comes from splat expansion and can vary across
    // calls at this @ref cache, so we must install the checking (complex)
    // prologue to guarantee validation on every cache hit.
    return dispatch_call_pgo(c, n, recv_val, name, argc, arg_index + 1, blk, mc, false, baked_prologue);
}

// === Block-carrying call nodes ===
//
// Parser routes every call that has a block literal (`{ ... }` / `do..end`)
// to these nodes.  Block-less call paths are unchanged so the block-less
// hot path pays zero extra cost.
//
// Common contract:
//   - block_literal is a NODE * whose kind is node_block_literal; its
//     union field holds (body, params_cnt, param_base).
//   - At call time we materialize a `struct abruby_block` on the C stack,
//     capturing the caller's fp/self/defining_frame so `yield` in the callee
//     (or in cfunc via abruby_yield) can execute the block closure.
//   - Dispatch goes through dispatch_method_frame_with_block, which sets
//     frame.block = blk and demotes RESULT_BREAK on method boundary.

#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
node_method_call_with_block_slow(CTX * restrict c, NODE * restrict n,
                                 VALUE recv_val, const struct abruby_class *klass, ID name,
                                 uint32_t params_cnt, uint32_t arg_index,
                                 struct method_cache *mc,
                                 const struct abruby_block *blk, bool static_argc)
{
    const struct abruby_method *method = abruby_class_find_method(klass, name);
    if (UNLIKELY(method == NULL)) {
        // method_missing: block is silently dropped in MVP.  Ruby passes
        // the block through to method_missing, but that adds complexity we
        // do not need for Phase 1 iterators.
        return method_missing_dispatch(c, n, klass, name, recv_val, params_cnt, arg_index);
    }
    method_cache_fill(c, mc, klass, method, params_cnt, static_argc);
    return dispatch_method_with_klass_with_block(c, n, recv_val, klass, method,
                                                 params_cnt, arg_index, blk);
}
#endif

// === Runtime-block call nodes ===
//
// Like the _with_block variants but the block comes from a runtime
// expression (the `&expr` form at a call site).  We evaluate the
// expression, expect a Proc, and build a temporary `struct abruby_block`
// pointing into the Proc's heap env.

static inline RESULT
build_block_from_proc_value(CTX *c, NODE *call_site, VALUE proc_val, struct abruby_block *out_blk)
{
    if (proc_val == Qnil) {
        return RESULT_OK(Qnil);   // signal "no block"
    }
    if (!ab_obj_type_p(proc_val, ABRUBY_OBJ_PROC)) {
        VALUE exc;
        PUSH_FRAME(call_site);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c, "wrong argument type (expected Proc) for &arg"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    const struct abruby_proc *p = (const struct abruby_proc *)ABRUBY_DATA_PTR(proc_val);
    out_blk->body          = p->body;
    out_blk->captured_fp   = p->env;
    out_blk->captured_self = p->captured_self;
    out_blk->defining_frame = NULL;  // proc may have escaped — no live frame
    out_blk->cref          = p->cref;
    out_blk->params_cnt    = p->params_cnt;
    out_blk->param_base    = p->param_base;
    out_blk->env_size      = p->env_size;
    return RESULT_OK(Qtrue);  // signal "have block"
}

// === super ===

// Find super target class and method name for the current lexical frame.
// `super` resolves against the enclosing *lexical* method's defining class:
// from inside a block, that's the block's defining frame's method.
static inline bool
find_super_target(const struct abruby_frame *lex,
                  const struct abruby_class **out_klass,
                  ID *out_name)
{
    if (!lex || !lex->entry) return false;
    const struct abruby_method *m = lex->entry->method;
    if (!m || !m->defining_class) return false;
    *out_klass = m->defining_class->super;
    *out_name  = m->name;
    return *out_klass != NULL;
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
raise_super_no_method(CTX *c, NODE *n)
{
    VALUE exc;
    PUSH_FRAME(n);
    exc = abruby_exception_new(c, c->current_frame,
        abruby_str_new_cstr(c,"super: no superclass method"));
    POP_FRAME();
    return (RESULT){exc, RESULT_RAISE};
}
#endif

// Slow path: resolve method, fill cache, dispatch.  Out-of-line so the
// hot cache-hit path in node_super stays small and inline.
#ifndef NODE_SKIP_COLD
__attribute__((noinline)) RESULT
node_super_slow(CTX * restrict c, NODE * restrict n,
                const struct abruby_class *klass, ID name,
                uint32_t params_cnt, uint32_t arg_index,
                const struct abruby_block *blk,
                struct method_cache *mc, bool static_argc)
{
    const struct abruby_method *method = abruby_class_find_method(klass, name);
    if (UNLIKELY(method == NULL)) return raise_super_no_method(c, n);
    method_cache_fill(c, mc, klass, method, params_cnt, static_argc);
    VALUE recv_self = c->current_frame->self;
    if (blk != NULL) {
        return dispatch_method_frame_with_block(c, n, mc, recv_self, params_cnt, arg_index, blk);
    }
    return dispatch_method_frame(c, n, mc, recv_self, params_cnt, arg_index);
}
#endif

// `super(args)` — call parent method with explicit arguments.
// Any block the current method received is implicitly forwarded to the
// parent (matching Ruby), unless the parser emitted node_super_with_block
// for an explicit `super(...) { ... }` form.
//
// Cache semantics: the lookup is `lex->method->defining_class->super#name`.
// For a given AST site, lex->method is fixed (determined by the AST's
// lexical position), so target klass + name are stable across hits.
// method_serial invalidates the cache on any method redefinition.
NODE_DEF
node_super(CTX * restrict c, NODE * restrict n, uint32_t params_cnt, uint32_t arg_index, struct method_cache *mc@ref, method_prologue_t baked_prologue)
{
    const struct abruby_frame *lex = abruby_context_frame(c);
    const struct abruby_class *target;
    ID name;
    if (UNLIKELY(!find_super_target(lex, &target, &name))) return raise_super_no_method(c, n);

    const struct abruby_block *inherited = lex->block;
    if (LIKELY(mc->klass == target && mc->serial == c->abm->method_serial)) {
        VALUE recv_self = c->current_frame->self;
        if (inherited != NULL) {
            return dispatch_method_frame_with_block(c, n, mc, recv_self, params_cnt, arg_index, inherited);
        }
        return dispatch_method_frame_pgo(c, n, mc, recv_self, params_cnt, arg_index, baked_prologue);
    }
    return node_super_slow(c, n, target, name, params_cnt, arg_index, inherited, mc, true);
}

// Explicit `super(args) { |x| ... }` — parser routes here when a block
// literal is supplied at the super call site.  Caller-provided block
// always wins over the inherited one.
NODE_DEF
node_super_with_block(CTX * restrict c, NODE * restrict n, uint32_t params_cnt, uint32_t arg_index, NODE *block_literal, struct method_cache *mc@ref)
{
    const struct abruby_frame *lex = abruby_context_frame(c);
    const struct abruby_class *target;
    ID name;
    if (UNLIKELY(!find_super_target(lex, &target, &name))) return raise_super_no_method(c, n);

    struct abruby_block blk;
    blk.body              = block_literal->u.node_block_literal.body;
    blk.captured_fp       = c->current_frame->fp;
    blk.captured_self     = c->current_frame->self;
    blk.defining_frame    = (struct abruby_frame *)lex;
    blk.cref              = ctx_cref(c);
    blk.params_cnt        = block_literal->u.node_block_literal.params_cnt;
    blk.param_base        = block_literal->u.node_block_literal.param_base;
    blk.env_size          = block_literal->u.node_block_literal.env_size;

    if (LIKELY(mc->klass == target && mc->serial == c->abm->method_serial)) {
        return dispatch_method_frame_with_block(c, n, mc, c->current_frame->self, params_cnt, arg_index, &blk);
    }
    return node_super_slow(c, n, target, name, params_cnt, arg_index, &blk, mc, true);
}

// === Arithmetic rewrite (type-specific nodes) ===

// Forward decl: default Object#==. When method dispatch resolves to this
// function we skip the full dispatch and use identity comparison directly.
extern RESULT ab_object_eq(CTX *c, VALUE self, unsigned int argc, VALUE *argv);

// Fallback: general method call for arithmetic operators (recv=lv, arg=rv)
#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_arith_fallback(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, ID op, uint32_t arg_index)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, lv);
    const struct abruby_method *method = abruby_class_find_method(klass, op);
    // Inline default Object#== when it resolves here: short-circuit the
    // dispatch to a pointer comparison. Correct so long as the class hasn't
    // overridden == (method would not be ab_object_eq in that case).
    if (method && method->type == ABRUBY_METHOD_CFUNC &&
        method->u.cfunc.func == ab_object_eq) {
        return RESULT_OK(lv == rv ? Qtrue : Qfalse);
    }
    if (!method) {
        method = abruby_class_find_method(klass, c->ids->method_missing);
        if (!method) {
            VALUE exc;
            PUSH_FRAME(n);
            VALUE mstr2 = rb_str_new_cstr("undefined method `");
            rb_str_cat_cstr(mstr2, rb_id2name(op));
            rb_str_cat_cstr(mstr2, "'");
            exc = abruby_exception_new(c, c->current_frame, mstr2);
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        c->current_frame->fp[arg_index] = abruby_str_new_cstr(c,rb_id2name(op));
        c->current_frame->fp[arg_index + 1] = rv;
        return dispatch_method_with_klass(c, n, lv, klass, method, 2, arg_index);
    }
    c->current_frame->fp[arg_index] = rv;
    return dispatch_method_with_klass(c, n, lv, klass, method, 1, arg_index);
}
#endif

// Integer arithmetic helper (works for both fixnum and bignum)
static inline bool
ab_is_integer(VALUE v)
{
    return FIXNUM_P(v) || ab_obj_type_p(v, ABRUBY_OBJ_BIGNUM);
}

// Float type check (Flonum immediate or heap Float wrapped in abruby_float)
static inline bool
ab_is_float(VALUE v)
{
    return RB_FLONUM_P(v) || ab_obj_type_p(v, ABRUBY_OBJ_FLOAT);
}

// Forward declarations for cross-referencing dispatchers
static RESULT DISPATCH_node_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_div(CTX *c, NODE *n);

extern const struct NodeKind kind_node_plus;
extern const struct NodeKind kind_node_fixnum_plus;
extern const struct NodeKind kind_node_integer_plus;
extern const struct NodeKind kind_node_flonum_plus;
extern const struct NodeKind kind_node_minus;
extern const struct NodeKind kind_node_fixnum_minus;
extern const struct NodeKind kind_node_integer_minus;
extern const struct NodeKind kind_node_flonum_minus;
extern const struct NodeKind kind_node_mul;
extern const struct NodeKind kind_node_fixnum_mul;
extern const struct NodeKind kind_node_integer_mul;
extern const struct NodeKind kind_node_flonum_mul;
extern const struct NodeKind kind_node_div;
extern const struct NodeKind kind_node_fixnum_div;
extern const struct NodeKind kind_node_integer_div;
extern const struct NodeKind kind_node_flonum_div;

// Integer calc helpers (used by fixnum_*_slow and integer_* nodes).
// Use rb_big_* directly when a Bignum is involved to skip rb_funcall overhead.
// rb_big_*(x, y) requires x to be a Bignum but accepts any y.
static inline RESULT
integer_plus_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM))      result = rb_big_plus(l, r);
    else if (RB_TYPE_P(r, T_BIGNUM)) result = rb_big_plus(r, l);  // commutative
    else                     result = rb_funcall(l, c->ids->op_plus, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

static inline RESULT
integer_minus_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM)) result = rb_big_minus(l, r);
    else                result = rb_funcall(l, c->ids->op_minus, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

static inline RESULT
integer_mul_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM))      result = rb_big_mul(l, r);
    else if (RB_TYPE_P(r, T_BIGNUM)) result = rb_big_mul(r, l);  // commutative
    else                     result = rb_funcall(l, c->ids->op_mul, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

static inline RESULT
integer_div_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM)) result = rb_big_div(l, r);
    else                result = rb_funcall(l, c->ids->op_div, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

// Wrap a double result back into an abruby value.  Uses the inline
// flonum encoder so the common case never calls rb_float_new.  Only
// out-of-range doubles (NaN/Inf/denormals/0x3000…) fall back to the
// heap-allocated abruby_float wrapper.
static inline RESULT
flonum_result(CTX *c, double d)
{
    VALUE flo = ab_flonum_encode(d);
    if (LIKELY(flo != 0)) return RESULT_OK(flo);
    return RESULT_OK(abruby_float_new_wrap(c, rb_float_new(d)));
}

// Float calc helpers (used by fixnum_*_slow promotion and flonum_* nodes).
// Input values must pass ab_is_float().
static inline RESULT
flonum_plus_calc(CTX *c, VALUE lv, VALUE rv)
{
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) + AB_FLOAT_TO_DOUBLE(rv));
}

static inline RESULT
flonum_minus_calc(CTX *c, VALUE lv, VALUE rv)
{
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) - AB_FLOAT_TO_DOUBLE(rv));
}

static inline RESULT
flonum_mul_calc(CTX *c, VALUE lv, VALUE rv)
{
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) * AB_FLOAT_TO_DOUBLE(rv));
}

static inline RESULT
flonum_div_calc(CTX *c, VALUE lv, VALUE rv)
{
    // Float division: no ZeroDivisionError; IEEE 754 handles 0 → inf/nan.
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) / AB_FLOAT_TO_DOUBLE(rv));
}

// swap_dispatcher moved to node_helper.c.

// node_plus: generic fallback (method dispatch via "+")
NODE_DEF
node_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_plus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (!c->abm->basic_op_redefined) {
        if (ab_is_float(lv) && ab_is_float(rv)) {
            swap_dispatcher(n, &kind_node_flonum_plus);
            return flonum_plus_calc(c, lv, rv);
        }
        if (ab_is_integer(lv) && ab_is_integer(rv)) {
            swap_dispatcher(n, &kind_node_integer_plus);
            return integer_plus_calc(c, lv, rv);
        }
    }
    swap_dispatcher(n, &kind_node_plus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}
#endif

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_flonum_plus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_plus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}
#endif

NODE_DEF @canonical=node_plus
node_flonum_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(ab_is_float(lv) && ab_is_float(rv) && !c->abm->basic_op_redefined)) {
        return flonum_plus_calc(c, lv, rv);
    }
    return node_flonum_plus_slow(c, n, lv, rv, arg_index);
}

// node_fixnum_plus_overflow moved to node_helper.c (see node.h prototype).

NODE_DEF @canonical=node_plus
node_fixnum_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long result;
        if (LIKELY(!__builtin_add_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return node_fixnum_plus_overflow(c, lv, rv);
    }
    return node_fixnum_plus_slow(c, n, lv, rv, arg_index);
}

NODE_DEF @canonical=node_plus
node_integer_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long result = FIX2LONG(lv) + FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_plus_calc(c, lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

NODE_DEF
node_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_fixnum_minus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (!c->abm->basic_op_redefined) {
        if (ab_is_float(lv) && ab_is_float(rv)) {
        swap_dispatcher(n, &kind_node_flonum_minus);
        return flonum_minus_calc(c, lv, rv);
    }
        if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_minus);
        return integer_minus_calc(c, lv, rv);
    }
    }
    swap_dispatcher(n, &kind_node_minus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}
#endif

#ifndef NODE_SKIP_COLD
__attribute__((noinline, cold)) RESULT
node_flonum_minus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_minus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}
#endif

NODE_DEF @canonical=node_minus
node_flonum_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(ab_is_float(lv) && ab_is_float(rv) && !c->abm->basic_op_redefined)) {
        return flonum_minus_calc(c, lv, rv);
    }
    return node_flonum_minus_slow(c, n, lv, rv, arg_index);
}

// node_fixnum_minus_overflow moved to node_helper.c.

NODE_DEF @canonical=node_minus
node_fixnum_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long result;
        if (LIKELY(!__builtin_sub_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return node_fixnum_minus_overflow(c, lv, rv);
    }
    return node_fixnum_minus_slow(c, n, lv, rv, arg_index);
}

NODE_DEF @canonical=node_minus
node_integer_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv) && !c->abm->basic_op_redefined)) {
        long result = FIX2LONG(lv) - FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_minus_calc(c, lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

NODE_DEF
node_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
}

