// abruby node definitions
// RESULT is the return type for all node evaluators.
// UNWRAP extracts VALUE from RESULT, propagating non-normal state.

#define UNWRAP(r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL)) return _r; \
    _r.value; \
})

// UNWRAP_ALSO: like UNWRAP but does not propagate the specified state.
// Used in dispatch_method_frame to catch RESULT_RETURN while propagating others.
#define UNWRAP_ALSO(except_state, r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL && _r.state != (except_state))) return _r; \
    _r.value; \
})

// Push/pop a lightweight frame to record the current execution point.
// Used before creating inline exceptions (e.g., division by zero) so that
// the backtrace includes the correct source location.
// PUSH_FRAME opens a do { block; POP_FRAME closes it with } while (0).
// This scoping prevents accidental nesting of _push_frame variable names.
// Variables needed after POP_FRAME must be declared BEFORE PUSH_FRAME.
#define PUSH_FRAME(node) do { \
    struct abruby_frame _push_frame; \
    _push_frame.prev = c->current_frame; \
    _push_frame.method = NULL; \
    _push_frame.caller_node = (node); \
    _push_frame.block = NULL; \
    _push_frame.frame_id = ++c->frame_id_counter; \
    c->current_frame = &_push_frame

#define POP_FRAME() \
    c->current_frame = _push_frame.prev; \
    } while (0)

// helper functions (included before generated eval code)

// VM accessor helpers
#define CTX_MAIN_CLASS(c) (&(c)->abm->main_class_body)
#define CTX_GVARS(c)      (&(c)->abm->gvars)

// class system helpers

// Forward declarations so abruby_class_add_method can recognize attr_reader /
// attr_writer style bodies and mark the method as an IVAR accessor.
extern const struct NodeKind kind_node_ivar_get;
extern const struct NodeKind kind_node_ivar_set;
extern const struct NodeKind kind_node_lvar_get;

// Detect the AST shapes the parser emits for attr_reader / attr_writer:
//   def x;       @x;                     end  -> node_ivar_get
//   def x=(v);   @x = v;                 end  -> node_ivar_set(name, node_lvar_get(0))
// If matched, mark the method so the dispatch hot path skips the frame setup.
static inline bool
abruby_method_try_set_ivar_accessor(struct abruby_method *m, struct Node *body,
                                    unsigned int params_cnt)
{
    if (body == NULL) return false;
    if (params_cnt == 0 && body->head.kind == &kind_node_ivar_get) {
        m->type = ABRUBY_METHOD_IVAR_GETTER;
        m->u.ivar_accessor.ivar_name = body->u.node_ivar_get.name;
        return true;
    }
    if (params_cnt == 1 && body->head.kind == &kind_node_ivar_set) {
        const NODE *rhs = body->u.node_ivar_set.value;
        if (rhs && rhs->head.kind == &kind_node_lvar_get &&
            rhs->u.node_lvar_get.index == 0) {
            m->type = ABRUBY_METHOD_IVAR_SETTER;
            m->u.ivar_accessor.ivar_name = body->u.node_ivar_set.name;
            return true;
        }
    }
    return false;
}

static void
abruby_class_add_method(CTX *c, struct abruby_class *klass, ID name,
                        struct Node *body, unsigned int params_cnt, unsigned int locals_cnt,
                        const char *source_file)
{
    VALUE existing;
    if (ab_id_table_lookup(&klass->methods, name, &existing)) {
        struct abruby_method *m = (struct abruby_method *)existing;
        if (!abruby_method_try_set_ivar_accessor(m, body, params_cnt)) {
            m->type = ABRUBY_METHOD_AST;
            m->u.ast.body = body;
            m->u.ast.params_cnt = params_cnt;
            m->u.ast.locals_cnt = locals_cnt;
            m->u.ast.source_file = source_file;
        }
        c->abm->method_serial++;
        return;
    }
    struct abruby_method *m = ruby_xcalloc(1, sizeof(struct abruby_method));
    m->name = name;
    m->defining_class = klass;
    if (!abruby_method_try_set_ivar_accessor(m, body, params_cnt)) {
        m->type = ABRUBY_METHOD_AST;
        m->u.ast.body = body;
        m->u.ast.params_cnt = params_cnt;
        m->u.ast.locals_cnt = locals_cnt;
        m->u.ast.source_file = source_file;
    }
    ab_id_table_insert(&klass->methods, name, (VALUE)m);
    c->abm->method_serial++;
}

static struct abruby_method *
abruby_class_find_method(const struct abruby_class *klass, ID name)
{
    while (klass) {
        VALUE v;
        if (ab_id_table_lookup(&klass->methods, name, &v))
            return (struct abruby_method *)v;
        klass = klass->super;
    }
    return NULL;
}

static struct abruby_class *
find_class_in(const struct abruby_class *scope, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(&scope->constants, name, &v) && RB_TYPE_P(v, T_DATA)) {
        const struct abruby_header *h = (const struct abruby_header *)RTYPEDDATA_GET_DATA(v);
        if (h->klass->obj_type == ABRUBY_OBJ_CLASS || h->klass->obj_type == ABRUBY_OBJ_MODULE) {
            return (struct abruby_class *)h;
        }
    }
    return NULL;
}

static struct abruby_class *
find_class(const CTX *c, ID name)
{
    // Check per-instance main_class first, then per-instance Object
    struct abruby_class *klass = find_class_in(CTX_MAIN_CLASS(c), name);
    if (klass) return klass;
    if (CTX_MAIN_CLASS(c) != c->abm->object_class) {
        return find_class_in(c->abm->object_class, name);
    }
    return NULL;
}


extern VALUE abruby_new_object(struct abruby_class *klass);
extern void abruby_object_grow_ivars(struct abruby_object *obj, unsigned int new_cnt);

// === Literals ===

NODE_DEF
node_num(CTX * restrict c, NODE * restrict n, int32_t num)
{
    return RESULT_OK(INT2FIX(num));
}

extern VALUE abruby_float_new_wrap(CTX *c, VALUE rb_float);
extern VALUE abruby_bignum_new(CTX *c, VALUE rb_bignum);

NODE_DEF
node_float_new(CTX * restrict c, NODE * restrict n, double val)
{
    // Non-flonum fallback only. Flonum-representable literals are
    // pre-encoded at parse time by rb_alloc_node_float_new and routed
    // to node_literal instead.
    return RESULT_OK(abruby_float_new_wrap(c, rb_float_new(val)));
}

// Immediate-valued literal.  The uint64_t operand is any Ruby VALUE
// whose bit pattern is stable across processes — today only the CRuby
// flonum encoding (a pure function of the source double, computed once
// by rb_alloc_node_float_new via ab_flonum_encode); in the future,
// node_num/node_sym/node_true/node_false/node_nil could collapse into
// this node for uniform handling.  EVAL just returns the stored VALUE.
// The code store serializes the operand as a C integer literal.
NODE_DEF
node_literal(CTX * restrict c, NODE * restrict n, uint64_t val)
{
    (void)c; (void)n;
    return RESULT_OK((VALUE)val);
}

NODE_DEF
node_bignum_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_bignum_new(c, rb_cstr_to_inum(str, 10, 1)));
}

NODE_DEF
node_true(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qtrue);
}

NODE_DEF
node_false(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qfalse);
}

NODE_DEF
node_nil(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qnil);
}

NODE_DEF
node_str_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_str_new_cstr(c, str));
}

NODE_DEF
node_str_concat(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE result = rb_str_new(NULL, 0);
    for (uint32_t i = 0; i < argc; i++) {
        VALUE part = c->fp[arg_index + i];
        VALUE rs = abruby_str_rstr(part);
        rb_str_cat(result, RSTRING_PTR(rs), RSTRING_LEN(rs));
    }
    return RESULT_OK(abruby_str_new(c, result));
}

NODE_DEF
node_sym(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(ID2SYM(rb_intern(str)));
}

extern VALUE abruby_range_new(CTX *c, VALUE begin, VALUE end, bool exclude_end);

NODE_DEF
node_range_new(CTX * restrict c, NODE * restrict n, NODE *begin_node, NODE *end_node, uint32_t exclude_end)
{
    VALUE b = UNWRAP(EVAL_ARG(c, begin_node));
    VALUE e = UNWRAP(EVAL_ARG(c, end_node));
    return RESULT_OK(abruby_range_new(c, b, e, exclude_end != 0));
}

extern VALUE abruby_regexp_new(CTX *c, VALUE rb_regexp);

NODE_DEF
node_regexp_new(CTX * restrict c, NODE * restrict n, const char *source, const char *flags)
{
    int options = 0;
    for (const char *p = flags; *p; p++) {
        if (*p == 'i') options |= 1;  // ONIG_OPTION_IGNORECASE
        if (*p == 'x') options |= 2;  // ONIG_OPTION_EXTEND
        if (*p == 'm') options |= 4;  // ONIG_OPTION_MULTILINE
    }
    VALUE src = rb_str_new_cstr(source);
    VALUE re = rb_reg_new(RSTRING_PTR(src), RSTRING_LEN(src), options);
    return RESULT_OK(abruby_regexp_new(c, re));
}

NODE_DEF
node_self(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(c->self);
}

static RESULT
abruby_const_get(CTX *c, NODE *n, const struct abruby_class *klass, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(&klass->constants, name, &v))
        return RESULT_OK(v);
    VALUE exc;
    PUSH_FRAME(n);
    exc = abruby_exception_new(c, c->current_frame,
        abruby_str_new_cstr(c,"uninitialized constant"));
    POP_FRAME();
    return (RESULT){exc, RESULT_RAISE};
}

NODE_DEF
node_const_path_get(CTX * restrict c, NODE * restrict n, ID parent_name, ID name)
{
    const struct abruby_class *klass = find_class(c, parent_name);
    if (!klass) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c,"uninitialized constant"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    return abruby_const_get(c, n, klass, name);
}

NODE_DEF
node_const_set(CTX * restrict c, NODE * restrict n, ID name, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    struct abruby_class *scope = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    abruby_class_set_const(scope, name, v);
    return RESULT_OK(v);
}

NODE_DEF
node_const_get(CTX * restrict c, NODE * restrict n, ID name)
{
    // Check main_class first, then Object
    VALUE v;
    if (ab_id_table_lookup(&CTX_MAIN_CLASS(c)->constants, name, &v))
        return RESULT_OK(v);
    if (CTX_MAIN_CLASS(c) != c->abm->object_class) {
        return abruby_const_get(c, n, c->abm->object_class, name);
    }
    VALUE exc;
    PUSH_FRAME(n);
    exc = abruby_exception_new(c, c->current_frame,
        abruby_str_new_cstr(c,"uninitialized constant"));
    POP_FRAME();
    return (RESULT){exc, RESULT_RAISE};
}

// === Array / Hash literals ===

NODE_DEF
node_ary_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE ary = rb_ary_new_capa(argc);
    for (uint32_t i = 0; i < argc; i++) {
        rb_ary_push(ary, c->fp[arg_index + i]);
    }
    return RESULT_OK(abruby_ary_new(c, ary));
}

// Convert abruby value to CRuby value for use as Hash key
static VALUE
ab_to_hash_key(VALUE v)
{
    if (FIXNUM_P(v) || SYMBOL_P(v) || RB_FLONUM_P(v) ||
        v == Qtrue || v == Qfalse || v == Qnil) return v;
    const struct abruby_header *h = (const struct abruby_header *)RTYPEDDATA_GET_DATA(v);
    if (h->klass->obj_type == ABRUBY_OBJ_STRING) return ((const struct abruby_string *)h)->rb_str;
    return v; // user objects as-is (identity based)
}

NODE_DEF
node_hash_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE hash = rb_hash_new();
    for (uint32_t i = 0; i < argc; i += 2) {
        rb_hash_aset(hash, ab_to_hash_key(c->fp[arg_index + i]), c->fp[arg_index + i + 1]);
    }
    return RESULT_OK(abruby_hash_new_wrap(c, hash));
}

// === Instance Variables ===

// Slow path for ivar get cache miss: consult the class shape, update the IC.
static __attribute__((noinline)) VALUE
node_ivar_get_slow(const struct abruby_object *obj, ID name, struct ivar_cache *ic)
{
    VALUE slot_fix;
    if (ab_id_table_lookup(&obj->klass->ivar_shape, name, &slot_fix)) {
        unsigned int slot = (unsigned int)FIX2ULONG(slot_fix);
        ic->klass = obj->klass;
        ic->slot = slot;
        if (slot < obj->ivar_cnt) {
            return abruby_object_ivar_read(obj, slot);
        }
    }
    return Qnil;
}

NODE_DEF
node_ivar_get(CTX * restrict c, NODE * restrict n, ID name, struct ivar_cache *ic@ref)
{
    ab_verify(c->self);
    const struct abruby_object *obj =
        (const struct abruby_object *)RTYPEDDATA_GET_DATA(c->self);
    if (LIKELY(ic->klass == obj->klass && ic->slot < obj->ivar_cnt)) {
        // Branch-free inline slot fast path: most ivars fit inline.
        if (LIKELY(ic->slot < ABRUBY_OBJECT_INLINE_IVARS)) {
            return RESULT_OK(obj->ivars[ic->slot]);
        }
        return RESULT_OK(obj->extra_ivars[ic->slot - ABRUBY_OBJECT_INLINE_IVARS]);
    }
    return RESULT_OK(node_ivar_get_slow(obj, name, ic));
}

static __attribute__((noinline)) void
node_ivar_set_slow(struct abruby_object *obj, ID name, VALUE v, struct ivar_cache *ic)
{
    // Look up the slot in the class shape; add it if new.
    struct abruby_class *klass = (struct abruby_class *)obj->klass;
    VALUE slot_fix;
    unsigned int slot;
    if (ab_id_table_lookup(&klass->ivar_shape, name, &slot_fix)) {
        slot = (unsigned int)FIX2ULONG(slot_fix);
    } else {
        slot = klass->ivar_shape.cnt;
        ab_id_table_insert(&klass->ivar_shape, name, LONG2FIX((long)slot));
    }
    abruby_object_grow_ivars(obj, slot + 1);
    if (slot < ABRUBY_OBJECT_INLINE_IVARS) {
        obj->ivars[slot] = v;
    } else {
        obj->extra_ivars[slot - ABRUBY_OBJECT_INLINE_IVARS] = v;
    }
    ic->klass = obj->klass;
    ic->slot = slot;
}

NODE_DEF
node_ivar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *value, struct ivar_cache *ic@ref)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    ab_verify(c->self);
    if (UNLIKELY(!RB_TYPE_P(c->self, T_DATA))) {
        rb_raise(rb_eRuntimeError, "can't set instance variable on non-object");
    }
    struct abruby_object *obj =
        (struct abruby_object *)RTYPEDDATA_GET_DATA(c->self);
    if (LIKELY(ic->klass == obj->klass && ic->slot < obj->ivar_cnt)) {
        if (LIKELY(ic->slot < ABRUBY_OBJECT_INLINE_IVARS)) {
            obj->ivars[ic->slot] = v;
        } else {
            obj->extra_ivars[ic->slot - ABRUBY_OBJECT_INLINE_IVARS] = v;
        }
        return RESULT_OK(v);
    }
    node_ivar_set_slow(obj, name, v, ic);
    return RESULT_OK(v);
}

// === Global Variables ===

static VALUE
abruby_gvar_get(CTX *c, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(CTX_GVARS(c), name, &v)) return v;
    return Qnil;
}

static void
abruby_gvar_set(CTX *c, ID name, VALUE val)
{
    ab_id_table_insert(CTX_GVARS(c), name, val);
}

NODE_DEF
node_gvar_get(CTX * restrict c, NODE * restrict n, ID name)
{
    return RESULT_OK(abruby_gvar_get(c, name));
}

NODE_DEF
node_gvar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    abruby_gvar_set(c, name, v);
    return RESULT_OK(v);
}

// === Local Variables ===

NODE_DEF
node_lvar_get(CTX * restrict c, NODE * restrict n, uint32_t index)
{
    return RESULT_OK(c->fp[index]);
}

NODE_DEF
node_lvar_set(CTX * restrict c, NODE * restrict n, uint32_t index, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    c->fp[index] = v;
    return RESULT_OK(v);
}

// === Control Flow ===

NODE_DEF
node_scope(CTX * restrict c, NODE * restrict n, uint32_t envsize, NODE *body)
{
    c->fp += envsize;
    RESULT r = EVAL_ARG(c, body);
    c->fp -= envsize;
    return r;
}

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, NODE *head, NODE *tail)
{
    UNWRAP(EVAL_ARG(c, head));
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *then_node, NODE *else_node)
{
    if (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    while (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        RESULT r = EVAL_ARG(c, body);
        if (UNLIKELY(r.state != RESULT_NORMAL)) {
            if (r.state == RESULT_BREAK) return RESULT_OK(r.value);
            return r;
        }
    }
    return RESULT_OK(Qnil);
}

NODE_DEF
node_break(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_BREAK};
}

// === Non-local exit ===

NODE_DEF
node_return(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    // Non-local return target:
    //   - executing inside a block body: target the block's defining
    //     frame so the return unwinds past intervening yielding methods.
    //   - otherwise: target=0 (wildcard) catches at the nearest method
    //     boundary, matching pre-block semantics exactly.
    if (UNLIKELY(c->in_block)) {
        c->return_target_frame_id = c->current_block->defining_frame->frame_id;
    } else {
        c->return_target_frame_id = 0;
    }
    return (RESULT){v, RESULT_RETURN};
}

// `next` inside a block returns (value) to the yielding call site, which
// demotes NEXT back to NORMAL with that value.  Outside a block this still
// propagates RESULT_NEXT; there is no enclosing catcher, so a LocalJumpError
// is the intended Ruby behavior.  In MVP we leave that to fall out naturally.
NODE_DEF
node_next(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_NEXT};
}

// Data-only node carrying a block literal attached to a call site.  Parser
// emits it as the `block_literal` operand of a node_*_call_with_block; the
// call node unpacks `body`, `params_cnt`, `param_base` directly from the
// NODE union at dispatch time.  It should never be dispatched on its own;
// the @noinline annotation keeps it out of specialization, and the body is
// a safety net that returns nil (asserting in debug builds).
NODE_DEF @noinline
node_block_literal(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t params_cnt, uint32_t param_base)
{
    (void)c; (void)body; (void)params_cnt; (void)param_base;
    ABRUBY_ASSERT(!"node_block_literal must not be EVAL'd directly");
    (void)n;
    return RESULT_OK(Qnil);
}

// `yield args` from within an AST method body.
// Looks up the block attached to the current frame, transfers argc values
// into the block's captured frame at param_base, swaps the execution context
// into the block (fp/self/current_block/in_block), evaluates the block body,
// then restores the swapped state.  NEXT is demoted to NORMAL here so `next`
// returns from the block cleanly; BREAK / RAISE / RETURN keep propagating.
NODE_DEF
node_yield(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    const struct abruby_block *blk = c->current_frame->block;
    if (UNLIKELY(blk == NULL)) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c, "no block given (yield)"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }

    // Transfer args into the block's captured fp at param_base.
    // Missing args default to nil; extra args are dropped (MVP semantics
    // — matches the Ruby "proc" (not lambda) convention, which is the
    // right one for `yield`).
    uint32_t n_params = blk->params_cnt;
    uint32_t n_copy = argc < n_params ? argc : n_params;
    for (uint32_t i = 0; i < n_copy; i++) {
        blk->captured_fp[blk->param_base + i] = c->fp[arg_index + i];
    }
    for (uint32_t i = n_copy; i < n_params; i++) {
        blk->captured_fp[blk->param_base + i] = Qnil;
    }

    // Swap execution context into the block's captured environment.
    // current_frame is rerouted to the defining frame so that `yield`
    // and `super` inside the block body see the *enclosing method's*
    // context, not the method currently yielding (which is the Ruby
    // semantics: `yield` is bound at the block's definition site).
    VALUE *save_fp = c->fp;
    VALUE save_self = c->self;
    struct abruby_frame *save_frame = c->current_frame;
    const struct abruby_block *save_current_block = c->current_block;
    bool save_in_block = c->in_block;

    c->fp = blk->captured_fp;
    c->self = blk->captured_self;
    c->current_frame = blk->defining_frame;
    c->current_block = blk;
    c->in_block = true;

    RESULT r = EVAL(c, blk->body);

    c->fp = save_fp;
    c->self = save_self;
    c->current_frame = save_frame;
    c->current_block = save_current_block;
    c->in_block = save_in_block;

    // Demote NEXT → NORMAL (value retained).  BREAK / RAISE / RETURN
    // pass through for upper-layer catches.
    r.state &= ~(unsigned)RESULT_NEXT;
    return r;
}

NODE_DEF
node_rescue(CTX * restrict c, NODE * restrict n, NODE *body, NODE *rescue_body, NODE *ensure_body, uint32_t exception_lvar_index)
{
    RESULT r = EVAL_ARG(c, body);

    if (r.state == RESULT_RAISE) {
        if (exception_lvar_index != UINT32_MAX) {
            c->fp[exception_lvar_index] = r.value;
        }
        r = EVAL_ARG(c, rescue_body);
    }

    // ensure: always run; raise/return in ensure overrides original
    RESULT er = EVAL_ARG(c, ensure_body);
    if (er.state != RESULT_NORMAL) return er;

    return r;
}

// === Method definition & call ===

NODE_DEF @noinline
node_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body, uint32_t params_cnt, uint32_t locals_cnt)
{
    struct abruby_class *klass = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    // Derive source file from current frame
    const char *file = NULL;
    if (c->current_frame) {
        if (c->current_frame->method && c->current_frame->method->type == ABRUBY_METHOD_AST)
            file = c->current_frame->method->u.ast.source_file;
        else
            file = c->current_frame->source_file;  // <main>/<top>
    }
    abruby_class_add_method(c, klass, name, body, params_cnt, locals_cnt, file);
    return RESULT_OK(Qnil);
}

// === OOP: class, method call with receiver, new ===

NODE_DEF @noinline
node_module_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body)
{
    struct abruby_class *mod = find_class(c, name);
    if (!mod) {
        mod = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        mod->klass = c->abm->module_class;
        mod->obj_type = ABRUBY_OBJ_MODULE;
        mod->name = name;
        mod->super = NULL;
        abruby_class_set_const(CTX_MAIN_CLASS(c), name, abruby_wrap_class(mod));
    }

    struct abruby_class *save_class = c->current_class;
    VALUE save_self = c->self;
    c->current_class = mod;
    c->self = abruby_wrap_class(mod);
    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->self = save_self;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(mod));
}

NODE_DEF @noinline
node_class_def(CTX * restrict c, NODE * restrict n, ID name, NODE *super_expr, NODE *body)
{
    struct abruby_class *klass = find_class(c, name);
    if (!klass) {
        struct abruby_class *super = c->abm->object_class;
        VALUE sv = UNWRAP(EVAL_ARG(c, super_expr));
        if (sv != Qnil) {
            if (AB_CLASS_OF(c, sv) != c->abm->class_class) {
                VALUE exc;
                PUSH_FRAME(n);
                exc = abruby_exception_new(c, c->current_frame,
                    abruby_str_new_cstr(c,"superclass must be a Class"));
                POP_FRAME();
                return (RESULT){exc, RESULT_RAISE};
            }
            super = abruby_unwrap_class(sv);
        }
        klass = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        klass->klass = c->abm->class_class;
        klass->obj_type = ABRUBY_OBJ_GENERIC;  // instances are user objects
        klass->name = name;
        klass->super = super;
        abruby_class_set_const(CTX_MAIN_CLASS(c), name, abruby_wrap_class(klass));
    }

    struct abruby_class *save_class = c->current_class;
    VALUE save_self = c->self;
    c->current_class = klass;
    c->self = abruby_wrap_class(klass);
    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->self = save_self;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(klass));
}

// Populate cached fields in method_cache.
static inline void
method_cache_fill(CTX *c, struct method_cache *mc, const struct abruby_class *klass,
                  const struct abruby_method *method)
{
    mc->klass = klass;
    mc->method = method;
    mc->serial = c->abm->method_serial;
    mc->ivar_slot = 0;
    if (method->type == ABRUBY_METHOD_AST) {
        mc->body = method->u.ast.body;
        mc->dispatcher = method->u.ast.body->head.dispatcher;
    } else if (method->type == ABRUBY_METHOD_IVAR_GETTER ||
               method->type == ABRUBY_METHOD_IVAR_SETTER) {
        mc->body = NULL;
        mc->dispatcher = NULL;
        // Resolve (or register) the ivar's slot in the receiver's class shape.
        struct abruby_class *klass_mut = (struct abruby_class *)klass;
        ID ivar_name = method->u.ivar_accessor.ivar_name;
        VALUE slot_fix;
        if (ab_id_table_lookup(&klass_mut->ivar_shape, ivar_name, &slot_fix)) {
            mc->ivar_slot = (uint32_t)FIX2ULONG(slot_fix);
        } else {
            uint32_t new_slot = klass_mut->ivar_shape.cnt;
            ab_id_table_insert(&klass_mut->ivar_shape, ivar_name, LONG2FIX((long)new_slot));
            mc->ivar_slot = new_slot;
        }
    } else {
        mc->body = NULL;
        mc->dispatcher = NULL;
    }
}

// Inner dispatch using cached method_cache.
// Does NOT save/restore c->self — caller is responsible.
// Cache hit paths call this directly; non-cache paths go through dispatch_method_with_klass.
static inline RESULT
dispatch_method_frame(CTX * restrict c, NODE * restrict call_site,
                      const struct method_cache *mc,
                      unsigned int argc, uint32_t arg_index)
{
    // Fast path: attr_reader / attr_writer. Skip the frame dance entirely
    // and touch obj->ivars[slot] directly. mc->ivar_slot was resolved at
    // fill time from mc->klass's shape; if the receiver's class matches, we
    // can use it directly. When it differs (e.g. super call where the method
    // is inherited), fall back to looking up the slot in the receiver's own
    // class shape so inherited attr_accessors see per-subclass ivar layout.
    enum abruby_method_type mtype = mc->method->type;
    if (mtype == ABRUBY_METHOD_IVAR_GETTER) {
        const struct abruby_object *obj =
            (const struct abruby_object *)RTYPEDDATA_GET_DATA(c->self);
        unsigned int slot;
        if (LIKELY(mc->klass == obj->klass)) {
            slot = mc->ivar_slot;
        } else {
            VALUE slot_fix;
            if (!ab_id_table_lookup(&obj->klass->ivar_shape,
                                    mc->method->u.ivar_accessor.ivar_name, &slot_fix)) {
                return RESULT_OK(Qnil);
            }
            slot = (unsigned int)FIX2ULONG(slot_fix);
        }
        if (LIKELY(slot < obj->ivar_cnt)) {
            return RESULT_OK(abruby_object_ivar_read(obj, slot));
        }
        return RESULT_OK(Qnil);
    }
    if (mtype == ABRUBY_METHOD_IVAR_SETTER) {
        struct abruby_object *obj =
            (struct abruby_object *)RTYPEDDATA_GET_DATA(c->self);
        VALUE v = c->fp[arg_index];
        unsigned int slot;
        if (LIKELY(mc->klass == obj->klass)) {
            slot = mc->ivar_slot;
        } else {
            struct abruby_class *obj_klass = obj->klass;
            ID ivar_name = mc->method->u.ivar_accessor.ivar_name;
            VALUE slot_fix;
            if (ab_id_table_lookup(&obj_klass->ivar_shape, ivar_name, &slot_fix)) {
                slot = (unsigned int)FIX2ULONG(slot_fix);
            } else {
                slot = obj_klass->ivar_shape.cnt;
                ab_id_table_insert(&obj_klass->ivar_shape, ivar_name, LONG2FIX((long)slot));
            }
        }
        if (slot >= obj->ivar_cnt) abruby_object_grow_ivars(obj, slot + 1);
        if (LIKELY(slot < ABRUBY_OBJECT_INLINE_IVARS)) {
            obj->ivars[slot] = v;
        } else {
            obj->extra_ivars[slot - ABRUBY_OBJECT_INLINE_IVARS] = v;
        }
        return RESULT_OK(v);
    }

    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.method = mc->method;
    frame.caller_node = call_site;
    frame.block = NULL;
    frame.frame_id = ++c->frame_id_counter;
    c->current_frame = &frame;

    RESULT r;
    if (LIKELY(mc->body != NULL)) {
        VALUE *save_fp = c->fp;
        c->fp = save_fp + arg_index;
        r = mc->dispatcher(c, mc->body);
        c->fp = save_fp;
        // Method boundary catch:
        //   RETURN is caught iff return_target_frame_id is 0 (wildcard,
        //   the common case — plain `return` inside this method) or it
        //   names this frame (non-local return from a block whose
        //   defining frame is this one).  Otherwise RETURN keeps
        //   propagating up to its true target.
        //   RAISE/BREAK/NEXT stay set for the caller's UNWRAP.
        uint32_t tgt = c->return_target_frame_id;
        if (tgt == 0 || tgt == frame.frame_id) {
            r.state &= ~(unsigned)RESULT_RETURN;
            c->return_target_frame_id = 0;
        }
    } else {
        r = mc->method->u.cfunc.func(c, c->self, argc, c->fp + arg_index);
    }

    c->current_frame = frame.prev;
    return r;
}

// Outer dispatch for non-cache paths: build temp mc, save/restore self.
// Used by method_missing_dispatch, node_super, node_arith_fallback.
static inline RESULT
dispatch_method_with_klass(CTX * restrict c, NODE * restrict call_site,
                           VALUE recv, const struct abruby_class *klass,
                           const struct abruby_method *method,
                           unsigned int argc, uint32_t arg_index)
{
    struct method_cache mc;
    method_cache_fill(c, &mc, klass, method);
    VALUE save_self = c->self;
    c->self = recv;
    RESULT r = dispatch_method_frame(c, call_site, &mc, argc, arg_index);
    c->self = save_self;
    return r;
}

// Block-carrying variant of dispatch_method_frame.
// Same structure as dispatch_method_frame but:
//   - Installs `blk` on the pushed frame.
//   - On method boundary, also demotes RESULT_BREAK (break from the
//     block lands here — Ruby semantics).
// IVAR_GETTER/SETTER fast path is NOT taken: block-carrying calls always
// go through a full frame so the block is visible to a `yield` inside.
// The ivar-accessor optimization is irrelevant anyway when a block is
// attached (Ruby-side warning-and-ignore; we just ignore).
static inline RESULT
dispatch_method_frame_with_block(CTX * restrict c, NODE * restrict call_site,
                                 const struct method_cache *mc,
                                 unsigned int argc, uint32_t arg_index,
                                 const struct abruby_block *blk)
{
    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.method = mc->method;
    frame.caller_node = call_site;
    frame.block = blk;
    frame.frame_id = ++c->frame_id_counter;
    c->current_frame = &frame;

    RESULT r;
    if (LIKELY(mc->body != NULL)) {
        VALUE *save_fp = c->fp;
        c->fp = save_fp + arg_index;
        r = mc->dispatcher(c, mc->body);
        c->fp = save_fp;
    } else {
        r = mc->method->u.cfunc.func(c, c->self, argc, c->fp + arg_index);
    }

    // Method boundary catch:
    //   BREAK → always demoted (the block that broke was passed to *this* method).
    //   RETURN → demoted if target matches (wildcard or this frame_id).
    //   RAISE / NEXT are not touched.
    uint32_t tgt = c->return_target_frame_id;
    if (tgt == 0 || tgt == frame.frame_id) {
        r.state &= ~(unsigned)(RESULT_RETURN | RESULT_BREAK);
        c->return_target_frame_id = 0;
    } else {
        r.state &= ~(unsigned)RESULT_BREAK;
    }

    c->current_frame = frame.prev;
    return r;
}

// Slow-path wrapper that fills a method_cache and delegates to the
// block-carrying dispatcher.  Saves/restores self like
// dispatch_method_with_klass does.
static inline RESULT
dispatch_method_with_klass_with_block(CTX * restrict c, NODE * restrict call_site,
                                      VALUE recv, const struct abruby_class *klass,
                                      const struct abruby_method *method,
                                      unsigned int argc, uint32_t arg_index,
                                      const struct abruby_block *blk)
{
    struct method_cache mc;
    method_cache_fill(c, &mc, klass, method);
    VALUE save_self = c->self;
    c->self = recv;
    RESULT r = dispatch_method_frame_with_block(c, call_site, &mc, argc, arg_index, blk);
    c->self = save_self;
    return r;
}

static __attribute__((noinline)) RESULT
method_missing_dispatch(CTX * restrict c, NODE * restrict n, const struct abruby_class *klass,
                        ID name, VALUE recv_val,
                        uint32_t params_cnt, uint32_t arg_index)
{
    const struct abruby_method *mm = abruby_class_find_method(klass, c->ids->method_missing);
    if (!mm) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c,"undefined method"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    // shift args by 1, insert method name as first arg
    for (int i = (int)params_cnt - 1; i >= 0; i--) {
        c->fp[arg_index + i + 1] = c->fp[arg_index + i];
    }
    c->fp[arg_index] = abruby_str_new_cstr(c,rb_id2name(name));
    return dispatch_method_with_klass(c, n, recv_val, klass, mm, params_cnt + 1, arg_index);
}

// Not marked `cold`: polymorphic dispatch sites (e.g. bm_dispatch) hit this
// path every other iteration, and sending it to the cold section wrecks icache.
static __attribute__((noinline)) RESULT
node_method_call_slow(CTX * restrict c, NODE * restrict n,
                      VALUE recv_val, const struct abruby_class *klass, ID name,
                      uint32_t params_cnt, uint32_t arg_index,
                      struct method_cache *mc)
{
    const struct abruby_method *method = abruby_class_find_method(klass, name);
    if (UNLIKELY(method == NULL)) {
        return method_missing_dispatch(c, n, klass, name, recv_val, params_cnt, arg_index);
    }
    method_cache_fill(c, mc, klass, method);
    return dispatch_method_with_klass(c, n, recv_val, klass, method, params_cnt, arg_index);
}

NODE_DEF
node_method_call(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t params_cnt, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);

    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        VALUE save_self = c->self;
        c->self = recv_val;
        RESULT r = dispatch_method_frame(c, n, mc, params_cnt, arg_index);
        c->self = save_self;
        return r;
    }
    else {
        return node_method_call_slow(c, n, recv_val, klass, name, params_cnt, arg_index, mc);
    }
}

// Function call (implicit self as receiver, no recv operand).
// Uses dispatch_method_frame directly (no self save/restore needed).
// Shares node_method_call_slow for cache miss path.
NODE_DEF
node_func_call(CTX * restrict c, NODE * restrict n, ID name, uint32_t params_cnt, uint32_t arg_index, struct method_cache *mc@ref)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, c->self);

    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return dispatch_method_frame(c, n, mc,
                                     params_cnt, arg_index);
    }
    else {
        return node_method_call_slow(c, n, c->self, klass, name,
                                     params_cnt, arg_index, mc);
    }
}

// === Block-carrying call nodes ===
//
// Parser routes every call that has a block literal (`{ ... }` / `do..end`)
// to these nodes.  Block-less call paths are unchanged so the block-less
// hot path pays zero extra cost.
//
// Common contract:
//   - block_literal is a NODE * whose kind is node_block_literal; its
//     union field holds (body, params_cnt, param_base).
//   - At call time we materialize a `struct abruby_block` on the C stack,
//     capturing the caller's fp/self/frame_id so `yield` in the callee
//     (or in cfunc via abruby_yield) can execute the block closure.
//   - Dispatch goes through dispatch_method_frame_with_block, which sets
//     frame.block = blk and demotes RESULT_BREAK on method boundary.

static __attribute__((noinline)) RESULT
node_method_call_with_block_slow(CTX * restrict c, NODE * restrict n,
                                 VALUE recv_val, const struct abruby_class *klass, ID name,
                                 uint32_t params_cnt, uint32_t arg_index,
                                 struct method_cache *mc,
                                 const struct abruby_block *blk)
{
    const struct abruby_method *method = abruby_class_find_method(klass, name);
    if (UNLIKELY(method == NULL)) {
        // method_missing: block is silently dropped in MVP.  Ruby passes
        // the block through to method_missing, but that adds complexity we
        // do not need for Phase 1 iterators.
        return method_missing_dispatch(c, n, klass, name, recv_val, params_cnt, arg_index);
    }
    method_cache_fill(c, mc, klass, method);
    return dispatch_method_with_klass_with_block(c, n, recv_val, klass, method,
                                                 params_cnt, arg_index, blk);
}

NODE_DEF
node_method_call_with_block(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t params_cnt, uint32_t arg_index, struct method_cache *mc@ref, NODE *block_literal)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    const struct abruby_class *klass = AB_CLASS_OF(c, recv_val);

    struct abruby_block blk;
    blk.body              = block_literal->u.node_block_literal.body;
    blk.captured_fp       = c->fp;
    blk.captured_self     = c->self;
    blk.defining_frame    = c->current_frame;
    blk.params_cnt        = block_literal->u.node_block_literal.params_cnt;
    blk.param_base        = block_literal->u.node_block_literal.param_base;

    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        VALUE save_self = c->self;
        c->self = recv_val;
        RESULT r = dispatch_method_frame_with_block(c, n, mc, params_cnt, arg_index, &blk);
        c->self = save_self;
        return r;
    }
    else {
        return node_method_call_with_block_slow(c, n, recv_val, klass, name,
                                                params_cnt, arg_index, mc, &blk);
    }
}

NODE_DEF
node_func_call_with_block(CTX * restrict c, NODE * restrict n, ID name, uint32_t params_cnt, uint32_t arg_index, struct method_cache *mc@ref, NODE *block_literal)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, c->self);

    struct abruby_block blk;
    blk.body              = block_literal->u.node_block_literal.body;
    blk.captured_fp       = c->fp;
    blk.captured_self     = c->self;
    blk.defining_frame    = c->current_frame;
    blk.params_cnt        = block_literal->u.node_block_literal.params_cnt;
    blk.param_base        = block_literal->u.node_block_literal.param_base;

    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return dispatch_method_frame_with_block(c, n, mc, params_cnt, arg_index, &blk);
    }
    else {
        return node_method_call_with_block_slow(c, n, c->self, klass, name,
                                                params_cnt, arg_index, mc, &blk);
    }
}

// === super ===

// Find the super method: walk from method->defining_class->super looking for the same name.
static struct abruby_method *
find_super_method(const struct abruby_frame *frame)
{
    if (!frame || !frame->method || !frame->method->defining_class) return NULL;
    ID name = frame->method->name;
    const struct abruby_class *klass = frame->method->defining_class->super;
    return abruby_class_find_method(klass, name);
}

// super(args) — call parent method with explicit arguments.
// Any block the current method received is implicitly forwarded to the
// parent (matching Ruby), unless the parser emitted node_super_with_block
// for an explicit `super(...) { ... }` form.
NODE_DEF
node_super(CTX * restrict c, NODE * restrict n, uint32_t params_cnt, uint32_t arg_index)
{
    const struct abruby_method *method = find_super_method(c->current_frame);
    if (!method) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c,"super: no superclass method"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    // dispatch via the defining class (receiver stays the same).
    const struct abruby_class *klass = method->defining_class;
    const struct abruby_block *inherited = c->current_frame->block;
    if (inherited != NULL) {
        return dispatch_method_with_klass_with_block(c, n, c->self, klass, method,
                                                     params_cnt, arg_index, inherited);
    }
    return dispatch_method_with_klass(c, n, c->self, klass, method, params_cnt, arg_index);
}

// Explicit `super(args) { |x| ... }` — parser routes here when an
// explicit block literal is supplied at the super call site.  The
// caller-provided block always wins over the implicitly inherited one.
NODE_DEF
node_super_with_block(CTX * restrict c, NODE * restrict n, uint32_t params_cnt, uint32_t arg_index, NODE *block_literal)
{
    const struct abruby_method *method = find_super_method(c->current_frame);
    if (!method) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr(c,"super: no superclass method"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    struct abruby_block blk;
    blk.body              = block_literal->u.node_block_literal.body;
    blk.captured_fp       = c->fp;
    blk.captured_self     = c->self;
    blk.defining_frame    = c->current_frame;
    blk.params_cnt        = block_literal->u.node_block_literal.params_cnt;
    blk.param_base        = block_literal->u.node_block_literal.param_base;
    const struct abruby_class *klass = method->defining_class;
    return dispatch_method_with_klass_with_block(c, n, c->self, klass, method,
                                                 params_cnt, arg_index, &blk);
}

// === Arithmetic rewrite (type-specific nodes) ===

// Forward decl: default Object#==. When method dispatch resolves to this
// function we skip the full dispatch and use identity comparison directly.
extern RESULT ab_object_eq(CTX *c, VALUE self, unsigned int argc, VALUE *argv);

// Fallback: general method call for arithmetic operators (recv=lv, arg=rv)
static __attribute__((noinline, cold)) RESULT
node_arith_fallback(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, ID op, uint32_t arg_index)
{
    const struct abruby_class *klass = AB_CLASS_OF(c, lv);
    const struct abruby_method *method = abruby_class_find_method(klass, op);
    // Inline default Object#== when it resolves here: short-circuit the
    // dispatch to a pointer comparison. Correct so long as the class hasn't
    // overridden == (method would not be ab_object_eq in that case).
    if (method && method->type == ABRUBY_METHOD_CFUNC &&
        method->u.cfunc.func == ab_object_eq) {
        return RESULT_OK(lv == rv ? Qtrue : Qfalse);
    }
    if (!method) {
        method = abruby_class_find_method(klass, c->ids->method_missing);
        if (!method) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr(c,"undefined method"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        c->fp[arg_index] = abruby_str_new_cstr(c,rb_id2name(op));
        c->fp[arg_index + 1] = rv;
        return dispatch_method_with_klass(c, n, lv, klass, method, 2, arg_index);
    }
    c->fp[arg_index] = rv;
    return dispatch_method_with_klass(c, n, lv, klass, method, 1, arg_index);
}

// Integer arithmetic helper (works for both fixnum and bignum)
static inline bool
ab_is_integer(VALUE v)
{
    return FIXNUM_P(v) || ab_obj_type_p(v, ABRUBY_OBJ_BIGNUM);
}

// Float type check (Flonum immediate or heap Float wrapped in abruby_float)
static inline bool
ab_is_float(VALUE v)
{
    return RB_FLONUM_P(v) || ab_obj_type_p(v, ABRUBY_OBJ_FLOAT);
}

// Forward declarations for cross-referencing dispatchers
static RESULT DISPATCH_node_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_div(CTX *c, NODE *n);

extern const struct NodeKind kind_node_plus;
extern const struct NodeKind kind_node_fixnum_plus;
extern const struct NodeKind kind_node_integer_plus;
extern const struct NodeKind kind_node_flonum_plus;
extern const struct NodeKind kind_node_minus;
extern const struct NodeKind kind_node_fixnum_minus;
extern const struct NodeKind kind_node_integer_minus;
extern const struct NodeKind kind_node_flonum_minus;
extern const struct NodeKind kind_node_mul;
extern const struct NodeKind kind_node_fixnum_mul;
extern const struct NodeKind kind_node_integer_mul;
extern const struct NodeKind kind_node_flonum_mul;
extern const struct NodeKind kind_node_div;
extern const struct NodeKind kind_node_fixnum_div;
extern const struct NodeKind kind_node_integer_div;
extern const struct NodeKind kind_node_flonum_div;

// Integer calc helpers (used by fixnum_*_slow and integer_* nodes).
// Use rb_big_* directly when a Bignum is involved to skip rb_funcall overhead.
// rb_big_*(x, y) requires x to be a Bignum but accepts any y.
static inline RESULT
integer_plus_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM))      result = rb_big_plus(l, r);
    else if (RB_TYPE_P(r, T_BIGNUM)) result = rb_big_plus(r, l);  // commutative
    else                     result = rb_funcall(l, c->ids->op_plus, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

static inline RESULT
integer_minus_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM)) result = rb_big_minus(l, r);
    else                result = rb_funcall(l, c->ids->op_minus, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

static inline RESULT
integer_mul_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM))      result = rb_big_mul(l, r);
    else if (RB_TYPE_P(r, T_BIGNUM)) result = rb_big_mul(r, l);  // commutative
    else                     result = rb_funcall(l, c->ids->op_mul, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

static inline RESULT
integer_div_calc(CTX *c, VALUE lv, VALUE rv)
{
    VALUE l = AB_INT_UNWRAP(lv), r = AB_INT_UNWRAP(rv);
    VALUE result;
    if (RB_TYPE_P(l, T_BIGNUM)) result = rb_big_div(l, r);
    else                result = rb_funcall(l, c->ids->op_div, 1, r);
    return RESULT_OK(AB_NUM_WRAP(c, result));
}

// Wrap a double result back into an abruby value.  Uses the inline
// flonum encoder so the common case never calls rb_float_new.  Only
// out-of-range doubles (NaN/Inf/denormals/0x3000…) fall back to the
// heap-allocated abruby_float wrapper.
static inline RESULT
flonum_result(CTX *c, double d)
{
    VALUE flo = ab_flonum_encode(d);
    if (LIKELY(flo != 0)) return RESULT_OK(flo);
    return RESULT_OK(abruby_float_new_wrap(c, rb_float_new(d)));
}

// Float calc helpers (used by fixnum_*_slow promotion and flonum_* nodes).
// Input values must pass ab_is_float().
static inline RESULT
flonum_plus_calc(CTX *c, VALUE lv, VALUE rv)
{
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) + AB_FLOAT_TO_DOUBLE(rv));
}

static inline RESULT
flonum_minus_calc(CTX *c, VALUE lv, VALUE rv)
{
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) - AB_FLOAT_TO_DOUBLE(rv));
}

static inline RESULT
flonum_mul_calc(CTX *c, VALUE lv, VALUE rv)
{
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) * AB_FLOAT_TO_DOUBLE(rv));
}

static inline RESULT
flonum_div_calc(CTX *c, VALUE lv, VALUE rv)
{
    // Float division: no ZeroDivisionError; IEEE 754 handles 0 → inf/nan.
    return flonum_result(c, AB_FLOAT_TO_DOUBLE(lv) / AB_FLOAT_TO_DOUBLE(rv));
}

// Dispatcher swap: change the dispatcher without creating a new node.
// kind is also updated for consistency (DUMP, HASH).
static inline void
swap_dispatcher(NODE *n, const struct NodeKind *target_kind)
{
    if (n->head.kind != target_kind) {
        n->head.dispatcher = target_kind->default_dispatcher;
        n->head.kind = target_kind;
    }
}

// node_plus: generic fallback (method dispatch via "+")
NODE_DEF
node_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_plus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_float(lv) && ab_is_float(rv)) {
        swap_dispatcher(n, &kind_node_flonum_plus);
        return flonum_plus_calc(c, lv, rv);
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_plus);
        return integer_plus_calc(c, lv, rv);
    }
    swap_dispatcher(n, &kind_node_plus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_flonum_plus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_plus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

NODE_DEF
node_flonum_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(ab_is_float(lv) && ab_is_float(rv))) {
        return flonum_plus_calc(c, lv, rv);
    }
    return node_flonum_plus_slow(c, n, lv, rv, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_plus_overflow(CTX *c, VALUE lv, VALUE rv)
{
    return RESULT_OK(abruby_bignum_new(c, LONG2NUM(FIX2LONG(lv) + FIX2LONG(rv))));
}

NODE_DEF
node_fixnum_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result;
        if (LIKELY(!__builtin_add_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return node_fixnum_plus_overflow(c, lv, rv);
    }
    if (RB_FLONUM_P(lv) && RB_FLONUM_P(rv)) {
        return flonum_result(c, ab_flonum_value(lv) + ab_flonum_value(rv));
    }
    return node_fixnum_plus_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result = FIX2LONG(lv) + FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_plus_calc(c, lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

NODE_DEF
node_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_minus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_float(lv) && ab_is_float(rv)) {
        swap_dispatcher(n, &kind_node_flonum_minus);
        return flonum_minus_calc(c, lv, rv);
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_minus);
        return integer_minus_calc(c, lv, rv);
    }
    swap_dispatcher(n, &kind_node_minus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_flonum_minus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_minus);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

NODE_DEF
node_flonum_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(ab_is_float(lv) && ab_is_float(rv))) {
        return flonum_minus_calc(c, lv, rv);
    }
    return node_flonum_minus_slow(c, n, lv, rv, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_minus_overflow(CTX *c, VALUE lv, VALUE rv)
{
    return RESULT_OK(abruby_bignum_new(c, LONG2NUM(FIX2LONG(lv) - FIX2LONG(rv))));
}

NODE_DEF
node_fixnum_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result;
        if (LIKELY(!__builtin_sub_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return node_fixnum_minus_overflow(c, lv, rv);
    }
    if (RB_FLONUM_P(lv) && RB_FLONUM_P(rv)) {
        return flonum_result(c, ab_flonum_value(lv) - ab_flonum_value(rv));
    }
    return node_fixnum_minus_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result = FIX2LONG(lv) - FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_minus_calc(c, lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

NODE_DEF
node_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_mul_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_float(lv) && ab_is_float(rv)) {
        swap_dispatcher(n, &kind_node_flonum_mul);
        return flonum_mul_calc(c, lv, rv);
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_mul);
        return integer_mul_calc(c, lv, rv);
    }
    swap_dispatcher(n, &kind_node_mul);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_flonum_mul_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_mul);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
}

NODE_DEF
node_flonum_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(ab_is_float(lv) && ab_is_float(rv))) {
        return flonum_mul_calc(c, lv, rv);
    }
    return node_flonum_mul_slow(c, n, lv, rv, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_mul_overflow(CTX *c, long a, long b)
{
    return integer_mul_calc(c, LONG2FIX(a), LONG2FIX(b));
}

NODE_DEF
node_fixnum_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long a = FIX2LONG(lv), b = FIX2LONG(rv);
        long result;
        if (LIKELY(!__builtin_mul_overflow(a, b, &result) && FIXABLE(result)))
            return RESULT_OK(LONG2FIX(result));
        return node_fixnum_mul_overflow(c, a, b);
    }
    // Inline flonum fast path: swap_dispatcher is a no-op in compiled
    // mode, so hot float loops (mandelbrot) would otherwise pay a cold
    // function call on every multiply.
    if (RB_FLONUM_P(lv) && RB_FLONUM_P(rv)) {
        return flonum_result(c, ab_flonum_value(lv) * ab_flonum_value(rv));
    }
    return node_fixnum_mul_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long a = FIX2LONG(lv), b = FIX2LONG(rv);
        long result;
        if (LIKELY(!__builtin_mul_overflow(a, b, &result) && FIXABLE(result)))
            return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_mul_calc(c, lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
}

NODE_DEF
node_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_div_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_float(lv) && ab_is_float(rv)) {
        swap_dispatcher(n, &kind_node_flonum_div);
        return flonum_div_calc(c, lv, rv);
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_div);
        return integer_div_calc(c, lv, rv);
    }
    swap_dispatcher(n, &kind_node_div);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_flonum_div_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    swap_dispatcher(n, &kind_node_div);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
}

NODE_DEF
node_flonum_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(ab_is_float(lv) && ab_is_float(rv))) {
        return flonum_div_calc(c, lv, rv);
    }
    return node_flonum_div_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_fixnum_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr(c,"divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    if (RB_FLONUM_P(lv) && RB_FLONUM_P(rv)) {
        return flonum_result(c, ab_flonum_value(lv) / ab_flonum_value(rv));
    }
    return node_fixnum_div_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr(c,"divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_div_calc(c, lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
}

// === Comparison rewrite (type-specific nodes) ===

static RESULT DISPATCH_node_lt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_lt(CTX *c, NODE *n);
static RESULT DISPATCH_node_le(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_le(CTX *c, NODE *n);
static RESULT DISPATCH_node_gt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_gt(CTX *c, NODE *n);
static RESULT DISPATCH_node_ge(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_ge(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_lt(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_le(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_gt(CTX *c, NODE *n);
static RESULT DISPATCH_node_flonum_ge(CTX *c, NODE *n);

extern const struct NodeKind kind_node_lt;
extern const struct NodeKind kind_node_fixnum_lt;
extern const struct NodeKind kind_node_le;
extern const struct NodeKind kind_node_fixnum_le;
extern const struct NodeKind kind_node_gt;
extern const struct NodeKind kind_node_fixnum_gt;
extern const struct NodeKind kind_node_ge;
extern const struct NodeKind kind_node_fixnum_ge;
extern const struct NodeKind kind_node_flonum_lt;
extern const struct NodeKind kind_node_flonum_le;
extern const struct NodeKind kind_node_flonum_gt;
extern const struct NodeKind kind_node_flonum_ge;

NODE_DEF
node_lt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_lt, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_lt_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_float(lv) && ab_is_float(rv)) {
        swap_dispatcher(n, &kind_node_flonum_lt);
        double lf = RFLOAT_VALUE(AB_FLOAT_UNWRAP(lv));
        double rf = RFLOAT_VALUE(AB_FLOAT_UNWRAP(rv));
        return RESULT_OK(lf < rf ? Qtrue : Qfalse);
    }
    swap_dispatcher(n, &kind_node_lt);
    return node_arith_fallback(c, n, lv, rv, c->ids->op_lt, arg_index);
}

NODE_DEF
node_fixnum_lt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK((long)lv < (long)rv ? Qtrue : Qfalse);
    }
    if (RB_FLONUM_P(lv) && RB_FLONUM_P(rv)) {
        return RESULT_OK(ab_flonum_value(lv) < ab_flonum_value(rv) ? Qtrue : Qfalse);
    }
    return node_fixnum_lt_slow(c, n, lv, rv, arg_index);
