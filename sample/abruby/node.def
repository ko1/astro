    return node_arith_fallback(c, n, lv, rv, c->ids->op_lt, arg_index);
}

NODE_DEF
node_fixnum_lt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK((long)lv < (long)rv ? Qtrue : Qfalse);
    }
    return node_fixnum_lt_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_le(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
