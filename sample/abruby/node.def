// abruby node definitions
// RESULT is the return type for all node evaluators.
// UNWRAP extracts VALUE from RESULT, propagating non-normal state.

#define UNWRAP(r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL)) return _r; \
    _r.value; \
})

// UNWRAP_ALSO: like UNWRAP but does not propagate the specified state.
// Used in dispatch_method_frame to catch RESULT_RETURN while propagating others.
#define UNWRAP_ALSO(except_state, r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL && _r.state != (except_state))) return _r; \
    _r.value; \
})

// Push/pop a lightweight frame to record the current execution point.
// Used before creating inline exceptions (e.g., division by zero) so that
// the backtrace includes the correct source location.
// PUSH_FRAME opens a do { block; POP_FRAME closes it with } while (0).
// This scoping prevents accidental nesting of _push_frame variable names.
// Variables needed after POP_FRAME must be declared BEFORE PUSH_FRAME.
#define PUSH_FRAME(node) do { \
    struct abruby_frame _push_frame; \
    _push_frame.prev = c->current_frame; \
    _push_frame.method = NULL; \
    _push_frame.klass = NULL; \
    _push_frame.caller_node = (node); \
    c->current_frame = &_push_frame

#define POP_FRAME() \
    c->current_frame = _push_frame.prev; \
    } while (0)

// helper functions (included before generated eval code)

// VM accessor helpers
#define CTX_MAIN_CLASS(c) (&(c)->abm->main_class_body)
#define CTX_GVARS(c)      (&(c)->abm->gvars)

// class system helpers


static void
abruby_class_add_method(CTX *c, struct abruby_class *klass, ID name,
                        struct Node *body, unsigned int params_cnt, unsigned int locals_cnt,
                        const char *source_file)
{
    VALUE existing;
    if (ab_id_table_lookup(&klass->methods, name, &existing)) {
        struct abruby_method *m = (struct abruby_method *)existing;
        m->type = ABRUBY_METHOD_AST;
        m->u.ast.body = body;
        m->u.ast.params_cnt = params_cnt;
        m->u.ast.locals_cnt = locals_cnt;
        m->u.ast.source_file = source_file;
        return;
    }
    struct abruby_method *m = ruby_xcalloc(1, sizeof(struct abruby_method));
    m->name = name;
    m->type = ABRUBY_METHOD_AST;
    m->u.ast.body = body;
    m->u.ast.params_cnt = params_cnt;
    m->u.ast.locals_cnt = locals_cnt;
    m->u.ast.source_file = source_file;
    ab_id_table_insert(&klass->methods, name, (VALUE)m);
    c->abm->method_serial++;
}

static struct abruby_method *
abruby_class_find_method(struct abruby_class *klass, ID name)
{
    while (klass) {
        VALUE v;
        if (ab_id_table_lookup(&klass->methods, name, &v))
            return (struct abruby_method *)v;
        klass = klass->super;
    }
    return NULL;
}

static struct abruby_class *
find_class_in(struct abruby_class *scope, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(&scope->constants, name, &v) && RB_TYPE_P(v, T_DATA)) {
        struct abruby_header *h = (struct abruby_header *)RTYPEDDATA_GET_DATA(v);
        if (h->klass == ab_class_class || h->klass == ab_module_class) {
            return (struct abruby_class *)h;
        }
    }
    return NULL;
}

static struct abruby_class *
find_class(CTX *c, ID name)
{
    // Check per-instance main_class first, then global Object
    struct abruby_class *klass = find_class_in(CTX_MAIN_CLASS(c), name);
    if (klass) return klass;
    if (CTX_MAIN_CLASS(c) != ab_object_class) {
        return find_class_in(ab_object_class, name);
    }
    return NULL;
}


extern VALUE abruby_new_object(struct abruby_class *klass);

// === Literals ===

NODE_DEF
node_num(CTX * restrict c, NODE * restrict n, int32_t num)
{
    return RESULT_OK(INT2FIX(num));
}

extern VALUE abruby_float_new_wrap(VALUE rb_float);
extern VALUE abruby_bignum_new(VALUE rb_bignum);

NODE_DEF
node_float_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_float_new_wrap(rb_float_new(strtod(str, NULL))));
}

NODE_DEF
node_bignum_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_bignum_new(rb_cstr_to_inum(str, 10, 1)));
}

NODE_DEF
node_true(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qtrue);
}

NODE_DEF
node_false(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qfalse);
}

NODE_DEF
node_nil(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qnil);
}

NODE_DEF
node_str_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_str_new_cstr(str));
}

NODE_DEF
node_str_concat(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE result = rb_str_new(NULL, 0);
    for (uint32_t i = 0; i < argc; i++) {
        VALUE part = c->fp[arg_index + i];
        VALUE rs = abruby_str_rstr(part);
        rb_str_cat(result, RSTRING_PTR(rs), RSTRING_LEN(rs));
    }
    return RESULT_OK(abruby_str_new(result));
}

NODE_DEF
node_sym(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(ID2SYM(rb_intern(str)));
}

extern VALUE abruby_range_new(VALUE begin, VALUE end, bool exclude_end);

NODE_DEF
node_range_new(CTX * restrict c, NODE * restrict n, NODE *begin_node, NODE *end_node, uint32_t exclude_end)
{
    VALUE b = UNWRAP(EVAL_ARG(c, begin_node));
    VALUE e = UNWRAP(EVAL_ARG(c, end_node));
    return RESULT_OK(abruby_range_new(b, e, exclude_end != 0));
}

extern VALUE abruby_regexp_new(VALUE rb_regexp);

NODE_DEF
node_regexp_new(CTX * restrict c, NODE * restrict n, const char *source, const char *flags)
{
    int options = 0;
    for (const char *p = flags; *p; p++) {
        if (*p == 'i') options |= 1;  // ONIG_OPTION_IGNORECASE
        if (*p == 'x') options |= 2;  // ONIG_OPTION_EXTEND
        if (*p == 'm') options |= 4;  // ONIG_OPTION_MULTILINE
    }
    VALUE src = rb_str_new_cstr(source);
    VALUE re = rb_reg_new(RSTRING_PTR(src), RSTRING_LEN(src), options);
    return RESULT_OK(abruby_regexp_new(re));
}

NODE_DEF
node_self(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(c->self);
}

static RESULT
abruby_const_get(CTX *c, NODE *n, struct abruby_class *klass, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(&klass->constants, name, &v))
        return RESULT_OK(v);
    VALUE exc;
    PUSH_FRAME(n);
    exc = abruby_exception_new(c, c->current_frame,
        abruby_str_new_cstr("uninitialized constant"));
    POP_FRAME();
    return (RESULT){exc, RESULT_RAISE};
}

NODE_DEF
node_const_path_get(CTX * restrict c, NODE * restrict n, ID parent_name, ID name)
{
    struct abruby_class *klass = find_class(c, parent_name);
    if (!klass) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr("uninitialized constant"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    return abruby_const_get(c, n, klass, name);
}

NODE_DEF
node_const_set(CTX * restrict c, NODE * restrict n, ID name, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    struct abruby_class *scope = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    abruby_class_set_const(scope, name, v);
    return RESULT_OK(v);
}

NODE_DEF
node_const_get(CTX * restrict c, NODE * restrict n, ID name)
{
    // Check main_class first, then Object
    VALUE v;
    if (ab_id_table_lookup(&CTX_MAIN_CLASS(c)->constants, name, &v))
        return RESULT_OK(v);
    if (CTX_MAIN_CLASS(c) != ab_object_class) {
        return abruby_const_get(c, n, ab_object_class, name);
    }
    VALUE exc;
    PUSH_FRAME(n);
    exc = abruby_exception_new(c, c->current_frame,
        abruby_str_new_cstr("uninitialized constant"));
    POP_FRAME();
    return (RESULT){exc, RESULT_RAISE};
}

// === Array / Hash literals ===

NODE_DEF
node_ary_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE ary = rb_ary_new_capa(argc);
    for (uint32_t i = 0; i < argc; i++) {
        rb_ary_push(ary, c->fp[arg_index + i]);
    }
    return RESULT_OK(abruby_ary_new(ary));
}

// Convert abruby value to CRuby value for use as Hash key
static VALUE
ab_to_hash_key(VALUE v)
{
    if (FIXNUM_P(v) || SYMBOL_P(v) || v == Qtrue || v == Qfalse || v == Qnil) return v;
    struct abruby_header *h = (struct abruby_header *)RTYPEDDATA_GET_DATA(v);
    if (h->klass == ab_string_class) return ((struct abruby_string *)h)->rb_str;
    return v; // user objects as-is (identity based)
}

NODE_DEF
node_hash_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE hash = rb_hash_new();
    for (uint32_t i = 0; i < argc; i += 2) {
        rb_hash_aset(hash, ab_to_hash_key(c->fp[arg_index + i]), c->fp[arg_index + i + 1]);
    }
    return RESULT_OK(abruby_hash_new_wrap(hash));
}

// === Instance Variables ===

NODE_DEF
node_ivar_get(CTX * restrict c, NODE * restrict n, ID name)
{
    return RESULT_OK(abruby_ivar_get(c->self, name));
}

NODE_DEF
node_ivar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    abruby_ivar_set(c->self, name, v);
    return RESULT_OK(v);
}

// === Global Variables ===

static VALUE
abruby_gvar_get(CTX *c, ID name)
{
    VALUE v;
    if (ab_id_table_lookup(CTX_GVARS(c), name, &v)) return v;
    return Qnil;
}

static void
abruby_gvar_set(CTX *c, ID name, VALUE val)
{
    ab_id_table_insert(CTX_GVARS(c), name, val);
}

NODE_DEF
node_gvar_get(CTX * restrict c, NODE * restrict n, ID name)
{
    return RESULT_OK(abruby_gvar_get(c, name));
}

NODE_DEF
node_gvar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    abruby_gvar_set(c, name, v);
    return RESULT_OK(v);
}

// === Local Variables ===

NODE_DEF
node_lvar_get(CTX * restrict c, NODE * restrict n, uint32_t index)
{
    return RESULT_OK(c->fp[index]);
}

NODE_DEF
node_lvar_set(CTX * restrict c, NODE * restrict n, uint32_t index, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    c->fp[index] = v;
    return RESULT_OK(v);
}

// === Control Flow ===

NODE_DEF
node_scope(CTX * restrict c, NODE * restrict n, uint32_t envsize, NODE *body)
{
    c->fp += envsize;
    RESULT r = EVAL_ARG(c, body);
    c->fp -= envsize;
    return r;
}

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, NODE *head, NODE *tail)
{
    UNWRAP(EVAL_ARG(c, head));
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *then_node, NODE *else_node)
{
    if (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    while (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        RESULT r = EVAL_ARG(c, body);
        if (UNLIKELY(r.state != RESULT_NORMAL)) {
            if (r.state == RESULT_BREAK) return RESULT_OK(r.value);
            return r;
        }
    }
    return RESULT_OK(Qnil);
}

NODE_DEF
node_break(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_BREAK};
}

// === Non-local exit ===

NODE_DEF
node_return(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_RETURN};
}

NODE_DEF
node_rescue(CTX * restrict c, NODE * restrict n, NODE *body, NODE *rescue_body, NODE *ensure_body, uint32_t exception_lvar_index)
{
    RESULT r = EVAL_ARG(c, body);

    if (r.state == RESULT_RAISE) {
        if (exception_lvar_index != UINT32_MAX) {
            c->fp[exception_lvar_index] = r.value;
        }
        r = EVAL_ARG(c, rescue_body);
    }

    // ensure: always run; raise/return in ensure overrides original
    RESULT er = EVAL_ARG(c, ensure_body);
    if (er.state != RESULT_NORMAL) return er;

    return r;
}

// === Method definition & call ===

NODE_DEF @noinline
node_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body, uint32_t params_cnt, uint32_t locals_cnt)
{
    struct abruby_class *klass = c->current_class ? c->current_class : CTX_MAIN_CLASS(c);
    // Derive source file from current frame
    const char *file = NULL;
    if (c->current_frame) {
        if (c->current_frame->method && c->current_frame->method->type == ABRUBY_METHOD_AST)
            file = c->current_frame->method->u.ast.source_file;
        else
            file = c->current_frame->source_file;  // <main>/<top>
    }
    abruby_class_add_method(c, klass, name, body, params_cnt, locals_cnt, file);
    return RESULT_OK(Qnil);
}

// === OOP: class, method call with receiver, new ===

NODE_DEF @noinline
node_module_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body)
{
    struct abruby_class *mod = find_class(c, name);
    if (!mod) {
        mod = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        mod->klass = ab_module_class;
        mod->obj_type = ABRUBY_OBJ_MODULE;
        mod->name = name;
        mod->super = NULL;
        abruby_class_set_const(CTX_MAIN_CLASS(c), name, abruby_wrap_class(mod));
    }

    struct abruby_class *save_class = c->current_class;
    VALUE save_self = c->self;
    c->current_class = mod;
    c->self = abruby_wrap_class(mod);
    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->self = save_self;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(mod));
}

NODE_DEF @noinline
node_class_def(CTX * restrict c, NODE * restrict n, ID name, NODE *super_expr, NODE *body)
{
    struct abruby_class *klass = find_class(c, name);
    if (!klass) {
        struct abruby_class *super = ab_object_class;
        VALUE sv = UNWRAP(EVAL_ARG(c, super_expr));
        if (sv != Qnil) {
            if (!AB_CLASS_P(sv, ab_class_class)) {
                VALUE exc;
                PUSH_FRAME(n);
                exc = abruby_exception_new(c, c->current_frame,
                    abruby_str_new_cstr("superclass must be a Class"));
                POP_FRAME();
                return (RESULT){exc, RESULT_RAISE};
            }
            super = abruby_unwrap_class(sv);
        }
        klass = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        klass->klass = ab_class_class;
        klass->obj_type = ABRUBY_OBJ_GENERIC;  // instances are user objects
        klass->name = name;
        klass->super = super;
        abruby_class_set_const(CTX_MAIN_CLASS(c), name, abruby_wrap_class(klass));
    }

    struct abruby_class *save_class = c->current_class;
    VALUE save_self = c->self;
    c->current_class = klass;
    c->self = abruby_wrap_class(klass);
    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->self = save_self;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(klass));
}

// Populate cached fields in method_cache.
static inline void
method_cache_fill(CTX *c, struct method_cache *mc, struct abruby_class *klass,
                  struct abruby_method *method)
{
    mc->klass = klass;
    mc->method = method;
    mc->serial = c->abm->method_serial;
    if (method->type == ABRUBY_METHOD_AST) {
        mc->body = method->u.ast.body;
        mc->dispatcher = method->u.ast.body->head.dispatcher;
    } else {
        mc->body = NULL;
        mc->dispatcher = NULL;
    }
}

// Inner dispatch using cached method_cache.
// Does NOT save/restore c->self — caller is responsible.
// Cache hit paths call this directly; non-cache paths go through dispatch_method_with_klass.
static inline RESULT
dispatch_method_frame(CTX * restrict c, NODE * restrict call_site,
                      struct abruby_class *klass,
                      struct method_cache *mc,
                      unsigned int argc, uint32_t arg_index)
{
    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.method = mc->method;
    frame.klass = klass;
    frame.caller_node = call_site;
    c->current_frame = &frame;

    RESULT r;
    if (LIKELY(mc->body != NULL)) {
        VALUE *save_fp = c->fp;
        c->fp = save_fp + arg_index;
        r = mc->dispatcher(c, mc->body);
        c->fp = save_fp;
        r = RESULT_OK(UNWRAP_ALSO(RESULT_RETURN, r));
    } else {
        r = mc->method->u.cfunc.func(c, c->self, argc, c->fp + arg_index);
    }

    c->current_frame = frame.prev;
    return r;
}

// Outer dispatch for non-cache paths: build temp mc, save/restore self.
// Used by method_missing_dispatch, node_super, node_arith_fallback.
static inline RESULT
dispatch_method_with_klass(CTX * restrict c, NODE * restrict call_site,
                           VALUE recv, struct abruby_class *klass,
                           struct abruby_method *method,
                           unsigned int argc, uint32_t arg_index)
{
    struct method_cache mc;
    method_cache_fill(c, &mc, klass, method);
    VALUE save_self = c->self;
    c->self = recv;
    RESULT r = dispatch_method_frame(c, call_site, klass, &mc, argc, arg_index);
    c->self = save_self;
    return r;
}

static __attribute__((noinline)) RESULT
method_missing_dispatch(CTX * restrict c, NODE * restrict n, struct abruby_class *klass,
                        ID name, VALUE recv_val,
                        uint32_t params_cnt, uint32_t arg_index)
{
    struct abruby_method *mm = abruby_class_find_method(klass, c->ids->method_missing);
    if (!mm) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr("undefined method"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }
    // shift args by 1, insert method name as first arg
    for (int i = (int)params_cnt - 1; i >= 0; i--) {
        c->fp[arg_index + i + 1] = c->fp[arg_index + i];
    }
    c->fp[arg_index] = abruby_str_new_cstr(rb_id2name(name));
    return dispatch_method_with_klass(c, n, recv_val, klass, mm, params_cnt + 1, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_method_call_slow(CTX * restrict c, NODE * restrict n,
                      VALUE recv_val, struct abruby_class *klass, ID name,
                      uint32_t params_cnt, uint32_t arg_index,
                      struct method_cache *mc)
{
    struct abruby_method *method = abruby_class_find_method(klass, name);
    if (UNLIKELY(method == NULL)) {
        return method_missing_dispatch(c, n, klass, name, recv_val, params_cnt, arg_index);
    }
    method_cache_fill(c, mc, klass, method);
    return dispatch_method_with_klass(c, n, recv_val, klass, method, params_cnt, arg_index);
}

NODE_DEF
node_method_call(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t params_cnt, uint32_t arg_index, struct method_cache *mc@ref)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    struct abruby_class *klass = AB_CLASS_OF(recv_val);

    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        VALUE save_self = c->self;
        c->self = recv_val;
        RESULT r = dispatch_method_frame(c, n, klass, mc, params_cnt, arg_index);
        c->self = save_self;
        return r;
    }
    else {
        return node_method_call_slow(c, n, recv_val, klass, name, params_cnt, arg_index, mc);
    }
}

// Function call (implicit self as receiver, no recv operand).
// Uses dispatch_method_frame directly (no self save/restore needed).
// Shares node_method_call_slow for cache miss path.
NODE_DEF
node_func_call(CTX * restrict c, NODE * restrict n, ID name, uint32_t params_cnt, uint32_t arg_index, struct method_cache *mc@ref)
{
    struct abruby_class *klass = AB_CLASS_OF(c->self);

    if (LIKELY(mc->klass == klass && mc->serial == c->abm->method_serial)) {
        return dispatch_method_frame(c, n, klass, mc,
                                     params_cnt, arg_index);
    }
    else {
        return node_method_call_slow(c, n, c->self, klass, name,
                                     params_cnt, arg_index, mc);
    }
}

// === super ===

// Find the super method: walk from frame->klass->super looking for same method name
static struct abruby_method *
find_super_method(struct abruby_frame *frame)
{
    if (!frame || !frame->method || !frame->klass) return NULL;
    ID name = frame->method->name;
    struct abruby_class *klass = frame->klass->super;
    return abruby_class_find_method(klass, name);
}

// super(args) — call parent method with explicit arguments
NODE_DEF
node_super(CTX * restrict c, NODE * restrict n, uint32_t params_cnt, uint32_t arg_index)
{
    struct abruby_method *method = find_super_method(c->current_frame);
    if (!method) {
        VALUE exc;
        PUSH_FRAME(n);
        exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr("super: no superclass method"));
        POP_FRAME();
        return (RESULT){exc, RESULT_RAISE};
    }

    // Find which class owns this method for correct super chain
    struct abruby_class *klass = c->current_frame->klass->super;
    while (klass) {
        VALUE v;
        if (ab_id_table_lookup(&klass->methods, method->name, &v) &&
            (struct abruby_method *)v == method)
            goto found_super;
        klass = klass->super;
    }
found_super:
    return dispatch_method_with_klass(c, n, c->self, klass, method, params_cnt, arg_index);
}

// === Arithmetic rewrite (type-specific nodes) ===

// Fallback: general method call for arithmetic operators (recv=lv, arg=rv)
static __attribute__((noinline, cold)) RESULT
node_arith_fallback(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, ID op, uint32_t arg_index)
{
    struct abruby_class *klass = AB_CLASS_OF(lv);
    struct abruby_method *method = abruby_class_find_method(klass, op);
    if (!method) {
        method = abruby_class_find_method(klass, c->ids->method_missing);
        if (!method) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr("undefined method"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        c->fp[arg_index] = abruby_str_new_cstr(rb_id2name(op));
        c->fp[arg_index + 1] = rv;
        return dispatch_method_with_klass(c, n, lv, klass, method, 2, arg_index);
    }
    c->fp[arg_index] = rv;
    return dispatch_method_with_klass(c, n, lv, klass, method, 1, arg_index);
}

// Integer arithmetic helper (works for both fixnum and bignum)
static inline bool
ab_is_integer(VALUE v)
{
    return FIXNUM_P(v) || AB_CLASS_P(v, ab_integer_class);
}

// Forward declarations for cross-referencing dispatchers
static RESULT DISPATCH_node_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_div(CTX *c, NODE *n);

extern const struct NodeKind kind_node_plus;
extern const struct NodeKind kind_node_fixnum_plus;
extern const struct NodeKind kind_node_integer_plus;
extern const struct NodeKind kind_node_minus;
extern const struct NodeKind kind_node_fixnum_minus;
extern const struct NodeKind kind_node_integer_minus;
extern const struct NodeKind kind_node_mul;
extern const struct NodeKind kind_node_fixnum_mul;
extern const struct NodeKind kind_node_integer_mul;
extern const struct NodeKind kind_node_div;
extern const struct NodeKind kind_node_fixnum_div;
extern const struct NodeKind kind_node_integer_div;

// Integer calc helpers (used by fixnum_*_slow and integer_* nodes)
static inline RESULT
integer_plus_calc(VALUE lv, VALUE rv)
{
    return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("+"), 1, AB_INT_UNWRAP(rv))));
}

static inline RESULT
integer_minus_calc(VALUE lv, VALUE rv)
{
    return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("-"), 1, AB_INT_UNWRAP(rv))));
}

static inline RESULT
integer_mul_calc(VALUE lv, VALUE rv)
{
    return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("*"), 1, AB_INT_UNWRAP(rv))));
}

static inline RESULT
integer_div_calc(VALUE lv, VALUE rv)
{
    return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("/"), 1, AB_INT_UNWRAP(rv))));
}

// Dispatcher swap: change the dispatcher without creating a new node.
// kind is also updated for consistency (DUMP, HASH).
static inline void
swap_dispatcher(NODE *n, const struct NodeKind *target_kind)
{
    if (n->head.kind != target_kind) {
        n->head.dispatcher = target_kind->default_dispatcher;
        n->head.kind = target_kind;
    }
}

// node_plus: generic fallback (method dispatch via "+")
NODE_DEF
node_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_plus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_plus);
        return integer_plus_calc(lv, rv);
    }
    else {
        swap_dispatcher(n, &kind_node_plus);
        return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
    }
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_plus_overflow(VALUE lv, VALUE rv)
{
    return RESULT_OK(abruby_bignum_new(LONG2NUM(FIX2LONG(lv) + FIX2LONG(rv))));
}

NODE_DEF
node_fixnum_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result;
        if (LIKELY(!__builtin_add_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return node_fixnum_plus_overflow(lv, rv);
    }
    return node_fixnum_plus_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result = FIX2LONG(lv) + FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_plus_calc(lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_plus, arg_index);
}

NODE_DEF
node_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_minus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_minus);
        return integer_minus_calc(lv, rv);
    }
    else {
        swap_dispatcher(n, &kind_node_minus);
        return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
    }
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_minus_overflow(VALUE lv, VALUE rv)
{
    return RESULT_OK(abruby_bignum_new(LONG2NUM(FIX2LONG(lv) - FIX2LONG(rv))));
}

NODE_DEF
node_fixnum_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result;
        if (LIKELY(!__builtin_sub_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return node_fixnum_minus_overflow(lv, rv);
    }
    return node_fixnum_minus_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result = FIX2LONG(lv) - FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_minus_calc(lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_minus, arg_index);
}

NODE_DEF
node_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_mul_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_mul);
        return integer_mul_calc(lv, rv);
    }
    else {
        swap_dispatcher(n, &kind_node_mul);
        return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
    }
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_mul_overflow(long a, long b)
{
    return integer_mul_calc(LONG2FIX(a), LONG2FIX(b));
}

NODE_DEF
node_fixnum_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long a = FIX2LONG(lv), b = FIX2LONG(rv);
        long result;
        if (LIKELY(!__builtin_mul_overflow(a, b, &result) && FIXABLE(result)))
            return RESULT_OK(LONG2FIX(result));
        return node_fixnum_mul_overflow(a, b);
    }
    return node_fixnum_mul_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long a = FIX2LONG(lv), b = FIX2LONG(rv);
        long result;
        if (LIKELY(!__builtin_mul_overflow(a, b, &result) && FIXABLE(result)))
            return RESULT_OK(LONG2FIX(result));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_mul_calc(lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_mul, arg_index);
}

NODE_DEF
node_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_div_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        swap_dispatcher(n, &kind_node_integer_div);
        return integer_div_calc(lv, rv);
    }
    else {
        swap_dispatcher(n, &kind_node_div);
        return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
    }
}

NODE_DEF
node_fixnum_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr("divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    return node_fixnum_div_slow(c, n, lv, rv, arg_index);
}

NODE_DEF
node_integer_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc;
            PUSH_FRAME(n);
            exc = abruby_exception_new(c, c->current_frame,
                abruby_str_new_cstr("divided by 0"));
            POP_FRAME();
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    if (ab_is_integer(lv) && ab_is_integer(rv)) {
        return integer_div_calc(lv, rv);
    }
    return node_arith_fallback(c, n, lv, rv, c->ids->op_div, arg_index);
}

// === Comparison rewrite (type-specific nodes) ===

static RESULT DISPATCH_node_lt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_lt(CTX *c, NODE *n);
static RESULT DISPATCH_node_le(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_le(CTX *c, NODE *n);
static RESULT DISPATCH_node_gt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_gt(CTX *c, NODE *n);
static RESULT DISPATCH_node_ge(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_ge(CTX *c, NODE *n);

extern const struct NodeKind kind_node_lt;
extern const struct NodeKind kind_node_fixnum_lt;
extern const struct NodeKind kind_node_le;
extern const struct NodeKind kind_node_fixnum_le;
extern const struct NodeKind kind_node_gt;
extern const struct NodeKind kind_node_fixnum_gt;
extern const struct NodeKind kind_node_ge;
extern const struct NodeKind kind_node_fixnum_ge;

NODE_DEF
node_lt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right, uint32_t arg_index)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    return node_arith_fallback(c, n, lv, rv, c->ids->op_lt, arg_index);
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_lt_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, uint32_t arg_index)
{
