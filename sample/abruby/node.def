// abruby node definitions
// RESULT is the return type for all node evaluators.
// UNWRAP extracts VALUE from RESULT, propagating non-normal state.

#define UNWRAP(r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL)) return _r; \
    _r.value; \
})

// UNWRAP_ALSO: like UNWRAP but does not propagate the specified state.
// Used in method_call_body to catch RESULT_RETURN while propagating others.
#define UNWRAP_ALSO(except_state, r) ({ \
    RESULT _r = (r); \
    if (UNLIKELY(_r.state != RESULT_NORMAL && _r.state != (except_state))) return _r; \
    _r.value; \
})

// helper functions (included before generated eval code)

// class system helpers

static void
abruby_class_add_method(struct abruby_class *klass, const char *name,
                        struct Node *body, unsigned int params_cnt, unsigned int locals_cnt,
                        const char *source_file)
{
    for (unsigned int i = 0; i < klass->method_cnt; i++) {
        if (strcmp(klass->methods[i].name, name) == 0) {
            klass->methods[i].type = ABRUBY_METHOD_AST;
            klass->methods[i].u.ast.body = body;
            klass->methods[i].u.ast.params_cnt = params_cnt;
            klass->methods[i].u.ast.locals_cnt = locals_cnt;
            klass->methods[i].u.ast.source_file = source_file;
            return;
        }
    }
    struct abruby_method *m = &klass->methods[klass->method_cnt++];
    m->name = name;
    m->type = ABRUBY_METHOD_AST;
    m->u.ast.body = body;
    m->u.ast.params_cnt = params_cnt;
    m->u.ast.locals_cnt = locals_cnt;
    m->u.ast.source_file = source_file;
}

static struct abruby_method *
abruby_class_find_method(struct abruby_class *klass, const char *name)
{
    while (klass) {
        for (unsigned int i = 0; i < klass->method_cnt; i++) {
            if (strcmp(klass->methods[i].name, name) == 0) {
                return &klass->methods[i];
            }
        }
        klass = klass->super;
    }
    return NULL;
}

static struct abruby_class *
find_class_in(struct abruby_class *scope, const char *name)
{
    for (unsigned int i = 0; i < scope->const_cnt; i++) {
        if (strcmp(scope->constants[i].name, name) == 0) {
            VALUE v = scope->constants[i].value;
            if (RB_TYPE_P(v, T_DATA)) {
                struct abruby_header *h = (struct abruby_header *)RTYPEDDATA_GET_DATA(v);
                if (h->klass == ab_class_class || h->klass == ab_module_class) {
                    return (struct abruby_class *)h;
                }
            }
        }
    }
    return NULL;
}

static struct abruby_class *
find_class(CTX *c, const char *name)
{
    // Check per-instance main_class first, then global Object
    struct abruby_class *klass = find_class_in(c->main_class, name);
    if (klass) return klass;
    if (c->main_class != ab_object_class) {
        return find_class_in(ab_object_class, name);
    }
    return NULL;
}

static RESULT
method_call_body(CTX *c, uint32_t arg_index, VALUE recv, struct Node *body)
{
    VALUE *save_fp = c->fp;
    VALUE save_self = c->self;
    c->fp = save_fp + arg_index;
    c->self = recv;
    RESULT r = EVAL(c, body);
    c->fp = save_fp;
    c->self = save_self;
    return RESULT_OK(UNWRAP_ALSO(RESULT_RETURN, r));
}

extern VALUE abruby_new_object(struct abruby_class *klass);

// === Literals ===

NODE_DEF
node_num(CTX * restrict c, NODE * restrict n, int32_t num)
{
    return RESULT_OK(INT2FIX(num));
}

extern VALUE abruby_float_new_wrap(VALUE rb_float);
extern VALUE abruby_bignum_new(VALUE rb_bignum);

NODE_DEF
node_float_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_float_new_wrap(rb_float_new(strtod(str, NULL))));
}

NODE_DEF
node_bignum_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_bignum_new(rb_cstr_to_inum(str, 10, 1)));
}

NODE_DEF
node_true(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qtrue);
}

NODE_DEF
node_false(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qfalse);
}

NODE_DEF
node_nil(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(Qnil);
}

NODE_DEF
node_str_new(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(abruby_str_new_cstr(str));
}

NODE_DEF
node_str_concat(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE result = rb_str_new(NULL, 0);
    for (uint32_t i = 0; i < argc; i++) {
        VALUE part = c->fp[arg_index + i];
        VALUE rs = abruby_str_rstr(part);
        rb_str_cat(result, RSTRING_PTR(rs), RSTRING_LEN(rs));
    }
    return RESULT_OK(abruby_str_new(result));
}

NODE_DEF
node_sym(CTX * restrict c, NODE * restrict n, const char *str)
{
    return RESULT_OK(ID2SYM(rb_intern(str)));
}

extern VALUE abruby_range_new(VALUE begin, VALUE end, bool exclude_end);

NODE_DEF
node_range_new(CTX * restrict c, NODE * restrict n, NODE *begin_node, NODE *end_node, uint32_t exclude_end)
{
    VALUE b = UNWRAP(EVAL_ARG(c, begin_node));
    VALUE e = UNWRAP(EVAL_ARG(c, end_node));
    return RESULT_OK(abruby_range_new(b, e, exclude_end != 0));
}

extern VALUE abruby_regexp_new(VALUE rb_regexp);

NODE_DEF
node_regexp_new(CTX * restrict c, NODE * restrict n, const char *source, const char *flags)
{
    int options = 0;
    for (const char *p = flags; *p; p++) {
        if (*p == 'i') options |= 1;  // ONIG_OPTION_IGNORECASE
        if (*p == 'x') options |= 2;  // ONIG_OPTION_EXTEND
        if (*p == 'm') options |= 4;  // ONIG_OPTION_MULTILINE
    }
    VALUE src = rb_str_new_cstr(source);
    VALUE re = rb_reg_new(RSTRING_PTR(src), RSTRING_LEN(src), options);
    return RESULT_OK(abruby_regexp_new(re));
}

NODE_DEF
node_self(CTX * restrict c, NODE * restrict n)
{
    return RESULT_OK(c->self);
}

static VALUE
abruby_const_get(struct abruby_class *klass, const char *name)
{
    for (unsigned int i = 0; i < klass->const_cnt; i++) {
        if (strcmp(klass->constants[i].name, name) == 0) {
            return klass->constants[i].value;
        }
    }
    rb_raise(rb_eNameError, "uninitialized constant %s::%s", klass->name, name);
    return Qnil;
}

NODE_DEF
node_const_path_get(CTX * restrict c, NODE * restrict n, const char *parent_name, const char *name)
{
    struct abruby_class *klass = find_class(c, parent_name);
    if (!klass) {
        rb_raise(rb_eNameError, "uninitialized constant %s", parent_name);
    }
    // rb_raise does not return, but abruby_const_get may also rb_raise
    return RESULT_OK(abruby_const_get(klass, name));
}

NODE_DEF
node_const_set(CTX * restrict c, NODE * restrict n, const char *name, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    struct abruby_class *scope = c->current_class ? c->current_class : c->main_class;
    abruby_class_set_const(scope, name, v);
    return RESULT_OK(v);
}

NODE_DEF
node_const_get(CTX * restrict c, NODE * restrict n, const char *name)
{
    // Check main_class first, then Object
    for (unsigned int i = 0; i < c->main_class->const_cnt; i++) {
        if (strcmp(c->main_class->constants[i].name, name) == 0) {
            return RESULT_OK(c->main_class->constants[i].value);
        }
    }
    if (c->main_class != ab_object_class) {
        return RESULT_OK(abruby_const_get(ab_object_class, name));
    }
    rb_raise(rb_eNameError, "uninitialized constant %s", name);
    return RESULT_OK(Qnil);
}

// === Array / Hash literals ===

NODE_DEF
node_ary_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE ary = rb_ary_new_capa(argc);
    for (uint32_t i = 0; i < argc; i++) {
        rb_ary_push(ary, c->fp[arg_index + i]);
    }
    return RESULT_OK(abruby_ary_new(ary));
}

// Convert abruby value to CRuby value for use as Hash key
static VALUE
ab_to_hash_key(VALUE v)
{
    if (FIXNUM_P(v) || SYMBOL_P(v) || v == Qtrue || v == Qfalse || v == Qnil) return v;
    struct abruby_header *h = (struct abruby_header *)RTYPEDDATA_GET_DATA(v);
    if (h->klass == ab_string_class) return ((struct abruby_string *)h)->rb_str;
    return v; // user objects as-is (identity based)
}

NODE_DEF
node_hash_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE hash = rb_hash_new();
    for (uint32_t i = 0; i < argc; i += 2) {
        rb_hash_aset(hash, ab_to_hash_key(c->fp[arg_index + i]), c->fp[arg_index + i + 1]);
    }
    return RESULT_OK(abruby_hash_new_wrap(hash));
}

// === Instance Variables ===

NODE_DEF
node_ivar_get(CTX * restrict c, NODE * restrict n, const char *name)
{
    return RESULT_OK(abruby_ivar_get(c->self, name));
}

NODE_DEF
node_ivar_set(CTX * restrict c, NODE * restrict n, const char *name, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    abruby_ivar_set(c->self, name, v);
    return RESULT_OK(v);
}

// === Global Variables ===

static VALUE
abruby_gvar_get(CTX *c, const char *name)
{
    struct abruby_gvar_table *t = c->gvars;
    for (unsigned int i = 0; i < t->cnt; i++) {
        if (strcmp(t->entries[i].name, name) == 0)
            return t->entries[i].value;
    }
    return Qnil;
}

static void
abruby_gvar_set(CTX *c, const char *name, VALUE val)
{
    struct abruby_gvar_table *t = c->gvars;
    for (unsigned int i = 0; i < t->cnt; i++) {
        if (strcmp(t->entries[i].name, name) == 0) {
            t->entries[i].value = val;
            return;
        }
    }
    t->entries[t->cnt].name = name;
    t->entries[t->cnt].value = val;
    t->cnt++;
}

NODE_DEF
node_gvar_get(CTX * restrict c, NODE * restrict n, const char *name)
{
    return RESULT_OK(abruby_gvar_get(c, name));
}

NODE_DEF
node_gvar_set(CTX * restrict c, NODE * restrict n, const char *name, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    abruby_gvar_set(c, name, v);
    return RESULT_OK(v);
}

// === Local Variables ===

NODE_DEF
node_lvar_get(CTX * restrict c, NODE * restrict n, uint32_t index)
{
    return RESULT_OK(c->fp[index]);
}

NODE_DEF
node_lvar_set(CTX * restrict c, NODE * restrict n, uint32_t index, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    c->fp[index] = v;
    return RESULT_OK(v);
}

// === Control Flow ===

NODE_DEF
node_scope(CTX * restrict c, NODE * restrict n, uint32_t envsize, NODE *body)
{
    c->fp += envsize;
    RESULT r = EVAL_ARG(c, body);
    c->fp -= envsize;
    return r;
}

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, NODE *head, NODE *tail)
{
    UNWRAP(EVAL_ARG(c, head));
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *then_node, NODE *else_node)
{
    if (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    while (RTEST(UNWRAP(EVAL_ARG(c, cond)))) {
        RESULT r = EVAL_ARG(c, body);
        if (UNLIKELY(r.state != RESULT_NORMAL)) {
            if (r.state == RESULT_BREAK) return RESULT_OK(r.value);
            return r;
        }
    }
    return RESULT_OK(Qnil);
}

NODE_DEF
node_break(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_BREAK};
}

// === Non-local exit ===

NODE_DEF
node_return(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = UNWRAP(EVAL_ARG(c, value));
    return (RESULT){v, RESULT_RETURN};
}

NODE_DEF
node_rescue(CTX * restrict c, NODE * restrict n, NODE *body, NODE *rescue_body, NODE *ensure_body, uint32_t exception_lvar_index)
{
    RESULT r = EVAL_ARG(c, body);

    if (r.state == RESULT_RAISE) {
        if (exception_lvar_index != UINT32_MAX) {
            c->fp[exception_lvar_index] = r.value;
        }
        r = EVAL_ARG(c, rescue_body);
    }

    // ensure: always run; raise/return in ensure overrides original
    RESULT er = EVAL_ARG(c, ensure_body);
    if (er.state != RESULT_NORMAL) return er;

    return r;
}

// === Method definition & call ===

NODE_DEF @noinline
node_def(CTX * restrict c, NODE * restrict n, const char *name, NODE *body, uint32_t params_cnt, uint32_t locals_cnt)
{
    struct abruby_class *klass = c->current_class ? c->current_class : c->main_class;
    // Derive source file from current frame
    const char *file = NULL;
    if (c->current_frame) {
        if (c->current_frame->method && c->current_frame->method->type == ABRUBY_METHOD_AST)
            file = c->current_frame->method->u.ast.source_file;
        else
            file = c->current_frame->source_file;  // <main>/<top>
    }
    abruby_class_add_method(klass, name, body, params_cnt, locals_cnt, file);
    return RESULT_OK(Qnil);
}

// === OOP: class, method call with receiver, new ===

NODE_DEF @noinline
node_module_def(CTX * restrict c, NODE * restrict n, const char *name, NODE *body)
{
    struct abruby_class *mod = find_class(c, name);
    if (!mod) {
        mod = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        mod->klass = ab_module_class;
        mod->name = name;
        mod->super = NULL;
        abruby_class_set_const(c->main_class, name, abruby_wrap_class(mod));
    }

    struct abruby_class *save_class = c->current_class;
    VALUE save_self = c->self;
    c->current_class = mod;
    c->self = abruby_wrap_class(mod);
    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->self = save_self;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(mod));
}

NODE_DEF @noinline
node_class_def(CTX * restrict c, NODE * restrict n, const char *name, const char *super_name, NODE *body)
{
    struct abruby_class *klass = find_class(c, name);
    if (!klass) {
        struct abruby_class *super = ab_object_class;
        if (super_name[0] != '\0') {
            super = find_class(c, super_name);
            if (!super) {
                rb_raise(rb_eNameError, "uninitialized constant %s", super_name);
            }
        }
        klass = (struct abruby_class *)ruby_xcalloc(1, sizeof(struct abruby_class));
        klass->klass = ab_class_class;
        klass->name = name;
        klass->super = super;
        abruby_class_set_const(c->main_class, name, abruby_wrap_class(klass));
    }

    struct abruby_class *save_class = c->current_class;
    VALUE save_self = c->self;
    c->current_class = klass;
    c->self = abruby_wrap_class(klass);
    RESULT _rb = EVAL_ARG(c, body);
    c->current_class = save_class;
    c->self = save_self;
    if (UNLIKELY(_rb.state != RESULT_NORMAL)) return _rb;
    return RESULT_OK(abruby_wrap_class(klass));
}

static __attribute__((noinline)) RESULT
method_missing_dispatch(CTX * restrict c, NODE * restrict n, struct abruby_class *klass,
                        const char *name, VALUE recv_val,
                        uint32_t params_cnt, uint32_t arg_index)
{
    struct abruby_method *mm = abruby_class_find_method(klass, "method_missing");
    if (!mm) {
        rb_raise(rb_eNoMethodError, "undefined method '%s' for %s", name, klass->name);
    }
    // shift args by 1, insert method name as first arg
    for (int i = (int)params_cnt - 1; i >= 0; i--) {
        c->fp[arg_index + i + 1] = c->fp[arg_index + i];
    }
    c->fp[arg_index] = abruby_str_new_cstr(name);
    if (mm->type == ABRUBY_METHOD_CFUNC) {
        return mm->u.cfunc.func(c, recv_val, params_cnt + 1, c->fp + arg_index);
    }
    else {
        return method_call_body(c, arg_index, recv_val, mm->u.ast.body);
    }
}

NODE_DEF
node_method_call(CTX * restrict c, NODE * restrict n, NODE *recv, const char *name, uint32_t params_cnt, uint32_t arg_index)
{
    VALUE recv_val = UNWRAP(EVAL_ARG(c, recv));
    struct abruby_class *klass = AB_CLASS_OF(recv_val);
    struct abruby_method *method = abruby_class_find_method(klass, name);

    // Update parent frame's call site node (only for method frames;
    // <main>/<top> frames keep their source_file in the union)
    if (c->current_frame && c->current_frame->method)
        c->current_frame->node = n;

    // Push callee's frame (node left uninitialized — set by child's push)
    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.method = method;
    frame.klass = klass;
    c->current_frame = &frame;

    RESULT r;
    if (LIKELY(method != NULL)) {
        if (method->type == ABRUBY_METHOD_CFUNC) {
            r = method->u.cfunc.func(c, recv_val, params_cnt, c->fp + arg_index);
        }
        else {
            r = method_call_body(c, arg_index, recv_val, method->u.ast.body);
        }
    }
    else {
        r = method_missing_dispatch(c, n, klass, name, recv_val, params_cnt, arg_index);
    }

    // Pop call frame (always — backtrace is on exception object)
    c->current_frame = frame.prev;
    return r;
}

// === super ===

// Find the super method: walk from frame->klass->super looking for same method name
static struct abruby_method *
find_super_method(struct abruby_frame *frame)
{
    if (!frame || !frame->method || !frame->klass) return NULL;
    const char *name = frame->method->name;
    struct abruby_class *klass = frame->klass->super;
    while (klass) {
        for (unsigned int i = 0; i < klass->method_cnt; i++) {
            if (strcmp(klass->methods[i].name, name) == 0) {
                return &klass->methods[i];
            }
        }
        klass = klass->super;
    }
    return NULL;
}

// super(args) — call parent method with explicit arguments
NODE_DEF
node_super(CTX * restrict c, NODE * restrict n, uint32_t params_cnt, uint32_t arg_index)
{
    struct abruby_method *method = find_super_method(c->current_frame);
    if (!method) {
        VALUE exc = abruby_exception_new(c, c->current_frame,
            abruby_str_new_cstr("super: no superclass method"));
        return (RESULT){exc, RESULT_RAISE};
    }

    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.method = method;
    // Find which class owns this method for correct super chain
    frame.klass = c->current_frame->klass->super;
    while (frame.klass) {
        for (unsigned int i = 0; i < frame.klass->method_cnt; i++) {
            if (&frame.klass->methods[i] == method) goto found;
        }
        frame.klass = frame.klass->super;
    }
found:
    c->current_frame = &frame;

    RESULT r;
    if (method->type == ABRUBY_METHOD_CFUNC) {
        r = method->u.cfunc.func(c, c->self, params_cnt, c->fp + arg_index);
    } else {
        r = method_call_body(c, arg_index, c->self, method->u.ast.body);
    }

    c->current_frame = frame.prev;
    return r;
}

// === Arithmetic rewrite (type-specific nodes) ===

// Fallback: general method call for arithmetic operators
static __attribute__((noinline, cold)) RESULT
node_arith_fallback(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv, const char *op)
{
    struct abruby_class *klass = AB_CLASS_OF(lv);
    struct abruby_method *method = abruby_class_find_method(klass, op);
    if (!method) {
        // Try method_missing
        method = abruby_class_find_method(klass, "method_missing");
        if (!method) {
            rb_raise(rb_eNoMethodError, "undefined method '%s' for %s", op, klass->name);
        }
        // Call method_missing(op_name, rv)
        VALUE args[2] = {abruby_str_new_cstr(op), rv};

        if (c->current_frame && c->current_frame->method)
            c->current_frame->node = n;
        struct abruby_frame frame;
        frame.prev = c->current_frame;
        frame.method = method;
        c->current_frame = &frame;

        RESULT r;
        if (method->type == ABRUBY_METHOD_CFUNC) {
            r = method->u.cfunc.func(c, lv, 2, args);
        } else {
            uint32_t offset = 16;
            VALUE *save_fp = c->fp;
            c->fp = save_fp + offset;
            c->fp[0] = args[0];
            c->fp[1] = args[1];
            VALUE save_self = c->self;
            c->self = lv;
            r = EVAL(c, method->u.ast.body);
            c->fp = save_fp;
            c->self = save_self;
            if (r.state == RESULT_RETURN) r = RESULT_OK(r.value);
        }
        c->current_frame = frame.prev;
        return r;
    }

    // Push call frame for backtrace
    if (c->current_frame && c->current_frame->method)
        c->current_frame->node = n;
    struct abruby_frame frame;
    frame.prev = c->current_frame;
    frame.method = method;
    c->current_frame = &frame;

    RESULT r;
    if (method->type == ABRUBY_METHOD_CFUNC) {
        r = method->u.cfunc.func(c, lv, 1, &rv);
    } else {
        // For AST method: place arg at fp offset and call body
        uint32_t offset = 16; // generous offset to avoid clobbering
        VALUE *save_fp = c->fp;
        c->fp = save_fp + offset;
        c->fp[0] = rv;
        VALUE save_self = c->self;
        c->self = lv;
        r = EVAL(c, method->u.ast.body);
        c->fp = save_fp;
        c->self = save_self;
        if (r.state == RESULT_RETURN) r = RESULT_OK(r.value);
    }

    c->current_frame = frame.prev;
    return r;
}

// Forward declarations for cross-referencing dispatchers
static RESULT DISPATCH_node_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_plus(CTX *c, NODE *n);
static RESULT DISPATCH_node_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_minus(CTX *c, NODE *n);
static RESULT DISPATCH_node_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_mul(CTX *c, NODE *n);
static RESULT DISPATCH_node_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_div(CTX *c, NODE *n);
static RESULT DISPATCH_node_integer_div(CTX *c, NODE *n);

extern const struct NodeKind kind_node_plus;
extern const struct NodeKind kind_node_fixnum_plus;
extern const struct NodeKind kind_node_integer_plus;
extern const struct NodeKind kind_node_minus;
extern const struct NodeKind kind_node_fixnum_minus;
extern const struct NodeKind kind_node_integer_minus;
extern const struct NodeKind kind_node_mul;
extern const struct NodeKind kind_node_fixnum_mul;
extern const struct NodeKind kind_node_integer_mul;
extern const struct NodeKind kind_node_div;
extern const struct NodeKind kind_node_fixnum_div;
extern const struct NodeKind kind_node_integer_div;

// Helper: re-read current children from node after EVAL_ARG.
// Children may have been rewritten to type-specific nodes during evaluation,
// which updates the parent's child field via node_replace.
#define CUR_LEFT(n, kind)  (n->u.kind.left)
#define CUR_RIGHT(n, kind) (n->u.kind.right)

// Skip rewrite for orphaned nodes (already replaced by a prior rewrite).
// After node_replace, old_node->head.parent is set to NULL.
// Arithmetic/comparison nodes always have a parent when live in the tree.
#define SHOULD_REWRITE(n) ((n)->head.parent != NULL)

NODE_DEF
node_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_plus(CUR_LEFT(n, node_plus), CUR_RIGHT(n, node_plus));
            sp->u.node_fixnum_plus.replaced_from = n;
            node_replace(n, sp);
        }
        long result = FIX2LONG(lv) + FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
        return RESULT_OK(abruby_bignum_new(LONG2NUM(result)));
    }
    return node_arith_fallback(c, n, lv, rv, "+");
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_plus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv)
{
    if (SHOULD_REWRITE(n) && n->head.kind == &kind_node_fixnum_plus) {
        NODE *ip = ALLOC_node_integer_plus(CUR_LEFT(n, node_fixnum_plus), CUR_RIGHT(n, node_fixnum_plus));
        ip->u.node_integer_plus.replaced_from = n;
        node_replace(n, ip);
        return EVAL(c, ip);
    }
    return node_arith_fallback(c, n, lv, rv, "+");
}

NODE_DEF @rewritable
node_fixnum_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result;
        if (LIKELY(!__builtin_add_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return RESULT_OK(abruby_bignum_new(LONG2NUM(FIX2LONG(lv) + FIX2LONG(rv))));
    }
    return node_fixnum_plus_slow(c, n, lv, rv);
}

NODE_DEF @rewritable
node_integer_plus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result = FIX2LONG(lv) + FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if ((FIXNUM_P(lv) || AB_CLASS_OF(lv) == ab_integer_class) &&
        (FIXNUM_P(rv) || AB_CLASS_OF(rv) == ab_integer_class)) {
        return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("+"), 1, AB_INT_UNWRAP(rv))));
    }
    return node_arith_fallback(c, n, lv, rv, "+");
}

NODE_DEF
node_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_minus(CUR_LEFT(n, node_minus), CUR_RIGHT(n, node_minus));
            sp->u.node_fixnum_minus.replaced_from = n;
            node_replace(n, sp);
        }
        long result = FIX2LONG(lv) - FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
        return RESULT_OK(abruby_bignum_new(LONG2NUM(result)));
    }
    return node_arith_fallback(c, n, lv, rv, "-");
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_minus_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv)
{
    if (SHOULD_REWRITE(n) && n->head.kind == &kind_node_fixnum_minus) {
        NODE *ip = ALLOC_node_integer_minus(CUR_LEFT(n, node_fixnum_minus), CUR_RIGHT(n, node_fixnum_minus));
        ip->u.node_integer_minus.replaced_from = n;
        node_replace(n, ip);
        return EVAL(c, ip);
    }
    return node_arith_fallback(c, n, lv, rv, "-");
}

NODE_DEF @rewritable
node_fixnum_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result;
        if (LIKELY(!__builtin_sub_overflow((long)lv, (long)(rv - 1), &result)))
            return RESULT_OK((VALUE)result);
        return RESULT_OK(abruby_bignum_new(LONG2NUM(FIX2LONG(lv) - FIX2LONG(rv))));
    }
    return node_fixnum_minus_slow(c, n, lv, rv);
}

NODE_DEF @rewritable
node_integer_minus(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long result = FIX2LONG(lv) - FIX2LONG(rv);
        if (LIKELY(FIXABLE(result))) return RESULT_OK(LONG2FIX(result));
    }
    if ((FIXNUM_P(lv) || AB_CLASS_OF(lv) == ab_integer_class) &&
        (FIXNUM_P(rv) || AB_CLASS_OF(rv) == ab_integer_class)) {
        return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("-"), 1, AB_INT_UNWRAP(rv))));
    }
    return node_arith_fallback(c, n, lv, rv, "-");
}

NODE_DEF
node_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_mul(CUR_LEFT(n, node_mul), CUR_RIGHT(n, node_mul));
            sp->u.node_fixnum_mul.replaced_from = n;
            node_replace(n, sp);
        }
        long a = FIX2LONG(lv), b = FIX2LONG(rv);
        long result;
        if (LIKELY(!__builtin_mul_overflow(a, b, &result) && FIXABLE(result)))
            return RESULT_OK(LONG2FIX(result));
        VALUE big_result = rb_funcall(LONG2NUM(a), rb_intern("*"), 1, LONG2NUM(b));
        if (FIXNUM_P(big_result)) return RESULT_OK(big_result);
        return RESULT_OK(abruby_bignum_new(big_result));
    }
    return node_arith_fallback(c, n, lv, rv, "*");
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_mul_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv)
{
    if (SHOULD_REWRITE(n) && n->head.kind == &kind_node_fixnum_mul) {
        NODE *ip = ALLOC_node_integer_mul(CUR_LEFT(n, node_fixnum_mul), CUR_RIGHT(n, node_fixnum_mul));
        ip->u.node_integer_mul.replaced_from = n;
        node_replace(n, ip);
        return EVAL(c, ip);
    }
    return node_arith_fallback(c, n, lv, rv, "*");
}

NODE_DEF @rewritable
node_fixnum_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long a = FIX2LONG(lv), b = FIX2LONG(rv);
        long result;
        if (LIKELY(!__builtin_mul_overflow(a, b, &result) && FIXABLE(result)))
            return RESULT_OK(LONG2FIX(result));
        VALUE big_result = rb_funcall(LONG2NUM(a), rb_intern("*"), 1, LONG2NUM(b));
        if (FIXNUM_P(big_result)) return RESULT_OK(big_result);
        return RESULT_OK(abruby_bignum_new(big_result));
    }
    return node_fixnum_mul_slow(c, n, lv, rv);
}

NODE_DEF @rewritable
node_integer_mul(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long a = FIX2LONG(lv), b = FIX2LONG(rv);
        long result;
        if (LIKELY(!__builtin_mul_overflow(a, b, &result) && FIXABLE(result)))
            return RESULT_OK(LONG2FIX(result));
    }
    if ((FIXNUM_P(lv) || AB_CLASS_OF(lv) == ab_integer_class) &&
        (FIXNUM_P(rv) || AB_CLASS_OF(rv) == ab_integer_class)) {
        return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("*"), 1, AB_INT_UNWRAP(rv))));
    }
    return node_arith_fallback(c, n, lv, rv, "*");
}

NODE_DEF
node_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc = abruby_exception_new(c, c->current_frame->prev,
                abruby_str_new_cstr("divided by 0"));
            return (RESULT){exc, RESULT_RAISE};
        }
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_div(CUR_LEFT(n, node_div), CUR_RIGHT(n, node_div));
            sp->u.node_fixnum_div.replaced_from = n;
            node_replace(n, sp);
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    return node_arith_fallback(c, n, lv, rv, "/");
}

static __attribute__((noinline, cold)) RESULT
node_fixnum_div_slow(CTX * restrict c, NODE * restrict n, VALUE lv, VALUE rv)
{
    if (SHOULD_REWRITE(n) && n->head.kind == &kind_node_fixnum_div) {
        NODE *ip = ALLOC_node_integer_div(CUR_LEFT(n, node_fixnum_div), CUR_RIGHT(n, node_fixnum_div));
        ip->u.node_integer_div.replaced_from = n;
        node_replace(n, ip);
        return EVAL(c, ip);
    }
    return node_arith_fallback(c, n, lv, rv, "/");
}

NODE_DEF @rewritable
node_fixnum_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc = abruby_exception_new(c, c->current_frame->prev,
                abruby_str_new_cstr("divided by 0"));
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    return node_fixnum_div_slow(c, n, lv, rv);
}

NODE_DEF @rewritable
node_integer_div(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        long b = FIX2LONG(rv);
        if (UNLIKELY(b == 0)) {
            VALUE exc = abruby_exception_new(c, c->current_frame->prev,
                abruby_str_new_cstr("divided by 0"));
            return (RESULT){exc, RESULT_RAISE};
        }
        long a = FIX2LONG(lv);
        long d = a / b;
        if ((a ^ b) < 0 && d * b != a) d--;
        return RESULT_OK(LONG2FIX(d));
    }
    if ((FIXNUM_P(lv) || AB_CLASS_OF(lv) == ab_integer_class) &&
        (FIXNUM_P(rv) || AB_CLASS_OF(rv) == ab_integer_class)) {
        return RESULT_OK(AB_NUM_WRAP(rb_funcall(AB_INT_UNWRAP(lv), rb_intern("/"), 1, AB_INT_UNWRAP(rv))));
    }
    return node_arith_fallback(c, n, lv, rv, "/");
}

// === Comparison rewrite (type-specific nodes) ===

static RESULT DISPATCH_node_lt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_lt(CTX *c, NODE *n);
static RESULT DISPATCH_node_le(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_le(CTX *c, NODE *n);
static RESULT DISPATCH_node_gt(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_gt(CTX *c, NODE *n);
static RESULT DISPATCH_node_ge(CTX *c, NODE *n);
static RESULT DISPATCH_node_fixnum_ge(CTX *c, NODE *n);

extern const struct NodeKind kind_node_lt;
extern const struct NodeKind kind_node_fixnum_lt;
extern const struct NodeKind kind_node_le;
extern const struct NodeKind kind_node_fixnum_le;
extern const struct NodeKind kind_node_gt;
extern const struct NodeKind kind_node_fixnum_gt;
extern const struct NodeKind kind_node_ge;
extern const struct NodeKind kind_node_fixnum_ge;

NODE_DEF
node_lt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_lt(CUR_LEFT(n, node_lt), CUR_RIGHT(n, node_lt));
            sp->u.node_fixnum_lt.replaced_from = n;
            node_replace(n, sp);
        }
        return RESULT_OK(FIX2LONG(lv) < FIX2LONG(rv) ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, "<");
}

NODE_DEF @rewritable
node_fixnum_lt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK((long)lv < (long)rv ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, "<");
}

NODE_DEF
node_le(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_le(CUR_LEFT(n, node_le), CUR_RIGHT(n, node_le));
            sp->u.node_fixnum_le.replaced_from = n;
            node_replace(n, sp);
        }
        return RESULT_OK(FIX2LONG(lv) <= FIX2LONG(rv) ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, "<=");
}

NODE_DEF @rewritable
node_fixnum_le(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK((long)lv <= (long)rv ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, "<=");
}

NODE_DEF
node_gt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_gt(CUR_LEFT(n, node_gt), CUR_RIGHT(n, node_gt));
            sp->u.node_fixnum_gt.replaced_from = n;
            node_replace(n, sp);
        }
        return RESULT_OK(FIX2LONG(lv) > FIX2LONG(rv) ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, ">");
}

NODE_DEF @rewritable
node_fixnum_gt(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK((long)lv > (long)rv ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, ">");
}

NODE_DEF
node_ge(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        if (SHOULD_REWRITE(n)) {
            NODE *sp = ALLOC_node_fixnum_ge(CUR_LEFT(n, node_ge), CUR_RIGHT(n, node_ge));
            sp->u.node_fixnum_ge.replaced_from = n;
            node_replace(n, sp);
        }
        return RESULT_OK((long)lv >= (long)rv ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, ">=");
}

NODE_DEF @rewritable
node_fixnum_ge(CTX * restrict c, NODE * restrict n, NODE *left, NODE *right)
{
    VALUE lv = UNWRAP(EVAL_ARG(c, left));
    VALUE rv = UNWRAP(EVAL_ARG(c, right));
    if (LIKELY(FIXNUM_P(lv) && FIXNUM_P(rv))) {
        return RESULT_OK((long)lv >= (long)rv ? Qtrue : Qfalse);
    }
    return node_arith_fallback(c, n, lv, rv, ">=");
}

