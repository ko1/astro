
// =====================================================================
// castro: a C subset on ASTro.  VALUE is a union (.i / .d / .p);
// each typed node knows which slot to read / write.
// =====================================================================

// --- literals -------------------------------------------------------

NODE_DEF
node_lit_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, int32_t v)
{
    return (VALUE){.i = v};
}

// 64-bit literal (for big constants).  astrogen has uint64_t support.
NODE_DEF
node_lit_i64(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint64_t v)
{
    return (VALUE){.i = (int64_t)v};
}

NODE_DEF
node_lit_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, double v)
{
    return (VALUE){.d = v};
}

// String literal — stored in the .p slot of the VALUE union.
NODE_DEF
node_lit_str(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *v)
{
    return (VALUE){.p = (void *)v};
}

// --- locals ---------------------------------------------------------

NODE_DEF
node_lget(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return fp[idx];
}

NODE_DEF
node_lset(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx, NODE *rhs)
{
    VALUE v = EVAL_ARG(c, rhs);
    fp[idx] = v;
    return v;
}

// --- globals --------------------------------------------------------
//
// Globals live in c->globals (a flat VALUE region).  parse.rb assigns
// each global a slot index; arrays and structs span multiple consecutive
// slots starting at their head index.

NODE_DEF
node_gget(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return c->globals[idx];
}

NODE_DEF
node_gset(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx, NODE *rhs)
{
    VALUE v = EVAL_ARG(c, rhs);
    c->globals[idx] = v;
    return v;
}

// --- address-of -----------------------------------------------------

NODE_DEF
node_addr_local(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return (VALUE){.p = &fp[idx]};
}

NODE_DEF
node_addr_global(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return (VALUE){.p = &c->globals[idx]};
}

// --- pointer load / store -------------------------------------------
//
// All castro data lives in 8-byte VALUE slots; pointer arithmetic is
// done in slot units (see node_ptr_add).  The load_x / store_x family
// reads or writes the corresponding union slot through the pointer.
// parse.rb picks the variant matching the pointer's pointee type.

NODE_DEF
node_load_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    VALUE *vp = (VALUE *)EVAL_ARG(c, p).p;
    return (VALUE){.i = vp->i};
}

NODE_DEF
node_load_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    VALUE *vp = (VALUE *)EVAL_ARG(c, p).p;
    return (VALUE){.d = vp->d};
}

NODE_DEF
node_load_p(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    VALUE *vp = (VALUE *)EVAL_ARG(c, p).p;
    return (VALUE){.p = vp->p};
}

NODE_DEF
node_store_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *v)
{
    void *pv = EVAL_ARG(c, p).p;
    int64_t vv = EVAL_ARG(c, v).i;
    ((VALUE *)pv)->i = vv;
    return (VALUE){.i = vv};
}

NODE_DEF
node_store_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *v)
{
    void *pv = EVAL_ARG(c, p).p;
    double vv = EVAL_ARG(c, v).d;
    ((VALUE *)pv)->d = vv;
    return (VALUE){.d = vv};
}

NODE_DEF
node_store_p(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *v)
{
    void *pv = EVAL_ARG(c, p).p;
    void *vv = EVAL_ARG(c, v).p;
    ((VALUE *)pv)->p = vv;
    return (VALUE){.p = vv};
}

// p + i  /  p - i  /  p1 - p2 — all in slot units (see header note).

NODE_DEF
node_ptr_add(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *off)
{
    VALUE *pv = (VALUE *)EVAL_ARG(c, p).p;
    int64_t o = EVAL_ARG(c, off).i;
    return (VALUE){.p = pv + o};
}

NODE_DEF
node_ptr_sub_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *off)
{
    VALUE *pv = (VALUE *)EVAL_ARG(c, p).p;
    int64_t o = EVAL_ARG(c, off).i;
    return (VALUE){.p = pv - o};
}

NODE_DEF
node_ptr_diff(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *a, NODE *b)
{
    VALUE *av = (VALUE *)EVAL_ARG(c, a).p;
    VALUE *bv = (VALUE *)EVAL_ARG(c, b).p;
    return (VALUE){.i = av - bv};
}

// String literal → VALUE-slot region.  parse.rb hands us the unescaped
// bytes (NUL-terminated); the runtime caches the conversion so equal
// literals share storage.

extern VALUE *castro_intern_string(const char *s);

NODE_DEF
node_lit_str_array(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *v)
{
    return (VALUE){.p = castro_intern_string(v)};
}

// --- common libc-ish builtins (operate on VALUE-slot buffers) -------

NODE_DEF
node_call_malloc(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *bytes)
{
    int64_t b = EVAL_ARG(c, bytes).i;
    if (b <= 0) return (VALUE){.p = NULL};
    // Bytes-to-slots: castro stores 1 element per VALUE slot, so we
    // allocate enough slots to hold one element of the largest reasonable
    // type the caller could mean (we conservatively round up to slot).
    size_t slots = ((size_t)b + sizeof(VALUE) - 1) / sizeof(VALUE);
    return (VALUE){.p = calloc(slots, sizeof(VALUE))};
}

NODE_DEF
node_call_calloc(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *count, NODE *size)
{
    int64_t k = EVAL_ARG(c, count).i;
    int64_t b = EVAL_ARG(c, size).i;
    if (k <= 0 || b <= 0) return (VALUE){.p = NULL};
    size_t total_bytes = (size_t)k * (size_t)b;
    size_t slots = (total_bytes + sizeof(VALUE) - 1) / sizeof(VALUE);
    if (slots == 0) slots = 1;
    return (VALUE){.p = calloc(slots, sizeof(VALUE))};
}

NODE_DEF
node_call_free(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    free(EVAL_ARG(c, p).p);
    return (VALUE){.i = 0};
}

extern int64_t castro_strlen(const VALUE *s);
extern int64_t castro_strcmp(const VALUE *a, const VALUE *b);
extern int64_t castro_strncmp(const VALUE *a, const VALUE *b, int64_t n);
extern VALUE *castro_strcpy(VALUE *dst, const VALUE *src);
extern VALUE *castro_strncpy(VALUE *dst, const VALUE *src, int64_t n);
extern VALUE *castro_strcat(VALUE *dst, const VALUE *src);
extern void *castro_memset(VALUE *dst, int64_t v, int64_t n);
extern void *castro_memcpy(VALUE *dst, const VALUE *src, int64_t n);
extern int64_t castro_atoi(const VALUE *s);
extern void castro_exit(int code);

NODE_DEF
node_call_strlen(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *s)
{
    return (VALUE){.i = castro_strlen((const VALUE *)EVAL_ARG(c, s).p)};
}

NODE_DEF
node_call_strcmp(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *a, NODE *b)
{
    return (VALUE){.i = castro_strcmp((const VALUE *)EVAL_ARG(c, a).p,
                                       (const VALUE *)EVAL_ARG(c, b).p)};
}

NODE_DEF
node_call_strncmp(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *a, NODE *b, NODE *k)
{
    return (VALUE){.i = castro_strncmp((const VALUE *)EVAL_ARG(c, a).p,
                                        (const VALUE *)EVAL_ARG(c, b).p,
                                        EVAL_ARG(c, k).i)};
}

NODE_DEF
node_call_strcpy(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src)
{
    return (VALUE){.p = castro_strcpy((VALUE *)EVAL_ARG(c, dst).p,
                                       (const VALUE *)EVAL_ARG(c, src).p)};
}

NODE_DEF
node_call_strncpy(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src, NODE *k)
{
    return (VALUE){.p = castro_strncpy((VALUE *)EVAL_ARG(c, dst).p,
                                        (const VALUE *)EVAL_ARG(c, src).p,
                                        EVAL_ARG(c, k).i)};
}

NODE_DEF
node_call_strcat(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src)
{
    return (VALUE){.p = castro_strcat((VALUE *)EVAL_ARG(c, dst).p,
                                       (const VALUE *)EVAL_ARG(c, src).p)};
}

NODE_DEF
node_call_memset(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *v, NODE *k)
{
    return (VALUE){.p = castro_memset((VALUE *)EVAL_ARG(c, dst).p,
                                       EVAL_ARG(c, v).i, EVAL_ARG(c, k).i)};
}

NODE_DEF
node_call_memcpy(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src, NODE *k)
{
    return (VALUE){.p = castro_memcpy((VALUE *)EVAL_ARG(c, dst).p,
                                       (const VALUE *)EVAL_ARG(c, src).p,
                                       EVAL_ARG(c, k).i)};
}

NODE_DEF
node_call_atoi(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *s)
{
    return (VALUE){.i = castro_atoi((const VALUE *)EVAL_ARG(c, s).p)};
}

NODE_DEF @noinline
node_call_exit(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *code)
{
    castro_exit((int)EVAL_ARG(c, code).i);
    __builtin_unreachable();
}

NODE_DEF
node_call_abs(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *x)
{
    int64_t v = EVAL_ARG(c, x).i;
    return (VALUE){.i = v < 0 ? -v : v};
}

// --- sequencing -----------------------------------------------------

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *head, NODE *tail)
{
    EVAL_ARG(c, head);
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_nop(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    return (VALUE){.i = 0};
}

NODE_DEF
node_drop(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    EVAL_ARG(c, e);
    return (VALUE){.i = 0};
}

// --- control flow ---------------------------------------------------

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *then_node, NODE *else_node)
{
    if (EVAL_ARG(c, cond).i) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *body)
{
    while (EVAL_ARG(c, cond).i) {
        EVAL_ARG(c, body);
    }
    return (VALUE){.i = 0};
}

NODE_DEF
node_do_while(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *body, NODE *cond)
{
    do {
        EVAL_ARG(c, body);
    } while (EVAL_ARG(c, cond).i);
    return (VALUE){.i = 0};
}

NODE_DEF
node_for(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *init, NODE *cond, NODE *step, NODE *body)
{
    EVAL_ARG(c, init);
    while (EVAL_ARG(c, cond).i) {
        EVAL_ARG(c, body);
        EVAL_ARG(c, step);
    }
    return (VALUE){.i = 0};
}

NODE_DEF @noinline
node_return(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *expr)
{
    c->return_value = EVAL_ARG(c, expr);
    longjmp(*c->return_buf, 1);
    // unreachable
    __builtin_unreachable();
}

NODE_DEF @noinline
node_return_void(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    c->return_value = (VALUE){.i = 0};
    longjmp(*c->return_buf, 1);
    __builtin_unreachable();
}

// --- break / continue / loop-with-brk -------------------------------
//
// Loops in source that contain a break or continue statement get
// rerouted by parse.rb to the *_brk variants below.  A non-inline
// helper sets up the appropriate jmp_buf so node_break / node_continue
// can longjmp back to the loop boundary.  Plain loops (no break /
// continue in body) keep the fast pointer-call path.

NODE_DEF @noinline
node_break(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    longjmp(*c->break_buf, 1);
    __builtin_unreachable();
}

NODE_DEF @noinline
node_continue(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    longjmp(*c->continue_buf, 1);
    __builtin_unreachable();
}

VALUE castro_loop_while(CTX *c, VALUE *fp, NODE *cond, node_dispatcher_func_t cd,
                        NODE *body, node_dispatcher_func_t bd, bool has_continue);
VALUE castro_loop_do_while(CTX *c, VALUE *fp, NODE *body, node_dispatcher_func_t bd,
                           NODE *cond, node_dispatcher_func_t cd, bool has_continue);
VALUE castro_loop_for(CTX *c, VALUE *fp, NODE *init, node_dispatcher_func_t id,
                      NODE *cond, node_dispatcher_func_t cd,
                      NODE *step, node_dispatcher_func_t sd,
                      NODE *body, node_dispatcher_func_t bd, bool has_continue);

NODE_DEF
node_while_brk(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *body)
{
    return castro_loop_while(c, fp, cond, cond_dispatcher, body, body_dispatcher, true);
}

NODE_DEF
node_while_brk_only(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *body)
{
    return castro_loop_while(c, fp, cond, cond_dispatcher, body, body_dispatcher, false);
}

NODE_DEF
node_do_while_brk(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *body, NODE *cond)
{
    return castro_loop_do_while(c, fp, body, body_dispatcher, cond, cond_dispatcher, true);
}

NODE_DEF
node_do_while_brk_only(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *body, NODE *cond)
{
    return castro_loop_do_while(c, fp, body, body_dispatcher, cond, cond_dispatcher, false);
}

NODE_DEF
node_for_brk(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *init, NODE *cond, NODE *step, NODE *body)
{
    return castro_loop_for(c, fp, init, init_dispatcher, cond, cond_dispatcher,
                           step, step_dispatcher, body, body_dispatcher, true);
}

NODE_DEF
node_for_brk_only(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *init, NODE *cond, NODE *step, NODE *body)
{
    return castro_loop_for(c, fp, init, init_dispatcher, cond, cond_dispatcher,
                           step, step_dispatcher, body, body_dispatcher, false);
}

// --- ternary --------------------------------------------------------
// (Same as node_if but kept separate for readability of dumps.)

NODE_DEF
node_ternary(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *t, NODE *e)
{
    return (EVAL_ARG(c, cond).i) ? EVAL_ARG(c, t) : EVAL_ARG(c, e);
}

// --- short-circuit logical ------------------------------------------

NODE_DEF
node_land(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    if (!EVAL_ARG(c, l).i) return (VALUE){.i = 0};
    return (VALUE){.i = EVAL_ARG(c, r).i ? 1 : 0};
}

NODE_DEF
node_lor(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    if (EVAL_ARG(c, l).i)  return (VALUE){.i = 1};
    return (VALUE){.i = EVAL_ARG(c, r).i ? 1 : 0};
}

NODE_DEF
node_lnot(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return (VALUE){.i = !EVAL_ARG(c, e).i};
}

// --- int arithmetic -------------------------------------------------

NODE_DEF
node_add_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = EVAL_ARG(c, l).i;
    int64_t rv = EVAL_ARG(c, r).i;
    return (VALUE){.i = lv + rv};
}

NODE_DEF
node_sub_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = EVAL_ARG(c, l).i;
    int64_t rv = EVAL_ARG(c, r).i;
    return (VALUE){.i = lv - rv};
}

NODE_DEF
node_mul_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = EVAL_ARG(c, l).i;
    int64_t rv = EVAL_ARG(c, r).i;
    return (VALUE){.i = lv * rv};
}

NODE_DEF
node_div_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = EVAL_ARG(c, l).i;
    int64_t rv = EVAL_ARG(c, r).i;
    return (VALUE){.i = lv / rv};
}

NODE_DEF
node_mod_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = EVAL_ARG(c, l).i;
    int64_t rv = EVAL_ARG(c, r).i;
    return (VALUE){.i = lv % rv};
}

NODE_DEF
node_neg_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return (VALUE){.i = -EVAL_ARG(c, e).i};
}

// --- int bitwise ----------------------------------------------------

NODE_DEF
node_band(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i & EVAL_ARG(c, r).i};
}

NODE_DEF
node_bor(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i | EVAL_ARG(c, r).i};
}

NODE_DEF
node_bxor(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i ^ EVAL_ARG(c, r).i};
}

NODE_DEF
node_bnot(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return (VALUE){.i = ~EVAL_ARG(c, e).i};
}

NODE_DEF
node_shl(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i << EVAL_ARG(c, r).i};
}

NODE_DEF
node_shr(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i >> EVAL_ARG(c, r).i};
}

// --- int comparison (returns int) ----------------------------------

NODE_DEF
node_lt_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i < EVAL_ARG(c, r).i};
}

NODE_DEF
node_le_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i <= EVAL_ARG(c, r).i};
}

NODE_DEF
node_gt_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i > EVAL_ARG(c, r).i};
}

NODE_DEF
node_ge_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i >= EVAL_ARG(c, r).i};
}

NODE_DEF
node_eq_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i == EVAL_ARG(c, r).i};
}

NODE_DEF
node_neq_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).i != EVAL_ARG(c, r).i};
}

// --- double arithmetic ---------------------------------------------

NODE_DEF
node_add_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = EVAL_ARG(c, l).d;
    double rv = EVAL_ARG(c, r).d;
    return (VALUE){.d = lv + rv};
}

NODE_DEF
node_sub_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = EVAL_ARG(c, l).d;
    double rv = EVAL_ARG(c, r).d;
    return (VALUE){.d = lv - rv};
}

NODE_DEF
node_mul_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = EVAL_ARG(c, l).d;
    double rv = EVAL_ARG(c, r).d;
    return (VALUE){.d = lv * rv};
}

NODE_DEF
node_div_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = EVAL_ARG(c, l).d;
    double rv = EVAL_ARG(c, r).d;
    return (VALUE){.d = lv / rv};
}

NODE_DEF
node_neg_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return (VALUE){.d = -EVAL_ARG(c, e).d};
}

// --- double comparison (returns int) -------------------------------

NODE_DEF
node_lt_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).d < EVAL_ARG(c, r).d};
}

NODE_DEF
node_le_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).d <= EVAL_ARG(c, r).d};
}

NODE_DEF
node_gt_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).d > EVAL_ARG(c, r).d};
}

NODE_DEF
node_ge_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).d >= EVAL_ARG(c, r).d};
}

NODE_DEF
node_eq_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).d == EVAL_ARG(c, r).d};
}

NODE_DEF
node_neq_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return (VALUE){.i = EVAL_ARG(c, l).d != EVAL_ARG(c, r).d};
}

// --- casts ---------------------------------------------------------

NODE_DEF
node_cast_id(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return (VALUE){.d = (double)EVAL_ARG(c, e).i};
}

NODE_DEF
node_cast_di(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return (VALUE){.i = (int64_t)EVAL_ARG(c, e).d};
}

// --- function call -------------------------------------------------
//
// Calls in C are resolved at parse time: parse.rb assigns each
// function_definition a stable index into `c->func_set[]`, and the IR
// just carries that index.  No name lookup, no inline cache.
//
// Hot path: if the callee has no remaining `return` (parse.rb lifted
// all tail returns), we dispatch the body directly with no setjmp.
// Cold path: castro_invoke_jmp wraps setjmp/longjmp.

VALUE castro_invoke_jmp(CTX *c, struct Node *body, node_dispatcher_func_t disp, VALUE *callee_fp);

// Two call variants picked by parse.rb at parse time:
//   - `node_call`     — callee has no early `return` (parse-time
//                       lifted), so we never need a setjmp boundary.
//                       The hot path is just an indirect call to the
//                       callee SD with the callee frame in a register.
//   - `node_call_jmp` — callee has at least one un-lifted `return`,
//                       so we wrap the dispatch in setjmp/longjmp.

NODE_DEF
node_call(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t func_idx, uint32_t arg_count, uint32_t arg_index)
{
    (void)arg_count;
    struct function_entry *fe = &c->func_set[func_idx];
    NODE *body = fe->body;
    // Compute the callee frame in a register; no CTX writes.
    return (*body->head.dispatcher)(c, body, fp + arg_index);
}

NODE_DEF
node_call_jmp(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t func_idx, uint32_t arg_count, uint32_t arg_index)
{
    (void)arg_count;
    struct function_entry *fe = &c->func_set[func_idx];
    return castro_invoke_jmp(c, fe->body, fe->body->head.dispatcher, fp + arg_index);
}

// --- builtin: printf / putchar / puts -----------------------------
//
// printf-family is variadic; each typed arg is read from the caller's
// frame at fp[arg_index..arg_index+arg_count-1].  The format string is
// fp[arg_index].p; subsequent slots carry typed values selected per
// conversion specifier.  See castro_run_printf in main.c.

extern int castro_run_printf(const char *fmt, VALUE *args, uint32_t arg_count);

NODE_DEF @noinline
node_printf(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t arg_count, uint32_t arg_index)
{
    const char *fmt = (const char *)fp[arg_index].p;
    int r = castro_run_printf(fmt, &fp[arg_index + 1], arg_count - 1);
    return (VALUE){.i = r};
}

NODE_DEF
node_putchar(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    int ch = (int)EVAL_ARG(c, e).i;
    return (VALUE){.i = putchar(ch)};
}

extern int castro_puts(const VALUE *slot_str);

NODE_DEF
node_puts(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return (VALUE){.i = castro_puts((const VALUE *)EVAL_ARG(c, e).p)};
}

// --- function pointer ----------------------------------------------
//
// Taking a function's address: parse.rb gives us the index, runtime
// returns the matching `function_entry *` in the .p slot of VALUE.
// An indirect call reads the entry, sets up frame pointer, and dispatches.

NODE_DEF
node_func_addr(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t func_idx)
{
    return (VALUE){.p = &c->func_set[func_idx]};
}

VALUE castro_indirect_invoke(CTX *c, struct function_entry *fe, VALUE *callee_fp);

NODE_DEF
node_call_indirect(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *fn_expr, uint32_t arg_count, uint32_t arg_index)
{
    struct function_entry *fe = (struct function_entry *)EVAL_ARG(c, fn_expr).p;
    (void)arg_count;
    return castro_indirect_invoke(c, fe, fp + arg_index);
}

// --- goto / labels --------------------------------------------------
//
// parse.rb compiles a function with goto into:
//   while (1) { switch (label) { case 0: ...goto-A...; case 1: ...; } }
// node_label_dispatch / node_goto / node_label_yield form the runtime
// of that lowering.  See parse.rb for details.

NODE_DEF @noinline
node_goto(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, int32_t label)
{
    c->goto_target = label;
    longjmp(*c->goto_buf, 1);
    __builtin_unreachable();
}

VALUE castro_goto_dispatch(CTX *c, NODE *body, node_dispatcher_func_t bd, VALUE *fp);

NODE_DEF
node_goto_dispatch(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *body)
{
    return castro_goto_dispatch(c, body, body_dispatcher, fp);
}

NODE_DEF
node_goto_target(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    return (VALUE){.i = c->goto_target};
}

// (No statement-level node_def: function definitions are registered
// by load_program in main.c at SX-load time, not as evaluatable AST
// nodes.  The previous `node_def` was a runtime-defining hook left
// over from the dynamic-language samples.)
