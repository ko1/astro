
// =====================================================================
// castro: a C subset on ASTro.  VALUE is a union (.i / .d / .p);
// each typed node knows which slot to read / write.
//
// Every node returns RESULT (= rax:rdx).  Helpers below extract VALUE
// while propagating non-NORMAL state via early-return.  The state
// machinery is what subsumes setjmp/longjmp for return/break/continue/
// goto — abruby's design, see context.h.
// =====================================================================

// Extract VALUE from a RESULT, propagating non-NORMAL state up the
// call chain by early-returning the whole RESULT.  In a fully-inlined
// SD chain `_r.state` is a constant 0 so the test and the early-return
// branch both DCE; only at non-inlined boundaries (e.g. a recursive
// SD call) does the propagation actually emit code, where it's a
// single register cmp+jne with a perfectly-predicted not-taken branch.
#define UNWRAP(r) ({ RESULT _r = (r); if (UNLIKELY(_r.state != RESULT_NORMAL)) return _r; _r.value; })

// --- literals -------------------------------------------------------

NODE_DEF
node_lit_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, int32_t v)
{
    return RESULT_OK((VALUE){.i = v});
}

// 64-bit literal (for big constants).  astrogen has uint64_t support.
NODE_DEF
node_lit_i64(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint64_t v)
{
    return RESULT_OK((VALUE){.i = (int64_t)v});
}

NODE_DEF
node_lit_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, double v)
{
    return RESULT_OK((VALUE){.d = v});
}

// String literal — stored in the .p slot of the VALUE union.
NODE_DEF
node_lit_str(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *v)
{
    return RESULT_OK((VALUE){.p = (void *)v});
}

// --- locals ---------------------------------------------------------

NODE_DEF
node_lget(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return RESULT_OK(fp[idx]);
}

NODE_DEF
node_lset(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    fp[idx] = v;
    return RESULT_OK(v);
}

// --- globals --------------------------------------------------------
//
// Globals live in c->globals (a flat VALUE region).  parse.rb assigns
// each global a slot index; arrays and structs span multiple consecutive
// slots starting at their head index.

NODE_DEF
node_gget(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return RESULT_OK(c->globals[idx]);
}

NODE_DEF
node_gset(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx, NODE *rhs)
{
    VALUE v = UNWRAP(EVAL_ARG(c, rhs));
    c->globals[idx] = v;
    return RESULT_OK(v);
}

// --- address-of -----------------------------------------------------

NODE_DEF
node_addr_local(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return RESULT_OK((VALUE){.p = &fp[idx]});
}

NODE_DEF
node_addr_global(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t idx)
{
    return RESULT_OK((VALUE){.p = &c->globals[idx]});
}

// --- pointer load / store -------------------------------------------
//
// All castro data lives in 8-byte VALUE slots; pointer arithmetic is
// done in slot units (see node_ptr_add).  The load_x / store_x family
// reads or writes the corresponding union slot through the pointer.
// parse.rb picks the variant matching the pointer's pointee type.

// Loads/stores go through typed `int64_t *` / `double *` rather than
// through the `VALUE` union so gcc's TBAA can prove they don't alias
// `VALUE *fp`.  Without this gcc treats every store_i as potentially
// aliasing the frame and reloads loop locals (i, j, n) from `fp[]`
// every iteration of e.g. sieve's mark loop.

NODE_DEF
node_load_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    int64_t *ip = (int64_t *)UNWRAP(EVAL_ARG(c, p)).p;
    return RESULT_OK((VALUE){.i = *ip});
}

NODE_DEF
node_load_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    double *dp = (double *)UNWRAP(EVAL_ARG(c, p)).p;
    return RESULT_OK((VALUE){.d = *dp});
}

NODE_DEF
node_load_p(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    void **pp = (void **)UNWRAP(EVAL_ARG(c, p)).p;
    return RESULT_OK((VALUE){.p = *pp});
}

NODE_DEF
node_store_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *v)
{
    int64_t *ip = (int64_t *)UNWRAP(EVAL_ARG(c, p)).p;
    int64_t vv = UNWRAP(EVAL_ARG(c, v)).i;
    *ip = vv;
    return RESULT_OK((VALUE){.i = vv});
}

NODE_DEF
node_store_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *v)
{
    double *dp = (double *)UNWRAP(EVAL_ARG(c, p)).p;
    double vv = UNWRAP(EVAL_ARG(c, v)).d;
    *dp = vv;
    return RESULT_OK((VALUE){.d = vv});
}

NODE_DEF
node_store_p(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *v)
{
    void *pv = UNWRAP(EVAL_ARG(c, p)).p;
    void *vv = UNWRAP(EVAL_ARG(c, v)).p;
    ((VALUE *)pv)->p = vv;
    return RESULT_OK((VALUE){.p = vv});
}

// p + i  /  p - i  /  p1 - p2 — all in slot units (see header note).

NODE_DEF
node_ptr_add(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *off)
{
    VALUE *pv = (VALUE *)UNWRAP(EVAL_ARG(c, p)).p;
    int64_t o = UNWRAP(EVAL_ARG(c, off)).i;
    return RESULT_OK((VALUE){.p = pv + o});
}

NODE_DEF
node_ptr_sub_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p, NODE *off)
{
    VALUE *pv = (VALUE *)UNWRAP(EVAL_ARG(c, p)).p;
    int64_t o = UNWRAP(EVAL_ARG(c, off)).i;
    return RESULT_OK((VALUE){.p = pv - o});
}

NODE_DEF
node_ptr_diff(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *a, NODE *b)
{
    VALUE *av = (VALUE *)UNWRAP(EVAL_ARG(c, a)).p;
    VALUE *bv = (VALUE *)UNWRAP(EVAL_ARG(c, b)).p;
    return RESULT_OK((VALUE){.i = av - bv});
}

// String literal → VALUE-slot region.  parse.rb hands us the unescaped
// bytes (NUL-terminated); the runtime caches the conversion so equal
// literals share storage.

extern VALUE *castro_intern_string(const char *s);

NODE_DEF
node_lit_str_array(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, const char *v)
{
    return RESULT_OK((VALUE){.p = castro_intern_string(v)});
}

// --- common libc-ish builtins (operate on VALUE-slot buffers) -------

NODE_DEF
node_call_malloc(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *bytes)
{
    int64_t b = UNWRAP(EVAL_ARG(c, bytes)).i;
    if (b <= 0) return RESULT_OK((VALUE){.p = NULL});
    // Bytes-to-slots: castro stores 1 element per VALUE slot, so we
    // allocate enough slots to hold one element of the largest reasonable
    // type the caller could mean (we conservatively round up to slot).
    size_t slots = ((size_t)b + sizeof(VALUE) - 1) / sizeof(VALUE);
    return RESULT_OK((VALUE){.p = calloc(slots, sizeof(VALUE))});
}

NODE_DEF
node_call_calloc(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *count, NODE *size)
{
    int64_t k = UNWRAP(EVAL_ARG(c, count)).i;
    int64_t b = UNWRAP(EVAL_ARG(c, size)).i;
    if (k <= 0 || b <= 0) return RESULT_OK((VALUE){.p = NULL});
    // Castro stores one C scalar per VALUE slot regardless of its byte
    // width: an `int` and a `double` both occupy 1 slot.  C programs
    // typically write `calloc(N, sizeof(T))` to mean "N elements"; the
    // multiplied byte-count vs slot-count rounds wrong (e.g.
    // `calloc(64, 4)` = 256 bytes = 32 slots, but the program expects
    // 64 ints).  So compute slots-per-element from the byte size and
    // multiply by element count.  Sub-slot element sizes (char, short,
    // int) round up to 1 slot each; struct sizes that exceed 8 bytes
    // get the right multi-slot allocation.
    size_t elem_slots = ((size_t)b + sizeof(VALUE) - 1) / sizeof(VALUE);
    if (elem_slots == 0) elem_slots = 1;
    size_t total_slots = (size_t)k * elem_slots;
    return RESULT_OK((VALUE){.p = calloc(total_slots, sizeof(VALUE))});
}

NODE_DEF
node_call_free(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *p)
{
    free(UNWRAP(EVAL_ARG(c, p)).p);
    return RESULT_OK((VALUE){.i = 0});
}

extern int64_t castro_strlen(const VALUE *s);
extern int64_t castro_strcmp(const VALUE *a, const VALUE *b);
extern int64_t castro_strncmp(const VALUE *a, const VALUE *b, int64_t n);
extern VALUE *castro_strcpy(VALUE *dst, const VALUE *src);
extern VALUE *castro_strncpy(VALUE *dst, const VALUE *src, int64_t n);
extern VALUE *castro_strcat(VALUE *dst, const VALUE *src);
extern void *castro_memset(VALUE *dst, int64_t v, int64_t n);
extern void *castro_memcpy(VALUE *dst, const VALUE *src, int64_t n);
extern int64_t castro_memcmp(const VALUE *a, const VALUE *b, int64_t n);
extern int64_t castro_atoi(const VALUE *s);
extern void castro_exit(int code);

NODE_DEF
node_call_strlen(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *s)
{
    return RESULT_OK((VALUE){.i = castro_strlen((const VALUE *)UNWRAP(EVAL_ARG(c, s)).p)});
}

NODE_DEF
node_call_strcmp(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *a, NODE *b)
{
    return RESULT_OK((VALUE){.i = castro_strcmp((const VALUE *)UNWRAP(EVAL_ARG(c, a)).p,
                                       (const VALUE *)UNWRAP(EVAL_ARG(c, b)).p)});
}

NODE_DEF
node_call_strncmp(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *a, NODE *b, NODE *k)
{
    return RESULT_OK((VALUE){.i = castro_strncmp((const VALUE *)UNWRAP(EVAL_ARG(c, a)).p,
                                        (const VALUE *)UNWRAP(EVAL_ARG(c, b)).p,
                                        UNWRAP(EVAL_ARG(c, k)).i)});
}

NODE_DEF
node_call_strcpy(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src)
{
    return RESULT_OK((VALUE){.p = castro_strcpy((VALUE *)UNWRAP(EVAL_ARG(c, dst)).p,
                                       (const VALUE *)UNWRAP(EVAL_ARG(c, src)).p)});
}

NODE_DEF
node_call_strncpy(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src, NODE *k)
{
    return RESULT_OK((VALUE){.p = castro_strncpy((VALUE *)UNWRAP(EVAL_ARG(c, dst)).p,
                                        (const VALUE *)UNWRAP(EVAL_ARG(c, src)).p,
                                        UNWRAP(EVAL_ARG(c, k)).i)});
}

NODE_DEF
node_call_strcat(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src)
{
    return RESULT_OK((VALUE){.p = castro_strcat((VALUE *)UNWRAP(EVAL_ARG(c, dst)).p,
                                       (const VALUE *)UNWRAP(EVAL_ARG(c, src)).p)});
}

NODE_DEF
node_call_memset(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *v, NODE *k)
{
    return RESULT_OK((VALUE){.p = castro_memset((VALUE *)UNWRAP(EVAL_ARG(c, dst)).p,
                                       UNWRAP(EVAL_ARG(c, v)).i, UNWRAP(EVAL_ARG(c, k)).i)});
}

NODE_DEF
node_call_memcpy(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *dst, NODE *src, NODE *k)
{
    return RESULT_OK((VALUE){.p = castro_memcpy((VALUE *)UNWRAP(EVAL_ARG(c, dst)).p,
                                       (const VALUE *)UNWRAP(EVAL_ARG(c, src)).p,
                                       UNWRAP(EVAL_ARG(c, k)).i)});
}

NODE_DEF
node_call_memcmp(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *a, NODE *b, NODE *k)
{
    return RESULT_OK((VALUE){.i = castro_memcmp((const VALUE *)UNWRAP(EVAL_ARG(c, a)).p,
                                        (const VALUE *)UNWRAP(EVAL_ARG(c, b)).p,
                                        UNWRAP(EVAL_ARG(c, k)).i)});
}

NODE_DEF
node_call_atoi(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *s)
{
    return RESULT_OK((VALUE){.i = castro_atoi((const VALUE *)UNWRAP(EVAL_ARG(c, s)).p)});
}

NODE_DEF @noinline
node_call_exit(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *code)
{
    castro_exit((int)UNWRAP(EVAL_ARG(c, code)).i);
    __builtin_unreachable();
}

NODE_DEF
node_call_abs(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *x)
{
    int64_t v = UNWRAP(EVAL_ARG(c, x)).i;
    return RESULT_OK((VALUE){.i = v < 0 ? -v : v});
}

// --- sequencing -----------------------------------------------------

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *head, NODE *tail)
{
    UNWRAP(EVAL_ARG(c, head));
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_nop(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    return RESULT_OK((VALUE){.i = 0});
}

NODE_DEF
node_drop(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    UNWRAP(EVAL_ARG(c, e));
    return RESULT_OK((VALUE){.i = 0});
}

// --- control flow ---------------------------------------------------

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *then_node, NODE *else_node)
{
    if (UNWRAP(EVAL_ARG(c, cond)).i) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

// Loops uniformly catch RESULT_BREAK and RESULT_CONTINUE; other states
// (RETURN, GOTO) propagate up to the function / dispatch boundary.  No
// per-loop / per-iter setjmp anywhere — the predicted-not-taken state
// branch is the only cost on the no-break/no-continue path.

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *body)
{
    for (;;) {
        if (!UNWRAP(EVAL_ARG(c, cond)).i) break;
        RESULT _r = EVAL_ARG(c, body);
        if (UNLIKELY(_r.state != RESULT_NORMAL)) {
            if (_r.state == RESULT_BREAK) break;
            if (_r.state == RESULT_CONTINUE) continue;
            return _r;
        }
    }
    return RESULT_OK((VALUE){.i = 0});
}

NODE_DEF
node_do_while(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *body, NODE *cond)
{
    for (;;) {
        RESULT _r = EVAL_ARG(c, body);
        if (UNLIKELY(_r.state != RESULT_NORMAL)) {
            if (_r.state == RESULT_BREAK) break;
            if (_r.state == RESULT_CONTINUE) goto check_cond;
            return _r;
        }
      check_cond:
        if (!UNWRAP(EVAL_ARG(c, cond)).i) break;
    }
    return RESULT_OK((VALUE){.i = 0});
}

NODE_DEF
node_for(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *init, NODE *cond, NODE *step, NODE *body)
{
    UNWRAP(EVAL_ARG(c, init));
    for (;;) {
        if (!UNWRAP(EVAL_ARG(c, cond)).i) break;
        RESULT _r = EVAL_ARG(c, body);
        if (UNLIKELY(_r.state != RESULT_NORMAL)) {
            if (_r.state == RESULT_BREAK) break;
            if (_r.state != RESULT_CONTINUE) return _r;
            // CONTINUE falls through to step
        }
        UNWRAP(EVAL_ARG(c, step));
    }
    return RESULT_OK((VALUE){.i = 0});
}

// node_return / node_break / node_continue: emit RESULT state.  No
// longjmp.  The enclosing loop / function-call site picks them up.
// `node_return` is @noinline only so SPECIALIZE can opt out of
// inlining the recursive payload — the runtime cost is the same.

NODE_DEF
node_return(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *expr)
{
    VALUE v = UNWRAP(EVAL_ARG(c, expr));
    return (RESULT){v, RESULT_RETURN};
}

NODE_DEF
node_return_void(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    return (RESULT){{.i = 0}, RESULT_RETURN};
}

NODE_DEF
node_break(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    return (RESULT){{.i = 0}, RESULT_BREAK};
}

NODE_DEF
node_continue(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    return (RESULT){{.i = 0}, RESULT_CONTINUE};
}

// --- ternary --------------------------------------------------------
// (Same as node_if but kept separate for readability of dumps.)

NODE_DEF
node_ternary(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *cond, NODE *t, NODE *e)
{
    return (UNWRAP(EVAL_ARG(c, cond)).i) ? EVAL_ARG(c, t) : EVAL_ARG(c, e);
}

// --- short-circuit logical ------------------------------------------

NODE_DEF
node_land(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    if (!UNWRAP(EVAL_ARG(c, l)).i) return RESULT_OK((VALUE){.i = 0});
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, r)).i ? 1 : 0});
}

NODE_DEF
node_lor(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    if (UNWRAP(EVAL_ARG(c, l)).i)  return RESULT_OK((VALUE){.i = 1});
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, r)).i ? 1 : 0});
}

NODE_DEF
node_lnot(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return RESULT_OK((VALUE){.i = !UNWRAP(EVAL_ARG(c, e)).i});
}

// --- int arithmetic -------------------------------------------------

NODE_DEF
node_add_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = UNWRAP(EVAL_ARG(c, l)).i;
    int64_t rv = UNWRAP(EVAL_ARG(c, r)).i;
    return RESULT_OK((VALUE){.i = lv + rv});
}

NODE_DEF
node_sub_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = UNWRAP(EVAL_ARG(c, l)).i;
    int64_t rv = UNWRAP(EVAL_ARG(c, r)).i;
    return RESULT_OK((VALUE){.i = lv - rv});
}

NODE_DEF
node_mul_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = UNWRAP(EVAL_ARG(c, l)).i;
    int64_t rv = UNWRAP(EVAL_ARG(c, r)).i;
    return RESULT_OK((VALUE){.i = lv * rv});
}

NODE_DEF
node_div_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = UNWRAP(EVAL_ARG(c, l)).i;
    int64_t rv = UNWRAP(EVAL_ARG(c, r)).i;
    return RESULT_OK((VALUE){.i = lv / rv});
}

NODE_DEF
node_mod_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    int64_t lv = UNWRAP(EVAL_ARG(c, l)).i;
    int64_t rv = UNWRAP(EVAL_ARG(c, r)).i;
    return RESULT_OK((VALUE){.i = lv % rv});
}

NODE_DEF
node_neg_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return RESULT_OK((VALUE){.i = -UNWRAP(EVAL_ARG(c, e)).i});
}

// --- int bitwise ----------------------------------------------------

NODE_DEF
node_band(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i & UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_bor(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i | UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_bxor(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i ^ UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_bnot(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return RESULT_OK((VALUE){.i = ~UNWRAP(EVAL_ARG(c, e)).i});
}

NODE_DEF
node_shl(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i << UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_shr(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i >> UNWRAP(EVAL_ARG(c, r)).i});
}

// --- int comparison (returns int) ----------------------------------

NODE_DEF
node_lt_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i < UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_le_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i <= UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_gt_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i > UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_ge_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i >= UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_eq_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i == UNWRAP(EVAL_ARG(c, r)).i});
}

NODE_DEF
node_neq_i(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).i != UNWRAP(EVAL_ARG(c, r)).i});
}

// --- double arithmetic ---------------------------------------------

NODE_DEF
node_add_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = UNWRAP(EVAL_ARG(c, l)).d;
    double rv = UNWRAP(EVAL_ARG(c, r)).d;
    return RESULT_OK((VALUE){.d = lv + rv});
}

NODE_DEF
node_sub_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = UNWRAP(EVAL_ARG(c, l)).d;
    double rv = UNWRAP(EVAL_ARG(c, r)).d;
    return RESULT_OK((VALUE){.d = lv - rv});
}

NODE_DEF
node_mul_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = UNWRAP(EVAL_ARG(c, l)).d;
    double rv = UNWRAP(EVAL_ARG(c, r)).d;
    return RESULT_OK((VALUE){.d = lv * rv});
}

NODE_DEF
node_div_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    double lv = UNWRAP(EVAL_ARG(c, l)).d;
    double rv = UNWRAP(EVAL_ARG(c, r)).d;
    return RESULT_OK((VALUE){.d = lv / rv});
}

NODE_DEF
node_neg_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return RESULT_OK((VALUE){.d = -UNWRAP(EVAL_ARG(c, e)).d});
}

// --- double comparison (returns int) -------------------------------

NODE_DEF
node_lt_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).d < UNWRAP(EVAL_ARG(c, r)).d});
}

NODE_DEF
node_le_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).d <= UNWRAP(EVAL_ARG(c, r)).d});
}

NODE_DEF
node_gt_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).d > UNWRAP(EVAL_ARG(c, r)).d});
}

NODE_DEF
node_ge_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).d >= UNWRAP(EVAL_ARG(c, r)).d});
}

NODE_DEF
node_eq_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).d == UNWRAP(EVAL_ARG(c, r)).d});
}

NODE_DEF
node_neq_d(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *l, NODE *r)
{
    return RESULT_OK((VALUE){.i = UNWRAP(EVAL_ARG(c, l)).d != UNWRAP(EVAL_ARG(c, r)).d});
}

// --- casts ---------------------------------------------------------

NODE_DEF
node_cast_id(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return RESULT_OK((VALUE){.d = (double)UNWRAP(EVAL_ARG(c, e)).i});
}

NODE_DEF
node_cast_di(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return RESULT_OK((VALUE){.i = (int64_t)UNWRAP(EVAL_ARG(c, e)).d});
}

// --- function call -------------------------------------------------
//
// Calls in C are resolved at parse time: parse.rb assigns each
// function_definition a stable index into `c->func_bodies[]`, and the
// IR just carries that index.  No name lookup, no inline cache, no
// setjmp.
//
// At the function boundary we **catch** `RESULT_RETURN` — that's the
// callee's normal "I'm finished, here's my value" — and demote it to
// `RESULT_NORMAL` so the caller proceeds.  Other states (BREAK /
// CONTINUE / GOTO escaping a function) shouldn't happen in valid C
// but are propagated as-is if they do.
//
// (We tried lifting the callee resolution into a `NODE *callee` child
// operand patched in by load_program.  Conceptually cleaner, but in
// practice slower: `n->u.node_call.callee` requires the SD to chase
// through the inlined AST tree at runtime, while
// `c->func_bodies[FUNC_IDX]` keeps `func_idx` baked as a uint32_t
// immediate at SPECIALIZE time → single indexed load against `c`,
// which is a register parameter.  Determinism across runs also
// favours an integer index over a heap pointer.)

// Caller-allocates the callee's frame as a stack VLA `F[local_cnt]`
// (wastro's pattern, node.def:1672 over there).  When the parent SD
// chain is fully `static inline always_inline`, `&F` never escapes —
// gcc's SROA recognises the array as a set of independent scalars and
// register-promotes each slot.  Loop variables that previously lived
// in `fp[i]` (heap memory) become real registers, and the inner
// store-loop in sieve / quicksort / matmul stops reloading invariant
// loop bounds every iteration.
//
// `local_cnt` is the callee's full local count (params + declared
// locals), baked at SPECIALIZE time as a uint32_t immediate so the
// VLA size is a compile-time constant in the inlined body — needed
// for SROA to fire.

NODE_DEF
node_call(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t func_idx, uint32_t arg_count, uint32_t arg_index, uint32_t local_cnt)
{
    NODE *body = c->func_bodies[func_idx];
    VALUE F[local_cnt];
    for (uint32_t i = 0; i < arg_count; i++) F[i] = fp[arg_index + i];
    for (uint32_t i = arg_count; i < local_cnt; i++) F[i].i = 0;
    RESULT r = (*body->head.dispatcher)(c, body, F);
    // In valid C, BREAK/CONTINUE/GOTO are caught inside the callee
    // before reaching this point, and RETURN is the callee's normal
    // exit — discard the state entirely so the surrounding SD's
    // EVAL_ARG/UNWRAP sees a compile-time-constant NORMAL and DCEs the
    // state-propagation branch.
    return RESULT_OK(r.value);
}

// Non-recursive call.  Carries the callee body NODE* as a child
// operand, populated by load_program's 3rd pass (callee starts NULL
// during phase 2 since the body might not be built yet).  The
// framework's natural SPECIALIZE walks into the callee subtree and
// emits its SD chain as `static inline` in the caller's TU — gcc -O3
// then inlines through.

NODE_DEF
node_call_static(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *callee, uint32_t arg_count, uint32_t arg_index, uint32_t local_cnt)
{
    VALUE F[local_cnt];
    for (uint32_t i = 0; i < arg_count; i++) F[i] = fp[arg_index + i];
    for (uint32_t i = arg_count; i < local_cnt; i++) F[i].i = 0;
    // Shadow `fp` so EVAL_ARG dispatches the callee at the new frame
    // (the framework's macro expands `EVAL_ARG(c, callee)` to
    // `(*callee_dispatcher)(c, callee, fp)`, picking up the local
    // `fp` we've overwritten).  Going through EVAL_ARG instead of an
    // explicit dispatcher call is what lets the parent specializer
    // pass the baked `SD_<callee_hash>` symbol as the dispatcher arg
    // — making the call direct and inline-able.
    fp = F;
    RESULT r = EVAL_ARG(c, callee);
    return RESULT_OK(r.value);
}

// --- builtin: printf / putchar / puts -----------------------------
//
// printf-family is variadic; each typed arg is read from the caller's
// frame at fp[arg_index..arg_index+arg_count-1].  The format string is
// fp[arg_index].p; subsequent slots carry typed values selected per
// conversion specifier.  See castro_run_printf in main.c.

extern int castro_run_printf(const char *fmt, VALUE *args, uint32_t arg_count);

NODE_DEF @noinline
node_printf(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t arg_count, uint32_t arg_index)
{
    const char *fmt = (const char *)fp[arg_index].p;
    int r = castro_run_printf(fmt, &fp[arg_index + 1], arg_count - 1);
    return RESULT_OK((VALUE){.i = r});
}

NODE_DEF
node_putchar(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    int ch = (int)UNWRAP(EVAL_ARG(c, e)).i;
    return RESULT_OK((VALUE){.i = putchar(ch)});
}

extern int castro_puts(const VALUE *slot_str);

NODE_DEF
node_puts(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *e)
{
    return RESULT_OK((VALUE){.i = castro_puts((const VALUE *)UNWRAP(EVAL_ARG(c, e)).p)});
}

// --- function pointer ----------------------------------------------
//
// Taking a function's address: parse.rb gives us the index, runtime
// returns the matching body NODE * in the .p slot of VALUE.  An
// indirect call dereferences the pointer, sets up the frame, and
// dispatches.  No struct in between — the body NODE is enough.

NODE_DEF
node_func_addr(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, uint32_t func_idx)
{
    return RESULT_OK((VALUE){.p = c->func_bodies[func_idx]});
}

NODE_DEF
node_call_indirect(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *fn_expr, uint32_t arg_count, uint32_t arg_index)
{
    NODE *body = (NODE *)UNWRAP(EVAL_ARG(c, fn_expr)).p;
    (void)arg_count;
    if (UNLIKELY(body == NULL)) {
        fprintf(stderr, "castro: NULL function pointer\n");
        exit(1);
    }
    RESULT r = (*body->head.dispatcher)(c, body, fp + arg_index);
    return RESULT_OK(r.value);
}

// --- goto / labels --------------------------------------------------
//
// parse.rb compiles a function with goto into:
//   while (1) { switch (label) { case 0: stmts; goto N1; case 1: ...; } }
// `node_goto LABEL` returns RESULT_GOTO carrying the label in
// .value.i; the enclosing `node_goto_dispatch` loop catches GOTO,
// stores the new target into c->goto_target, and re-evaluates the
// body so the inner switch picks the matching segment.

NODE_DEF
node_goto(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, int32_t label)
{
    return (RESULT){{.i = (int64_t)label}, RESULT_GOTO};
}

NODE_DEF
node_goto_dispatch(CTX * restrict c, NODE * restrict n, VALUE * restrict fp, NODE *body)
{
    c->goto_target = 0;
    for (;;) {
        RESULT r = EVAL_ARG(c, body);
        if (r.state == RESULT_GOTO) {
            c->goto_target = (int32_t)r.value.i;
            continue;
        }
        return r;
    }
}

NODE_DEF
node_goto_target(CTX * restrict c, NODE * restrict n, VALUE * restrict fp)
{
    return RESULT_OK((VALUE){.i = c->goto_target});
}

// (No statement-level node_def: function definitions are registered
// by load_program in main.c at SX-load time, not as evaluatable AST
// nodes.  The previous `node_def` was a runtime-defining hook left
// over from the dynamic-language samples.)
