// koruby AST nodes.
// EVAL_ARG returns VALUE; if c->state != KORB_NORMAL after a child eval the
// current frame must propagate by returning Qnil immediately.

#define EA(c, n) ({                                       \
    VALUE _v = EVAL_ARG(c, n);                            \
    if (UNLIKELY((c)->state != KORB_NORMAL)) return Qnil;   \
    _v;                                                   \
})
#define CHECK_STATE(c) do { if (UNLIKELY((c)->state != KORB_NORMAL)) return Qnil; } while (0)

// ---------------- literals ----------------

NODE_DEF
node_num(CTX * restrict c, NODE * restrict n, int32_t v)
{
    return INT2FIX(v);
}

NODE_DEF
node_int_lit(CTX * restrict c, NODE * restrict n, intptr_t v)
{
    /* literal that fits in a fixnum */
    return (VALUE)((uintptr_t)v << 1) | FIXNUM_FLAG;
}

NODE_DEF
node_bignum_lit(CTX * restrict c, NODE * restrict n, const char *str)
{
    return korb_bignum_new_str(str, 10);
}

NODE_DEF
node_float_lit(CTX * restrict c, NODE * restrict n, double v)
{
    return korb_float_new(v);
}

NODE_DEF
node_str_lit(CTX * restrict c, NODE * restrict n, const char *str, uint32_t len)
{
    return korb_str_new(str, len);
}

NODE_DEF
node_sym_lit(CTX * restrict c, NODE * restrict n, ID id)
{
    return korb_id2sym(id);
}

NODE_DEF
node_true(CTX * restrict c, NODE * restrict n)
{
    return Qtrue;
}

NODE_DEF
node_false(CTX * restrict c, NODE * restrict n)
{
    return Qfalse;
}

NODE_DEF
node_nil(CTX * restrict c, NODE * restrict n)
{
    return Qnil;
}

NODE_DEF
node_self(CTX * restrict c, NODE * restrict n)
{
    return c->self;
}

// ---------------- variables ----------------

NODE_DEF
node_lvar_get(CTX * restrict c, NODE * restrict n, uint32_t index)
{
    return c->fp[index];
}

NODE_DEF
node_lvar_set(CTX * restrict c, NODE * restrict n, uint32_t index, NODE *rhs)
{
    VALUE v = EA(c, rhs);
    c->fp[index] = v;
    return v;
}

NODE_DEF
node_ivar_get(CTX * restrict c, NODE * restrict n, ID name, struct ivar_cache *cache@ref)
{
    return korb_ivar_get_ic(c->self, name, cache);
}

NODE_DEF
node_ivar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *rhs, struct ivar_cache *cache@ref)
{
    VALUE v = EA(c, rhs);
    korb_ivar_set_ic(c->self, name, v, cache);
    return v;
}

NODE_DEF
node_gvar_get(CTX * restrict c, NODE * restrict n, ID name)
{
    return korb_gvar_get(name);
}

NODE_DEF
node_gvar_set(CTX * restrict c, NODE * restrict n, ID name, NODE *rhs)
{
    VALUE v = EA(c, rhs);
    korb_gvar_set(name, v);
    return v;
}

NODE_DEF
node_const_get(CTX * restrict c, NODE * restrict n, ID name)
{
    return korb_const_lookup(c, name);
}

NODE_DEF
node_const_set(CTX * restrict c, NODE * restrict n, ID name, NODE *rhs)
{
    VALUE v = EA(c, rhs);
    struct korb_class *host = c->cref ? c->cref->klass : c->current_class;
    korb_const_set(host, name, v);
    return v;
}

NODE_DEF
node_const_path_get(CTX * restrict c, NODE * restrict n, NODE *parent, ID name)
{
    VALUE p = EA(c, parent);
    if (BUILTIN_TYPE(p) == T_CLASS || BUILTIN_TYPE(p) == T_MODULE) {
        VALUE v = korb_const_get((struct korb_class *)p, name);
        if (UNDEF_P(v)) {
            korb_raise(c, NULL, "uninitialized constant %s::%s",
                     korb_id_name(((struct korb_class *)p)->name), korb_id_name(name));
            return Qnil;
        }
        return v;
    }
    korb_raise(c, NULL, "not a class/module");
    return Qnil;
}

// ---------------- syntax / control ----------------

NODE_DEF
node_scope(CTX * restrict c, NODE * restrict n, uint32_t envsize, NODE *body)
{
    VALUE *prev_fp = c->fp;
    c->fp += envsize;
    if (UNLIKELY(c->fp + envsize >= c->stack_end)) {
        c->fp = prev_fp;
        korb_raise(c, NULL, "stack overflow");
        return Qnil;
    }
    if (c->fp + envsize > c->sp) c->sp = c->fp + envsize;
    /* zero working area so GC sees Qnil instead of garbage */
    for (uint32_t i = 0; i < envsize; i++) c->fp[i] = Qnil;
    VALUE v = EVAL_ARG(c, body);
    c->fp = prev_fp;
    return v;
}

NODE_DEF
node_seq(CTX * restrict c, NODE * restrict n, NODE *head, NODE *tail)
{
    EA(c, head);
    return EVAL_ARG(c, tail);
}

NODE_DEF
node_if(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *then_node, NODE *else_node)
{
    VALUE v = EA(c, cond);
    if (RTEST(v)) {
        return EVAL_ARG(c, then_node);
    }
    else {
        return EVAL_ARG(c, else_node);
    }
}

NODE_DEF
node_while(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    while (1) {
        VALUE v = EVAL_ARG(c, cond);
        if (UNLIKELY(c->state != KORB_NORMAL)) return Qnil;
        if (!RTEST(v)) break;
        EVAL_ARG(c, body);
        if (UNLIKELY(c->state != KORB_NORMAL)) {
            if (c->state == KORB_BREAK) {
                VALUE bv = c->state_value;
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
                return bv;
            }
            else if (c->state == KORB_NEXT) {
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
                continue;
            }
            return Qnil;
        }
    }
    return Qnil;
}

NODE_DEF
node_until(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    while (1) {
        VALUE v = EVAL_ARG(c, cond);
        if (UNLIKELY(c->state != KORB_NORMAL)) return Qnil;
        if (RTEST(v)) break;
        EVAL_ARG(c, body);
        if (UNLIKELY(c->state != KORB_NORMAL)) {
            if (c->state == KORB_BREAK) {
                VALUE bv = c->state_value;
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
                return bv;
            }
            else if (c->state == KORB_NEXT) {
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
                continue;
            }
            return Qnil;
        }
    }
    return Qnil;
}

NODE_DEF
node_return(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = EA(c, value);
    c->state = KORB_RETURN;
    c->state_value = v;
    return v;
}

NODE_DEF
node_break(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = EA(c, value);
    c->state = KORB_BREAK;
    c->state_value = v;
    return v;
}

NODE_DEF
node_next(CTX * restrict c, NODE * restrict n, NODE *value)
{
    VALUE v = EA(c, value);
    c->state = KORB_NEXT;
    c->state_value = v;
    return v;
}

NODE_DEF
node_not(CTX * restrict c, NODE * restrict n, NODE *expr)
{
    VALUE v = EA(c, expr);
    return RTEST(v) ? Qfalse : Qtrue;
}

NODE_DEF
node_and(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs)
{
    VALUE l = EA(c, lhs);
    if (!RTEST(l)) return l;
    return EVAL_ARG(c, rhs);
}

NODE_DEF
node_or(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs)
{
    VALUE l = EA(c, lhs);
    if (RTEST(l)) return l;
    return EVAL_ARG(c, rhs);
}

// ---------------- containers ----------------

NODE_DEF
node_ary_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    /* args are pre-evaluated and stored at fp[arg_index..arg_index+argc-1] */
    VALUE ary = korb_ary_new_capa(argc);
    for (uint32_t i = 0; i < argc; i++) {
        korb_ary_push(ary, c->fp[arg_index + i]);
    }
    return ary;
}

NODE_DEF
node_hash_new(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    /* argc is # of pairs * 2; flat key,value,key,value,... */
    VALUE h = korb_hash_new();
    for (uint32_t i = 0; i + 1 < argc; i += 2) {
        korb_hash_aset(h, c->fp[arg_index + i], c->fp[arg_index + i + 1]);
    }
    return h;
}

NODE_DEF
node_range_new(CTX * restrict c, NODE * restrict n, NODE *begin, NODE *end, uint32_t exclude_end)
{
    VALUE b = EA(c, begin);
    VALUE e = EA(c, end);
    return korb_range_new(b, e, exclude_end != 0);
}

NODE_DEF
node_str_concat(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    VALUE r = korb_str_new("", 0);
    for (uint32_t i = 0; i < argc; i++) {
        VALUE part = c->fp[arg_index + i];
        if (BUILTIN_TYPE(part) != T_STRING) {
            part = korb_to_s_dispatch(c, part);
        }
        r = korb_str_concat(r, part);
    }
    return r;
}

// ---------------- method definition / call ----------------

NODE_DEF @noinline
node_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body, uint32_t params_cnt, uint32_t locals_cnt)
{
    /* Method goes on the innermost lexical class/module — same as Ruby's
     * `def foo` semantics inside a class body. */
    struct korb_class *target = c->cref ? c->cref->klass : c->current_class;
    korb_class_add_method_ast_full_cref(target, name, body, params_cnt, params_cnt, -1, locals_cnt, c->cref);
    return korb_id2sym(name);
}

NODE_DEF @noinline
node_class_def(CTX * restrict c, NODE * restrict n, ID name, NODE *super_expr, NODE *body)
{
    struct korb_class *super = korb_vm->object_class;
    if (super_expr) {
        VALUE sv = EA(c, super_expr);
        if (BUILTIN_TYPE(sv) != T_CLASS) {
            korb_raise(c, NULL, "superclass must be a Class");
            return Qnil;
        }
        super = (struct korb_class *)sv;
    }
    struct korb_class *host = c->cref ? c->cref->klass : c->current_class;
    struct korb_class *klass;
    VALUE existing = korb_const_get(host, name);
    /* Reopen an existing Class OR Module (Module is itself a class
     * but with T_MODULE flags — `class Module ... end` is valid and
     * adds methods to the existing one). */
    if (!UNDEF_P(existing) && (BUILTIN_TYPE(existing) == T_CLASS ||
                                BUILTIN_TYPE(existing) == T_MODULE)) {
        klass = (struct korb_class *)existing;
    }
    else {
        klass = korb_class_new(name, super, T_OBJECT);
        korb_const_set(host, name, (VALUE)klass);
    }
    struct korb_class *prev_class = c->current_class;
    VALUE prev_self = c->self;
    struct korb_cref new_cref = { .klass = klass, .prev = c->cref };
    struct korb_cref *prev_cref = c->cref;
    c->current_class = klass;
    c->self = (VALUE)klass;
    c->cref = &new_cref;
    VALUE r = body ? EVAL_ARG(c, body) : Qnil;
    c->current_class = prev_class;
    c->self = prev_self;
    c->cref = prev_cref;
    return r;
}

NODE_DEF @noinline
node_module_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body)
{
    struct korb_class *host = c->cref ? c->cref->klass : c->current_class;
    struct korb_class *mod;
    VALUE existing = korb_const_get(host, name);
    if (!UNDEF_P(existing) && BUILTIN_TYPE(existing) == T_MODULE) {
        mod = (struct korb_class *)existing;
    }
    else {
        mod = korb_module_new(name);
        korb_const_set(host, name, (VALUE)mod);
    }
    struct korb_class *prev_class = c->current_class;
    VALUE prev_self = c->self;
    struct korb_cref new_cref = { .klass = mod, .prev = c->cref };
    struct korb_cref *prev_cref = c->cref;
    c->current_class = mod;
    c->self = (VALUE)mod;
    c->cref = &new_cref;
    VALUE r = body ? EVAL_ARG(c, body) : Qnil;
    c->current_class = prev_class;
    c->self = prev_self;
    c->cref = prev_cref;
    return r;
}

/* dispatch helpers (declared in node.h via include) */

NODE_DEF
node_func_call(CTX * restrict c, NODE * restrict n, ID name, uint32_t argc, uint32_t arg_index, struct method_cache *mc)
{
    /* implicit-self call — _cached version inlines the IC + prologue
     * dispatch directly into the SD body, so a hot self-call (e.g.
     * `render_pixel` from the per-frame loop) avoids a function-pointer
     * jump per call. */
    return korb_dispatch_call_cached(c, n, c->self, name, argc, arg_index, NULL, mc);
}

NODE_DEF
node_method_call(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t argc, uint32_t arg_index, struct method_cache *mc)
{
    VALUE r = EA(c, recv);
    return korb_dispatch_call_cached(c, n, r, name, argc, arg_index, NULL, mc);
}

NODE_DEF
node_method_call_block(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, uint32_t argc, uint32_t arg_index, NODE *blk, struct method_cache *mc)
{
    VALUE r = EA(c, recv);
    /* blk node is node_block_literal which when EVAL'd produces a Proc */
    VALUE block = blk ? EA(c, blk) : Qnil;
    return korb_dispatch_call_cached(c, n, r, name, argc, arg_index, block == Qnil ? NULL : (struct korb_proc *)block, mc);
}

NODE_DEF
node_func_call_block(CTX * restrict c, NODE * restrict n, ID name, uint32_t argc, uint32_t arg_index, NODE *blk, struct method_cache *mc)
{
    VALUE block = blk ? EA(c, blk) : Qnil;
    return korb_dispatch_call_cached(c, n, c->self, name, argc, arg_index, block == Qnil ? NULL : (struct korb_proc *)block, mc);
}

NODE_DEF @noinline
node_block_literal(CTX * restrict c, NODE * restrict n, NODE *body, uint32_t params_cnt, uint32_t param_base, uint32_t env_size)
{
    return korb_proc_new(body, c->fp, env_size, params_cnt, param_base, c->self, false);
}

NODE_DEF
node_yield(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    return korb_yield(c, argc, &c->fp[arg_index]);
}

// ---------------- arithmetic (generic + fixnum fast path) ----------------

NODE_DEF
node_plus(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(l), b = FIX2LONG(r), s;
        if (LIKELY(!__builtin_add_overflow(a, b, &s) && FIXABLE(s))) return INT2FIX(s);
        return korb_int_plus(l, r);
    }
    /* Float fast path: skip dispatch_binop when both ops can be coerced
     * to double cheaply (FLONUM or FIXNUM). */
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) {
        return korb_float_new(korb_flonum_to_double(l) + korb_flonum_to_double(r));
    }
    return korb_node_plus_slow(c, l, r, arg_index);
}

NODE_DEF
node_minus(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(l), b = FIX2LONG(r), s;
        if (LIKELY(!__builtin_sub_overflow(a, b, &s) && FIXABLE(s))) return INT2FIX(s);
        return korb_int_minus(l, r);
    }
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) {
        return korb_float_new(korb_flonum_to_double(l) - korb_flonum_to_double(r));
    }
    return korb_node_minus_slow(c, l, r, arg_index);
}

NODE_DEF
node_mul(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(l), b = FIX2LONG(r), s;
        if (LIKELY(!__builtin_mul_overflow(a, b, &s) && FIXABLE(s))) return INT2FIX(s);
        return korb_int_mul(l, r);
    }
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) {
        return korb_float_new(korb_flonum_to_double(l) * korb_flonum_to_double(r));
    }
    return korb_node_mul_slow(c, l, r, arg_index);
}

NODE_DEF
node_div(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(l), b = FIX2LONG(r);
        if (UNLIKELY(b == 0)) { korb_raise(c, NULL, "divided by 0"); return Qnil; }
        long q = a / b;
        if ((a % b) != 0 && ((a ^ b) < 0)) q--;
        if (FIXABLE(q)) return INT2FIX(q);
        return korb_int_div(l, r);
    }
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) {
        return korb_float_new(korb_flonum_to_double(l) / korb_flonum_to_double(r));
    }
    return korb_node_div_slow(c, l, r, arg_index);
}

NODE_DEF
node_mod(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(l), b = FIX2LONG(r);
        if (UNLIKELY(b == 0)) { korb_raise(c, NULL, "divided by 0"); return Qnil; }
        long m = a % b;
        if (m != 0 && ((a ^ b) < 0)) m += b;
        return INT2FIX(m);
    }
    return korb_node_mod_slow(c, l, r, arg_index);
}

NODE_DEF
node_uminus(CTX * restrict c, NODE * restrict n, NODE *operand, uint32_t arg_index)
{
    VALUE v = EA(c, operand);
    if (LIKELY(FIXNUM_P(v) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(v), s;
        if (!__builtin_sub_overflow(0L, a, &s) && FIXABLE(s)) return INT2FIX(s);
    }
    return korb_node_uminus_slow(c, v);
}

// ---------------- bit ops ----------------

NODE_DEF
node_bit_and(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) return l & r;
    return korb_node_band_slow(c, l, r, arg_index);
}

NODE_DEF
node_bit_or(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) return l | r;
    return korb_node_bor_slow(c, l, r, arg_index);
}

NODE_DEF
node_bit_xor(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) return (l ^ r) | FIXNUM_FLAG;
    return korb_node_bxor_slow(c, l, r, arg_index);
}

NODE_DEF
node_lshift(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(l), b = FIX2LONG(r);
        if (b >= 0 && b < 62) {
            long s = a << b;
            if ((s >> b) == a && FIXABLE(s)) return INT2FIX(s);
        }
        return korb_int_lshift(l, r);
    }
    /* Array#<< — push and return self.  Hot in optcarrot's
     * render_pixel (`@output_pixels << ...` runs once per pixel). */
    if (LIKELY(!SPECIAL_CONST_P(l) && BUILTIN_TYPE(l) == T_ARRAY && !korb_g_basic_op_redefined)) {
        korb_ary_push(l, r);
        return l;
    }
    return korb_node_lshift_slow(c, l, r, arg_index);
}

NODE_DEF
node_rshift(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) {
        long a = FIX2LONG(l), b = FIX2LONG(r);
        if (b >= 0 && b < 62) return INT2FIX(a >> b);
        return korb_int_rshift(l, r);
    }
    return korb_node_rshift_slow(c, l, r, arg_index);
}

// ---------------- comparisons ----------------

NODE_DEF
node_lt(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL((intptr_t)l < (intptr_t)r);
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL(korb_flonum_to_double(l) < korb_flonum_to_double(r));
    return korb_node_lt_slow(c, l, r, arg_index);
}

NODE_DEF
node_le(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL((intptr_t)l <= (intptr_t)r);
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL(korb_flonum_to_double(l) <= korb_flonum_to_double(r));
    return korb_node_le_slow(c, l, r, arg_index);
}

NODE_DEF
node_gt(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL((intptr_t)l > (intptr_t)r);
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL(korb_flonum_to_double(l) > korb_flonum_to_double(r));
    return korb_node_gt_slow(c, l, r, arg_index);
}

NODE_DEF
node_ge(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL((intptr_t)l >= (intptr_t)r);
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r) && !korb_g_basic_op_redefined)) return KORB_BOOL(korb_flonum_to_double(l) >= korb_flonum_to_double(r));
    return korb_node_ge_slow(c, l, r, arg_index);
}

NODE_DEF
node_eq(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (UNLIKELY(korb_g_basic_op_redefined)) {
        c->fp[arg_index+1] = r;
        return korb_dispatch_binop(c, l, korb_intern("=="), 1, &c->fp[arg_index+1]);
    }
    /* Pure FIXNUM / FLONUM compare: identity = numeric equality.
     * (Note: FLONUM excludes NaN — never encodable, so always heap.) */
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r))) return KORB_BOOL(l == r);
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r))) return KORB_BOOL(l == r);
    if ((SPECIAL_CONST_P(l) && !FIXNUM_P(l) && !FLONUM_P(l)) ||
        (SPECIAL_CONST_P(r) && !FIXNUM_P(r) && !FLONUM_P(r))) {
        /* one side is a non-numeric special const (Qnil, Qtrue, Qfalse,
         * Symbol).  Equal iff identical VALUE. */
        return KORB_BOOL(l == r);
    }
    /* General case: dispatch user-defined `==`.  For built-in types
     * (T_STRING, T_ARRAY, T_HASH, ...) this finds the methods we
     * registered in builtins.c; for user classes that include
     * Comparable or override ==, it picks up their definition. */
    c->fp[arg_index+1] = r;
    VALUE ret = korb_dispatch_binop(c, l, korb_intern("=="), 1, &c->fp[arg_index+1]);
    return KORB_BOOL(RTEST(ret));
}

NODE_DEF
node_neq(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs, uint32_t arg_index)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (UNLIKELY(korb_g_basic_op_redefined)) {
        c->fp[arg_index+1] = r;
        VALUE eq = korb_dispatch_binop(c, l, korb_intern("=="), 1, &c->fp[arg_index+1]);
        return KORB_BOOL(!RTEST(eq));
    }
    if (LIKELY(FIXNUM_P(l) && FIXNUM_P(r))) return KORB_BOOL(l != r);
    if (LIKELY(FLONUM_P(l) && FLONUM_P(r))) return KORB_BOOL(l != r);
    if ((SPECIAL_CONST_P(l) && !FIXNUM_P(l) && !FLONUM_P(l)) ||
        (SPECIAL_CONST_P(r) && !FIXNUM_P(r) && !FLONUM_P(r))) {
        return KORB_BOOL(l != r);
    }
    c->fp[arg_index+1] = r;
    VALUE eq = korb_dispatch_binop(c, l, korb_intern("=="), 1, &c->fp[arg_index+1]);
    return KORB_BOOL(!RTEST(eq));
}

// ---------------- subscript [] / []= ----------------

NODE_DEF
node_aref(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *idx, uint32_t arg_index)
{
    VALUE r = EA(c, recv);
    VALUE i = EA(c, idx);
    if (LIKELY(!SPECIAL_CONST_P(r) && !korb_g_basic_op_redefined)) {
        if (BUILTIN_TYPE(r) == T_ARRAY && FIXNUM_P(i)) return korb_ary_aref(r, FIX2LONG(i));
        if (BUILTIN_TYPE(r) == T_HASH) return korb_hash_aref(r, i);
    }
    return korb_node_aref_slow(c, r, i, arg_index);
}

NODE_DEF
node_aset(CTX * restrict c, NODE * restrict n, NODE *recv, NODE *idx, NODE *val, uint32_t arg_index)
{
    VALUE r = EA(c, recv);
    VALUE i = EA(c, idx);
    VALUE v = EA(c, val);
    if (LIKELY(!SPECIAL_CONST_P(r) && !korb_g_basic_op_redefined)) {
        if (BUILTIN_TYPE(r) == T_ARRAY && FIXNUM_P(i)) { korb_ary_aset(r, FIX2LONG(i), v); return v; }
        if (BUILTIN_TYPE(r) == T_HASH)                 { korb_hash_aset(r, i, v);          return v; }
    }
    return korb_node_aset_slow(c, r, i, v, arg_index);
}

// ---------------- exception ----------------

NODE_DEF @noinline
node_rescue(CTX * restrict c, NODE * restrict n, NODE *body, NODE *rescue_body, uint32_t exception_lvar_index)
{
retry:;
    VALUE v = EVAL_ARG(c, body);
    if (c->state == KORB_RAISE && rescue_body) {
        VALUE exc = c->state_value;
        c->state = KORB_NORMAL;
        c->state_value = Qnil;
        c->fp[exception_lvar_index] = exc;
        v = EVAL_ARG(c, rescue_body);
        /* `retry` inside the rescue body sets state=KORB_RETRY; clear
         * and jump back to re-evaluate the begin body. */
        if (c->state == KORB_RETRY) {
            c->state = KORB_NORMAL;
            c->state_value = Qnil;
            goto retry;
        }
    }
    return v;
}

NODE_DEF
node_retry(CTX * restrict c, NODE * restrict n)
{
    c->state = KORB_RETRY;
    c->state_value = Qnil;
    return Qnil;
}

NODE_DEF
node_redo(CTX * restrict c, NODE * restrict n)
{
    c->state = KORB_REDO;
    c->state_value = Qnil;
    return Qnil;
}

NODE_DEF
node_raise(CTX * restrict c, NODE * restrict n, NODE *exc_expr)
{
    VALUE e;
    if (exc_expr) {
        e = EA(c, exc_expr);
        if (BUILTIN_TYPE(e) == T_STRING) {
            e = korb_exc_new(NULL, korb_str_cstr(e));
        }
    }
    else {
        e = korb_exc_new(NULL, "unhandled exception");
    }
    c->state = KORB_RAISE;
    c->state_value = e;
    return Qnil;
}

// ---------------- multi-assign helpers ----------------

NODE_DEF
node_splat_to_ary(CTX * restrict c, NODE * restrict n, NODE *expr)
{
    VALUE v = EA(c, expr);
    if (BUILTIN_TYPE(v) == T_ARRAY) return v;
    if (BUILTIN_TYPE(v) == T_RANGE) {
        /* convert Range to Array for splat */
        struct korb_range *r = (struct korb_range *)v;
        if (FIXNUM_P(r->begin) && FIXNUM_P(r->end)) {
            long b = FIX2LONG(r->begin), e = FIX2LONG(r->end);
            if (r->exclude_end) e--;
            if (e < b) return korb_ary_new();
            VALUE a = korb_ary_new_capa(e - b + 1);
            for (long i = b; i <= e; i++) korb_ary_push(a, INT2FIX(i));
            return a;
        }
    }
    VALUE a = korb_ary_new_capa(1);
    korb_ary_push(a, v);
    return a;
}

NODE_DEF
node_ary_aget(CTX * restrict c, NODE * restrict n, NODE *ary_node, uint32_t idx)
{
    VALUE a = EA(c, ary_node);
    if (BUILTIN_TYPE(a) != T_ARRAY) return Qnil;
    return korb_ary_aref(a, idx);
}

NODE_DEF
node_str_to_sym(CTX * restrict c, NODE * restrict n, NODE *str_node)
{
    VALUE s = EA(c, str_node);
    if (BUILTIN_TYPE(s) != T_STRING) return Qnil;
    return korb_str_to_sym(s);
}

NODE_DEF
node_super(CTX * restrict c, NODE * restrict n, uint32_t argc, uint32_t arg_index)
{
    if (!c->current_frame || !c->current_frame->method) {
        korb_raise(c, NULL, "super called outside of method");
        return Qnil;
    }
    struct korb_method *m = c->current_frame->method;
    struct korb_class *parent = m->defining_class ? m->defining_class->super : NULL;
    if (!parent) {
        korb_raise(c, NULL, "no superclass method '%s'", korb_id_name(m->name));
        return Qnil;
    }
    struct korb_method *sm = korb_class_find_method(parent, m->name);
    if (!sm) {
        korb_raise(c, NULL, "super: no superclass method '%s'", korb_id_name(m->name));
        return Qnil;
    }
    if (sm->type == KORB_METHOD_CFUNC) {
        return sm->u.cfunc.func(c, c->self, argc, &c->fp[arg_index]);
    }
    VALUE *prev_fp = c->fp;
    VALUE *new_fp = prev_fp + arg_index;
    if (new_fp + sm->u.ast.locals_cnt >= c->stack_end) { korb_raise(c, NULL, "stack overflow"); return Qnil; }
    if (new_fp + sm->u.ast.locals_cnt > c->sp) c->sp = new_fp + sm->u.ast.locals_cnt;
    for (uint32_t i = argc; i < sm->u.ast.locals_cnt; i++) new_fp[i] = Qnil;
    c->fp = new_fp;
    VALUE r = EVAL(c, sm->u.ast.body);
    c->fp = prev_fp;
    if (c->state == KORB_RETURN) { r = c->state_value; c->state = KORB_NORMAL; c->state_value = Qnil; }
    return r;
}

NODE_DEF
node_super_forward(CTX * restrict c, NODE * restrict n)
{
    if (!c->current_frame || !c->current_frame->method) {
        korb_raise(c, NULL, "super called outside of method");
        return Qnil;
    }
    struct korb_method *m = c->current_frame->method;
    struct korb_class *parent = m->defining_class ? m->defining_class->super : NULL;
    if (!parent) { korb_raise(c, NULL, "no superclass"); return Qnil; }
    struct korb_method *sm = korb_class_find_method(parent, m->name);
    if (!sm) { korb_raise(c, NULL, "no superclass method"); return Qnil; }
    int argc = (m->type == KORB_METHOD_AST) ? (int)m->u.ast.required_params_cnt : 0;
    VALUE *args = c->fp;
    if (sm->type == KORB_METHOD_CFUNC) return sm->u.cfunc.func(c, c->self, argc, args);
    VALUE *prev_fp = c->fp;
    VALUE *new_fp = prev_fp + (m->type == KORB_METHOD_AST ? m->u.ast.locals_cnt : 0);
    if (new_fp + sm->u.ast.locals_cnt >= c->stack_end) { korb_raise(c, NULL, "stack overflow"); return Qnil; }
    for (int i = 0; i < argc; i++) new_fp[i] = args[i];
    for (uint32_t i = argc; i < sm->u.ast.locals_cnt; i++) new_fp[i] = Qnil;
    c->fp = new_fp;
    if (c->fp + sm->u.ast.locals_cnt > c->sp) c->sp = c->fp + sm->u.ast.locals_cnt;
    VALUE r = EVAL(c, sm->u.ast.body);
    c->fp = prev_fp;
    if (c->state == KORB_RETURN) { r = c->state_value; c->state = KORB_NORMAL; c->state_value = Qnil; }
    return r;
}

NODE_DEF
node_ensure(CTX * restrict c, NODE * restrict n, NODE *body, NODE *ensure_body)
{
    int saved_state = KORB_NORMAL;
    VALUE saved_value = Qnil;
    VALUE r = EVAL_ARG(c, body);
    if (c->state != KORB_NORMAL) {
        saved_state = c->state;
        saved_value = c->state_value;
        c->state = KORB_NORMAL;
        c->state_value = Qnil;
    }
    EVAL_ARG(c, ensure_body);
    if (c->state == KORB_NORMAL && saved_state != KORB_NORMAL) {
        c->state = saved_state;
        c->state_value = saved_value;
    }
    return r;
}

NODE_DEF @noinline
node_singleton_def(CTX * restrict c, NODE * restrict n, ID name, NODE *body, uint32_t params_cnt, uint32_t locals_cnt)
{
    /* def self.foo — install on c->self's singleton class. */
    if (BUILTIN_TYPE(c->self) != T_CLASS && BUILTIN_TYPE(c->self) != T_MODULE) {
        korb_raise(c, NULL, "def self.* outside of class/module");
        return Qnil;
    }
    struct korb_class *target = korb_singleton_class_of((struct korb_class *)c->self);
    korb_class_add_method_ast_full_cref(target, name, body, params_cnt, params_cnt, -1, locals_cnt, c->cref);
    return korb_id2sym(name);
}

NODE_DEF
node_default_init(CTX * restrict c, NODE * restrict n, uint32_t slot, NODE *default_expr)
{
    /* If c->fp[slot] is Qundef (= caller did not supply this optional arg),
     * evaluate the default and store it. */
    if (c->fp[slot] == Qundef) {
        VALUE v = EVAL_ARG(c, default_expr);
        if (UNLIKELY(c->state != KORB_NORMAL)) return Qnil;
        c->fp[slot] = v;
    }
    return Qnil;
}

NODE_DEF @noinline
node_def_full(CTX * restrict c, NODE * restrict n, ID name, NODE *body, uint32_t required_cnt, uint32_t total_cnt, int32_t rest_slot, int32_t block_slot, uint32_t locals_cnt)
{
    struct korb_class *target = c->cref ? c->cref->klass : c->current_class;
    korb_class_add_method_ast_full_cref(target, name, body, required_cnt, total_cnt, rest_slot, locals_cnt, c->cref);
    if (block_slot >= 0) korb_class_set_method_block_slot(target, name, block_slot);
    /* If user redefined something on a basic class, EVAL_node_* fast
     * paths must stop short-circuiting through C-side arithmetic. */
    korb_check_basic_op_redef(target);
    return korb_id2sym(name);
}

/* `alias new_name old_name` — keyword form, lexical scope.  Goes
 * directly to korb_class_alias_method on the cref's class so a
 * redefinition of Module#alias_method has no effect (`alias` is a
 * keyword, not a method call). */
NODE_DEF @noinline
node_alias_method(CTX * restrict c, NODE * restrict n, NODE *new_name, NODE *old_name)
{
    VALUE new_v = EA(c, new_name);
    VALUE old_v = EA(c, old_name);
    if (!SYMBOL_P(new_v) || !SYMBOL_P(old_v)) {
        korb_raise(c, NULL, "alias requires symbol names");
        return Qnil;
    }
    ID new_id = korb_sym2id(new_v);
    ID old_id = korb_sym2id(old_v);
    struct korb_class *target = c->cref ? c->cref->klass : c->current_class;
    struct korb_method *m = korb_class_find_method(target, old_id);
    if (!m) {
        korb_raise(c, NULL, "undefined method '%s' for %s",
                   korb_id_name(old_id), korb_id_name(target->name));
        return Qnil;
    }
    korb_class_alias_method(target, new_id, m);
    return korb_id2sym(new_id);
}

NODE_DEF
node_ary_concat(CTX * restrict c, NODE * restrict n, NODE *lhs, NODE *rhs)
{
    VALUE l = EA(c, lhs);
    VALUE r = EA(c, rhs);
    if (BUILTIN_TYPE(l) != T_ARRAY) return l;
    if (BUILTIN_TYPE(r) != T_ARRAY) return l;
    struct korb_array *la = (struct korb_array *)l;
    struct korb_array *ra = (struct korb_array *)r;
    VALUE out = korb_ary_new_capa(la->len + ra->len);
    for (long i = 0; i < la->len; i++) korb_ary_push(out, la->ptr[i]);
    for (long i = 0; i < ra->len; i++) korb_ary_push(out, ra->ptr[i]);
    return out;
}

NODE_DEF
node_apply_call(CTX * restrict c, NODE * restrict n, NODE *recv, ID name, NODE *args_node, uint32_t arg_index, NODE *blk, uint32_t is_method, struct method_cache *mc)
{
    VALUE recv_val = is_method ? EA(c, recv) : c->self;
    VALUE args_array = EA(c, args_node);
    long n_args = 0;
    if (BUILTIN_TYPE(args_array) == T_ARRAY) {
        struct korb_array *aa = (struct korb_array *)args_array;
        n_args = aa->len;
        for (long i = 0; i < n_args; i++) {
            c->fp[arg_index + i] = aa->ptr[i];
        }
    }
    VALUE block_v = blk ? EA(c, blk) : Qnil;
    struct korb_proc *block = (BUILTIN_TYPE(block_v) == T_PROC) ? (struct korb_proc *)block_v : NULL;
    return korb_dispatch_call(c, n, recv_val, name, (uint32_t)n_args, arg_index, block, mc);
}

NODE_DEF @noinline
node_class_def_in(CTX * restrict c, NODE * restrict n, NODE *parent_expr, ID name, NODE *super_expr, NODE *body)
{
    VALUE parent_v = EA(c, parent_expr);
    if (BUILTIN_TYPE(parent_v) != T_CLASS && BUILTIN_TYPE(parent_v) != T_MODULE) {
        korb_raise(c, NULL, "not a class/module");
        return Qnil;
    }
    struct korb_class *parent = (struct korb_class *)parent_v;
    struct korb_class *super = korb_vm->object_class;
    if (super_expr) {
        VALUE sv = EA(c, super_expr);
        if (BUILTIN_TYPE(sv) == T_CLASS) super = (struct korb_class *)sv;
    }
    struct korb_class *klass;
    VALUE existing = korb_const_get(parent, name);
    if (!UNDEF_P(existing) && BUILTIN_TYPE(existing) == T_CLASS) {
        klass = (struct korb_class *)existing;
    } else {
        klass = korb_class_new(name, super, T_OBJECT);
        korb_const_set(parent, name, (VALUE)klass);
    }
    struct korb_class *prev_class = c->current_class;
    VALUE prev_self = c->self;
    struct korb_cref new_cref = { .klass = klass, .prev = c->cref };
    struct korb_cref *prev_cref = c->cref;
    c->current_class = klass;
    c->self = (VALUE)klass;
    c->cref = &new_cref;
    VALUE r = body ? EVAL_ARG(c, body) : Qnil;
    c->current_class = prev_class;
    c->self = prev_self;
    c->cref = prev_cref;
    return r;
}

NODE_DEF @noinline
node_module_def_in(CTX * restrict c, NODE * restrict n, NODE *parent_expr, ID name, NODE *body)
{
    VALUE parent_v = EA(c, parent_expr);
    if (BUILTIN_TYPE(parent_v) != T_CLASS && BUILTIN_TYPE(parent_v) != T_MODULE) {
        korb_raise(c, NULL, "not a class/module");
        return Qnil;
    }
    struct korb_class *parent = (struct korb_class *)parent_v;
    struct korb_class *mod;
    VALUE existing = korb_const_get(parent, name);
    if (!UNDEF_P(existing) && BUILTIN_TYPE(existing) == T_MODULE) {
        mod = (struct korb_class *)existing;
    } else {
        mod = korb_module_new(name);
        korb_const_set(parent, name, (VALUE)mod);
    }
    struct korb_class *prev_class = c->current_class;
    VALUE prev_self = c->self;
    struct korb_cref new_cref = { .klass = mod, .prev = c->cref };
    struct korb_cref *prev_cref = c->cref;
    c->current_class = mod;
    c->self = (VALUE)mod;
    c->cref = &new_cref;
    VALUE r = body ? EVAL_ARG(c, body) : Qnil;
    c->current_class = prev_class;
    c->self = prev_self;
    c->cref = prev_cref;
    return r;
}

NODE_DEF
node_do_while(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    /* begin; body; end while cond */
    do {
        EVAL_ARG(c, body);
        if (UNLIKELY(c->state != KORB_NORMAL)) {
            if (c->state == KORB_BREAK) {
                VALUE bv = c->state_value;
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
                return bv;
            }
            else if (c->state == KORB_NEXT) {
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
                /* go back to cond check */
            }
            else return Qnil;
        }
        VALUE v = EVAL_ARG(c, cond);
        if (UNLIKELY(c->state != KORB_NORMAL)) return Qnil;
        if (!RTEST(v)) break;
    } while (1);
    return Qnil;
}

NODE_DEF
node_do_until(CTX * restrict c, NODE * restrict n, NODE *cond, NODE *body)
{
    do {
        EVAL_ARG(c, body);
        if (UNLIKELY(c->state != KORB_NORMAL)) {
            if (c->state == KORB_BREAK) {
                VALUE bv = c->state_value;
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
                return bv;
            }
            else if (c->state == KORB_NEXT) {
                c->state = KORB_NORMAL;
                c->state_value = Qnil;
            }
            else return Qnil;
        }
        VALUE v = EVAL_ARG(c, cond);
        if (UNLIKELY(c->state != KORB_NORMAL)) return Qnil;
        if (RTEST(v)) break;
    } while (1);
    return Qnil;
}
